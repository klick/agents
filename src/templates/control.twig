{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Agents Control" %}
{% set selectedSubnavItem = "control" %}
{% set controlHeadingByKey = {
  approvals: 'Approvals',
  rules: 'Rules',
} %}
{% set controlHeading = controlHeadingByKey[activeControlTab]|default('Approvals') %}
{% set controlIntroByKey = {
  approvals: 'Review, approve, and run governed requests with clear operator actions and audit visibility.',
  rules: 'Define risk and approval behavior for governed actions, and validate outcomes with dry-run simulation.',
} %}
{% set controlSidebarNavItems = {} %}
{% for tab in controlTabs %}
  {% set controlSidebarNavItems = controlSidebarNavItems|merge({
    (tab.key): {
      label: tab.label,
      url: tab.url,
    }
  }) %}
{% endfor %}

{% block sidebar %}
  {% include "_includes/nav"
    with {
      label: 'Control',
      items: controlSidebarNavItems,
      selectedItem: activeControlTab,
    }
    only
  %}
{% endblock %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <div class="agents-page-header">
    <h1>{{ controlHeading }}</h1>
    <p class="agents-page-intro">{{ controlIntroByKey[activeControlTab] ?? 'Operate governed approval and execution workflows.' }}</p>
  </div>

  <div class="agents-layout-stack">
  {% if activeControlTab == 'approvals' %}
  {% set controlPendingCount = controlSummary.approvalsPending|default(0) %}
  {% set controlExpiredApprovalsCount = controlSummary.approvalsExpired|default(0) %}
  {% set controlBlockedRunsCount = controlSummary.executionsBlocked|default(0) %}
  {% set controlCompletedRunsCount = controlSummary.executionsSucceeded|default(0) %}
  {% set controlActiveRulesCount = controlSummary.policies|default(0) %}
  {% set controlActivityCount = controlSummary.auditEvents|default(0) %}

  <section class="border rounded p-3">
    <h2 class="h4">Now</h2>
    <div class="agents-metric-strip-wrap">
      <div class="agents-metric-strip">
      <div class="agents-metric agents-metric-strip-card {{ controlPendingCount > 0 ? 'agents-metric--warn' : 'agents-metric--good' }}">
        <div class="label">Waiting for decision</div>
        <div class="value">{{ controlPendingCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlExpiredApprovalsCount > 0 ? 'agents-metric--bad' : 'agents-metric--good' }}">
        <div class="label">Expired approvals</div>
        <div class="value">{{ controlExpiredApprovalsCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlBlockedRunsCount > 0 ? 'agents-metric--bad' : 'agents-metric--good' }}">
        <div class="label">Runs blocked</div>
        <div class="value">{{ controlBlockedRunsCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlCompletedRunsCount > 0 ? 'agents-metric--good' : 'agents-metric--warn' }}">
        <div class="label">Runs completed</div>
        <div class="value">{{ controlCompletedRunsCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlActiveRulesCount > 0 ? 'agents-metric--good' : 'agents-metric--warn' }}">
        <div class="label">Active rules</div>
        <div class="value">{{ controlActiveRulesCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlActivityCount > 0 ? 'agents-metric--good' : 'agents-metric--warn' }}">
        <div class="label">Activity entries</div>
        <div class="value">{{ controlActivityCount }}</div>
      </div>
      </div>
    </div>
  </section>


  <hr>


  <section class="border rounded p-3">
    <h2 class="h4">Waiting for Decision</h2>
    {% if controlPendingApprovals|length %}
      <table class="data fullwidth">
        <thead>
        <tr>
          <th>Request #</th>
          <th>Action</th>
          <th>Rule</th>
          <th>Requested</th>
          <th>Reason</th>
          <th>SLA</th>
          <th>Decision</th>
        </tr>
        </thead>
        <tbody>
        {% for approval in controlPendingApprovals %}
          {% set policy = approval.policy ?? null %}
          {% set reviewMode = approval.reviewMode ?? 'none' %}
          {% set reviewGuards = approval.reviewGuards ?? [] %}
          {% set hasBlockingReviewGuards = approval.reviewHasBlockingGuards ?? false %}
          <tr>
            <td>#{{ approval.id }}</td>
            <td>
              <div>{{ approval.actionLabel ?: 'Unknown action' }}</div>
              <span class="agents-actor-raw">{{ approval.actionType }}</span>
              {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
              <div class="light">
                {% if approval.targetEntryCpUrl %}
                  <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                {% else %}
                  {{ targetTitle }}
                {% endif %}
              </div>
              {% if reviewMode == 'draft' %}
                <div class="light agents-control-review-mode">
                  Reviewing draft{% if approval.reviewDraftId %} #{{ approval.reviewDraftId }}{% endif %}
                  {% if approval.targetEntryCanonicalCpUrl %}
                    ·
                    <a href="{{ cpUrl(approval.targetEntryCanonicalCpUrl) }}" class="agents-control-target-link">
                      open canonical
                    </a>
                  {% endif %}
                </div>
              {% elseif reviewMode == 'canonical' %}
                <div class="light agents-control-review-mode">Review falls back to canonical entry.</div>
              {% endif %}
              {% if approval.targetEntryId %}
                <button
                  class="btn small js-control-review-entry agents-control-review-btn"
                  type="button"
                  data-entry-id="{{ approval.targetEntryId }}"
                  data-site-id="{{ approval.targetEntrySiteId ?: 0 }}"
                  data-entry-url="{{ approval.targetEntryCpUrl ? cpUrl(approval.targetEntryCpUrl) : '' }}"
                >Review</button>
              {% endif %}
              <span class="agents-actor-raw">Ref: {{ approval.actionRef ?: 'n/a' }}</span>
              {% if approval.reviewChangeSummary|length %}
                <div class="agents-control-change-summary">
                  <div class="light">Proposed changes</div>
                  <ul>
                    {% for change in approval.reviewChangeSummary %}
                      <li><strong>{{ change.label }}:</strong> {{ change.value }}</li>
                    {% endfor %}
                  </ul>
                </div>
              {% endif %}
              {% if reviewGuards|length %}
                <div class="agents-control-review-guards">
                  {% for guard in reviewGuards %}
                    <div class="agents-control-review-guard agents-control-review-guard--{{ guard.level == 'critical' ? 'critical' : 'warning' }}">
                      <strong>{{ guard.label }}</strong>: {{ guard.detail }}
                    </div>
                  {% endfor %}
                </div>
              {% endif %}
            </td>
            <td>
              {% if policy %}
                <span class="badge">RISK {{ policy.riskLevel|upper }}</span>
                <div class="light">Rule: <code>{{ policy.handle }}</code></div>
                <div class="light">Approval required: {{ policy.requiresApproval ? 'yes' : 'no' }}</div>
              {% else %}
                <span class="light">Default rule</span>
              {% endif %}
              <div class="light">
                Approvals: {{ approval.approvalCount|default(0) }}/{{ approval.requiredApprovals|default(1) }}
                {% if approval.approvalsRemaining|default(0) > 0 %}
                  ({{ approval.approvalsRemaining }} remaining)
                {% endif %}
              </div>
              {% if approval.decidedBy %}
                <div class="light">Primary approver: {{ approval.decidedByLabel ?: approval.decidedBy }}</div>
                <span class="agents-actor-raw">Primary ID: {{ approval.decidedBy }}</span>
              {% endif %}
            </td>
            <td>
              <div>{{ approval.requestedByLabel ?: approval.requestedBy }}</div>
              {% if approval.requestedBy %}
                <span class="agents-actor-raw">{{ approval.requestedBy }}</span>
              {% endif %}
              <div class="light">{{ approval.dateCreated ? approval.dateCreated|datetime('short') : 'n/a' }}</div>
            </td>
            <td>{{ approval.reason ?: 'n/a' }}</td>
            <td>
              <div><strong>{{ approval.slaState|default('none') }}</strong></div>
              <div class="light">due: {{ approval.slaDueAt ? approval.slaDueAt|datetime('short') : 'n/a' }}</div>
              {% if approval.escalatedAt %}
                <div class="light">escalated: {{ approval.escalatedAt|datetime('short') }}</div>
              {% endif %}
            </td>
            <td>
              {% if canManageApprovals %}
                {% if hasBlockingReviewGuards %}
                  <div class="agents-control-review-guard agents-control-review-guard--critical" style="margin-bottom: 6px;">
                    Approve actions disabled until review blockers are resolved.
                  </div>
                {% endif %}
                <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Approve request #{{ approval.id }} ({{ approval.actionType }})? It will execute automatically once required approvals are complete." style="margin-bottom: 6px;">
                  {{ csrfInput() }}
                  {{ actionInput('agents/dashboard/decide-control-approval') }}
                  {{ redirectInput('agents/control') }}
                  <input type="hidden" name="approvalId" value="{{ approval.id }}">
                  <input type="hidden" name="decision" value="approved">
                  <input type="text" name="decisionReason" placeholder="Optional note" style="width: 100%; margin-bottom: 4px;">
                  <button class="btn" type="submit"{% if hasBlockingReviewGuards %} disabled{% endif %}>Approve</button>
                </form>
                {% if approval.requiredApprovals|default(1) > 1 and approval.approvalsRemaining|default(0) > 1 %}
                  <div class="light" style="margin-bottom: 6px;">
                    This is the first approval step. Action executes automatically after final required approval.
                  </div>
                {% endif %}
                <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Reject request #{{ approval.id }} ({{ approval.actionType }})?">
                  {{ csrfInput() }}
                  {{ actionInput('agents/dashboard/decide-control-approval') }}
                  {{ redirectInput('agents/control') }}
                  <input type="hidden" name="approvalId" value="{{ approval.id }}">
                  <input type="hidden" name="decision" value="rejected">
                  <input type="text" name="decisionReason" placeholder="Reason for rejection" style="width: 100%; margin-bottom: 4px;">
                  <button class="btn" type="submit">Reject</button>
                </form>
              {% else %}
                <span class="light">Read-only</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>No requests are waiting for a decision.</p>
    {% endif %}
  </section>


  <hr>


  <section class="border rounded p-3">
    <h2 class="h4">Approved</h2>
    {% if controlApprovedApprovals|length %}
      <table class="data fullwidth">
        <thead>
        <tr>
          <th>Request #</th>
          <th>Action</th>
          <th>Approver</th>
          <th>Approved</th>
          <th>Execution</th>
          <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for approval in controlApprovedApprovals %}
          {% set latestExecution = approval.latestExecution ?? null %}
          {% set executionStatus = latestExecution ? latestExecution.status|lower : '' %}
          {% set canApplyDraft = approval.actionType|lower == 'entry.updatedraft'
            and approval.reviewMode == 'draft'
            and approval.targetEntryDraftRecordId
            and (executionStatus == '' or executionStatus == 'succeeded')
          %}
          <tr>
            <td>#{{ approval.id }}</td>
            <td>
              <div>{{ approval.actionLabel ?: 'Unknown action' }}</div>
              <span class="agents-actor-raw">{{ approval.actionType }}</span>
              {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
              <div class="light">
                {% if approval.targetEntryCpUrl %}
                  <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                {% else %}
                  {{ targetTitle }}
                {% endif %}
              </div>
              {% if approval.targetEntryId %}
                <button
                  class="btn small js-control-review-entry agents-control-review-btn"
                  type="button"
                  data-entry-id="{{ approval.targetEntryId }}"
                  data-site-id="{{ approval.targetEntrySiteId ?: 0 }}"
                  data-entry-url="{{ approval.targetEntryCpUrl ? cpUrl(approval.targetEntryCpUrl) : '' }}"
                >Review</button>
              {% endif %}
              <span class="agents-actor-raw">Ref: {{ approval.actionRef ?: 'n/a' }}</span>
            </td>
            <td>
              <div>{{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}</div>
              {% if approval.decidedBy %}
                <span class="agents-actor-raw">{{ approval.decidedBy }}</span>
              {% endif %}
              {% if approval.secondaryDecisionBy %}
                <div class="light">2nd: {{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}</div>
                <span class="agents-actor-raw">2nd ID: {{ approval.secondaryDecisionBy }}</span>
              {% endif %}
            </td>
            <td>{{ approval.decidedAt ? approval.decidedAt|datetime('short') : 'n/a' }}</td>
            <td>
              {% if latestExecution %}
                <div><strong>{{ latestExecution.status|upper }}</strong></div>
                <div class="light">run #{{ latestExecution.id }}</div>
                <div class="light">{{ (latestExecution.executedAt ?: latestExecution.dateCreated) ? (latestExecution.executedAt ?: latestExecution.dateCreated)|datetime('short') : 'n/a' }}</div>
              {% else %}
                <span class="light">n/a</span>
              {% endif %}
            </td>
            <td>
              {% if canApplyDraft %}
                <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Apply draft #{{ approval.targetEntryDraftRecordId }} to canonical entry now?">
                  {{ csrfInput() }}
                  {{ actionInput('elements/apply-draft') }}
                  {{ redirectInput('agents/control/approvals') }}
                  <input type="hidden" name="draftId" value="{{ approval.targetEntryDraftRecordId }}">
                  {% if approval.targetEntryCanonicalId %}
                    <input type="hidden" name="elementId" value="{{ approval.targetEntryCanonicalId }}">
                  {% endif %}
                  {% set applySiteId = approval.targetEntrySiteId ?: approval.targetEntryCanonicalSiteId ?: 0 %}
                  {% if applySiteId %}
                    <input type="hidden" name="siteId" value="{{ applySiteId }}">
                  {% endif %}
                  <button class="btn submit small" type="submit">Apply Draft</button>
                </form>
              {% elseif approval.actionType|lower == 'entry.updatedraft' and approval.reviewDraftId %}
                {% if latestExecution and latestExecution.status|lower != 'succeeded' %}
                  <span class="light">Apply blocked: run {{ latestExecution.status|lower }}.</span>
                {% else %}
                  <span class="light">Draft not available to apply.</span>
                {% endif %}
              {% else %}
                <span class="light">n/a</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>No approved requests yet.</p>
    {% endif %}
  </section>

  <hr>

  <section class="border rounded p-3">
    <h2 class="h4">Applied / Completed</h2>
    {% if controlCompletedApprovals|length %}
      <table class="data fullwidth">
        <thead>
        <tr>
          <th>Request #</th>
          <th>Action</th>
          <th>Approver</th>
          <th>Completed</th>
          <th>Outcome</th>
        </tr>
        </thead>
        <tbody>
        {% for approval in controlCompletedApprovals %}
          {% set latestExecution = approval.latestExecution ?? null %}
          {% set completionState = approval.completionState ?? {} %}
          <tr>
            <td>#{{ approval.id }}</td>
            <td>
              <div>{{ approval.actionLabel ?: 'Unknown action' }}</div>
              <span class="agents-actor-raw">{{ approval.actionType }}</span>
              {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
              <div class="light">
                {% if approval.targetEntryCpUrl %}
                  <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                {% else %}
                  {{ targetTitle }}
                {% endif %}
              </div>
              {% if approval.targetEntryId %}
                <button
                  class="btn small js-control-review-entry agents-control-review-btn"
                  type="button"
                  data-entry-id="{{ approval.targetEntryId }}"
                  data-site-id="{{ approval.targetEntrySiteId ?: 0 }}"
                  data-entry-url="{{ approval.targetEntryCpUrl ? cpUrl(approval.targetEntryCpUrl) : '' }}"
                >Review</button>
              {% endif %}
              <span class="agents-actor-raw">Ref: {{ approval.actionRef ?: 'n/a' }}</span>
            </td>
            <td>
              <div>{{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}</div>
              {% if approval.decidedBy %}
                <span class="agents-actor-raw">{{ approval.decidedBy }}</span>
              {% endif %}
              {% if approval.secondaryDecisionBy %}
                <div class="light">2nd: {{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}</div>
                <span class="agents-actor-raw">2nd ID: {{ approval.secondaryDecisionBy }}</span>
              {% endif %}
            </td>
            <td>
              <div><strong>{{ completionState.label ?: 'COMPLETED' }}</strong></div>
              {% if completionState.at %}
                <div class="light">{{ completionState.at|datetime('short') }}</div>
              {% else %}
                <div class="light">n/a</div>
              {% endif %}
            </td>
            <td>
              <div class="light">{{ completionState.detail ?: 'Completed.' }}</div>
              {% if latestExecution %}
                <div class="light">run #{{ latestExecution.id }} · {{ latestExecution.status|upper }}</div>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>No applied/completed requests yet.</p>
    {% endif %}
  </section>


  <hr>


  <section class="border rounded p-3">
    <h2 class="h4">Runs That Need Follow-up</h2>
    {% if controlAttentionExecutions|length %}
      <table class="data fullwidth">
        <thead>
        <tr>
          <th>Run #</th>
          <th>Action</th>
          <th>Status</th>
          <th>Rule</th>
          <th>Issue</th>
        </tr>
        </thead>
        <tbody>
        {% for execution in controlAttentionExecutions %}
          {% set policy = execution.policy ?? null %}
          <tr>
            <td>#{{ execution.id }}</td>
            <td>
              <div>{{ execution.actionLabel ?: 'Unknown action' }}</div>
              <span class="agents-actor-raw">{{ execution.actionType }}</span>
              {% set targetTitle = execution.targetTitle ?: 'Untitled target' %}
              <div class="light">
                {% if execution.targetEntryCpUrl %}
                  <a href="{{ cpUrl(execution.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                {% else %}
                  {{ targetTitle }}
                {% endif %}
              </div>
              {% if execution.targetEntryId %}
                <button
                  class="btn small js-control-review-entry agents-control-review-btn"
                  type="button"
                  data-entry-id="{{ execution.targetEntryId }}"
                  data-site-id="{{ execution.targetEntrySiteId ?: 0 }}"
                  data-entry-url="{{ execution.targetEntryCpUrl ? cpUrl(execution.targetEntryCpUrl) : '' }}"
                >Review</button>
              {% endif %}
              <span class="agents-actor-raw">Ref: {{ execution.actionRef ?: 'n/a' }}</span>
            </td>
            <td><strong>{{ execution.status }}</strong></td>
            <td>
              {% if policy %}
                <span class="badge">RISK {{ policy.riskLevel|upper }}</span>
                <div class="light">Rule: <code>{{ policy.handle }}</code></div>
              {% else %}
                <span class="light">Default rule</span>
              {% endif %}
            </td>
            <td>{{ execution.errorMessage ?: 'Check rule/approval requirements and retry.' }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>No blocked or failed runs in this view.</p>
    {% endif %}
  </section>


  {% endif %}

  {% if activeControlTab == 'rules' %}
  <section class="border rounded p-3">
    <h2 class="h4">Policy Simulator (Dry Run)</h2>
    <p class="light">Evaluate policy/approval outcomes without recording an execution run.</p>

    {% if canExecuteActions %}
      <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Run dry-run simulation?">
        {{ csrfInput() }}
        {{ actionInput('agents/dashboard/simulate-control-action') }}
        {{ redirectInput('agents/control/rules') }}

        {{ forms.textField({
          label: 'Action name',
          name: 'simulationActionType',
          required: true,
          placeholder: 'returns.exception.refund',
        }) }}

        {{ forms.textField({
          label: 'Case reference',
          name: 'simulationActionRef',
          placeholder: 'order-12345:return-998',
        }) }}

        {{ forms.textField({
          label: 'Approved request # (optional)',
          name: 'simulationApprovalId',
          placeholder: '123',
        }) }}

        <h3 class="h5">Dry-Run Payload</h3>
        {{ forms.textField({
          label: 'Order number / ID',
          name: 'simulationPayloadOrderId',
          placeholder: '12345',
        }) }}
        {{ forms.textField({
          label: 'Return number / ID',
          name: 'simulationPayloadReturnId',
          placeholder: '998',
        }) }}
        {{ forms.textField({
          label: 'Reason code',
          name: 'simulationPayloadReasonCode',
          placeholder: 'DAMAGED_ITEM',
        }) }}
        {{ forms.textField({
          label: 'Operator note',
          name: 'simulationPayloadOperatorNote',
          placeholder: 'Dry-run validation before execution.',
        }) }}

        <details style="margin-bottom: 12px;">
          <summary><strong>Advanced JSON payload override (optional)</strong></summary>
          <div style="margin-top: 8px;">
            {{ forms.textareaField({
              label: 'Payload JSON',
              instructions: 'Merged with guided fields. Duplicate keys in JSON take precedence.',
              name: 'simulationPayloadJson',
              rows: 4,
              value: '{}',
            }) }}
          </div>
        </details>

        <button class="btn" type="submit">Run Dry-Run</button>
      </form>
    {% else %}
      <p class="warning">You do not have permission to run policy simulations.</p>
    {% endif %}

    {% if controlSimulationResult %}
      <hr>
      <h3 class="h5">Latest Dry-Run Result</h3>
      {% set simEval = controlSimulationResult.evaluation ?? {} %}
      {% set simPolicy = controlSimulationResult.policy ?? {} %}
      <ul>
        <li>Status: <strong>{{ simEval.status ?? 'unknown' }}</strong></li>
        <li>Would execute: <strong>{{ simEval.wouldExecute ? 'yes' : 'no' }}</strong></li>
        <li>Required scope: <strong>{{ controlSimulationResult.requiredScope ?: 'n/a' }}</strong></li>
        <li>Policy: <strong>{{ simPolicy.handle ?: 'default' }}</strong></li>
        <li>Approval status: <strong>{{ simEval.approvalStatus ?? 'n/a' }}</strong></li>
      </ul>
      {% if simEval.reasons is defined and simEval.reasons|length %}
        <p><strong>Reasons</strong></p>
        <ul>
          {% for reason in simEval.reasons %}
            <li>{{ reason }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      <details>
        <summary><strong>Technical JSON</strong></summary>
        <pre class="border rounded p-3" style="margin-top: 8px;">{{ controlSimulationResult|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
      </details>
    {% endif %}
  </section>


  <hr>


  <section class="border rounded p-3">
    <h2 class="h4">Rules</h2>

    {% if controlPolicies|length %}
      <table class="data fullwidth" style="margin-bottom: 12px;">
        <thead>
        <tr>
          <th>Rule key</th>
          <th>Matches action</th>
          <th>Risk</th>
          <th>Approval required</th>
          <th>Active</th>
        </tr>
        </thead>
        <tbody>
        {% for policy in controlPolicies %}
          <tr>
            <td><code>{{ policy.handle }}</code><br><span class="light">{{ policy.displayName }}</span></td>
            <td><code>{{ policy.actionPattern }}</code></td>
            <td>{{ policy.riskLevel|upper }}</td>
            <td>{{ policy.requiresApproval ? 'yes' : 'no' }}</td>
            <td>{{ policy.enabled ? 'yes' : 'no' }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>No rules configured yet.</p>
    {% endif %}

    {% if canManagePolicies %}
      <details>
        <summary><strong>Create or update a rule</strong></summary>
        <div style="margin-top: 8px;">
          <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Save this rule?">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/upsert-control-policy') }}
            {{ redirectInput('agents/control/rules') }}

            {{ forms.textField({
              label: 'Rule key',
              instructions: 'Stable machine key for this rule.',
              name: 'handle',
              required: true,
              placeholder: 'returns-exception-high-risk',
            }) }}

            {{ forms.textField({
              label: 'Rule name',
              name: 'displayName',
              placeholder: 'Returns Exception High Risk',
            }) }}

            {{ forms.textField({
              label: 'Action match pattern',
              instructions: 'Wildcard pattern, for example: returns.exception.*',
              name: 'actionPattern',
              required: true,
              placeholder: 'returns.exception.*',
            }) }}

            {{ forms.selectField({
              label: 'Risk level',
              name: 'riskLevel',
              options: [
                {label: 'low', value: 'low'},
                {label: 'medium', value: 'medium'},
                {label: 'high', value: 'high'},
                {label: 'critical', value: 'critical'},
              ],
              value: 'medium',
            }) }}

            <div style="margin-bottom: 8px;">
              <input type="hidden" name="requiresApproval" value="0">
              <label><input type="checkbox" name="requiresApproval" value="1" checked> Require approval</label>
            </div>

            <div style="margin-bottom: 8px;">
              <input type="hidden" name="enabled" value="0">
              <label><input type="checkbox" name="enabled" value="1" checked> Rule is active</label>
            </div>

            <details style="margin-bottom: 12px;">
              <summary><strong>Advanced rule JSON</strong></summary>
              <div style="margin-top: 8px;">
                {{ forms.textareaField({
                  label: 'Advanced config JSON',
                  instructions: 'Optional advanced values, for example: {"requiredScope":"control:actions:execute"}.',
                  name: 'configJson',
                  rows: 4,
                  value: '{"requiredScope":"control:actions:execute"}',
                }) }}
              </div>
            </details>

            <button class="btn submit" type="submit">Save Rule</button>
          </form>
        </div>
      </details>
    {% else %}
      <p class="warning">You do not have permission to manage rules.</p>
    {% endif %}
  </section>
  {% endif %}

  {% if activeControlTab == 'approvals' %}
  <hr>
  <section class="border rounded p-3">
    <h2 class="h4">Activity Log</h2>
    {% if controlAuditEvents|length %}
      <table class="data fullwidth">
        <thead>
        <tr>
          <th>Time</th>
          <th>Type</th>
          <th>Event</th>
          <th>Actor</th>
          <th>Summary</th>
        </tr>
        </thead>
        <tbody>
        {% for event in controlAuditEvents %}
          <tr>
            <td>{{ event.dateCreated ? event.dateCreated|datetime('short') : 'n/a' }}</td>
            <td><code>{{ event.category }}</code></td>
            <td>{{ event.action }} ({{ event.outcome }})</td>
            <td>
              <div>{{ event.actorLabel ?: (event.actorId ?: 'n/a') }}</div>
              {% if event.actorId %}
                <span class="agents-actor-raw">{{ event.actorType }} / {{ event.actorId }}</span>
              {% endif %}
            </td>
            <td>{{ event.summary ?: 'n/a' }}</td>
          </tr>
        {% endfor %}
        </tbody>
      </table>
    {% else %}
      <p>No history events recorded yet.</p>
    {% endif %}

    <details style="margin-top: 12px;">
      <summary><strong>Technical Data (Advanced)</strong></summary>
      <pre class="border rounded p-3" style="margin-top: 8px;">{{ controlSnapshotJson }}</pre>
    </details>
  </section>
  {% endif %}
  </div>

  {% js %}
    (() => {
      const confirmForms = document.querySelectorAll('.js-confirm-form');
      confirmForms.forEach((form) => {
        form.addEventListener('submit', (event) => {
          const customMessage = form.getAttribute('data-confirm-message') || 'Are you sure?';
          if (!window.confirm(customMessage)) {
            event.preventDefault();
          }
        });
      });

      const reviewButtons = document.querySelectorAll('.js-control-review-entry');
      reviewButtons.forEach((button) => {
        button.addEventListener('click', (event) => {
          event.preventDefault();
          const entryIdRaw = button.getAttribute('data-entry-id') || '';
          const siteIdRaw = button.getAttribute('data-site-id') || '';
          const entryUrl = button.getAttribute('data-entry-url') || '';
          const entryId = Number.parseInt(entryIdRaw, 10);
          const siteId = Number.parseInt(siteIdRaw, 10);

          if (!Number.isInteger(entryId) || entryId <= 0) {
            if (entryUrl !== '') {
              window.location.href = entryUrl;
            }
            return;
          }

          if (typeof Craft !== 'undefined' && typeof Craft.createElementEditor === 'function') {
            const editorParams = {elementId: entryId};
            if (Number.isInteger(siteId) && siteId > 0) {
              editorParams.siteId = siteId;
            }

            try {
              Craft.createElementEditor('craft\\elements\\Entry', editorParams);
              return;
            } catch (error) {
              if (window.console && typeof window.console.warn === 'function') {
                console.warn('Unable to open entry flyout from control action table.', error);
              }
            }
          }

          if (entryUrl !== '') {
            window.location.href = entryUrl;
          }
        });
      });

    })();
  {% endjs %}

  {% css %}
    .agents-page-header {
      text-align: center;
      margin: 12px 0 24px;
    }

    .agents-page-header h1 {
      margin: 0;
    }

    .agents-page-header .agents-page-intro {
      margin: 0 auto;
    }

    .agents-page-header + .agents-layout-stack {
      margin-top: 40px;
    }

    .agents-actor-raw {
      display: block;
      margin-top: 2px;
      font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 11px;
      line-height: 1.3;
      color: #5f6d7c;
      word-break: break-all;
    }

    .agents-control-review-btn {
      margin-top: 6px;
    }

    .agents-control-review-mode {
      margin-top: 4px;
    }

    .agents-control-change-summary {
      margin-top: 8px;
    }

    .agents-control-change-summary ul {
      margin: 4px 0 0;
      padding-left: 18px;
    }

    .agents-control-change-summary li {
      margin: 2px 0;
      line-height: 1.3;
    }

    .agents-control-review-guards {
      margin-top: 8px;
    }

    .agents-control-review-guard {
      margin: 4px 0;
      padding: 6px 8px;
      border-radius: 4px;
      border: 1px solid #d9d9d9;
      background: #f9f9f9;
      color: #1f2933;
      line-height: 1.3;
    }

    .agents-control-review-guard--warning {
      background: #fff8e1;
      border-color: #f0cf80;
    }

    .agents-control-review-guard--critical {
      background: #fdeaea;
      border-color: #ec9ca7;
    }
  {% endcss %}
{% endblock %}
