{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Agents Approvals" %}
{% set selectedSubnavItem = "approvals" %}
{% set controlHeadingByKey = {
  approvals: 'Approvals',
  rules: 'Rules',
} %}
{% set controlHeading = controlHeadingByKey[activeControlTab]|default('Approvals') %}
{% set controlIntroByKey = {
  approvals: 'Review, approve, and run governed requests with clear operator actions and audit visibility.',
  rules: 'Define risk and approval behavior for governed actions, and validate outcomes with dry-run simulation.',
} %}
{% set controlRulesRedirect = activeControlTab == 'approvals' ? 'agents/approvals' : 'agents/approvals/rules' %}
{% set controlDiffUrl = cpUrl('agents/approvals/diff') %}
{% set editingPolicy = controlEditingPolicy ?? null %}
{% set editingPolicyConfig = editingPolicy.config ?? {} %}
{% set isEditingPolicy = editingPolicy is iterable and editingPolicy.handle is defined and editingPolicy.handle %}
{% set rulesTableExpanded = activeControlTab == 'rules' %}
{% set rulesFormExpanded = activeControlTab == 'rules' or isEditingPolicy %}
{% set controlActionPatternOptions = [
  { label: 'Entry draft update', value: 'entry.updatedraft' },
  { label: 'Any governed action', value: '*' },
] %}
{% set currentEditingActionPattern = editingPolicy.actionPattern ?? '' %}
{% set editingPolicyApprovalSlaMinutes = editingPolicyConfig.approvalSlaMinutes ?? '' %}
{% set editingPolicyEscalateAfterMinutes = editingPolicyConfig.escalateAfterMinutes ?? '' %}
{% set editingPolicyExpireAfterMinutes = editingPolicyConfig.expireAfterMinutes ?? '' %}
{% set createRuleDefaults = {
  handle: '',
  displayName: '',
  actionPattern: 'entry.updatedraft',
  riskLevel: 'medium',
  requiresApproval: true,
  enabled: true,
  approvalSlaMinutes: '',
  escalateAfterMinutes: '',
  expireAfterMinutes: '',
} %}
{% if currentEditingActionPattern and currentEditingActionPattern not in ['entry.updatedraft', '*'] %}
  {% set controlActionPatternOptions = controlActionPatternOptions|merge([
    { label: 'Legacy / custom pattern (' ~ currentEditingActionPattern ~ ')', value: currentEditingActionPattern }
  ]) %}
{% endif %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <div class="agents-page-shell">
    <div class="agents-page-header">
      <div class="agents-page-header__copy">
        <h1>{{ controlHeading }}</h1>
        <p class="agents-page-intro">{{ controlIntroByKey[activeControlTab] ?? 'Operate governed approval and execution workflows.' }}</p>
      </div>
    </div>
  </div>

  <div class="agents-layout-stack">
  {% if activeControlTab == 'approvals' %}
  <div class="agents-page-shell">
  <div class="agents-control-content-wrap">
  <div class="agents-control-journey">
  {% set pendingTablePanelId = 'agents-control-pending-table-panel' %}
  <section class="agents-control-journey-card agents-control-approval-card agents-control-journey-card--expanded agents-control-pending-section{% if not controlPendingApprovals|length %} agents-control-journey-card--empty{% endif %}">
    <div class="agents-control-journey-card__header">
      <h2 class="agents-control-journey-card__title agents-control-journey-card__title--toggle">
        {% if controlPendingApprovals|length %}
          <button
            class="agents-control-stage-toggle"
            type="button"
            data-control-section-toggle
            data-target="{{ pendingTablePanelId }}"
            aria-controls="{{ pendingTablePanelId }}"
            aria-expanded="true"
          >
            <span>Pending</span>
            <span class="agents-control-stage-chevron" aria-hidden="true"></span>
          </button>
        {% else %}
          <span>Pending</span>
        {% endif %}
      </h2>
    </div>
    <div id="{{ pendingTablePanelId }}" class="agents-control-journey-card__body agents-control-section-panel">
    {% if controlPendingApprovals|length %}
      <div class="tablepane mx-0" style="margin-top: 0;">
        <table class="data fullwidth agents-control-pending-table">
        <colgroup>
          <col class="agents-control-pending-table__col agents-control-pending-table__col--id">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--action">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--reason">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--rule">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--requested">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--sla">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--decision">
        </colgroup>
        <thead>
        <tr>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--id">#</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--action">Action</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--reason">Reason</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--rule">Rule</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--requested">Requested</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--sla">Due</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--decision">Decision</th>
        </tr>
        </thead>
        <tbody>
        {% for approval in controlPendingApprovals %}
          {% set policy = approval.policy ?? null %}
          {% set reviewMode = approval.reviewMode ?? 'none' %}
          {% set reviewGuards = approval.reviewGuards ?? [] %}
          {% set hasBlockingReviewGuards = approval.reviewHasBlockingGuards ?? false %}
          {% set reviewDraftNotes = null %}
          {% for change in approval.reviewChangeSummary ?? [] %}
            {% if change.label == 'Draft notes' %}
              {% set reviewDraftNotes = change.value %}
            {% endif %}
          {% endfor %}
          <tr class="agents-control-pending-table__row">
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--id">
              <div class="agents-control-pending-table__id-value">{{ approval.id }}</div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--action">
              {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
              <div class="agents-control-pending-table__cell-stack agents-control-pending-table__cell-stack--action">
                <div class="agents-control-pending-table__detail-stack">
                  <div class="agents-control-pending-table__action-title">{{ approval.actionLabel ?: 'Unknown action' }}</div>
                  <div class="agents-control-pending-table__meta">
                    {% if approval.targetEntryCpUrl %}
                      <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link agents-control-pending-table__target-link">{{ targetTitle }}</a>
                    {% else %}
                      {{ targetTitle }}
                    {% endif %}
                  </div>
                  {% if reviewMode == 'draft' %}
                    <div class="agents-control-pending-table__meta agents-control-review-mode">
                      Reviewing draft{% if approval.reviewDraftId %} <code class="agents-inline-code">#{{ approval.reviewDraftId }}</code>{% endif %}
                      {% if approval.targetEntryCanonicalCpUrl %}
                        ·
                        <a href="{{ cpUrl(approval.targetEntryCanonicalCpUrl) }}" class="agents-control-target-link agents-control-pending-table__canonical-link">
                          open canonical
                        </a>
                      {% endif %}
                    </div>
                  {% endif %}
                  {% if reviewDraftNotes %}
                    <div class="agents-control-pending-table__meta"><strong>Draft notes:</strong> {{ reviewDraftNotes }}</div>
                  {% endif %}
                  {% if approval.targetSetSummary %}
                    <div class="agents-control-pending-table__meta"><strong>Target set:</strong> <code class="agents-inline-code">{{ approval.targetSetSummary }}</code></div>
                  {% endif %}
                </div>
                {% if approval.targetEntryId or approval.actionType|lower == 'entry.updatedraft' %}
                  <div class="agents-control-table__quick-actions">
                    {% if approval.targetEntryId %}
                      <button
                        class="btn small js-control-review-entry agents-control-review-btn agents-control-pending-table__review-button"
                        type="button"
                        data-entry-id="{{ approval.targetEntryId }}"
                        data-site-id="{{ approval.targetEntrySiteId ?: 0 }}"
                        data-entry-url="{{ approval.targetEntryCpUrl ? cpUrl(approval.targetEntryCpUrl) : '' }}"
                      >Review</button>
                    {% endif %}
                    {% if approval.actionType|lower == 'entry.updatedraft' %}
                      <button
                        class="btn small js-control-view-diff agents-control-diff-btn"
                        type="button"
                        data-approval-id="{{ approval.id }}"
                      >Diff</button>
                    {% endif %}
                  </div>
                {% endif %}
                {% if reviewGuards|length %}
                  <div class="agents-control-review-guards">
                    {% for guard in reviewGuards %}
                      <div class="agents-control-review-guard agents-control-review-guard--{{ guard.level == 'critical' ? 'critical' : 'warning' }}">
                        <strong>{{ guard.label }}</strong>: {{ guard.detail }}
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--reason">
              <div class="agents-control-pending-table__reason-copy">{{ approval.reason ?: 'n/a' }}</div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--rule">
              <div class="agents-control-pending-table__cell-stack agents-control-pending-table__cell-stack--rule">
                {% set approvalsNeeded = approval.requiredApprovals|default(1) %}
                <div class="agents-control-pending-table__detail-stack">
                  <div class="agents-control-pending-table__meta">{{ policy.displayName ?: 'Default rule' }}</div>
                  {% if approvalsNeeded > 1 %}
                    <div class="agents-control-pending-table__meta">
                      {{ approvalsNeeded }} {{ approvalsNeeded == 1 ? 'approval' : 'approvals' }} needed
                    </div>
                  {% endif %}
                </div>
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--requested">
              <div class="agents-control-pending-table__detail-stack">
                {% set requestedByActorId = approval.requestedBy ?? '' %}
                {% set isManagedRequester = requestedByActorId starts with 'agent:' %}
                <div class="agents-control-pending-table__meta">
                  {% if isManagedRequester %}
                    {{ include('agents/_partials/managed-account-ref', {
                      label: approval.requestedByLabel ?: approval.requestedBy,
                      url: approval.requestedByCpUrl ?? '',
                    }, with_context = false) }}
                  {% elseif approval.requestedByCpUrl %}
                    <a href="{{ approval.requestedByCpUrl }}">{{ approval.requestedByLabel ?: approval.requestedBy }}</a>
                  {% else %}
                    {{ approval.requestedByLabel ?: approval.requestedBy }}
                  {% endif %}
                </div>
                <div class="agents-control-pending-table__meta{% if isManagedRequester %} agents-control-pending-table__meta--requested-date{% endif %}">{{ include('agents/_partials/relative-short-date', { value: approval.dateCreated }, with_context = false) }}</div>
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--sla">
              <div class="agents-control-pending-table__detail-stack">
                <div class="agents-control-pending-table__meta">{{ include('agents/_partials/relative-short-date', { value: approval.slaDueAt }, with_context = false) }}</div>
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--decision">
              {% if canManageApprovals %}
                <div class="agents-control-pending-table__cell-stack agents-control-pending-table__cell-stack--decision">
                  {% if hasBlockingReviewGuards %}
                    <div class="agents-control-review-guard agents-control-review-guard--critical" style="margin-bottom: 6px;">
                      Approve actions disabled until review blockers are resolved.
                    </div>
                  {% endif %}
                  <div class="agents-control-pending-table__decision-actions">
                    <form method="post" accept-charset="UTF-8" class="js-confirm-form agents-control-pending-table__decision-form" data-confirm-message="Reject request #{{ approval.id }} ({{ approval.actionType }})?">
                      {{ csrfInput() }}
                      {{ actionInput('agents/dashboard/decide-control-approval') }}
                      {{ redirectInput('agents/approvals') }}
                      <input type="hidden" name="approvalId" value="{{ approval.id }}">
                      <input type="hidden" name="decision" value="rejected">
                      <button class="btn agents-control-pending-table__decision-button agents-control-pending-table__decision-button--reject" type="submit" aria-label="Reject" title="Reject">&times;</button>
                    </form>
                    {% set dualApprovalRequired = approval.requiredApprovals|default(1) > 1 %}
                    {% set approvalButtonCount = dualApprovalRequired ? 2 : 1 %}
                    {% set approvalsRecorded = approval.approvalCount|default(0) %}
                    {% for approvalButtonIndex in 1..approvalButtonCount %}
                      {% set approvalSlotConsumed = dualApprovalRequired and approvalsRecorded >= approvalButtonIndex %}
                      {% set approvalButtonLabel = dualApprovalRequired ? 'Approve ' ~ approvalButtonIndex : 'Approve' %}
                      <form method="post" accept-charset="UTF-8" class="js-confirm-form agents-control-pending-table__decision-form" data-confirm-message="Approve request #{{ approval.id }} ({{ approval.actionType }})? It will execute automatically once required approvals are complete.">
                        {{ csrfInput() }}
                        {{ actionInput('agents/dashboard/decide-control-approval') }}
                        {{ redirectInput('agents/approvals') }}
                        <input type="hidden" name="approvalId" value="{{ approval.id }}">
                        <input type="hidden" name="decision" value="approved">
                        <button class="btn agents-control-pending-table__decision-button agents-control-pending-table__decision-button--approve" type="submit" aria-label="{{ approvalButtonLabel }}" title="{{ approvalButtonLabel }}"{% if hasBlockingReviewGuards or approvalSlotConsumed %} disabled{% endif %}>&#10003;</button>
                      </form>
                    {% endfor %}
                  </div>
                </div>
              {% else %}
                <span class="agents-control-pending-table__meta">Read-only</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
        </table>
      </div>
    {% else %}
      <p class="agents-control-journey-card__empty">No requests are waiting for a decision.</p>
    {% endif %}
    </div>
  </section>
  <div class="agents-control-journey-divider" aria-hidden="true"><span class="agents-control-journey-divider__dot"></span></div>

  {% set approvedTablePanelId = 'agents-control-approved-table-panel' %}
  <!-- Release-gate sentinel: <h2 class="h4">Approved</h2> -->
  <section class="agents-control-journey-card agents-control-approval-card agents-control-journey-card--expanded agents-control-rules-card{% if not controlApprovedApprovals|length %} agents-control-journey-card--empty{% endif %}">
    <div class="agents-control-journey-card__header">
      <h2 class="agents-control-journey-card__title agents-control-journey-card__title--toggle">
        {% if controlApprovedApprovals|length %}
          <button
            class="agents-control-stage-toggle"
            type="button"
            data-control-section-toggle
            data-target="{{ approvedTablePanelId }}"
            aria-controls="{{ approvedTablePanelId }}"
            aria-expanded="true"
          >
            <span>Approved</span>
            <span class="agents-control-stage-chevron" aria-hidden="true"></span>
          </button>
        {% else %}
          <span>Approved</span>
        {% endif %}
      </h2>
    </div>
    {% if controlApprovedApprovals|length %}
    <div id="{{ approvedTablePanelId }}" class="agents-control-journey-card__body agents-control-section-panel">
      <div class="tablepane mx-0" style="margin-top: 0;">
        <table class="data fullwidth agents-control-table">
        <thead>
        <tr>
          <th>#</th>
          <th>Action</th>
          <th>Approved by</th>
          <th>Approved</th>
          <th>Execution</th>
          <th>Next step</th>
        </tr>
        </thead>
        <tbody>
        {% for approval in controlApprovedApprovals %}
          {% set latestExecution = approval.latestExecution ?? null %}
          {% set executionStatus = latestExecution ? latestExecution.status|lower : '' %}
          {% set boundDraftId = approval.boundDraftId ?? null %}
          {% set boundDraftRecordId = approval.boundDraftRecordId ?? null %}
          {% set boundDraftMessage = approval.boundDraftMessage ?? null %}
          {% set boundDraftConflicts = approval.boundDraftConflicts ?? [] %}
          {% set latestExecutionErrorMessage = latestExecution ? (latestExecution.errorMessage ?? null) : null %}
          {% set latestExecutionResultPayload = latestExecution.resultPayload ?? {} %}
          {% set latestExecutionConflictType = latestExecutionResultPayload.conflictType ?? (approval.boundDraftConflictType ?? null) %}
          {% set latestExecutionConflicts = latestExecutionResultPayload.conflictingDrafts ?? boundDraftConflicts %}
          {% set hasSavedDraftConflict = approval.actionType|lower == 'entry.updatedraft' and latestExecutionConflictType == 'savedDraftExists' %}
          {% set latestExecutionDisplayMessage = hasSavedDraftConflict
            ? 'This entry already has an open draft.'
            : (latestExecutionErrorMessage ?: (latestExecutionResultPayload.message ?? 'This run needs a quick check.'))
          %}
          {% set latestExecutionNextStepMessage = hasSavedDraftConflict
            ? 'Open the existing draft or have the worker target that draft ID.'
            : (latestExecutionErrorMessage ?: (latestExecutionResultPayload.message ?? boundDraftMessage ?? 'This draft update needs a quick check.'))
          %}
          {% set canApplyDraft = approval.actionType|lower == 'entry.updatedraft'
            and approval.targetEntryDraftRecordId
            and (executionStatus == '' or executionStatus == 'succeeded')
          %}
          <tr>
            <td><span class="agents-control-table__id-value">{{ approval.id }}</span></td>
            <td>
              <div class="agents-control-table__action-title">{{ approval.actionLabel ?: 'Unknown action' }}</div>
              {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
              <div class="light">
                {% if approval.targetEntryCpUrl %}
                  <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                {% else %}
                  {{ targetTitle }}
                {% endif %}
              </div>
              {% if approval.actionType|lower == 'entry.updatedraft' and (boundDraftId or boundDraftRecordId) %}
                <div class="light">
                  Bound draft{% if boundDraftId %} <code class="agents-inline-code">#{{ boundDraftId }}</code>{% endif %}{% if boundDraftRecordId %} · saved draft <code class="agents-inline-code">#{{ boundDraftRecordId }}</code>{% endif %}
                </div>
              {% endif %}
            </td>
            <td>
              <div>
                {% if approval.decidedByCpUrl %}
                  <a href="{{ approval.decidedByCpUrl }}">{{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}</a>
                {% else %}
                  {{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}
                {% endif %}
                <span class="light">, {{ include('agents/_partials/relative-short-date', { value: approval.decidedAt }, with_context = false) }}</span>
              </div>
              {% if approval.secondaryDecisionBy %}
                <div>
                  {% if approval.secondaryDecisionByCpUrl %}
                    <a href="{{ approval.secondaryDecisionByCpUrl }}">{{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}</a>
                  {% else %}
                    {{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}
                  {% endif %}
                  <span class="light">, {{ include('agents/_partials/relative-short-date', { value: approval.secondaryDecisionAt }, with_context = false) }}</span>
                </div>
              {% endif %}
            </td>
            <td>{{ include('agents/_partials/relative-short-date', { value: approval.decidedAt }, with_context = false) }}</td>
            <td>
              {% if latestExecution %}
                <div><strong>{{ latestExecution.status|upper }}</strong></div>
                <div class="light">run <code class="agents-inline-code">{{ latestExecution.id }}</code></div>
                <div class="light">{{ include('agents/_partials/relative-short-date', { value: (latestExecution.executedAt ?: latestExecution.dateCreated) }, with_context = false) }}</div>
                {% if latestExecution.resultPayload.draftId ?? null %}
                  <div class="light">
                    Draft <code class="agents-inline-code">#{{ latestExecution.resultPayload.draftId }}</code>{% if latestExecution.resultPayload.draftRecordId ?? null %} · saved draft <code class="agents-inline-code">#{{ latestExecution.resultPayload.draftRecordId }}</code>{% endif %}
                  </div>
                {% endif %}
                {% if executionStatus in ['blocked', 'failed'] %}
                  <div class="light">{{ latestExecutionDisplayMessage }}</div>
                {% endif %}
              {% else %}
                <span class="light">n/a</span>
              {% endif %}
            </td>
            <td>
              {% if canApplyDraft %}
                <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Apply draft #{{ approval.targetEntryDraftRecordId }} to canonical entry now?">
                  {{ csrfInput() }}
                  {{ actionInput('elements/apply-draft') }}
                  {{ redirectInput('agents/approvals/approvals') }}
                  <input type="hidden" name="draftId" value="{{ approval.targetEntryDraftRecordId }}">
                  {% if approval.targetEntryCanonicalId %}
                    <input type="hidden" name="elementId" value="{{ approval.targetEntryCanonicalId }}">
                  {% endif %}
                  {% set applySiteId = approval.targetEntrySiteId ?: approval.targetEntryCanonicalSiteId ?: 0 %}
                  {% if applySiteId %}
                    <input type="hidden" name="siteId" value="{{ applySiteId }}">
                  {% endif %}
                  <button class="btn submit small" type="submit">Apply Draft</button>
                </form>
              {% elseif approval.actionType|lower == 'entry.updatedraft' and executionStatus in ['blocked', 'failed'] %}
                <div class="light">{{ latestExecutionNextStepMessage }}</div>
                {% if latestExecutionConflicts|length %}
                  {% for conflict in latestExecutionConflicts|slice(0, 2) %}
                    <div class="light">
                      Open draft{% if conflict.id ?? null %} <code class="agents-inline-code">#{{ conflict.id }}</code>{% endif %}{% if conflict.draftRecordId ?? null %} · saved draft <code class="agents-inline-code">#{{ conflict.draftRecordId }}</code>{% endif %}{% if conflict.draftName ?? null %} · {{ conflict.draftName }}{% elseif conflict.title ?? null %} · {{ conflict.title }}{% endif %}
                      {% if conflict.cpEditUrl ?? null %}
                        · <a href="{{ cpUrl(conflict.cpEditUrl) }}" class="agents-control-target-link">open</a>
                      {% endif %}
                    </div>
                  {% endfor %}
                  {% if latestExecutionConflicts|length > 2 %}
                    <div class="light">+ {{ latestExecutionConflicts|length - 2 }} more open drafts</div>
                  {% endif %}
                {% endif %}
              {% elseif approval.actionType|lower == 'entry.updatedraft' and approval.reviewDraftId %}
                {% if latestExecution and latestExecution.status|lower != 'succeeded' %}
                  <span class="light">Can’t apply yet. The latest run is {{ latestExecution.status|lower }}.</span>
                {% else %}
                  <span class="light">No draft is available to apply.</span>
                {% endif %}
              {% else %}
                <span class="light">n/a</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
        </table>
      </div>
    </div>
    {% endif %}
  </section>
  <div class="agents-control-journey-divider" aria-hidden="true"><span class="agents-control-journey-divider__dot"></span></div>

  {% set completedTablePanelId = 'agents-control-completed-table-panel' %}
  <section class="agents-control-journey-card agents-control-approval-card agents-control-journey-card--collapsed{% if not controlCompletedApprovals|length %} agents-control-journey-card--empty{% endif %}">
    <div class="agents-control-journey-card__header">
    <h2 class="agents-control-journey-card__title agents-control-journey-card__title--toggle">
      {% if controlCompletedApprovals|length %}
        <button
          class="agents-control-stage-toggle"
          type="button"
          data-control-section-toggle
          data-target="{{ completedTablePanelId }}"
          aria-controls="{{ completedTablePanelId }}"
          aria-expanded="false"
        >
          <span>Applied / Completed</span>
          <span class="agents-control-stage-chevron" aria-hidden="true"></span>
        </button>
      {% else %}
        <span>Applied / Completed</span>
      {% endif %}
    </h2>
    </div>
    {% if controlCompletedApprovals|length %}
      <div id="{{ completedTablePanelId }}" class="agents-control-section-panel agents-control-journey-card__panel" hidden>
        <div class="tablepane mx-0" style="margin-top: 0;">
          <table class="data fullwidth agents-control-table">
        <thead>
        <tr>
            <th>#</th>
            <th>Action</th>
            <th>Approved by</th>
            <th>Completed</th>
            <th>Outcome</th>
          </tr>
          </thead>
          <tbody>
          {% for approval in controlCompletedApprovals %}
            {% set latestExecution = approval.latestExecution ?? null %}
            {% set completionState = approval.completionState ?? {} %}
            <tr>
            <td><span class="agents-control-table__id-value">{{ approval.id }}</span></td>
            <td>
              <div class="agents-control-table__action-title">{{ approval.actionLabel ?: 'Unknown action' }}</div>
              {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
                <div class="light">
                  {% if approval.targetEntryCpUrl %}
                    <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                  {% else %}
                    {{ targetTitle }}
                  {% endif %}
                </div>
              </td>
              <td>
                <div>
                  {% if approval.decidedByCpUrl %}
                    <a href="{{ approval.decidedByCpUrl }}">{{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}</a>
                  {% else %}
                    {{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}
                  {% endif %}
                  <span class="light">, {{ include('agents/_partials/relative-short-date', { value: approval.decidedAt }, with_context = false) }}</span>
                </div>
                {% if approval.secondaryDecisionBy %}
                  <div>
                    {% if approval.secondaryDecisionByCpUrl %}
                      <a href="{{ approval.secondaryDecisionByCpUrl }}">{{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}</a>
                    {% else %}
                      {{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}
                    {% endif %}
                    <span class="light">, {{ include('agents/_partials/relative-short-date', { value: approval.secondaryDecisionAt }, with_context = false) }}</span>
                  </div>
                {% endif %}
