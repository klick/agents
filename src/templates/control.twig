      font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'SF Pro Display', sans-serif;
      font-weight: 400;
      line-height: 1.45;
      text-align: left;
      vertical-align: middle;
    }

    .agents-control-table--activity-log thead > tr > th,
    .agents-control-table--activity-log tbody > tr > td {
      font-size: 12px;
    }

    .agents-control-table--activity-log tbody > tr > td {
      border-bottom: 1px solid var(--gray-200);
    }

    .agents-control-table--activity-log tbody > tr:last-child > td {
      border-bottom: 0;
    }

    .agents-control-pending-table tbody tr:last-child td.agents-control-pending-table__body-cell,
    .agents-control-table:not(.agents-control-table--activity-log) tbody tr:last-child td {
      border-bottom: 0;
    }

    .agents-control-pending-table tbody tr.agents-control-pending-table__row:hover,
    .agents-control-pending-table tbody tr.agents-control-pending-table__row:hover td.agents-control-pending-table__body-cell,
    .agents-control-table:not(.agents-control-table--activity-log) tbody tr:hover,
    .agents-control-table:not(.agents-control-table--activity-log) tbody tr:hover td {
      background: transparent !important;
      background-color: transparent !important;
      background-image: none !important;
      box-shadow: none !important;
    }

    .agents-control-table .light {
      color: #596673;
      line-height: 1.45;
    }

    .agents-control-table__action-title {
      color: #596673;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.45;
    }

    .agents-control-table .badge {
      border: 0;
      background: #596673;
      color: #ffffff;
    }

    .agents-control-table .badge--good {
      background: rgba(16, 142, 128, 0.12);
      color: #108e80;
    }

    .agents-control-table .badge--warn {
      background: rgba(197, 138, 27, 0.16);
      color: #c58a1b;
    }

    .agents-control-table .badge--bad {
      background: rgba(194, 79, 66, 0.12);
      color: #c24f42;
    }

    .agents-control-pending-table__cell-stack {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }

    .agents-control-pending-table__detail-stack {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }

    .agents-control-pending-table__id-value {
      display: flex;
      align-items: center;
      justify-content: flex-start !important;
      width: 100%;
      color: #596673;
      font-size: 14px;
      font-weight: 400;
      line-height: 1.45;
      text-align: left;
      white-space: nowrap;
    }

    .agents-control-pending-table__action-title {
      color: #596673;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.45;
    }

    .agents-control-pending-table__meta,
    .agents-control-pending-table__reason-copy {
      color: #596673;
      font-weight: 400;
      line-height: 1.45;
    }

    .agents-control-pending-table__body-cell--requested .agents-control-pending-table__meta,
    .agents-control-pending-table__body-cell--sla .agents-control-pending-table__meta {
      white-space: nowrap;
    }

    .agents-control-pending-table__meta--requested-date {
      margin-left: 20px;
    }

    .agents-control-pending-table .agents-control-review-mode,
    .agents-control-pending-table .agents-control-change-summary,
    .agents-control-pending-table .agents-control-review-guards {
      margin-top: 0;
    }

    .agents-control-pending-table .agents-control-review-guards {
      width: 100%;
    }

    .agents-control-pending-table .agents-control-review-guard {
      margin: 0;
      line-height: 1.45;
    }

    .agents-control-diff-modal[hidden] {
      display: none !important;
    }

    .agents-control-rule-timing-fields {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
      margin-bottom: 8px;
    }

    .agents-control-diff-modal {
      position: fixed;
      inset: 0;
      z-index: 1010;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    .agents-control-diff-modal__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(15, 23, 42, 0.42);
    }

    .agents-control-diff-modal__dialog {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      width: min(1120px, calc(100vw - 48px));
      max-height: calc(100vh - 48px);
      overflow: hidden;
      border: 1px solid var(--gray-300);
      border-radius: 6px;
      background: var(--white);
      box-shadow: 0 24px 80px rgba(15, 23, 42, 0.22);
    }

    .agents-control-diff-modal__header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
      padding: 20px 20px 12px;
      border-bottom: 1px solid var(--gray-200);
      background: var(--gray-050);
    }

    .agents-control-diff-modal__heading h2 {
      margin: 0 0 4px;
      color: var(--gray-900);
      font-size: 18px;
      line-height: 1.2;
    }

    .agents-control-diff-modal__status,
    .agents-control-diff-modal__intro {
      margin: 0 20px;
    }

    .agents-control-diff-modal__status {
      margin-top: 16px;
      padding: 10px 12px;
      border-radius: 4px;
      border: 1px solid var(--gray-250, var(--gray-300));
      background: var(--gray-050);
      color: var(--gray-800);
    }

    .agents-control-diff-modal__status--loading {
      border-color: var(--gray-300);
      background: var(--gray-050);
    }

    .agents-control-diff-modal__status--error {
      border-color: var(--red-200);
      background: var(--red-050);
      color: var(--red-900);
    }

    .agents-control-diff-modal__intro {
      margin: 0;
      line-height: 1.45;
    }

    .agents-control-diff-modal__intro:not(:empty) {
      padding: 12px 20px 16px;
      background: var(--gray-050);
    }

    .agents-control-diff-modal__pane {
      display: flex;
      flex: 1 1 auto;
      flex-direction: column;
      min-height: 0;
      margin-top: 0;
      overflow: hidden;
      background: var(--white);
    }

    .agents-control-diff-modal__tabs {
      margin: 0;
      background: var(--gray-050);
    }

    .agents-control-diff-modal__tabs .scrollable {
      padding-inline: 0;
    }

    .agents-control-diff-modal__tabs [role='tablist'] [role='tab']:not(.sel) {
      background: var(--gray-050);
    }

    .agents-control-diff-modal__tabs [role='tablist'] [role='tab'].sel::after {
      content: '';
      position: absolute;
      inset-inline: -1px;
      bottom: -1px;
      height: 3px;
      background: var(--white);
      pointer-events: none;
    }

    .agents-control-diff-modal__pane-body {
      flex: 1 1 auto;
      min-height: 0;
      overflow: auto;
      background: var(--white);
    }

    .agents-control-diff-rows {
      display: grid;
      gap: 12px;
      padding: 16px;
    }

    .agents-control-diff-rows[hidden],
    .agents-control-redline-rows[hidden],
    .agents-control-focus-rows[hidden] {
      display: none !important;
    }

    .agents-control-diff-empty {
      padding: 16px;
      border: 1px dashed var(--gray-300);
      border-radius: 4px;
      background: var(--gray-050);
    }

    .agents-control-redline-rows {
      display: grid;
      gap: 12px;
      padding: 16px;
    }

    .agents-control-focus-toolbar {
      display: flex;
      justify-content: flex-end;
      width: min(100%, 744px);
      margin: 0 auto;
      padding: 28px 32px 0;
      box-sizing: border-box;
    }

    .agents-control-focus-toolbar[hidden] {
      display: none !important;
    }

    .agents-control-focus-toolbar .btn {
      min-width: 72px;
    }

    .agents-control-focus-rows {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 20px 32px 56px;
    }

    .agents-control-focus-row {
      width: min(100%, 744px);
    }

    .agents-control-focus-row__text {
      margin: 0;
      font-family: SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
      font-size: 12px;
      line-height: 1.62;
      white-space: pre-wrap;
      word-break: break-word;
      overflow-wrap: anywhere;
    }

    .agents-control-focus-row__text--before {
      color: #667482;
      opacity: 1;
      filter: none;
    }

    .agents-control-focus-row__segment {
      color: #bbc7d5;
      font-weight: 400;
      opacity: 0.64;
      filter: blur(0.85px);
    }

    .agents-control-focus-row__segment--changed {
      color: #596673;
      font-weight: 400;
      opacity: 1;
      filter: none;
    }

    .agents-control-focus-row__separator {
      display: flex;
      align-items: center;
      justify-content: center;
      width: min(100%, 744px);
      padding: 24px 0;
    }

    .agents-control-focus-row__dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: #d7e0eb;
    }

    @media (max-width: 720px) {
      .agents-control-focus-toolbar {
        padding: 24px 20px 0;
      }

      .agents-control-focus-rows {
        padding: 20px 20px 40px;
      }
    }

    .agents-control-diff-row {
      border: 1px solid var(--gray-200);
      border-radius: 4px;
      background: var(--gray-000, var(--white));
      overflow: hidden;
    }

    .agents-control-diff-row--unsupported {
      border-color: var(--gray-300);
    }

    .agents-control-diff-row__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 14px;
      border-bottom: 1px solid var(--gray-200);
      background: var(--gray-050);
    }

    .agents-control-diff-row__label {
      color: var(--gray-900);
      font-size: 13px;
      font-weight: 700;
      line-height: 1.35;
    }

    .agents-control-diff-row__change {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 3px 8px;
      border-radius: 999px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .agents-control-diff-row__change--added {
      background: var(--green-100);
      color: var(--green-900);
    }

    .agents-control-diff-row__change--removed {
      background: var(--red-100);
      color: var(--red-900);
    }

    .agents-control-diff-row__change--changed {
      background: var(--gray-150);
      color: var(--gray-900);
    }

    .agents-control-diff-row__columns {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      padding: 14px;
    }

    .agents-control-diff-row__column {
      min-width: 0;
      border: 1px solid var(--gray-200);
      border-radius: 4px;
      overflow: hidden;
      background: var(--white);
    }

    .agents-control-diff-row__column--before {
      border-color: var(--red-200);
      background: var(--red-050);
    }

    .agents-control-diff-row__column--after {
      border-color: var(--green-200);
      background: var(--green-050);
    }

    .agents-control-diff-row__column-label {
      padding: 8px 10px;
      border-bottom: 1px solid currentColor;
      color: var(--gray-700);
      font-size: 11px;
      font-weight: 700;
      line-height: 1.2;
      text-transform: uppercase;
      opacity: 0.85;
    }

    .agents-control-diff-row__value {
      margin: 0;
      padding: 10px;
      color: var(--gray-900);
      font-family: inherit;
      font-size: 12px;
      line-height: 1.5;
      white-space: pre-wrap;
      word-break: break-word;
      overflow-wrap: anywhere;
    }

    .agents-control-diff-row__note {
      padding: 0 14px 14px;
      color: var(--gray-700);
      font-size: 11px;
      line-height: 1.45;
    }

    .agents-control-redline-row {
      border: 1px solid var(--gray-200);
      border-radius: 4px;
      background: var(--gray-000, var(--white));
      overflow: hidden;
    }

    .agents-control-redline-row--unsupported {
      border-color: var(--gray-300);
    }

    .agents-control-redline-row__header {
      padding: 12px 14px;
      border-bottom: 1px solid var(--gray-200);
      background: var(--gray-050);
    }

    .agents-control-redline-row__label {
      color: var(--gray-900);
      font-size: 13px;
      font-weight: 700;
      line-height: 1.35;
    }

    .agents-control-redline-row__body {
      padding: 14px;
    }

    .agents-control-redline-row__text {
      color: var(--gray-900);
      font-size: 13px;
      line-height: 1.65;
      white-space: pre-wrap;
      word-break: break-word;
      overflow-wrap: anywhere;
    }

    .agents-control-redline-row__segment {
      color: inherit;
    }

    .agents-control-redline-row__segment--added {
      background: color-mix(in srgb, var(--green-100) 76%, white 24%);
      color: var(--green-900);
      text-decoration: none;
      border-radius: 2px;
      padding: 0 1px;
    }

    .agents-control-redline-row__segment--removed {
      background: color-mix(in srgb, var(--red-100) 74%, white 26%);
      color: var(--red-900);
      text-decoration-thickness: 1.5px;
      border-radius: 2px;
      padding: 0 1px;
    }

    .agents-control-redline-row__note {
      padding: 0 14px 14px;
      color: var(--gray-700);
      font-size: 11px;
      line-height: 1.45;
    }

    .agents-control-pending-table__decision-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .agents-control-pending-table__decision-form {
      display: inline-flex;
      margin: 0;
    }

    .agents-control-pending-table__decision-button {
      display: inline-flex;
      width: auto;
      min-width: 88px;
      min-height: auto;
      padding: 7px 10px;
      border-radius: 3px;
      background-image: none;
      box-shadow: none;
      font-size: 12px;
      font-weight: 400;
      line-height: normal;
    }

    .agents-control-pending-table__decision-button--reject {
      min-width: 34px;
      padding: 7px 8px;
      border: 1px solid #d4dbe4;
      background: #d4dbe4;
      color: #000000;
    }

    .agents-control-pending-table__decision-button--reject:hover,
    .agents-control-pending-table__decision-button--reject:focus {
      border-color: #c7d0db;
      background: #c7d0db;
      color: #000000;
    }

    .agents-control-pending-table__decision-button--approve {
      min-width: 34px;
      padding: 7px 8px;
      border: 1px solid #00b609;
      background: #00b609;
      color: #ffffff;
    }

    .agents-control-pending-table__decision-button--approve:hover,
    .agents-control-pending-table__decision-button--approve:focus {
      border-color: #009608;
      background: #009608;
      color: #ffffff;
    }

    .agents-control-pending-table__decision-button[disabled] {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .agents-control-pending-table__col--id,
    .agents-control-pending-table__cell--id,
    .agents-control-pending-table__body-cell--id {
      width: 70px;
      padding-left: 12px !important;
      padding-right: 12px !important;
      text-align: left !important;
      white-space: nowrap;
    }

    .agents-control-table thead > tr > th:first-child,
    .agents-control-table tbody > tr > td:first-child {
      width: 70px;
      padding-left: 12px !important;
      padding-right: 12px !important;
      text-align: left !important;
      white-space: nowrap;
    }

    .agents-control-table tbody > tr > td:first-child {
      font-variant-numeric: tabular-nums;
    }

    .agents-control-table tbody > tr > td:first-child > * {
      text-align: left;
    }

    .agents-control-rules-table thead > tr > th:first-child,
    .agents-control-rules-table tbody > tr > td:first-child {
      width: 28%;
      min-width: 240px;
      white-space: normal;
      font-weight: 700;
    }

    .agents-control-table__id-value {
      display: flex;
      align-items: center;
      justify-content: flex-start !important;
      width: 100%;
      font-weight: 700;
      text-align: left;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }

    .agents-control-pending-table__col--action,
    .agents-control-pending-table__cell--action,
    .agents-control-pending-table__body-cell--action {
      width: 392px;
    }

    .agents-control-pending-table__col--rule,
    .agents-control-pending-table__cell--rule,
    .agents-control-pending-table__body-cell--rule {
      width: 288px;
    }

    .agents-control-pending-table__col--requested,
    .agents-control-pending-table__cell--requested,
    .agents-control-pending-table__body-cell--requested {
      width: 186px;
    }

    .agents-control-pending-table__col--reason,
    .agents-control-pending-table__cell--reason,
    .agents-control-pending-table__body-cell--reason {
      width: 240px;
    }

    .agents-control-pending-table__col--sla,
    .agents-control-pending-table__cell--sla,
    .agents-control-pending-table__body-cell--sla {
      width: 120px;
    }

    .agents-control-pending-table__col--decision,
    .agents-control-pending-table__cell--decision,
    .agents-control-pending-table__body-cell--decision {
      width: 156px;
    }

    @media (min-width: 1280px) {
      .agents-control-pending-table__col--decision,
      .agents-control-pending-table__cell--decision,
      .agents-control-pending-table__body-cell--decision {
        width: 188px;
      }

      .agents-control-pending-table__decision-actions {
        flex-wrap: nowrap;
      }
    }
  {% endcss %}
{% endblock %}
