                {% endif %}
                {% if approval.assuranceModeLabel %}
                  <div class="light">Assurance: {{ approval.assuranceModeLabel }}</div>
                {% endif %}
                {% if approval.assuranceReasonLabel %}
                  <div class="light">{{ approval.assuranceReasonLabel }}</div>
                {% endif %}
                {% if approval.secondaryDecisionBy %}
