{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Agents Approvals" %}
{% set selectedSubnavItem = "control" %}
{% set controlHeadingByKey = {
  approvals: 'Approvals',
  rules: 'Rules',
} %}
{% set controlHeading = controlHeadingByKey[activeControlTab]|default('Approvals') %}
{% set controlIntroByKey = {
  approvals: 'Review, approve, and run governed requests with clear operator actions and audit visibility.',
  rules: 'Define risk and approval behavior for governed actions, and validate outcomes with dry-run simulation.',
} %}
{% set controlSidebarNavItems = {} %}
{% for tab in controlTabs %}
  {% set controlSidebarNavItems = controlSidebarNavItems|merge({
    (tab.key): {
      label: tab.label,
      url: tab.url,
    }
  }) %}
{% endfor %}

{% block sidebar %}
      {% include "_includes/nav"
    with {
      label: 'Approvals',
      items: controlSidebarNavItems,
      selectedItem: activeControlTab,
    }
    only
  %}
{% endblock %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <div class="agents-page-header">
    <h1>{{ controlHeading }}</h1>
    <p class="agents-page-intro">{{ controlIntroByKey[activeControlTab] ?? 'Operate governed approval and execution workflows.' }}</p>
  </div>

  <div class="agents-layout-stack">
  {% if activeControlTab == 'approvals' %}
  {% set controlPendingCount = controlSummary.approvalsPending|default(0) %}
  {% set controlExpiredApprovalsCount = controlSummary.approvalsExpired|default(0) %}
  {% set controlBlockedRunsCount = controlSummary.executionsBlocked|default(0) %}
  {% set controlCompletedRunsCount = controlSummary.executionsSucceeded|default(0) %}
  {% set controlActivityCount = controlSummary.auditEvents|default(0) %}

  <section class="border rounded p-3 agents-control-pending-section">
    <div class="agents-metric-strip-wrap">
      <div class="agents-metric-strip">
      <div class="agents-metric agents-metric-strip-card {{ controlPendingCount > 0 ? 'agents-metric--warn' : 'agents-metric--good' }}">
        <div class="label">Waiting for decision</div>
        <div class="value">{{ controlPendingCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlExpiredApprovalsCount > 0 ? 'agents-metric--bad' : 'agents-metric--good' }}">
        <div class="label">Expired approvals</div>
        <div class="value">{{ controlExpiredApprovalsCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlBlockedRunsCount > 0 ? 'agents-metric--bad' : 'agents-metric--good' }}">
        <div class="label">Runs blocked</div>
        <div class="value">{{ controlBlockedRunsCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlCompletedRunsCount > 0 ? 'agents-metric--good' : 'agents-metric--warn' }}">
        <div class="label">Runs completed</div>
        <div class="value">{{ controlCompletedRunsCount }}</div>
      </div>
      <div class="agents-metric agents-metric-strip-card {{ controlActivityCount > 0 ? 'agents-metric--good' : 'agents-metric--warn' }}">
        <div class="label">Activity entries</div>
        <div class="value">{{ controlActivityCount }}</div>
      </div>
      </div>
    </div>
  </section>


  <hr>


  <section class="border rounded p-3">
    <h2 class="h4">Waiting for Decision</h2>
    {% if controlPendingApprovals|length %}
      <div class="tablepane mx-0" style="margin-top: 0;">
        <table class="data fullwidth agents-control-pending-table">
        <colgroup>
          <col class="agents-control-pending-table__col agents-control-pending-table__col--id">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--action">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--rule">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--requested">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--reason">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--sla">
          <col class="agents-control-pending-table__col agents-control-pending-table__col--decision">
        </colgroup>
        <thead>
        <tr>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--id">#</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--action">Action</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--rule">Rule</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--requested">Requested</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--reason">Reason</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--sla">SLA</th>
          <th class="agents-control-pending-table__cell agents-control-pending-table__cell--decision">Decision</th>
        </tr>
        </thead>
        <tbody>
        {% for approval in controlPendingApprovals %}
          {% set policy = approval.policy ?? null %}
          {% set reviewMode = approval.reviewMode ?? 'none' %}
          {% set reviewGuards = approval.reviewGuards ?? [] %}
          {% set hasBlockingReviewGuards = approval.reviewHasBlockingGuards ?? false %}
          <tr class="agents-control-pending-table__row">
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--id">
              <div class="agents-control-pending-table__id-value">{{ approval.id }}</div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--action">
              {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
              <div class="agents-control-pending-table__cell-stack agents-control-pending-table__cell-stack--action">
                <div class="agents-control-pending-table__detail-stack">
                  <div class="agents-control-pending-table__action-title">{{ approval.actionLabel ?: 'Unknown action' }}</div>
                  <div class="agents-control-pending-table__meta">
                    {% if approval.targetEntryCpUrl %}
                      <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link agents-control-pending-table__target-link">{{ targetTitle }}</a>
                    {% else %}
                      {{ targetTitle }}
                    {% endif %}
                  </div>
                  {% if reviewMode == 'draft' %}
                    <div class="agents-control-pending-table__meta agents-control-review-mode">
                      Reviewing draft{% if approval.reviewDraftId %} #{{ approval.reviewDraftId }}{% endif %}
                      {% if approval.targetEntryCanonicalCpUrl %}
                        ·
                        <a href="{{ cpUrl(approval.targetEntryCanonicalCpUrl) }}" class="agents-control-target-link agents-control-pending-table__canonical-link">
                          open canonical
                        </a>
                      {% endif %}
                    </div>
                  {% elseif reviewMode == 'canonical' %}
                    <div class="agents-control-pending-table__meta agents-control-review-mode">Review falls back to canonical entry.</div>
                  {% endif %}
                  <div class="agents-control-pending-table__meta">Ref: {{ approval.actionRef ?: 'n/a' }}</div>
                </div>
                {% if approval.targetEntryId %}
                  <button
                    class="btn small js-control-review-entry agents-control-review-btn agents-control-pending-table__review-button"
                    type="button"
                    data-entry-id="{{ approval.targetEntryId }}"
                    data-site-id="{{ approval.targetEntrySiteId ?: 0 }}"
                    data-entry-url="{{ approval.targetEntryCpUrl ? cpUrl(approval.targetEntryCpUrl) : '' }}"
                  >Review</button>
                {% endif %}
                {% if approval.reviewChangeSummary|length %}
                  {% set reviewChangeSummaryPanelId = 'agents-control-review-change-summary-' ~ approval.id %}
                  <div class="agents-control-change-summary">
                    <button
                      class="agents-control-inline-toggle"
                      type="button"
                      data-control-inline-toggle
                      data-target="{{ reviewChangeSummaryPanelId }}"
                      aria-controls="{{ reviewChangeSummaryPanelId }}"
                      aria-expanded="false"
                    >
                      <span>Proposed changes</span>
                      <span class="agents-control-inline-chevron" aria-hidden="true"></span>
                    </button>
                    <div id="{{ reviewChangeSummaryPanelId }}" class="agents-control-inline-panel" hidden>
                      <ul>
                        {% for change in approval.reviewChangeSummary %}
                          <li><strong>{{ change.label }}:</strong> {{ change.value }}</li>
                        {% endfor %}
                      </ul>
                    </div>
                  </div>
                {% endif %}
                {% if reviewGuards|length %}
                  <div class="agents-control-review-guards">
                    {% for guard in reviewGuards %}
                      <div class="agents-control-review-guard agents-control-review-guard--{{ guard.level == 'critical' ? 'critical' : 'warning' }}">
                        <strong>{{ guard.label }}</strong>: {{ guard.detail }}
                      </div>
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--rule">
              <div class="agents-control-pending-table__cell-stack agents-control-pending-table__cell-stack--rule">
                {% if policy %}
                  <span class="agents-control-pending-table__risk-badge">Risk {{ policy.riskLevel|upper }}</span>
                  <div class="agents-control-pending-table__detail-stack">
                    <div class="agents-control-pending-table__meta">Rule: {{ policy.handle }}</div>
                    <div class="agents-control-pending-table__meta">Approval required: {{ policy.requiresApproval ? 'yes' : 'no' }}</div>
                    <div class="agents-control-pending-table__meta">
                      Approvals: {{ approval.approvalCount|default(0) }}/{{ approval.requiredApprovals|default(1) }}
                      {% if approval.approvalsRemaining|default(0) > 0 %}
                        ({{ approval.approvalsRemaining }} remaining)
                      {% endif %}
                    </div>
                  </div>
                {% else %}
                  <span class="agents-control-pending-table__meta">Default rule</span>
                {% endif %}
                {% if approval.assuranceModeLabel %}
                  <div class="agents-control-pending-table__detail-stack">
                    <div class="agents-control-pending-table__meta">
                      Assurance: <strong>{{ approval.assuranceModeLabel }}</strong>
                      {% if approval.assuranceEvaluatedAt %}
                        <span>· evaluated {{ approval.assuranceEvaluatedAt|datetime('short') }}</span>
                      {% endif %}
                      {% if approval.assuranceActiveCpUserCount is not null %}
                        <span>· active CP users {{ approval.assuranceActiveCpUserCount }}</span>
                      {% endif %}
                    </div>
                  </div>
                {% endif %}
                {% if approval.assuranceReasonLabel %}
                  <div class="agents-control-review-guard agents-control-review-guard--warning" style="margin-top: 6px;">
                    {{ approval.assuranceReasonLabel }}
                  </div>
                {% endif %}
                {% if approval.decidedBy %}
                  <div class="agents-control-pending-table__detail-stack">
                    <div class="agents-control-pending-table__meta">Primary approver: {{ approval.decidedByLabel ?: approval.decidedBy }}</div>
                    <div class="agents-control-pending-table__meta">Primary ID: {{ approval.decidedBy }}</div>
                  </div>
                {% endif %}
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--requested">
              <div class="agents-control-pending-table__detail-stack">
                <div class="agents-control-pending-table__meta">{{ approval.requestedByLabel ?: approval.requestedBy }}</div>
                {% if approval.requestedBy %}
                  <div class="agents-control-pending-table__meta">{{ approval.requestedBy }}</div>
                {% endif %}
                <div class="agents-control-pending-table__meta">{{ approval.dateCreated ? approval.dateCreated|datetime('short') : 'n/a' }}</div>
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--reason">
              <div class="agents-control-pending-table__reason-copy">{{ approval.reason ?: 'n/a' }}</div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--sla">
              <div class="agents-control-pending-table__detail-stack">
                <div class="agents-control-pending-table__meta">{{ approval.slaState|default('none') }}</div>
                <div class="agents-control-pending-table__meta">due: {{ approval.slaDueAt ? approval.slaDueAt|datetime('short') : 'n/a' }}</div>
                {% if approval.escalatedAt %}
                  <div class="agents-control-pending-table__meta">escalated: {{ approval.escalatedAt|datetime('short') }}</div>
                {% endif %}
              </div>
            </td>
            <td class="agents-control-pending-table__body-cell agents-control-pending-table__body-cell--decision">
              {% if canManageApprovals %}
                <div class="agents-control-pending-table__cell-stack agents-control-pending-table__cell-stack--decision">
                  {% if hasBlockingReviewGuards %}
                    <div class="agents-control-review-guard agents-control-review-guard--critical" style="margin-bottom: 6px;">
                      Approve actions disabled until review blockers are resolved.
                    </div>
                  {% endif %}
                  <div class="agents-control-pending-table__decision-actions">
                    <form method="post" accept-charset="UTF-8" class="js-confirm-form agents-control-pending-table__decision-form" data-confirm-message="Reject request #{{ approval.id }} ({{ approval.actionType }})?">
                      {{ csrfInput() }}
                      {{ actionInput('agents/dashboard/decide-control-approval') }}
                      {{ redirectInput('agents/control') }}
                      <input type="hidden" name="approvalId" value="{{ approval.id }}">
                      <input type="hidden" name="decision" value="rejected">
                      <input class="agents-control-pending-table__decision-input" type="text" name="decisionReason" placeholder="Reason for rejection">
                      <button class="btn agents-control-pending-table__decision-button agents-control-pending-table__decision-button--reject" type="submit">Reject</button>
                    </form>
                    <form method="post" accept-charset="UTF-8" class="js-confirm-form agents-control-pending-table__decision-form" data-confirm-message="Approve request #{{ approval.id }} ({{ approval.actionType }})? It will execute automatically once required approvals are complete.">
                      {{ csrfInput() }}
                      {{ actionInput('agents/dashboard/decide-control-approval') }}
                      {{ redirectInput('agents/control') }}
                      <input type="hidden" name="approvalId" value="{{ approval.id }}">
                      <input type="hidden" name="decision" value="approved">
                      <input class="agents-control-pending-table__decision-input" type="text" name="decisionReason" placeholder="Optional note">
                      <button class="btn agents-control-pending-table__decision-button agents-control-pending-table__decision-button--approve" type="submit"{% if hasBlockingReviewGuards %} disabled{% endif %}>Approve</button>
                    </form>
                  </div>
                  {% if approval.requiredApprovals|default(1) > 1 and approval.approvalsRemaining|default(0) > 1 %}
                    <div class="agents-control-pending-table__decision-note">
                      This is the first approval step. Action executes automatically after final required approval.
                    </div>
                  {% endif %}
                </div>
              {% else %}
                <span class="agents-control-pending-table__meta">Read-only</span>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
        </tbody>
        </table>
      </div>
    {% else %}
      <p>No requests are waiting for a decision.</p>
    {% endif %}
  </section>


  <hr>

  {% set approvedTablePanelId = 'agents-control-approved-table-panel' %}
  <!-- Release-gate sentinel: <h2 class="h4">Approved</h2> -->
  <section class="border rounded p-3">
    <h2 class="h4">
      {% if controlApprovedApprovals|length %}
        <button
          class="agents-control-section-toggle"
          type="button"
          data-control-section-toggle
          data-target="{{ approvedTablePanelId }}"
          aria-controls="{{ approvedTablePanelId }}"
          aria-expanded="false"
        >
          <span>Approved</span>
          <span class="agents-control-section-chevron" aria-hidden="true"></span>
        </button>
      {% else %}
        Approved
      {% endif %}
    </h2>
    {% if controlApprovedApprovals|length %}
      <div id="{{ approvedTablePanelId }}" class="agents-control-section-panel" hidden>
        <div class="tablepane mx-0" style="margin-top: 0;">
          <table class="data fullwidth agents-control-table">
          <thead>
          <tr>
            <th>Request #</th>
            <th>Action</th>
            <th>Approver</th>
            <th>Approved</th>
            <th>Execution</th>
            <th>Actions</th>
          </tr>
          </thead>
          <tbody>
          {% for approval in controlApprovedApprovals %}
            {% set latestExecution = approval.latestExecution ?? null %}
            {% set executionStatus = latestExecution ? latestExecution.status|lower : '' %}
            {% set canApplyDraft = approval.actionType|lower == 'entry.updatedraft'
              and approval.reviewMode == 'draft'
              and approval.targetEntryDraftRecordId
              and (executionStatus == '' or executionStatus == 'succeeded')
            %}
            <tr>
              <td>#{{ approval.id }}</td>
              <td>
                <div class="agents-control-table__action-title">{{ approval.actionLabel ?: 'Unknown action' }}</div>
                <span class="agents-actor-raw">{{ approval.actionType }}</span>
                {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
                <div class="light">
                  {% if approval.targetEntryCpUrl %}
                    <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                  {% else %}
                    {{ targetTitle }}
                  {% endif %}
                </div>
                {% if approval.targetEntryId %}
                  <button
                    class="btn small js-control-review-entry agents-control-review-btn"
                    type="button"
                    data-entry-id="{{ approval.targetEntryId }}"
                    data-site-id="{{ approval.targetEntrySiteId ?: 0 }}"
                    data-entry-url="{{ approval.targetEntryCpUrl ? cpUrl(approval.targetEntryCpUrl) : '' }}"
                  >Review</button>
                {% endif %}
                <span class="agents-actor-raw">Ref: {{ approval.actionRef ?: 'n/a' }}</span>
              </td>
              <td>
                <div>{{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}</div>
                {% if approval.decidedBy %}
                  <span class="agents-actor-raw">{{ approval.decidedBy }}</span>
                {% endif %}
                {% if approval.assuranceModeLabel %}
                  <div class="light">Assurance: {{ approval.assuranceModeLabel }}</div>
                {% endif %}
                {% if approval.assuranceReasonLabel %}
                  <div class="light">{{ approval.assuranceReasonLabel }}</div>
                {% endif %}
                {% if approval.secondaryDecisionBy %}
                  <div class="light">2nd: {{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}</div>
                  <span class="agents-actor-raw">2nd ID: {{ approval.secondaryDecisionBy }}</span>
                {% endif %}
              </td>
              <td>{{ approval.decidedAt ? approval.decidedAt|datetime('short') : 'n/a' }}</td>
              <td>
                {% if latestExecution %}
                  <div><strong>{{ latestExecution.status|upper }}</strong></div>
                  <div class="light">run #{{ latestExecution.id }}</div>
                  <div class="light">{{ (latestExecution.executedAt ?: latestExecution.dateCreated) ? (latestExecution.executedAt ?: latestExecution.dateCreated)|datetime('short') : 'n/a' }}</div>
                {% else %}
                  <span class="light">n/a</span>
                {% endif %}
              </td>
              <td>
                {% if canApplyDraft %}
                  <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Apply draft #{{ approval.targetEntryDraftRecordId }} to canonical entry now?">
                    {{ csrfInput() }}
                    {{ actionInput('elements/apply-draft') }}
                    {{ redirectInput('agents/control/approvals') }}
                    <input type="hidden" name="draftId" value="{{ approval.targetEntryDraftRecordId }}">
                    {% if approval.targetEntryCanonicalId %}
                      <input type="hidden" name="elementId" value="{{ approval.targetEntryCanonicalId }}">
                    {% endif %}
                    {% set applySiteId = approval.targetEntrySiteId ?: approval.targetEntryCanonicalSiteId ?: 0 %}
                    {% if applySiteId %}
                      <input type="hidden" name="siteId" value="{{ applySiteId }}">
                    {% endif %}
                    <button class="btn submit small" type="submit">Apply Draft</button>
                  </form>
                {% elseif approval.actionType|lower == 'entry.updatedraft' and approval.reviewDraftId %}
                  {% if latestExecution and latestExecution.status|lower != 'succeeded' %}
                    <span class="light">Apply blocked: run {{ latestExecution.status|lower }}.</span>
                  {% else %}
                    <span class="light">Draft not available to apply.</span>
                  {% endif %}
                {% else %}
                  <span class="light">n/a</span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          </tbody>
          </table>
        </div>
      </div>
    {% else %}
      <p>No approved requests yet.</p>
    {% endif %}
  </section>

  <hr>

  {% set completedTablePanelId = 'agents-control-completed-table-panel' %}
  <section class="border rounded p-3">
    <h2 class="h4">
      {% if controlCompletedApprovals|length %}
        <button
          class="agents-control-section-toggle"
          type="button"
          data-control-section-toggle
          data-target="{{ completedTablePanelId }}"
          aria-controls="{{ completedTablePanelId }}"
          aria-expanded="false"
        >
          <span>Applied / Completed</span>
          <span class="agents-control-section-chevron" aria-hidden="true"></span>
        </button>
      {% else %}
        Applied / Completed
      {% endif %}
    </h2>
    {% if controlCompletedApprovals|length %}
      <div id="{{ completedTablePanelId }}" class="agents-control-section-panel" hidden>
        <div class="tablepane mx-0" style="margin-top: 0;">
          <table class="data fullwidth agents-control-table">
          <thead>
          <tr>
            <th>Request #</th>
            <th>Action</th>
            <th>Approver</th>
            <th>Completed</th>
            <th>Outcome</th>
          </tr>
          </thead>
          <tbody>
          {% for approval in controlCompletedApprovals %}
            {% set latestExecution = approval.latestExecution ?? null %}
            {% set completionState = approval.completionState ?? {} %}
            <tr>
              <td>#{{ approval.id }}</td>
              <td>
                <div class="agents-control-table__action-title">{{ approval.actionLabel ?: 'Unknown action' }}</div>
                <span class="agents-actor-raw">{{ approval.actionType }}</span>
                {% set targetTitle = approval.targetTitle ?: 'Untitled target' %}
                <div class="light">
                  {% if approval.targetEntryCpUrl %}
                    <a href="{{ cpUrl(approval.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                  {% else %}
                    {{ targetTitle }}
                  {% endif %}
                </div>
                {% if approval.targetEntryId %}
                  <button
                    class="btn small js-control-review-entry agents-control-review-btn"
                    type="button"
                    data-entry-id="{{ approval.targetEntryId }}"
                    data-site-id="{{ approval.targetEntrySiteId ?: 0 }}"
                    data-entry-url="{{ approval.targetEntryCpUrl ? cpUrl(approval.targetEntryCpUrl) : '' }}"
                  >Review</button>
                {% endif %}
                <span class="agents-actor-raw">Ref: {{ approval.actionRef ?: 'n/a' }}</span>
              </td>
              <td>
                <div>{{ approval.decidedByLabel ?: (approval.decidedBy ?: 'n/a') }}</div>
                {% if approval.decidedBy %}
                  <span class="agents-actor-raw">{{ approval.decidedBy }}</span>
                {% endif %}
                {% if approval.assuranceModeLabel %}
                  <div class="light">Assurance: {{ approval.assuranceModeLabel }}</div>
                {% endif %}
                {% if approval.assuranceReasonLabel %}
                  <div class="light">{{ approval.assuranceReasonLabel }}</div>
                {% endif %}
                {% if approval.secondaryDecisionBy %}
                  <div class="light">2nd: {{ approval.secondaryDecisionByLabel ?: approval.secondaryDecisionBy }}</div>
                  <span class="agents-actor-raw">2nd ID: {{ approval.secondaryDecisionBy }}</span>
                {% endif %}
              </td>
              <td>
                <div><strong>{{ completionState.label ?: 'COMPLETED' }}</strong></div>
                {% if completionState.at %}
                  <div class="light">{{ completionState.at|datetime('short') }}</div>
                {% else %}
                  <div class="light">n/a</div>
                {% endif %}
              </td>
              <td>
                <div class="light">{{ completionState.detail ?: 'Completed.' }}</div>
                {% if latestExecution %}
                  <div class="light">run #{{ latestExecution.id }} · {{ latestExecution.status|upper }}</div>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          </tbody>
          </table>
        </div>
      </div>
    {% else %}
      <p>No applied/completed requests yet.</p>
    {% endif %}
  </section>


  <hr>

  {% set followUpTablePanelId = 'agents-control-follow-up-table-panel' %}
  <section class="border rounded p-3">
    <h2 class="h4">
      {% if controlAttentionExecutions|length %}
        <button
          class="agents-control-section-toggle"
          type="button"
          data-control-section-toggle
          data-target="{{ followUpTablePanelId }}"
          aria-controls="{{ followUpTablePanelId }}"
          aria-expanded="false"
        >
          <span>Runs That Need Follow-up</span>
          <span class="agents-control-section-chevron" aria-hidden="true"></span>
        </button>
      {% else %}
        Runs That Need Follow-up
      {% endif %}
    </h2>
    {% if controlAttentionExecutions|length %}
      <div id="{{ followUpTablePanelId }}" class="agents-control-section-panel" hidden>
        <div class="tablepane mx-0" style="margin-top: 0;">
          <table class="data fullwidth agents-control-table">
          <thead>
          <tr>
            <th>Run #</th>
            <th>Action</th>
            <th>Status</th>
            <th>Rule</th>
            <th>Issue</th>
          </tr>
          </thead>
          <tbody>
          {% for execution in controlAttentionExecutions %}
            {% set policy = execution.policy ?? null %}
            <tr>
