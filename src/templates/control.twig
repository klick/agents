  {% set followUpTablePanelId = 'agents-control-follow-up-table-panel' %}
  <section class="agents-control-journey-card agents-control-approval-card agents-control-journey-card--collapsed{% if not controlAttentionExecutions|length %} agents-control-journey-card--empty{% endif %}">
    <div class="agents-control-journey-card__header">
    <h2 class="agents-control-journey-card__title agents-control-journey-card__title--toggle">
      {% if controlAttentionExecutions|length %}
        <button
          class="agents-control-stage-toggle"
          type="button"
          data-control-section-toggle
          data-target="{{ followUpTablePanelId }}"
          aria-controls="{{ followUpTablePanelId }}"
          aria-expanded="false"
        >
          <span>Runs That Need Follow-up</span>
          <span class="agents-control-stage-chevron" aria-hidden="true"></span>
        </button>
      {% else %}
        <span>Runs That Need Follow-up</span>
      {% endif %}
    </h2>
    </div>
    {% if controlAttentionExecutions|length %}
      <div id="{{ followUpTablePanelId }}" class="agents-control-section-panel agents-control-journey-card__panel" hidden>
        <div class="tablepane mx-0" style="margin-top: 0;">
          <table class="data fullwidth agents-control-table">
          <thead>
          <tr>
            <th>#</th>
            <th>Action</th>
            <th>Status</th>
            <th>Rule</th>
            <th>Issue</th>
          </tr>
          </thead>
          <tbody>
          {% for execution in controlAttentionExecutions %}
            {% set executionResultPayload = execution.resultPayload ?? {} %}
            {% set executionConflictType = executionResultPayload.conflictType ?? null %}
            {% set executionConflicts = executionResultPayload.conflictingDrafts ?? [] %}
            {% set hasExecutionSavedDraftConflict = execution.actionType|lower == 'entry.updatedraft' and executionConflictType == 'savedDraftExists' %}
            {% set executionDisplayMessage = hasExecutionSavedDraftConflict
              ? 'This entry already has an open draft.'
              : (execution.errorMessage ?: (executionResultPayload.message ?? 'Check the rule or approval setup and try again.'))
            %}
            {% set policy = execution.policy ?? null %}
            <tr>
              <td><span class="agents-control-table__id-value">{{ execution.id }}</span></td>
              <td>
                <div class="agents-control-table__action-title">{{ execution.actionLabel ?: 'Unknown action' }}</div>
                {% set targetTitle = execution.targetTitle ?: 'Untitled target' %}
                <div class="light">
                  {% if execution.targetEntryCpUrl %}
                    <a href="{{ cpUrl(execution.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                  {% else %}
                    {{ targetTitle }}
                  {% endif %}
                </div>
                {% if execution.targetEntryId or (execution.actionType|lower == 'entry.updatedraft' and execution.approvalId) %}
                  <div class="agents-control-table__quick-actions">
                    {% if execution.targetEntryId %}
                      <button
                        class="btn small js-control-review-entry agents-control-review-btn"
                        type="button"
                        data-entry-id="{{ execution.targetEntryId }}"
                        data-site-id="{{ execution.targetEntrySiteId ?: 0 }}"
                        data-entry-url="{{ execution.targetEntryCpUrl ? cpUrl(execution.targetEntryCpUrl) : '' }}"
                      >Review</button>
                    {% endif %}
                    {% if execution.actionType|lower == 'entry.updatedraft' and execution.approvalId %}
                      <button
                        class="btn small js-control-view-diff agents-control-diff-btn"
                        type="button"
                        data-approval-id="{{ execution.approvalId }}"
                      >Diff</button>
                    {% endif %}
                  </div>
                {% endif %}
              </td>
              <td><strong>{{ execution.status|replace({'_': ' '})|title }}</strong></td>
              <td>
                {% if policy %}
                  <div>{{ policy.displayName ?? policy.handle }}</div>
                  <div class="light">Rule: <code class="agents-inline-code">{{ policy.handle }}</code></div>
                {% else %}
                  <span class="light">Default rule</span>
                {% endif %}
              </td>
              <td>
                <div>{{ executionDisplayMessage }}</div>
                {% if hasExecutionSavedDraftConflict and executionConflicts|length %}
                  <div class="light">Open the existing draft or have the worker target that draft ID.</div>
                  {% for conflict in executionConflicts|slice(0, 2) %}
                    <div class="light">
                      Open draft{% if conflict.id ?? null %} <code class="agents-inline-code">#{{ conflict.id }}</code>{% endif %}{% if conflict.draftRecordId ?? null %} · saved draft <code class="agents-inline-code">#{{ conflict.draftRecordId }}</code>{% endif %}{% if conflict.draftName ?? null %} · {{ conflict.draftName }}{% elseif conflict.title ?? null %} · {{ conflict.title }}{% endif %}
                      {% if conflict.cpEditUrl ?? null %}
                        · <a href="{{ cpUrl(conflict.cpEditUrl) }}" class="agents-control-target-link">open</a>
                      {% endif %}
                    </div>
                  {% endfor %}
                  {% if executionConflicts|length > 2 %}
                    <div class="light">+ {{ executionConflicts|length - 2 }} more open drafts</div>
                  {% endif %}
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          </tbody>
          </table>
        </div>
      </div>
    {% endif %}
  </section>
  <div class="agents-control-journey-divider" aria-hidden="true"><span class="agents-control-journey-divider__dot"></span></div>
  {% endif %}

  {% if activeControlTab == 'rules' %}
  <section class="border rounded p-3">
    <h2 class="h4">Policy Simulator (Dry Run)</h2>
    <p class="light">Evaluate policy/approval outcomes without recording an execution run.</p>

    {% if canExecuteActions %}
      <form method="post" accept-charset="UTF-8" class="js-confirm-form" data-confirm-message="Run dry-run simulation?">
        {{ csrfInput() }}
        {{ actionInput('agents/dashboard/simulate-control-action') }}
        {{ redirectInput(controlRulesRedirect) }}

        {{ forms.textField({
          label: 'Action name',
          name: 'simulationActionType',
          required: true,
          placeholder: 'returns.exception.refund',
        }) }}

        {{ forms.textField({
          label: 'Case reference',
          name: 'simulationActionRef',
          placeholder: 'order-12345:return-998',
        }) }}

        {{ forms.textField({
          label: 'Approved request # (optional)',
          name: 'simulationApprovalId',
          placeholder: '123',
        }) }}

        <h3 class="h5">Dry-Run Payload</h3>
        {{ forms.textField({
          label: 'Order number / ID',
          name: 'simulationPayloadOrderId',
          placeholder: '12345',
        }) }}
        {{ forms.textField({
          label: 'Return number / ID',
          name: 'simulationPayloadReturnId',
          placeholder: '998',
        }) }}
        {{ forms.textField({
          label: 'Reason code',
          name: 'simulationPayloadReasonCode',
          placeholder: 'DAMAGED_ITEM',
        }) }}
        {{ forms.textField({
          label: 'Operator note',
          name: 'simulationPayloadOperatorNote',
          placeholder: 'Dry-run validation before execution.',
        }) }}

        <details style="margin-bottom: 12px;">
          <summary><strong>Advanced JSON payload override (optional)</strong></summary>
          <div style="margin-top: 8px;">
            {{ forms.textareaField({
              label: 'Payload JSON',
              instructions: 'Merged with guided fields. Duplicate keys in JSON take precedence.',
              name: 'simulationPayloadJson',
              rows: 4,
              value: '{}',
            }) }}
          </div>
        </details>

        <button class="btn" type="submit">Run Dry-Run</button>
      </form>
    {% else %}
      <p class="warning">You do not have permission to run policy simulations.</p>
    {% endif %}

    {% if controlSimulationResult %}
      <hr>
      <h3 class="h5">Latest Dry-Run Result</h3>
      {% set simEval = controlSimulationResult.evaluation ?? {} %}
      {% set simPolicy = controlSimulationResult.policy ?? {} %}
      <ul>
        <li>Status: <strong>{{ simEval.status ?? 'unknown' }}</strong></li>
        <li>Would execute: <strong>{{ simEval.wouldExecute ? 'yes' : 'no' }}</strong></li>
        <li>Required scope: <strong>{{ controlSimulationResult.requiredScope ?: 'n/a' }}</strong></li>
        <li>Policy: <strong>{{ simPolicy.handle ?: 'default' }}</strong></li>
        <li>Approval status: <strong>{{ simEval.approvalStatus ?? 'n/a' }}</strong></li>
      </ul>
      {% if simEval.reasons is defined and simEval.reasons|length %}
        <p><strong>Reasons</strong></p>
        <ul>
          {% for reason in simEval.reasons %}
            <li>{{ reason }}</li>
          {% endfor %}
        </ul>
      {% endif %}
      <details>
        <summary><strong>Technical JSON</strong></summary>
        <pre class="border rounded p-3" style="margin-top: 8px;">{{ controlSimulationResult|json_encode(constant('JSON_PRETTY_PRINT')) }}</pre>
      </details>
    {% endif %}
  </section>
  </div>
  </div>

  <hr>

