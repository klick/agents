  {% set controlDiffModalTabs = {
    ( 'agentsControlDiffRows' ): {
      label: 'Structured',
      url: '#agentsControlDiffRows',
    },
    ( 'agentsControlFocusRows' ): {
      label: 'Focus',
      url: '#agentsControlFocusRows',
    },
  } %}
  <div class="agents-control-diff-modal" id="agentsControlDiffModal" hidden aria-hidden="true">
    <div class="agents-control-diff-modal__backdrop" data-control-diff-close></div>
    <div class="agents-control-diff-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="agentsControlDiffTitle">
      <div class="agents-control-diff-modal__header">
        <div class="agents-control-diff-modal__heading">
          <h2 id="agentsControlDiffTitle">Approval diff</h2>
          <div id="agentsControlDiffMeta" class="light"></div>
        </div>
        <button class="btn" type="button" data-control-diff-close>Close</button>
      </div>
      <div id="agentsControlDiffStatus" class="agents-control-diff-modal__status" hidden></div>
      <div id="agentsControlDiffIntro" class="agents-control-diff-modal__intro light"></div>
      <div class="agents-control-diff-modal__pane">
        {% include "_includes/tabs" with {
          tabs: controlDiffModalTabs,
          selectedTab: 'agentsControlDiffRows',
          tablistLabel: 'Diff view',
          containerAttributes: {
            id: 'agentsControlDiffTabs',
            class: ['agents-control-diff-modal__tabs'],
          },
        } only %}
        <div class="agents-control-diff-modal__pane-body">
          <div id="agentsControlDiffRows" class="agents-control-diff-rows"></div>
          <div id="agentsControlRedlineRows" class="agents-control-redline-rows" hidden></div>
          <div id="agentsControlFocusToolbar" class="agents-control-focus-toolbar" hidden>
            <div class="btngroup" role="group" aria-label="Focus content version">
              <button class="btn small active" type="button" data-agents-focus-mode="after" aria-pressed="true">After</button>
              <button class="btn small" type="button" data-agents-focus-mode="before" aria-pressed="false">Before</button>
            </div>
          </div>
          <div id="agentsControlFocusRows" class="agents-control-focus-rows" hidden></div>
        </div>
      </div>
    </div>
  </div>

  {% js %}
    (() => {
      const confirmForms = document.querySelectorAll('.js-confirm-form');
      confirmForms.forEach((form) => {
        form.addEventListener('submit', (event) => {
          const customMessage = form.getAttribute('data-confirm-message') || 'Are you sure?';
          if (!window.confirm(customMessage)) {
            event.preventDefault();
          }
        });
      });

      const reviewButtons = document.querySelectorAll('.js-control-review-entry');
      reviewButtons.forEach((button) => {
        button.addEventListener('click', (event) => {
          event.preventDefault();
          const entryIdRaw = button.getAttribute('data-entry-id') || '';
          const siteIdRaw = button.getAttribute('data-site-id') || '';
          const entryUrl = button.getAttribute('data-entry-url') || '';
          const entryId = Number.parseInt(entryIdRaw, 10);
          const siteId = Number.parseInt(siteIdRaw, 10);

          if (!Number.isInteger(entryId) || entryId <= 0) {
            if (entryUrl !== '') {
              window.location.href = entryUrl;
            }
            return;
          }

          if (typeof Craft !== 'undefined' && typeof Craft.createElementEditor === 'function') {
            const editorParams = {elementId: entryId};
            if (Number.isInteger(siteId) && siteId > 0) {
              editorParams.siteId = siteId;
            }

            try {
              Craft.createElementEditor('craft\\elements\\Entry', editorParams);
              return;
            } catch (error) {
              if (window.console && typeof window.console.warn === 'function') {
                console.warn('Unable to open entry flyout from control action table.', error);
              }
            }
          }

          if (entryUrl !== '') {
            window.location.href = entryUrl;
          }
        });
      });

      const diffModal = document.getElementById('agentsControlDiffModal');
      const diffTitle = document.getElementById('agentsControlDiffTitle');
      const diffMeta = document.getElementById('agentsControlDiffMeta');
      const diffStatus = document.getElementById('agentsControlDiffStatus');
      const diffIntro = document.getElementById('agentsControlDiffIntro');
      const diffTabs = document.getElementById('agentsControlDiffTabs');
      const diffTabTriggers = diffTabs ? Array.from(diffTabs.querySelectorAll('[data-id]')) : [];
      const diffRows = document.getElementById('agentsControlDiffRows');
      const redlineRows = document.getElementById('agentsControlRedlineRows');
      const focusToolbar = document.getElementById('agentsControlFocusToolbar');
      const focusModeButtons = focusToolbar ? Array.from(focusToolbar.querySelectorAll('[data-agents-focus-mode]')) : [];
      const focusRows = document.getElementById('agentsControlFocusRows');
      const diffButtons = Array.from(document.querySelectorAll('.js-control-view-diff'));
      const diffUrl = {{ controlDiffUrl|json_encode|raw }};
      const diffTabIds = new Set(['agentsControlDiffRows', 'agentsControlFocusRows']);
      const focusViewModes = new Set(['after', 'before']);
      let diffLastFocusedButton = null;
      let diffActiveTab = 'agentsControlDiffRows';
      let focusViewMode = 'after';
      let focusItems = [];

      const escapeHtml = (value) => {
        const div = document.createElement('div');
        div.textContent = value;
        return div.innerHTML;
      };

      const setDiffStatus = (message, tone = 'info') => {
        if (!diffStatus) {
          return;
        }

        if (!message) {
          diffStatus.setAttribute('hidden', 'hidden');
          diffStatus.textContent = '';
          diffStatus.className = 'agents-control-diff-modal__status';
          return;
        }

        diffStatus.textContent = message;
        diffStatus.className = `agents-control-diff-modal__status agents-control-diff-modal__status--${tone}`;
        diffStatus.removeAttribute('hidden');
      };

      const syncFocusModeButtons = () => {
        focusModeButtons.forEach((button) => {
          const isActive = button.dataset.agentsFocusMode === focusViewMode;
          button.classList.toggle('active', isActive);
          button.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });
      };

      const updateFocusToolbarVisibility = () => {
        if (!focusToolbar) {
          return;
        }

        const shouldShow = diffActiveTab === 'agentsControlFocusRows' && focusItems.length > 0;
        if (shouldShow) {
          focusToolbar.removeAttribute('hidden');
          return;
        }

        focusToolbar.setAttribute('hidden', 'hidden');
      };

      const setDiffTab = (tab) => {
        diffActiveTab = diffTabIds.has(tab) ? tab : 'agentsControlDiffRows';
        diffTabTriggers.forEach((trigger) => {
          const isActive = trigger.dataset.id === diffActiveTab;
          trigger.classList.toggle('sel', isActive);
          trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
          trigger.setAttribute('tabindex', isActive ? '0' : '-1');
        });

        if (diffRows) {
          if (diffActiveTab === 'agentsControlDiffRows') {
            diffRows.removeAttribute('hidden');
          } else {
            diffRows.setAttribute('hidden', 'hidden');
          }
        }

        if (redlineRows) {
          if (diffActiveTab === 'agentsControlRedlineRows') {
            redlineRows.removeAttribute('hidden');
          } else {
            redlineRows.setAttribute('hidden', 'hidden');
          }
        }

        if (focusRows) {
          if (diffActiveTab === 'agentsControlFocusRows') {
            focusRows.removeAttribute('hidden');
          } else {
            focusRows.setAttribute('hidden', 'hidden');
          }
        }

        updateFocusToolbarVisibility();
      };

      const closeDiffModal = () => {
        if (!diffModal) {
          return;
        }

        diffModal.setAttribute('hidden', 'hidden');
        diffModal.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('noscroll');
        setDiffTab('agentsControlDiffRows');
        if (diffLastFocusedButton && typeof diffLastFocusedButton.focus === 'function') {
          diffLastFocusedButton.focus();
        }
      };

      const renderDiffRows = (rows) => {
        if (!diffRows) {
          return;
        }

        if (!Array.isArray(rows) || rows.length === 0) {
          diffRows.innerHTML = '<div class="agents-control-diff-empty light">No changed content rows are available for this request.</div>';
          return;
        }

        diffRows.innerHTML = rows.map((row) => {
          const note = row.note ? `<div class="agents-control-diff-row__note">${escapeHtml(String(row.note))}</div>` : '';
          const unsupportedClass = row.supported ? '' : ' agents-control-diff-row--unsupported';
          const beforeDisplay = escapeHtml(String(row.beforeDisplay ?? '—'));
          const afterDisplay = escapeHtml(String(row.afterDisplay ?? '—'));
          const changeLabel = escapeHtml(String(row.change ?? 'changed'));
          const label = escapeHtml(String(row.label ?? 'Field'));

          return `
            <article class="agents-control-diff-row${unsupportedClass}">
              <div class="agents-control-diff-row__header">
                <div class="agents-control-diff-row__label">${label}</div>
                <span class="agents-control-diff-row__change agents-control-diff-row__change--${changeLabel}">${changeLabel}</span>
              </div>
              <div class="agents-control-diff-row__columns">
                <section class="agents-control-diff-row__column agents-control-diff-row__column--before">
                  <div class="agents-control-diff-row__column-label">Before</div>
                  <pre class="agents-control-diff-row__value">${beforeDisplay}</pre>
                </section>
                <section class="agents-control-diff-row__column agents-control-diff-row__column--after">
                  <div class="agents-control-diff-row__column-label">After</div>
                  <pre class="agents-control-diff-row__value">${afterDisplay}</pre>
                </section>
              </div>
              ${note}
            </article>
          `;
        }).join('');
      };

      const renderRedlineRows = (redline) => {
        if (!redlineRows) {
          return;
        }

        if (!redline || !Array.isArray(redline.rows) || redline.rows.length === 0) {
          const message = redline && redline.message ? escapeHtml(String(redline.message)) : 'No text-like field changes are available for redline preview in this request.';
          redlineRows.innerHTML = `<div class="agents-control-diff-empty light">${message}</div>`;
          return;
        }

        redlineRows.innerHTML = redline.rows.map((row) => {
          const label = escapeHtml(String(row.label ?? 'Field'));
          const note = row.note ? `<div class="agents-control-redline-row__note">${escapeHtml(String(row.note))}</div>` : '';
          const unsupportedClass = row.supported ? '' : ' agents-control-redline-row--unsupported';
          const segments = Array.isArray(row.segments) ? row.segments.map((segment) => {
            const type = String(segment.type || 'context');
            const text = escapeHtml(String(segment.text || ''));
            if (text === '') {
              return '';
            }

            if (type === 'added') {
              return `<ins class="agents-control-redline-row__segment agents-control-redline-row__segment--added">${text}</ins>`;
            }

            if (type === 'removed') {
              return `<del class="agents-control-redline-row__segment agents-control-redline-row__segment--removed">${text}</del>`;
            }

            return `<span class="agents-control-redline-row__segment">${text}</span>`;
          }).join('') : '';

          return `
            <article class="agents-control-redline-row${unsupportedClass}">
              <div class="agents-control-redline-row__header">
                <div class="agents-control-redline-row__label">${label}</div>
              </div>
              <div class="agents-control-redline-row__body">
                <div class="agents-control-redline-row__text">${segments || '<span class="light">No redline preview available.</span>'}</div>
              </div>
              ${note}
            </article>
          `;
        }).join('');
      };

      const tokenizeFocusText = (text) => {
        const matches = String(text || '').match(/\s+|[^\s]+/gu);
        return Array.isArray(matches) ? matches : [];
      };

      const appendFocusSegment = (segments, type, text) => {
        if (!text) {
          return;
        }

        const lastSegment = segments[segments.length - 1] || null;
        if (lastSegment && lastSegment.type === type) {
          lastSegment.text += text;
          return;
        }

        segments.push({type, text});
      };

      const buildFocusSegments = (redlineRow, diffRow) => {
        const redlineSegments = Array.isArray(redlineRow?.segments) ? redlineRow.segments : [];
        const tokenEntries = [];
        let hasChangedToken = false;

        redlineSegments.forEach((segment) => {
          const segmentType = String(segment?.type || '');
          if (!['context', 'added'].includes(segmentType)) {
            return;
          }

          const focusType = segmentType === 'added' ? 'changed' : 'context';
          tokenizeFocusText(segment?.text || '').forEach((token) => {
            tokenEntries.push({type: focusType, text: token});
            if (focusType === 'changed' && token.trim() !== '') {
              hasChangedToken = true;
            }
          });
        });

        const fallbackText = String(diffRow?.afterDisplay ?? '').trim();
        if (tokenEntries.length === 0) {
          if (!fallbackText || fallbackText === '—') {
            return [];
          }

          return [{type: 'changed', text: fallbackText}];
        }

        if (!hasChangedToken) {
          if (!fallbackText || fallbackText === '—') {
            return [];
          }

          return [{type: 'changed', text: fallbackText}];
        }

        const changedIndices = tokenEntries.reduce((indices, token, index) => {
          if (token.type === 'changed' && token.text.trim() !== '') {
            indices.push(index);
          }
          return indices;
        }, []);

        if (changedIndices.length === 0) {
          return [{type: 'changed', text: fallbackText || tokenEntries.map((token) => token.text).join('')}];
        }

        const windowPadding = 24;
        const mergeGap = 8;
        const windows = [];

        changedIndices.forEach((index) => {
          const nextWindow = {
            start: Math.max(0, index - windowPadding),
            end: Math.min(tokenEntries.length - 1, index + windowPadding),
          };

          const currentWindow = windows[windows.length - 1] || null;
          if (!currentWindow) {
            windows.push(nextWindow);
            return;
          }

          if (nextWindow.start <= (currentWindow.end + mergeGap)) {
            currentWindow.end = Math.max(currentWindow.end, nextWindow.end);
            return;
          }

          windows.push(nextWindow);
        });

        const segments = [];
        windows.forEach((window, index) => {
          if (index === 0 && window.start > 0) {
            appendFocusSegment(segments, 'context', '(…) ');
          } else if (index > 0) {
            appendFocusSegment(segments, 'context', ' (…) ');
          }

          for (let tokenIndex = window.start; tokenIndex <= window.end; tokenIndex += 1) {
            const token = tokenEntries[tokenIndex];
            appendFocusSegment(segments, token.type, token.text);
          }

          if (index === windows.length - 1 && window.end < (tokenEntries.length - 1)) {
            appendFocusSegment(segments, 'context', ' (…)');
          }
        });

        return segments;
      };

      const buildFocusItems = (rows, redline) => {
        const diffRowsList = Array.isArray(rows) ? rows : [];
        const redlineRowsList = Array.isArray(redline?.rows) ? redline.rows : [];
        const redlineByPath = new Map(redlineRowsList.map((row) => [String(row.path || ''), row]));

        return diffRowsList
          .filter((row) => String(row?.kind || '') === 'text')
          .map((row) => {
            const path = String(row?.path || '');
            const beforeDisplay = String(row?.beforeDisplay ?? '').trim();
            const afterDisplay = String(row?.afterDisplay ?? '').trim();

            return {
              path,
              beforeDisplay: beforeDisplay || '—',
              afterDisplay: afterDisplay || '—',
              afterSegments: buildFocusSegments(redlineByPath.get(path) || null, row),
            };
          })
          .filter((item) => item.beforeDisplay !== '—' || item.afterDisplay !== '—' || item.afterSegments.length > 0);
      };

      const renderFocusRows = () => {
        if (!focusRows) {
          return;
        }

        if (focusItems.length === 0) {
          focusRows.innerHTML = '<div class="agents-control-diff-empty light">No text-like field changes are available for Focus preview in this request.</div>';
          updateFocusToolbarVisibility();
          return;
        }

        focusRows.innerHTML = focusItems.map((item, index) => {
          const text = focusViewMode === 'before'
            ? `<p class="agents-control-focus-row__text agents-control-focus-row__text--before">${escapeHtml(item.beforeDisplay)}</p>`
            : `<p class="agents-control-focus-row__text">${(item.afterSegments.length > 0 ? item.afterSegments : [{type: 'changed', text: item.afterDisplay}]).map((segment) => {
              const segmentType = String(segment.type || 'context') === 'changed' ? 'changed' : 'context';
              return `<span class="agents-control-focus-row__segment agents-control-focus-row__segment--${segmentType}">${escapeHtml(String(segment.text || ''))}</span>`;
            }).join('')}</p>`;

          const separator = index < (focusItems.length - 1)
            ? `
              <div class="agents-control-focus-row__separator" aria-hidden="true">
                <span class="agents-control-focus-row__dot"></span>
              </div>
            `
            : '';

          return `
            <article class="agents-control-focus-row" data-path="${escapeHtml(item.path)}">
              ${text}
            </article>
            ${separator}
          `;
        }).join('');

        updateFocusToolbarVisibility();
      };

      const setFocusViewMode = (mode, rerender = true) => {
        focusViewMode = focusViewModes.has(mode) ? mode : 'after';
        syncFocusModeButtons();

        if (rerender) {
          renderFocusRows();
        }
      };

      focusModeButtons.forEach((button) => {
        button.addEventListener('click', (event) => {
          event.preventDefault();
          const nextMode = String(button.dataset.agentsFocusMode || 'after');
          if (nextMode === focusViewMode) {
            return;
          }

          setFocusViewMode(nextMode);
        });
      });

      const openDiffModal = async (button) => {
        if (!diffModal || !diffTitle || !diffMeta || !diffIntro || !diffRows || !redlineRows || !focusRows) {
          return;
        }

        const approvalId = Number.parseInt(button.getAttribute('data-approval-id') || '', 10);
        if (!Number.isInteger(approvalId) || approvalId <= 0) {
          return;
        }

        diffLastFocusedButton = button;
        diffTitle.textContent = `Approval diff #${approvalId}`;
        diffMeta.textContent = '';
        diffIntro.textContent = '';
        diffRows.innerHTML = '';
        redlineRows.innerHTML = '';
        focusRows.innerHTML = '';
        focusItems = [];
        setFocusViewMode('after', false);
        updateFocusToolbarVisibility();
        setDiffTab('agentsControlDiffRows');
        setDiffStatus('Loading diff…', 'loading');
        diffModal.removeAttribute('hidden');
        diffModal.setAttribute('aria-hidden', 'false');
        document.body.classList.add('noscroll');

        try {
          const response = await fetch(`${diffUrl}?approvalId=${approvalId}`, {
            headers: {
              'Accept': 'application/json',
              'X-Requested-With': 'XMLHttpRequest',
            },
            credentials: 'same-origin',
          });

          const payload = await response.json();
          if (!response.ok || !payload.ok || !payload.diff) {
            throw new Error(payload && payload.message ? payload.message : 'Unable to load diff.');
          }

          const diff = payload.diff;
          const target = diff.target || {};
          const siteLabel = target.siteName || target.siteHandle || '';
          const summary = diff.summary || {};
          const changedCount = Number(summary.changedFieldCount || 0);
          const unsupportedCount = Number(summary.unsupportedFieldCount || 0);
          const metaParts = [];
          if (target.entryTitle) {
            metaParts.push(String(target.entryTitle));
          }
          if (siteLabel) {
            metaParts.push(siteLabel);
          }
          metaParts.push(`${changedCount} changed row${changedCount === 1 ? '' : 's'}`);
          if (unsupportedCount > 0) {
            metaParts.push(`${unsupportedCount} fallback`);
          }
          diffMeta.textContent = metaParts.join(' · ');
          diffIntro.textContent = diff.message || '';
          renderDiffRows(diff.rows || []);
          renderRedlineRows(diff.redline || null);
          focusItems = buildFocusItems(diff.rows || [], diff.redline || null);
          renderFocusRows();
          setDiffStatus('', 'info');
        } catch (error) {
          renderDiffRows([]);
          renderRedlineRows(null);
          focusItems = [];
          renderFocusRows();
          diffIntro.textContent = '';
          setDiffStatus(error instanceof Error ? error.message : 'Unable to load diff.', 'error');
        }
      };

      diffButtons.forEach((button) => {
        button.addEventListener('click', (event) => {
          event.preventDefault();
          void openDiffModal(button);
        });
      });

      const diffCloseButtons = Array.from(document.querySelectorAll('[data-control-diff-close]'));
      diffCloseButtons.forEach((button) => {
        button.addEventListener('click', (event) => {
          event.preventDefault();
          closeDiffModal();
        });
      });

      diffTabTriggers.forEach((trigger) => {
        trigger.addEventListener('click', (event) => {
          event.preventDefault();
          const tab = trigger.dataset.id || 'agentsControlDiffRows';
          setDiffTab(tab);
        });

        trigger.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) {
            return;
          }

          event.preventDefault();

          const currentIndex = diffTabTriggers.indexOf(trigger);
          let nextIndex = currentIndex;

          if (event.key === 'ArrowRight') {
            nextIndex = (currentIndex + 1) % diffTabTriggers.length;
          } else if (event.key === 'ArrowLeft') {
            nextIndex = (currentIndex - 1 + diffTabTriggers.length) % diffTabTriggers.length;
          } else if (event.key === 'Home') {
            nextIndex = 0;
          } else if (event.key === 'End') {
            nextIndex = diffTabTriggers.length - 1;
          }

          const nextTrigger = diffTabTriggers[nextIndex];
          const nextTabId = nextTrigger?.dataset.id || 'agentsControlDiffRows';
          setDiffTab(nextTabId);
          nextTrigger?.focus();
        });
      });

      setDiffTab('agentsControlDiffRows');

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && diffModal && !diffModal.hasAttribute('hidden')) {
          closeDiffModal();
        }
      });

      const sectionToggles = Array.from(document.querySelectorAll('[data-control-section-toggle]'));
      sectionToggles.forEach((button) => {
        button.addEventListener('click', () => {
          const targetId = button.dataset.target || '';
          const target = targetId ? document.getElementById(targetId) : null;
          if (!target) {
            return;
          }

          const isOpen = !target.hasAttribute('hidden');
          if (isOpen) {
            target.setAttribute('hidden', 'hidden');
            button.setAttribute('aria-expanded', 'false');
          } else {
            target.removeAttribute('hidden');
            button.setAttribute('aria-expanded', 'true');
          }
        });
      });

      const inlineToggles = Array.from(document.querySelectorAll('[data-control-inline-toggle]'));
      inlineToggles.forEach((button) => {
        button.addEventListener('click', () => {
          const targetId = button.dataset.target || '';
          const target = targetId ? document.getElementById(targetId) : null;
          if (!target) {
            return;
          }

          const isOpen = !target.hasAttribute('hidden');
          if (isOpen) {
            target.setAttribute('hidden', 'hidden');
            button.setAttribute('aria-expanded', 'false');
          } else {
            target.removeAttribute('hidden');
            button.setAttribute('aria-expanded', 'true');
          }
        });
      });

      const parseRuleEditorJson = (raw, fallback = {}) => {
        if (!raw) {
          return { ...fallback };
        }

        try {
          const parsed = JSON.parse(raw);
          if (parsed && typeof parsed === 'object') {
            return { ...fallback, ...parsed };
          }
        } catch (error) {
          console.warn('Unable to parse rule editor JSON payload.', error);
        }

        return { ...fallback };
      };

      const ruleEditor = document.querySelector('[data-control-rule-editor]');
      if (ruleEditor) {
        const ruleNameField = document.getElementById('controlRuleDisplayName');
        const ruleHandleField = document.getElementById('controlRuleHandle');
        if (ruleNameField && ruleHandleField && typeof Craft !== 'undefined' && typeof Craft.BaseInputGenerator === 'function') {
          const RuleKebabHandleGenerator = Craft.BaseInputGenerator.extend({
            generateTargetValue(sourceVal) {
              let handle = (sourceVal || '').replace(/<(.*?)>/g, '');
              handle = handle.replace(/['"‘’“”ʻ\[\]\(\)\{\}:]/g, '').toLowerCase();
              handle = Craft.asciiString(handle);
              handle = handle.replace(/^[^a-z]+/, '');
              return Craft.filterArray(handle.split(/[^a-z0-9]+/)).join('-');
            },
          });

          new RuleKebabHandleGenerator('#controlRuleDisplayName', '#controlRuleHandle');
        }

        const ruleForm = ruleEditor.querySelector('[data-control-rule-form]');
        const ruleEditorTitle = ruleEditor.querySelector('[data-control-rule-editor-title]');
        const ruleEditorSubmit = ruleEditor.querySelector('[data-control-rule-submit]');
        const ruleEditorCancel = ruleEditor.querySelector('[data-control-rule-cancel]');
        const createRuleDefaults = parseRuleEditorJson(ruleEditor.dataset.controlRuleCreateJson, {});
        const ruleEditorPanelId = ruleEditor.dataset.controlRulePanelId || '';
        const ruleEditorPanel = ruleEditorPanelId ? document.getElementById(ruleEditorPanelId) : null;
        const ruleEditorToggle = ruleEditorPanelId ? document.querySelector(`[data-control-section-toggle][data-target="${ruleEditorPanelId}"]`) : null;

        const openRuleEditor = () => {
          if (ruleEditorPanel) {
            ruleEditorPanel.removeAttribute('hidden');
          }
          if (ruleEditorToggle) {
            ruleEditorToggle.setAttribute('aria-expanded', 'true');
          }
          if (ruleEditor.tagName === 'DETAILS') {
            ruleEditor.open = true;
          }
        };

        const closeRuleEditor = () => {
          if (ruleEditor.dataset.controlRuleCloseOnCancel === 'true') {
            if (ruleEditorPanel) {
              ruleEditorPanel.setAttribute('hidden', 'hidden');
            }
            if (ruleEditorToggle) {
              ruleEditorToggle.setAttribute('aria-expanded', 'false');
            }
            if (ruleEditor.tagName === 'DETAILS') {
              ruleEditor.open = false;
            }
          }
        };

        const getRuleField = (name) => ruleForm ? ruleForm.querySelector(`[name="${name}"]`) : null;

        const setRuleFieldValue = (name, value) => {
          const field = getRuleField(name);
          if (!field) {
            return;
          }
          field.value = value == null ? '' : String(value);
        };

        const setRuleCheckboxValue = (name, value) => {
          const field = getRuleField(name);
          if (!field) {
            return;
          }
          field.checked = !!value;
        };

        const updateRuleEditorPresentation = (isEditing) => {
          if (ruleEditorTitle) {
            ruleEditorTitle.textContent = isEditing
              ? (ruleEditor.dataset.controlRuleEditTitle || 'Edit Rule')
              : (ruleEditor.dataset.controlRuleCreateTitle || 'Create or Update Rule');
          }
          if (ruleEditorSubmit) {
            ruleEditorSubmit.textContent = isEditing
              ? (ruleEditor.dataset.controlRuleEditSubmitLabel || 'Save Changes')
              : (ruleEditor.dataset.controlRuleCreateSubmitLabel || 'Save Rule');
          }
          if (ruleEditorCancel) {
            ruleEditorCancel.hidden = !isEditing;
          }
        };

        const hydrateRuleEditor = (payload, isEditing) => {
          if (!ruleForm) {
            return;
          }

          const mergedPayload = { ...createRuleDefaults, ...(payload || {}) };
          setRuleFieldValue('originalHandle', isEditing ? (mergedPayload.handle || '') : '');
          setRuleFieldValue('handle', mergedPayload.handle || '');
          setRuleFieldValue('displayName', mergedPayload.displayName || '');
          setRuleFieldValue('actionPattern', mergedPayload.actionPattern || createRuleDefaults.actionPattern || 'entry.updatedraft');
          setRuleFieldValue('riskLevel', mergedPayload.riskLevel || createRuleDefaults.riskLevel || 'medium');
          setRuleFieldValue('approvalSlaMinutes', mergedPayload.approvalSlaMinutes ?? '');
          setRuleFieldValue('escalateAfterMinutes', mergedPayload.escalateAfterMinutes ?? '');
          setRuleFieldValue('expireAfterMinutes', mergedPayload.expireAfterMinutes ?? '');
          setRuleCheckboxValue('requiresApproval', mergedPayload.requiresApproval ?? true);
          setRuleCheckboxValue('enabled', mergedPayload.enabled ?? true);

          updateRuleEditorPresentation(isEditing);
          openRuleEditor();

          const displayNameField = getRuleField('displayName');
          if (displayNameField) {
            displayNameField.focus({ preventScroll: true });
          }
          ruleEditor.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        };

        document.querySelectorAll('[data-control-rule-edit]').forEach((trigger) => {
          trigger.addEventListener('click', (event) => {
            if (!ruleForm) {
              return;
            }
            event.preventDefault();
            const payload = parseRuleEditorJson(trigger.dataset.policyJson, createRuleDefaults);
            hydrateRuleEditor(payload, true);
          });
        });

        if (ruleEditorCancel) {
          ruleEditorCancel.addEventListener('click', (event) => {
            event.preventDefault();
            hydrateRuleEditor(createRuleDefaults, false);
            closeRuleEditor();
          });
        }
      }

    })();
  {% endjs %}

