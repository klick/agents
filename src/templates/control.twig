            <div class="agents-control-rule-form-actions">
              <button class="btn submit" type="submit" data-control-rule-submit>{{ isEditingPolicy ? 'Save Changes' : 'Save Rule' }}</button>
              <a class="btn" href="{{ cpUrl(controlRulesRedirect) }}" data-control-rule-cancel {% if not isEditingPolicy %}hidden{% endif %}>Cancel Edit</a>
            </div>
