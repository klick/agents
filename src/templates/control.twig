          </thead>
          <tbody>
          {% for execution in controlAttentionExecutions %}
            {% set policy = execution.policy ?? null %}
            <tr>
              <td>#{{ execution.id }}</td>
              <td>
                <div class="agents-control-table__action-title">{{ execution.actionLabel ?: 'Unknown action' }}</div>
                <span class="agents-actor-raw">{{ execution.actionType }}</span>
                {% set targetTitle = execution.targetTitle ?: 'Untitled target' %}
                <div class="light">
                  {% if execution.targetEntryCpUrl %}
                    <a href="{{ cpUrl(execution.targetEntryCpUrl) }}" class="agents-control-target-link">{{ targetTitle }}</a>
                  {% else %}
                    {{ targetTitle }}
                  {% endif %}
                </div>
                {% if execution.targetEntryId or (execution.actionType|lower == 'entry.updatedraft' and execution.approvalId) %}
                  <div class="agents-control-table__quick-actions">
                    {% if execution.targetEntryId %}
                      <button
                        class="btn small js-control-review-entry agents-control-review-btn"
                        type="button"
                        data-entry-id="{{ execution.targetEntryId }}"
                        data-site-id="{{ execution.targetEntrySiteId ?: 0 }}"
                        data-entry-url="{{ execution.targetEntryCpUrl ? cpUrl(execution.targetEntryCpUrl) : '' }}"
                      >Review</button>
                    {% endif %}
                    {% if execution.actionType|lower == 'entry.updatedraft' and execution.approvalId %}
                      <button
                        class="btn small js-control-view-diff agents-control-diff-btn"
                        type="button"
                        data-approval-id="{{ execution.approvalId }}"
                      >Diff</button>
                    {% endif %}
                  </div>
                {% else %}
                  <span class="agents-actor-raw">Ref: {{ execution.actionRef ?: 'n/a' }}</span>
                {% endif %}
                <span class="agents-actor-raw">Ref: {{ execution.actionRef ?: 'n/a' }}</span>
              </td>
              <td><strong>{{ execution.status }}</strong></td>
              <td>
                {% if policy %}
                  <span class="badge">RISK {{ policy.riskLevel|upper }}</span>
                  <div class="light">Rule: <code>{{ policy.handle }}</code></div>
                {% else %}
                  <span class="light">Default rule</span>
                {% endif %}
              </td>
              <td>
                <div>{{ execution.errorMessage ?: (execution.resultPayload.message ?? 'Check rule/approval requirements and retry.') }}</div>
                {% if execution.resultPayload.conflictType ?? null == 'savedDraftExists' and (execution.resultPayload.conflictingDrafts ?? [])|length %}
                  {% for conflict in execution.resultPayload.conflictingDrafts|slice(0, 2) %}
                    <div class="light">
                      Existing draft{% if conflict.id ?? null %} #{{ conflict.id }}{% endif %}{% if conflict.draftRecordId ?? null %} · saved draft #{{ conflict.draftRecordId }}{% endif %}{% if conflict.draftName ?? null %} · {{ conflict.draftName }}{% elseif conflict.title ?? null %} · {{ conflict.title }}{% endif %}
                      {% if conflict.cpEditUrl ?? null %}
                        · <a href="{{ cpUrl(conflict.cpEditUrl) }}" class="agents-control-target-link">open</a>
                      {% endif %}
                    </div>
                  {% endfor %}
                  {% if execution.resultPayload.conflictingDrafts|length > 2 %}
                    <div class="light">+ {{ execution.resultPayload.conflictingDrafts|length - 2 }} more conflicting drafts</div>
                  {% endif %}
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          </tbody>
          </table>
        </div>
      </div>
    {% endif %}
