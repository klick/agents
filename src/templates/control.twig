              <td>
                <div><strong>{{ completionState.label ?: 'COMPLETED' }}</strong></div>
                {% if completionState.at %}
                  <div class="light">{{ include('agents/_partials/relative-short-date', { value: completionState.at }, with_context = false) }}</div>
                {% else %}
                  <div class="light">n/a</div>
                {% endif %}
