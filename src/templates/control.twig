            <input type="hidden" name="originalHandle" value="{{ editingPolicy.handle ?? '' }}">

            {{ forms.textField({
              label: 'Rule name',
              id: 'controlRuleDisplayName',
              name: 'displayName',
              value: editingPolicy.displayName ?? '',
              placeholder: 'Entry Draft High Risk',
            }) }}

            {{ forms.textField({
              label: 'Rule key (stable)',
              id: 'controlRuleHandle',
              instructions: 'Stable machine key for this rule. Changing it renames the rule.',
              name: 'handle',
              required: true,
