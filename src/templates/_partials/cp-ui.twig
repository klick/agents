    flex-wrap: wrap;
    gap: 10px;
    padding-inline-end: 18px;
  }

  .agents-capability-pill {
    position: relative;
    display: inline-flex;
    cursor: pointer;
    user-select: none;
  }

  .agents-capability-pill input[type='checkbox'] {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
    margin: 0;
  }

  .agents-capability-pill-copy {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 8px 12px;
    border: 1px solid #d5dde7;
    border-radius: 14px;
    background: #e5eaf1;
    color: #3f4a57;
    transition: background-color 120ms ease, color 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
  }

  .agents-capability-pill:hover .agents-capability-pill-copy,
  .agents-capability-pill input:focus + .agents-capability-pill-copy {
    box-shadow: 0 0 0 1px rgba(89, 102, 115, 0.16);
  }

  .agents-capability-pill input:checked + .agents-capability-pill-copy,
  .agents-capability-pill.is-activated .agents-capability-pill-copy,
  .agents-capability-pill.is-selected .agents-capability-pill-copy {
