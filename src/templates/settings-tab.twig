{% extends "_layouts/cp" %}

{% set title = "Agents Settings" %}
{% set selectedSubnavItem = "settings" %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <h1>Settings</h1>
  <p class="agents-page-intro">Configure runtime switches, webhook transport, and reliability thresholds from one place.</p>

  <form method="post" accept-charset="UTF-8">
    {{ csrfInput() }}
    {{ actionInput('agents/dashboard/save-settings') }}
    {{ redirectInput('agents/settings') }}

    <div class="agents-layout-stack">
      {% include 'agents/settings' %}

      <div class="agents-actions">
        <button class="btn submit" type="submit">Save Settings</button>
        <a class="btn" href="{{ url('agents/status') }}">Back to Status</a>
      </div>
    </div>
  </form>
{% endblock %}
