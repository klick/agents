        ? []
        : simulationAccountsRaw
          .split(',')
          .map((value) => value.trim().toLowerCase())
          .filter((value, index, values) => value !== '' && values.indexOf(value) === index);
      const simulationIntervalRaw = Number.parseInt(simulationQueryParams.get('simulatePulseIntervalMs') || '', 10);
      const temporarySimulationDefaultIntervalMs = Number.isInteger(simulationIntervalRaw)
        ? Math.max(400, Math.min(simulationIntervalRaw, 15000))
        : 1800;
      const runtimePollingEnabled = credentialUsageIndicatorEnabled;
      if (!runtimePollingEnabled && !temporarySimulationEnabled) {
        return;
      }

      const pulseUrlBase = '{{ actionUrl("agents/dashboard/credential-usage-pulse")|e("js") }}';
      if (runtimePollingEnabled && !pulseUrlBase) {
        return;
      }

      const pulseClassRead = 'is-live-read';
      const pulseClassWrite = 'is-live-write';
      const pulseDurationMs = 2000;
      const pollIntervalMs = 2000;

      const managedCards = Array.from(cardList.querySelectorAll('[data-agent-card]:not(.is-template)'));
      const dotsByCredentialId = new Map();
      const credentialIdsByHandle = new Map();
      managedCards.forEach((card) => {
        const rawId = (card.dataset.agentCardId || '').trim();
        if (!/^\d+$/.test(rawId)) {
          return;
        }

        const credentialId = Number.parseInt(rawId, 10);
        if (!Number.isInteger(credentialId) || credentialId <= 0) {
          return;
        }

        const dot = card.querySelector('.agents-agent-card-dot');
        if (!dot) {
          return;
        }

        dotsByCredentialId.set(credentialId, dot);
        const handle = (card.dataset.agentCardHandle || '').trim().toLowerCase();
        if (handle !== '') {
          credentialIdsByHandle.set(handle, credentialId);
        }
      });

      if (!dotsByCredentialId.size) {
        return;
      }

      let activePollTimer = null;
      let pollingInFlight = false;
      let sinceMs = Math.trunc(Date.now());
      const pulseTimeoutByCredentialId = new Map();
      const simulationState = {
        active: false,
        timers: [],
        targets: [],
        options: {
          mode: temporarySimulationDefaultMode,
          intervalMs: temporarySimulationDefaultIntervalMs,
        },
      };

      const clearPulseClasses = (dot) => {
        dot.classList.remove(pulseClassRead, pulseClassWrite);
      };

      const schedulePulseClear = (credentialId, dot) => {
        const existing = pulseTimeoutByCredentialId.get(credentialId);
        if (existing) {
          window.clearTimeout(existing);
        }

        const timeoutId = window.setTimeout(() => {
          clearPulseClasses(dot);
          pulseTimeoutByCredentialId.delete(credentialId);
        }, pulseDurationMs);
        pulseTimeoutByCredentialId.set(credentialId, timeoutId);
      };

      const applyPulse = (credentialId, operation) => {
        const dot = dotsByCredentialId.get(credentialId);
        if (!dot) {
          return;
        }

        clearPulseClasses(dot);
        if (operation === 'write') {
          dot.classList.add(pulseClassWrite);
        } else {
          dot.classList.add(pulseClassRead);
        }

        schedulePulseClear(credentialId, dot);
      };

      const clearSimulationTimers = () => {
        simulationState.timers.forEach((timerId) => {
          window.clearTimeout(timerId);
        });
        simulationState.timers = [];
      };

      const pickSimulationOperation = (mode) => {
        if (mode === 'read' || mode === 'write') {
          return mode;
        }

        return Math.random() < 0.7 ? 'read' : 'write';
      };

      const normalizeSimulationStartOptions = (optionsOrTargetCount) => {
        if (Number.isFinite(optionsOrTargetCount)) {
          return {
            targetCount: Math.trunc(optionsOrTargetCount),
            mode: temporarySimulationDefaultMode,
            accounts: [...temporarySimulationDefaultAccounts],
            intervalMs: temporarySimulationDefaultIntervalMs,
          };
        }

        const options = optionsOrTargetCount && typeof optionsOrTargetCount === 'object'
          ? optionsOrTargetCount
          : {};
        const modeRaw = typeof options.mode === 'string' ? options.mode.trim().toLowerCase() : temporarySimulationDefaultMode;
        const mode = ['read', 'write', 'mixed'].includes(modeRaw) ? modeRaw : temporarySimulationDefaultMode;
        const accountValues = Array.isArray(options.accounts)
          ? options.accounts
          : (typeof options.accounts === 'string' && options.accounts.trim() !== ''
            ? options.accounts.split(',')
            : temporarySimulationDefaultAccounts);
        const accounts = accountValues
          .map((value) => `${value}`.trim().toLowerCase())
          .filter((value, index, values) => value !== '' && values.indexOf(value) === index);
        const intervalCandidate = Number.parseInt(`${options.intervalMs ?? temporarySimulationDefaultIntervalMs}`, 10);
        const intervalMs = Number.isInteger(intervalCandidate)
          ? Math.max(400, Math.min(intervalCandidate, 15000))
          : temporarySimulationDefaultIntervalMs;
        const targetCountCandidate = Number.parseInt(`${options.targetCount ?? temporarySimulationDefaultAgents}`, 10);
        const targetCount = Number.isInteger(targetCountCandidate) && targetCountCandidate > 0
          ? targetCountCandidate
          : temporarySimulationDefaultAgents;

        return {
          targetCount,
          mode,
          accounts,
          intervalMs,
        };
      };

      const resolveSimulationTargets = (requestedAccounts, requestedCount) => {
        if (requestedAccounts.length) {
          const targets = requestedAccounts
            .map((value) => {
              if (/^\d+$/.test(value)) {
                const credentialId = Number.parseInt(value, 10);
                return dotsByCredentialId.has(credentialId) ? credentialId : null;
              }

              return credentialIdsByHandle.get(value) ?? null;
            })
            .filter((credentialId, index, values) => Number.isInteger(credentialId) && credentialId > 0 && values.indexOf(credentialId) === index);

          if (targets.length) {
            return targets;
          }
        }

        const allCredentialIds = Array.from(dotsByCredentialId.keys());
        if (!allCredentialIds.length) {
          return [];
        }

        const normalizedCount = Number.isFinite(requestedCount)
          ? Math.max(1, Math.min(Math.trunc(requestedCount), allCredentialIds.length))
          : Math.min(temporarySimulationDefaultAgents, allCredentialIds.length);

        return allCredentialIds.slice(0, normalizedCount);
      };

      const scheduleSimulatedPulse = (credentialId) => {
        if (!simulationState.active) {
          return;
        }

        const baseIntervalMs = simulationState.options.intervalMs || temporarySimulationDefaultIntervalMs;
        const jitterMs = Math.max(120, Math.round(baseIntervalMs * 0.35));
        const nextDelayMs = Math.max(250, baseIntervalMs - jitterMs) + Math.floor(Math.random() * (jitterMs * 2));
        const timeoutId = window.setTimeout(() => {
          if (!simulationState.active) {
            return;
          }

          const operation = pickSimulationOperation(simulationState.options.mode);
          applyPulse(credentialId, operation);
          scheduleSimulatedPulse(credentialId);
        }, nextDelayMs);
        simulationState.timers.push(timeoutId);
      };

      const stopPulseSimulation = () => {
        simulationState.active = false;
        simulationState.targets = [];
        clearSimulationTimers();
      };

      const startPulseSimulation = (optionsOrTargetCount = temporarySimulationDefaultAgents) => {
        stopPulseSimulation();

        const options = normalizeSimulationStartOptions(optionsOrTargetCount);
        const targets = resolveSimulationTargets(options.accounts, options.targetCount);
        if (!targets.length) {
          return false;
        }

        simulationState.targets = targets;
        simulationState.active = true;
        simulationState.options = {
          mode: options.mode,
          intervalMs: options.intervalMs,
        };

        simulationState.targets.forEach((credentialId, index) => {
          const startupDelayMs = 180 + (index * 220);
          const timeoutId = window.setTimeout(() => {
            if (!simulationState.active) {
              return;
            }
            const operation = pickSimulationOperation(simulationState.options.mode);
            applyPulse(credentialId, operation);
            scheduleSimulatedPulse(credentialId);
          }, startupDelayMs);
          simulationState.timers.push(timeoutId);
        });

        return true;
      };

      window.agentsPulseSimulation = {
        start: (optionsOrTargetCount = temporarySimulationDefaultAgents) => startPulseSimulation(optionsOrTargetCount),
        stop: () => stopPulseSimulation(),
        isRunning: () => simulationState.active,
        targets: () => [...simulationState.targets],
        options: () => ({ ...simulationState.options }),
      };

      const buildPulseUrl = () => {
        const params = new URLSearchParams();
        dotsByCredentialId.forEach((_dot, id) => {
          params.append('credentialIds[]', `${id}`);
        });

        if (Number.isInteger(sinceMs) && sinceMs !== null && sinceMs > 0) {
          params.set('since', `${sinceMs}`);
        }

        const query = params.toString();
        if (query === '') {
          return pulseUrlBase;
        }

        return pulseUrlBase.includes('?')
          ? `${pulseUrlBase}&${query}`
          : `${pulseUrlBase}?${query}`;
      };

      const pollPulse = async () => {
        if (document.hidden || pollingInFlight) {
          return;
        }
        pollingInFlight = true;

        try {
          const response = await fetch(buildPulseUrl(), {
            method: 'GET',
            headers: {
              Accept: 'application/json',
              'X-Requested-With': 'XMLHttpRequest',
            },
            credentials: 'same-origin',
            cache: 'no-store',
          });

          if (!response.ok) {
            return;
          }

          const payload = await response.json();
          if (!payload || payload.ok !== true || typeof payload !== 'object') {
            return;
          }

          const serverNow = Number(payload.serverNow || 0);
          if (Number.isFinite(serverNow) && serverNow > 0) {
            sinceMs = Math.max(sinceMs ?? 0, Math.trunc(serverNow));
          }

          const events = payload.events;
          if (!events || typeof events !== 'object') {
            return;
          }

          Object.entries(events).forEach(([rawId, eventValue]) => {
            const credentialId = Number.parseInt(`${rawId}`, 10);
            if (!Number.isInteger(credentialId) || credentialId <= 0 || !dotsByCredentialId.has(credentialId)) {
              return;
            }

            if (!eventValue || typeof eventValue !== 'object') {
              return;
            }

            const opRaw = typeof eventValue.op === 'string' ? eventValue.op.toLowerCase() : 'read';
            const operation = opRaw === 'write' ? 'write' : 'read';
            applyPulse(credentialId, operation);

            const eventSeenMs = Number(eventValue.lastSeenAt || 0);
            if (Number.isFinite(eventSeenMs) && eventSeenMs > 0) {
              sinceMs = Math.max(sinceMs ?? 0, Math.trunc(eventSeenMs));
            }
          });
        } catch (_error) {
          // Silent retry on next interval.
        } finally {
          pollingInFlight = false;
        }
      };

      const stopPolling = () => {
        if (activePollTimer !== null) {
          window.clearInterval(activePollTimer);
          activePollTimer = null;
        }
      };

      const startPolling = () => {
        if (!runtimePollingEnabled || activePollTimer !== null) {
          return;
        }
        void pollPulse();
        activePollTimer = window.setInterval(() => {
          void pollPulse();
        }, pollIntervalMs);
      };

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          stopPolling();
          return;
        }
        startPolling();
      });

      window.addEventListener('beforeunload', () => {
        stopPolling();
        stopPulseSimulation();
        pulseTimeoutByCredentialId.forEach((timeoutId) => {
          window.clearTimeout(timeoutId);
        });
        pulseTimeoutByCredentialId.clear();
      });

      if (runtimePollingEnabled) {
        startPolling();
      }
      if (temporarySimulationEnabled) {
        startPulseSimulation({
          targetCount: temporarySimulationDefaultAgents,
          mode: temporarySimulationDefaultMode,
          accounts: temporarySimulationDefaultAccounts,
          intervalMs: temporarySimulationDefaultIntervalMs,
        });
      }
    })();
  {% endjs %}

  {% if revealedCredential and revealedCredential.token %}
    {% js %}
      (() => {
        const overlay = document.getElementById('revealedCredentialOverlay');
        const tokenInput = document.getElementById('revealedCredentialToken');
        const copyButton = document.getElementById('copyRevealedCredentialBtn');
        const downloadButton = document.getElementById('downloadRevealedCredentialBtn');
        const feedback = document.getElementById('revealedCredentialFeedback');
        const closeButton = document.getElementById('revealedCredentialOverlayClose');
        if (!tokenInput) {
          return;
        }

        const setFeedback = (message) => {
          if (feedback) {
            feedback.textContent = message;
          }
        };

        if (copyButton) {
          copyButton.addEventListener('click', async () => {
            const token = tokenInput.value || '';
            if (!token) {
              setFeedback('No token available to copy.');
              return;
            }

            try {
              if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                await navigator.clipboard.writeText(token);
              } else {
                tokenInput.focus();
                tokenInput.select();
                document.execCommand('copy');
              }
              setFeedback('Token copied to clipboard.');
            } catch (error) {
              setFeedback('Unable to copy automatically. Select the token and copy manually.');
            }
          });
        }

        if (downloadButton) {
          downloadButton.addEventListener('click', () => {
            const token = tokenInput.value || '';
            if (!token) {
              setFeedback('No token available to download.');
              return;
            }

            const filename = downloadButton.dataset.filename || 'accounts-api-token.txt';
            const blob = new Blob([token + '\n'], { type: 'text/plain;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = filename;
            document.body.appendChild(link);
            link.click();
            link.remove();
            URL.revokeObjectURL(url);
            setFeedback('Token file downloaded.');
          });
        }

        if (closeButton && overlay) {
          closeButton.addEventListener('click', () => {
            const confirmed = window.confirm('Close this token overlay? The token will not be shown again after you dismiss it.');
            if (!confirmed) {
              return;
            }

            overlay.remove();
          });
        }
      })();
    {% endjs %}
