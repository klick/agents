    }

    .agents-agent-card-write-icon.is-unlocked {
      color: #c84b4b;
    }

    .agents-agent-card.is-active .agents-agent-card-dot {
      background: #15958f;
    }

    .agents-agent-card .agents-agent-card-dot.is-live-read {
      background: #f3b600;
    }

    .agents-agent-card .agents-agent-card-dot.is-live-write {
      background: #f3b600;
    }

    .agents-agent-card-description {
      margin: 0;
      font-size: 12px;
      line-height: 16px;
      font-weight: 700;
      color: #596673;
    }

    .agents-agent-card-template-note {
      margin: -14px 0 0;
      font-size: 11px;
      line-height: 1.3;
      color: #6f7d8c;
    }

    .agents-agent-card-details-toggle {
      border: 0;
      background: transparent;
      padding: 0;
      margin: 0;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: #596673;
      font-size: 12px;
      font-weight: 700;
      line-height: 1;
      cursor: pointer;
    }

    .agents-details-chevron {
      width: 6px;
      height: 6px;
      border-top: 1.5px solid #596673;
      border-right: 1.5px solid #596673;
      transform: rotate(45deg);
      transform-origin: center;
      margin-right: 2px;
      transition: transform 120ms ease;
    }

    .agents-agent-card-details-toggle[aria-expanded='true'] .agents-details-chevron {
      transform: rotate(135deg);
    }

    .agents-agent-card-details {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .agents-agent-card-details[hidden] {
      display: none !important;
    }

    .agents-agent-card-kv {
      display: grid;
      grid-template-columns: 40% 1fr;
      gap: 8px;
      color: #596673;
      font-size: 12px;
      line-height: 14px;
    }

    .agents-agent-card-k {
      font-weight: 700;
      text-transform: none;
    }

    .agents-agent-card-v {
      font-weight: 400;
      overflow-wrap: anywhere;
    }

    .agents-agent-card-scopes {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      align-items: flex-start;
    }

    .agents-agent-scope-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 19px;
      background: rgba(89, 102, 115, 0.12);
      padding: 5px 10px;
      font-family: 'SF Mono', SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      font-size: 10px;
      line-height: 1;
      color: #000000;
      white-space: nowrap;
    }

    .agents-agent-card-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      width: 100%;
      margin-top: auto;
    }

    .agents-agent-card.is-editing-card .agents-agent-card-footer {
      display: block;
    }

    .agents-agent-card.is-editing-card .agents-agent-card-footer > :not(.agents-agent-card-cancel-edit) {
      display: none !important;
    }

    .agents-agent-card-actions-left {
      display: flex;
      align-items: center;
      gap: 7px;
      flex-wrap: wrap;
      min-width: 0;
    }

    .agents-agent-card-actions-group {
      display: flex;
      gap: 1px;
      align-items: center;
      background: #ffffff;
      border-radius: 3px;
      overflow: hidden;
    }

    .agents-agent-card-actions-group form,
    .agents-agent-card-footer form {
      margin: 0;
      display: flex;
    }

    .agents-card-btn.btn {
      border: 0;
      box-shadow: none;
      background: #d4dbe4;
      color: #000000;
      border-radius: 3px;
      padding: 7px 10px;
      font-size: 12px;
      line-height: 1;
      min-height: 30px;
    }

    .agents-agent-card-cancel-edit.btn {
      display: none;
      width: 100%;
      justify-content: center;
      min-height: 34px;
      border: 0;
      box-shadow: none;
      border-radius: 3px;
      background: #c84b4b;
      color: #ffffff;
      font-weight: 700;
    }

    .agents-agent-card.is-editing-card .agents-agent-card-cancel-edit.btn {
      display: inline-flex;
    }

    .agents-agent-card-cancel-edit.btn:hover,
    .agents-agent-card-cancel-edit.btn:focus {
      background: #b14040;
      color: #ffffff;
    }

    .agents-card-btn.btn:hover,
    .agents-card-btn.btn:focus {
      background: #c6cfda;
      color: #000000;
    }

    .agents-agent-card-actions-group .agents-card-btn.btn {
      border-radius: 0;
    }

    .agents-agent-card-actions-group form:first-child .agents-card-btn.btn {
      border-top-left-radius: 3px;
      border-bottom-left-radius: 3px;
    }

    .agents-agent-card-actions-group form:last-child .agents-card-btn.btn {
      border-top-right-radius: 3px;
      border-bottom-right-radius: 3px;
    }

    .agents-form-actions {
      margin-top: 10px;
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
    }

    .agents-token-rotation-note {
      margin-top: 6px;
      border: 1px solid #d7dde3;
      border-radius: 3px;
      background: #f8fafc;
      padding: 10px 12px;
      color: #475467;
      font-size: 13px;
      line-height: 1.45;
    }

    .agents-token-rotation-note p {
      margin: 0;
    }

    @media (max-width: 420px) {
      .agents-agent-card-footer {
        flex-wrap: wrap;
        justify-content: flex-start;
      }
    }

    .agents-create-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
    }

    .agents-create-agent-frame {
      margin-top: 12px;
      border: 1px solid #d7dde3;
      background: #f1f5f9;
      border-radius: 3px;
      padding: 14px 12px;
    }

    .agents-create-agent-frame hr {
      margin: 16px 0 18px;
      border: 0;
      border-top: 1px solid #d7dde3;
    }

    .agents-create-agent-frame .field {
      margin-bottom: 16px;
    }

    .agents-create-agent-frame .heading {
      margin-bottom: 4px;
    }

    .agents-create-agent-frame .instructions {
      margin-bottom: 8px;
    }

    .agents-create-agent-frame .instructions p {
      margin: 0;
      line-height: 1.45;
    }

    .agents-capability-pills {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-top: 6px;
    }

    .agents-capability-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .agents-capability-group-title {
      font-size: 12px;
      line-height: 1.2;
      font-weight: 700;
      color: #596673;
    }

    .agents-capability-group-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .agents-create-agent-frame .agents-capability-pill {
      position: relative;
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 6px 12px;
      border: 1px solid #d5dde7;
      background: #e5eaf1;
      color: #3f4a57;
      cursor: pointer;
      user-select: none;
    }

    .agents-create-agent-frame .agents-capability-pill input[type='checkbox'] {
      position: absolute;
      inset: 0;
      opacity: 0;
      cursor: pointer;
      margin: 0;
    }

    .agents-create-agent-frame .agents-capability-pill-text {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      font-size: 12px;
      line-height: 1;
      letter-spacing: 0.01em;
      white-space: nowrap;
    }

    .agents-create-agent-frame .agents-capability-pill.is-activated,
    .agents-create-agent-frame .agents-capability-pill.is-selected {
      background: #596673;
      border-color: #596673;
      color: #ffffff;
    }

    .agents-inline-checkboxes {
      display: flex;
      flex-wrap: wrap;
      gap: 14px 24px;
      padding-top: 4px;
    }

    .agents-inline-checkboxes label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
    }

    .agents-create-id-row {
      display: grid;
      gap: 14px;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .agents-create-id-row[hidden] {
      display: none !important;
    }

    .agents-create-agent-frame.is-edit-mode .agents-create-id-row {
      display: none !important;
    }

    .agents-create-id-action {
      padding-bottom: 24px;
    }

    .agents-create-agent-frame .btn.submit {
      margin-top: 10px;
    }

    .agents-account-templates-note {
      margin: 0 0 12px;
    }

    .agents-account-templates-grid {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .agents-account-template-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 14px;
      min-height: 156px;
      padding: 16px;
      border: 1px solid #bbc7d5;
      border-radius: 3px;
      background: #ffffff;
    }

    .agents-account-template-copy {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .agents-account-template-title {
      font-size: 14px;
      line-height: 1.25;
      font-weight: 700;
      color: #000000;
    }

    .agents-account-template-description {
      margin: 0;
      font-size: 12px;
      line-height: 16px;
      color: #596673;
    }

    .agents-account-template-actions {
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    @media (max-width: 767px) {
      .agents-create-id-row {
        grid-template-columns: 1fr;
      }

      .agents-create-id-action {
        padding-bottom: 0;
      }
    }
  {% endcss %}
{% endblock %}
