{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Accounts" %}
{% set selectedSubnavItem = "accounts" %}
{% set agentsPlugin = craft.app.plugins.getPlugin('agents') %}
{% set writesExperimentalEnabled = agentsPlugin ? agentsPlugin.isWritesExperimentalEnabled() : false %}
{% set commercePluginEnabled = agentsPlugin ? agentsPlugin.isCommercePluginEnabled() : false %}
{% set governedWriteScopes = ['entries:write:draft', 'entries:write'] %}
{% set commerceScopes = ['products:read', 'variants:read', 'subscriptions:read', 'transfers:read', 'donations:read', 'orders:read', 'orders:read_sensitive', 'addresses:read', 'addresses:read_sensitive'] %}
{% set targetSets = writesExperimentalEnabled ? (targetSets ?? []) : [] %}
{% set targetSetsUrl = cpUrl('agents/target-sets') %}
{% set externalResourceProviders = externalResourceProviders ?? [] %}
{% set defaultTemplateExamples = [
  {
    id: 'agent-content-qa',
    displayName: 'Content QA',
    description: 'Reviews entries, assets, and taxonomy for quality issues before they become publishing problems.',
    scopes: 'entries:read entries:read_all_statuses assets:read sections:read categories:read tags:read capabilities:read openapi:read',
  },
  {
    id: 'agent-draft-writer',
    displayName: 'Governed Content Drafts',
    description: 'Prepares governed draft updates for existing entries and routes them into human approval.',
    scopes: 'entries:read entries:read_all_statuses sections:read entries:write:draft control:approvals:request control:approvals:read capabilities:read openapi:read',
  },
  {
    id: 'agent-legal-consent-checker',
    displayName: 'Legal & Consent Checker',
    description: 'Checks legal texts and consent-related content against visible site behavior like cookies, trackers, and disclosures.',
    scopes: 'entries:read global-sets:read assets:read sections:read capabilities:read openapi:read',
  },
  {
    id: 'agent-site-reporting',
    displayName: 'Site Reporting',
    description: 'Builds recurring content and operations summaries for internal teams and client reporting.',
    scopes: 'entries:read assets:read sections:read changes:read metrics:read adoption:read capabilities:read openapi:read',
  },
  {
    id: 'agent-seo-metadata-auditor',
    displayName: 'SEO & Metadata Auditor',
    description: 'Reviews titles, metadata, indexability signals, and content structure for SEO and content hygiene issues.',
    scopes: 'entries:read entries:read_all_statuses sections:read assets:read capabilities:read openapi:read',
  },
  {
    id: 'agent-commerce-catalog-qa',
    displayName: 'Commerce Catalog QA',
    description: 'Reviews product and catalog data for merchandising, pricing, and content consistency issues.',
    scopes: 'products:read variants:read orders:read sections:read entries:read capabilities:read openapi:read',
  },
] %}
{% set secondaryTemplateExamples = [
  {
    id: 'agent-entry-translation-drafts',
    displayName: 'Translation Drafts',
    description: 'Reads approved source entries and creates target-language drafts for editorial review.',
    scopes: 'entries:read entries:read_all_statuses sections:read entries:write:draft control:approvals:request control:approvals:read capabilities:read openapi:read',
  },
  {
    id: 'agent-accessibility-review',
    displayName: 'Accessibility Review',
    description: 'Reviews content structure and asset usage for accessibility-related content issues and remediation follow-up.',
    scopes: 'entries:read entries:read_all_statuses assets:read sections:read capabilities:read openapi:read',
  },
  {
    id: 'agent-change-audit',
    displayName: 'Change Monitor',
    description: 'Tracks site changes over time and highlights content drift or unexpected updates for operators.',
    scopes: 'changes:read entries:read assets:read sections:read capabilities:read openapi:read',
  },
  {
    id: 'agent-launch-qa',
    displayName: 'Launch QA',
    description: 'Runs pre-launch or post-release checks across content, assets, and structure before handoff or rollout.',
    scopes: 'entries:read entries:read_all_statuses assets:read sections:read categories:read tags:read capabilities:read openapi:read',
  },
] %}
{% set allTemplateExamples = defaultTemplateExamples|merge(secondaryTemplateExamples) %}
{% set availableScopes = [] %}
{% for scope in defaultScopes %}
  {% set normalizedScope = scope|trim %}
  {% if normalizedScope and normalizedScope not in availableScopes %}
    {% set availableScopes = availableScopes|merge([normalizedScope]) %}
  {% endif %}
{% endfor %}
{% for example in allTemplateExamples %}
  {% for scope in example.scopes|split(' ') %}
    {% set normalizedScope = scope|trim %}
    {% if normalizedScope
      and normalizedScope not in availableScopes
      and (writesExperimentalEnabled or (normalizedScope not in governedWriteScopes and not (normalizedScope starts with 'control:')))
      and (commercePluginEnabled or normalizedScope not in commerceScopes) %}
      {% set availableScopes = availableScopes|merge([normalizedScope]) %}
    {% endif %}
  {% endfor %}
{% endfor %}
{% for scope in ['incidents:read', 'syncstate:read', 'syncstate:write', 'webhooks:dlq:read', 'webhooks:dlq:replay'] %}
  {% if scope not in availableScopes %}
    {% set availableScopes = availableScopes|merge([scope]) %}
  {% endif %}
{% endfor %}
{% set descriptionByHandle = {
  'agent-site-structure-review': 'Reviews sections, categories, tags, and global sets for IA, taxonomy, and governance issues.',
} %}
{% for example in allTemplateExamples %}
  {% set descriptionByHandle = descriptionByHandle|merge({ (example.id): example.description }) %}
{% endfor %}
  {% set availableScopes = availableScopes|sort %}
  {% set scopeGroupOrder = ['core', 'content', 'commerce', 'sync', 'governance', 'other'] %}
  {% set scopeGroups = {
    core: { label: 'Core contract & diagnostics', hint: 'Use when you need health, diagnostics, and machine-readable API access.', items: [] },
    content: { label: 'Content & site structure', hint: 'Use when you need to read entries, assets, users, and site structure.', items: [] },
    commerce: { label: 'Commerce data', hint: 'Use when you need to read products, orders, and other commerce records.', items: [] },
    sync: { label: 'Sync, webhooks & runtime feeds', hint: 'Use when you need change feeds, webhook operations, or sync-state reporting.', items: [] },
    governance: { label: 'Governed writes & approvals', hint: 'Use when you need draft writes, approval routing, or control-plane execution.', items: [] },
    other: { label: 'Other', hint: 'Use when you need a less common scope that does not fit the main groups.', items: [] },
  } %}
{% for scope in availableScopes %}
  {% set normalizedScope = scope|trim %}
  {% set scopeGroupKey = 'other' %}
  {% if normalizedScope starts with 'control:' or normalizedScope in governedWriteScopes %}
    {% set scopeGroupKey = 'governance' %}
  {% elseif normalizedScope starts with 'auth:' or normalizedScope starts with 'capabilities:' or normalizedScope starts with 'openapi:' or normalizedScope starts with 'schema:' or normalizedScope starts with 'diagnostics:' or normalizedScope starts with 'metrics:' or normalizedScope starts with 'adoption:' or normalizedScope starts with 'incidents:' or normalizedScope starts with 'lifecycle:' %}
    {% set scopeGroupKey = 'core' %}
  {% elseif normalizedScope starts with 'entries:' or normalizedScope starts with 'sections:' or normalizedScope starts with 'assets:' or normalizedScope starts with 'categories:' or normalizedScope starts with 'tags:' or normalizedScope starts with 'global-sets:' or normalizedScope starts with 'content-blocks:' or normalizedScope starts with 'users:' %}
    {% set scopeGroupKey = 'content' %}
  {% elseif normalizedScope starts with 'products:' or normalizedScope starts with 'orders:' or normalizedScope starts with 'variants:' or normalizedScope starts with 'subscriptions:' or normalizedScope starts with 'transfers:' or normalizedScope starts with 'donations:' or normalizedScope starts with 'addresses:' %}
    {% set scopeGroupKey = 'commerce' %}
  {% elseif normalizedScope starts with 'changes:' or normalizedScope starts with 'syncstate:' or normalizedScope starts with 'webhooks:' %}
    {% set scopeGroupKey = 'sync' %}
  {% endif %}
  {% set scopeGroups = scopeGroups|merge({
    (scopeGroupKey): scopeGroups[scopeGroupKey]|merge({
      items: scopeGroups[scopeGroupKey].items|merge([normalizedScope]),
    }),
  }) %}
{% endfor %}
{% set defaultCredentialOwnerUserElements = defaultCredentialOwnerUser ? [defaultCredentialOwnerUser] : [] %}
{% set firstWorkerGuideUrl = firstWorkerGuideUrl ?? 'https://marcusscheller.com/docs/agents/get-started/first-worker' %}
{% set scopeGuideUrl = scopeGuideUrl ?? 'https://marcusscheller.com/docs/agents/api/scope-guide' %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  {% set lifecycleSummaryTotal = lifecycleSummary.total|default(managedCredentials|length) %}
  {% set lifecycleSummaryPaused = lifecycleSummary.paused|default(0) %}
  {% set listFilterRaw = (craft.app.request.getQueryParam('listFilter', '')|lower) %}
  {% set listFilter = listFilterRaw in ['paused', 'attention'] ? listFilterRaw : '' %}
  {% set revealedCredentialId = revealedCredential.id ?? 0 %}
  {% set revealedCredentialHandleNormalized = revealedCredential.handle|default('')|trim|lower %}
  {% set revealedCredentialEnvFilename = revealedCredential and revealedCredential.handle|default('') ? 'accounts-' ~ revealedCredential.handle|replace({':': '-', '/': '-', ' ': '-'}) ~ '-worker.env' : 'agents-worker.env' %}
  {% set workerBootstrapSiteUrl = workerBootstrapSiteUrl ?? '' %}
  {% set workerBootstrapBaseUrl = workerBootstrapBaseUrl ?? '' %}
  {% set revealedCredentialWorkerEnv = revealedCredential and revealedCredential.token ? 'SITE_URL=' ~ workerBootstrapSiteUrl ~ "\n" ~ 'BASE_URL=' ~ workerBootstrapBaseUrl ~ "\n" ~ 'AGENTS_TOKEN=' ~ revealedCredential.token ~ "\n" ~ 'REQUEST_TIMEOUT_MS=15000' ~ "\n" ~ 'PRINT_JSON=1' : '' %}
  {% set pausedFilterUrl = cpUrl('agents/accounts', { listFilter: 'paused' }) %}
  {% set attentionFilterUrl = cpUrl('agents/accounts', { listFilter: 'attention' }) %}
  {% set clearFilterUrl = cpUrl('agents/accounts') %}
  {% set credentialsRedirectUrl = listFilter ? cpUrl('agents/accounts', { listFilter: listFilter }) : clearFilterUrl %}
  {% set showRiskColumn = listFilter == 'attention' %}
  {% set filteredManagedCredentials = [] %}
  {% set attentionAccountsCount = 0 %}
  {% for credential in managedCredentials %}
    {% set credentialMode = (credential.mode|default(''))|lower %}
    {% if credentialMode == '' %}
      {% if credential.revoked %}
        {% set credentialMode = 'revoked' %}
      {% elseif credential.expiryStatus|default('none') == 'expired' %}
        {% set credentialMode = 'expired' %}
      {% elseif credential.paused|default(false) %}
        {% set credentialMode = 'paused' %}
      {% elseif credential.expiryStatus|default('none') == 'expiring_soon' %}
        {% set credentialMode = 'expiring_soon' %}
      {% else %}
        {% set credentialMode = 'active' %}
      {% endif %}
    {% endif %}
    {% set credentialLifecycle = lifecycleByCredentialId[credential.id]|default(null) %}
    {% set credentialOwner = credential.ownerLabel|default(credentialLifecycle.metadata.owner|default('')) %}
    {% if credentialOwner == '' %}
      {% set credentialOwner = 'unassigned' %}
    {% endif %}
    {% set credentialHasNonPausedRisk = false %}
    {% for factor in credentialLifecycle.risk.factors|default([]) %}
      {% set factorId = (factor.id|default(''))|lower %}
      {% set factorLevel = (factor.level|default('ok'))|lower %}
      {% if factorLevel in ['warn', 'critical'] and factorId != 'paused' %}
        {% set credentialHasNonPausedRisk = true %}
      {% endif %}
    {% endfor %}
    {% set credentialNeedsAttention = credentialHasNonPausedRisk or credentialOwner == 'unassigned' %}
    {% if credentialNeedsAttention %}
      {% set attentionAccountsCount = attentionAccountsCount + 1 %}
    {% endif %}
    {% set includeCredential = true %}
    {% if listFilter == 'paused' %}
      {% set includeCredential = credentialMode == 'paused' %}
    {% elseif listFilter == 'attention' %}
      {% set includeCredential = credentialNeedsAttention %}
    {% endif %}
    {% if includeCredential %}
      {% set filteredManagedCredentials = filteredManagedCredentials|merge([credential]) %}
    {% endif %}
  {% endfor %}
  {% set lifecycleWarningCardClass = attentionAccountsCount > 0 ? 'agents-lifecycle-strip-card--status-warn' : 'agents-lifecycle-strip-card--status-good' %}

  <div class="agents-page-shell">
    <div class="agents-page-header">
      <div class="agents-page-header__copy">
        <h1>Accounts</h1>
        <p class="agents-page-intro">Manage machine accounts, their current mode, and access controls.<br>API tokens are generated on save and only shown once.<br><a href="{{ firstWorkerGuideUrl }}" target="_blank" rel="noopener">Guide to create your first worker &rarr;</a> &middot; <a href="{{ scopeGuideUrl }}" target="_blank" rel="noopener">Scope guide &rarr;</a></p>
      </div>
      {% if canManageCredentials %}
        <div class="agents-page-header__actions">
          <button class="btn submit" type="button" id="toggleCreateAgentForm">+ Add</button>
        </div>
      {% endif %}
    </div>
  </div>

  <div class="agents-layout-stack">
    <div class="agents-page-shell">

    <section class="agents-lifecycle-panel" aria-label="Lifecycle Governance">
      <div class="agents-lifecycle-strip-wrap">
        <div class="agents-lifecycle-strip">
          <a class="agents-lifecycle-strip-card agents-lifecycle-strip-card--clickable{{ listFilter == '' ? ' is-selected' : '' }}" href="{{ clearFilterUrl }}">
            <div class="agents-lifecycle-strip-label">Managed accounts</div>
            <div class="agents-lifecycle-strip-value">{{ lifecycleSummaryTotal }}</div>
          </a>
          <a class="agents-lifecycle-strip-card agents-lifecycle-strip-card--clickable{{ listFilter == 'paused' ? ' is-selected' : '' }}" href="{{ pausedFilterUrl }}">
            <div class="agents-lifecycle-strip-label">Paused accounts</div>
            <div class="agents-lifecycle-strip-value">{{ lifecycleSummaryPaused }}</div>
          </a>
          <a class="agents-lifecycle-strip-card agents-lifecycle-strip-card--clickable {{ lifecycleWarningCardClass }}{{ listFilter == 'attention' ? ' is-selected' : '' }}" href="{{ attentionFilterUrl }}">
            <div class="agents-lifecycle-strip-label">Need attention</div>
            <div class="agents-lifecycle-strip-value">{{ attentionAccountsCount }}</div>
          </a>
        </div>
      </div>
    </section>

    <section class="border rounded p-3">
      {% set existingManagedHandles = [] %}
      {% for credential in managedCredentials %}
        {% set normalizedCredentialHandle = credential.handle|default('')|trim|lower %}
        {% if normalizedCredentialHandle and normalizedCredentialHandle not in existingManagedHandles %}
          {% set existingManagedHandles = existingManagedHandles|merge([normalizedCredentialHandle]) %}
        {% endif %}
      {% endfor %}

      {% set suggestedAgentTemplates = [] %}
      {% for example in defaultTemplateExamples %}
        {% set templateRequiresWrites = false %}
        {% set templateRequiresCommerce = false %}
        {% for templateScope in example.scopes|default('')|split(' ') %}
          {% set normalizedTemplateScope = templateScope|trim %}
          {% if normalizedTemplateScope %}
            {% if normalizedTemplateScope in governedWriteScopes or normalizedTemplateScope starts with 'control:' %}
              {% set templateRequiresWrites = true %}
            {% endif %}
            {% if normalizedTemplateScope in commerceScopes %}
              {% set templateRequiresCommerce = true %}
            {% endif %}
          {% endif %}
        {% endfor %}
        {% set normalizedExampleHandle = example.id|default('')|trim|lower %}
        {% if normalizedExampleHandle
          and normalizedExampleHandle not in existingManagedHandles
          and (writesExperimentalEnabled or not templateRequiresWrites)
          and (commercePluginEnabled or not templateRequiresCommerce) %}
          {% set suggestedAgentTemplates = suggestedAgentTemplates|merge([example]) %}
        {% endif %}
      {% endfor %}

      {% set secondaryAgentTemplates = [] %}
      {% for example in secondaryTemplateExamples %}
        {% set templateRequiresWrites = false %}
        {% set templateRequiresCommerce = false %}
        {% for templateScope in example.scopes|default('')|split(' ') %}
          {% set normalizedTemplateScope = templateScope|trim %}
          {% if normalizedTemplateScope %}
            {% if normalizedTemplateScope in governedWriteScopes or normalizedTemplateScope starts with 'control:' %}
              {% set templateRequiresWrites = true %}
            {% endif %}
            {% if normalizedTemplateScope in commerceScopes %}
              {% set templateRequiresCommerce = true %}
            {% endif %}
          {% endif %}
        {% endfor %}
        {% set normalizedExampleHandle = example.id|default('')|trim|lower %}
        {% if normalizedExampleHandle
          and normalizedExampleHandle not in existingManagedHandles
          and (writesExperimentalEnabled or not templateRequiresWrites)
          and (commercePluginEnabled or not templateRequiresCommerce) %}
          {% set secondaryAgentTemplates = secondaryAgentTemplates|merge([example]) %}
        {% endif %}
      {% endfor %}

      {% if listFilter != '' %}
        {% set suggestedAgentTemplates = [] %}
        {% set secondaryAgentTemplates = [] %}
      {% endif %}

      {% if filteredManagedCredentials|length %}
        {% if listFilter != '' %}
          <p class="agents-subtle agents-card-filter-note">
            Showing {{ listFilter == 'paused' ? 'paused' : 'attention' }} accounts only.
            <a href="{{ clearFilterUrl }}">Show all</a>
          </p>
        {% endif %}
        <section class="agents-accounts-toolbar" aria-label="Accounts view options">
          <section class="btngroup btngroup--exclusive agents-accounts-view-switch" id="agentsAccountsViewSwitch" aria-label="View">
            <button type="button" class="btn active" data-agent-view-mode="table" data-icon="list" aria-label="Display in a table" aria-pressed="true" title="Display in a table"></button>
            <button type="button" class="btn" data-agent-view-mode="cards" data-icon="element-cards" aria-label="Display as cards" aria-pressed="false" title="Display as cards"></button>
          </section>
        </section>

        <div class="agents-accounts-view agents-accounts-view--table" id="agentsAccountsTableView">
          <div class="agents-accounts-registry-shell">
            <div class="tableview tablepane agents-accounts-registry-wrap">
              <span class="visually-hidden" data-status-message role="status"></span>
              <table class="data fullwidth big agents-accounts-registry" data-name="Accounts">
              <caption class="visually-hidden">Accounts registry</caption>
              <colgroup>
                <col class="agents-accounts-registry__col agents-accounts-registry__col--account">
                <col class="agents-accounts-registry__col agents-accounts-registry__col--state">
                {% if showRiskColumn %}
                  <col class="agents-accounts-registry__col agents-accounts-registry__col--risk">
                {% endif %}
                <col class="agents-accounts-registry__col agents-accounts-registry__col--purpose">
                <col class="agents-accounts-registry__col agents-accounts-registry__col--owner">
                <col class="agents-accounts-registry__col agents-accounts-registry__col--access">
                <col class="agents-accounts-registry__col agents-accounts-registry__col--last-used">
                <col class="agents-accounts-registry__col agents-accounts-registry__col--actions">
              </colgroup>
              <thead>
                <tr>
                  <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--account">Account</th>
                  <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--state">State</th>
                  {% if showRiskColumn %}
                    <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--risk">Risk</th>
                  {% endif %}
                  <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--purpose">Purpose</th>
                  <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--owner">Owner</th>
                  <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--access">Access</th>
                  <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--last-used">Last used</th>
                  <th scope="col" class="agents-accounts-registry__header-cell agents-accounts-registry__header-cell--actions">Actions</th>
                </tr>
              </thead>
              <tbody>
            {% for credential in filteredManagedCredentials %}
              {% set mode = (credential.mode|default(''))|lower %}
              {% if mode == '' %}
                {% if credential.revoked %}
                  {% set mode = 'revoked' %}
                {% elseif credential.expiryStatus|default('none') == 'expired' %}
                  {% set mode = 'expired' %}
                {% elseif credential.paused|default(false) %}
                  {% set mode = 'paused' %}
                {% elseif credential.expiryStatus|default('none') == 'expiring_soon' %}
                  {% set mode = 'expiring_soon' %}
                {% else %}
                  {% set mode = 'active' %}
                {% endif %}
              {% endif %}

              {% set modeLabel = mode == 'paused' ? 'Paused' : (mode == 'revoked' ? 'Revoked' : (mode == 'expired' ? 'Expired' : (mode == 'expiring_soon' ? 'Expiring soon' : 'Active'))) %}
              {% set isActiveState = mode in ['active', 'expiring_soon'] %}
              {% set detailSourceId = 'agent-details-source-' ~ credential.id %}
              {% set webhookResourceTypes = credential.webhookSubscriptions.resourceTypes ?? [] %}
              {% set webhookActions = credential.webhookSubscriptions.actions ?? [] %}
              {% set hasWebhookSubscriptions = webhookResourceTypes|length or webhookActions|length %}
              {% set expiryStatus = credential.expiryStatus ?? 'none' %}
              {% set expiresInDays = credential.expiresInDays ?? null %}
              {% set expiryReminderDays = credential.expiryReminderDays ?? 7 %}
              {% set ipAllowlist = credential.ipAllowlist ?? [] %}
              {% set hasWriteCapability = false %}
              {% for credentialScope in credential.scopes|default([]) %}
                {% set normalizedCredentialScope = credentialScope|lower %}
                {% if normalizedCredentialScope ends with ':write' or ':write:' in normalizedCredentialScope %}
                  {% set hasWriteCapability = true %}
                {% endif %}
              {% endfor %}
              {% set agentDescription = credential.description ?: (descriptionByHandle[credential.handle] ?? 'Managed account for governed runtime operations.') %}
              {% set webhookMode = hasWebhookSubscriptions ? 'targeted' : 'disabled' %}
              {% set expirySummary = 'none' %}
              {% set canPauseAction = canPauseCredentials and not credential.revoked and mode not in ['expired', 'revoked'] %}
              {% set canRotateAction = canRotateCredentials %}
              {% set canRevokeAction = canRevokeCredentials and not credential.revoked %}
              {% set lifecycle = lifecycleByCredentialId[credential.id]|default(null) %}
              {% set lifecycleRiskLevel = lifecycle and lifecycle.risk.level is defined ? (lifecycle.risk.level|lower) : 'ok' %}
              {% set lifecycleOwner = credential.ownerLabel|default(lifecycle.metadata.owner|default('unassigned')) %}
              {% set lifecycleUseCase = lifecycle.metadata.useCase|default(credential.displayName ?: credential.handle) %}
              {% set lifecycleEnvironment = lifecycle.metadata.environment|default('unknown') %}
              {% set normalizedCredentialHandle = credential.handle|default('')|trim|lower %}
              {% set tableTestFeedbackId = 'agent-table-test-feedback-' ~ credential.id %}
              {% set tableWorkerEnvFeedbackId = 'agent-table-worker-env-feedback-' ~ credential.id %}
              {% set revealedCredentialMatches = revealedCredential and revealedCredential.token and (
                (revealedCredentialId and revealedCredentialId == credential.id)
                or (revealedCredentialHandleNormalized and revealedCredentialHandleNormalized == normalizedCredentialHandle)
              ) %}
              {% set approvalRecipientLabels = [] %}
              {% for approvalRecipient in credential.approvalRecipients|default([]) %}
                {% set approvalRecipientLabel = approvalRecipient.label|default('')|trim %}
                {% if approvalRecipientLabel %}
                  {% set approvalRecipientLabels = approvalRecipientLabels|merge([approvalRecipientLabel]) %}
                {% endif %}
              {% endfor %}
              {% set credentialTargetSets = writesExperimentalEnabled ? (credential.targetSets|default([])) : [] %}
              {% set credentialTargetSetLabels = [] %}
              {% for targetSet in credentialTargetSets %}
                {% set targetSetLabel = targetSet.name|default(targetSet.handle|default(''))|trim %}
                {% if targetSetLabel %}
                  {% set credentialTargetSetLabels = credentialTargetSetLabels|merge([targetSetLabel]) %}
                {% endif %}
              {% endfor %}
              {% set bootstrapTestMissingScopes = [] %}
              {% for bootstrapTestScope in ['auth:read', 'health:read', 'readiness:read'] %}
                {% if bootstrapTestScope not in credential.scopes|default([]) %}
                  {% set bootstrapTestMissingScopes = bootstrapTestMissingScopes|merge([bootstrapTestScope]) %}
                {% endif %}
              {% endfor %}
              {% set riskLabels = [] %}
              {% for factor in lifecycle.risk.factors|default([]) %}
                {% set factorId = (factor.id|default(''))|lower %}
                {% set factorLabel = '' %}
                {% if factorId in ['stale_usage', 'never_used'] %}
                  {% set factorLabel = 'Stale status' %}
                {% elseif factorId == 'expired' %}
                  {% set factorLabel = 'Expired credential' %}
                {% elseif factorId == 'expiring_soon' %}
                  {% set factorLabel = 'Expiring soon' %}
                {% elseif factorId == 'rotation_overdue' %}
                  {% set factorLabel = 'Rotation overdue' %}
                {% elseif factorId == 'rotation_due' %}
                  {% set factorLabel = 'Rotation due' %}
                {% elseif factorId == 'no_expiry_policy' %}
                  {% set factorLabel = 'No expiry policy' %}
                {% elseif factorId == 'environment_mismatch' %}
                  {% set factorLabel = 'Environment mismatch' %}
                {% elseif factorId == 'revoked' %}
                  {% set factorLabel = 'Revoked' %}
                {% endif %}
                {% if factorLabel and factorLabel not in riskLabels %}
                  {% set riskLabels = riskLabels|merge([factorLabel]) %}
                {% endif %}
              {% endfor %}
              {% if lifecycleOwner == 'unassigned' and 'Owner missing' not in riskLabels %}
                {% set riskLabels = riskLabels|merge(['Owner missing']) %}
              {% endif %}
              {% if expiryStatus == 'expired' %}
                {% set expirySummary = 'expired' %}
              {% elseif expiryStatus == 'never' %}
                {% set expirySummary = 'never' %}
              {% elseif expiryStatus == 'expiring_soon' %}
                {% set expirySummary = (expiresInDays is not null) ? (expiresInDays ~ ' day(s) left') : 'expiring soon' %}
              {% elseif expiryStatus == 'active' and expiresInDays is not null %}
                {% set expirySummary = expiresInDays ~ ' day(s) left' %}
              {% endif %}
              {% set scopeCount = credential.scopes|default([])|length %}
              {% set accessSummary = scopeCount ? (hasWriteCapability ? 'Draft write' : 'Read-only') : 'No scopes' %}
              {% if hasWriteCapability and 'control:approvals:request' in credential.scopes|default([]) %}
                {% set accessSummary = 'Write' %}
              {% endif %}
              {% set governedContentRefreshHelperEnabled = writesExperimentalEnabled and hasWriteCapability and ('control:approvals:request' in credential.scopes|default([])) %}
              {% set lastUsedShortDate = credential.lastUsedAt ? credential.lastUsedAt|date('y/m/d', timezone='UTC') : 'Never' %}
              {% if credential.lastUsedAt %}
                {% set lastUsedAgeSeconds = ('now'|date('U')) - (credential.lastUsedAt|date('U')) %}
                {% if lastUsedAgeSeconds < 86400 %}
                  {% set lastUsedRelativeDate = 'Today' %}
                  {% set lastUsedDisplay = lastUsedRelativeDate %}
                {% elseif lastUsedAgeSeconds < 172800 %}
                  {% set lastUsedRelativeDate = 'Yesterday' %}
                  {% set lastUsedDisplay = lastUsedRelativeDate %}
                {% else %}
                  {% set lastUsedDaysAgo = (lastUsedAgeSeconds / 86400)|round(0, 'floor') %}
                  {% if lastUsedDaysAgo <= 7 %}
                    {% set lastUsedRelativeDate = lastUsedDaysAgo ~ ' days ago' %}
                    {% set lastUsedDisplay = lastUsedRelativeDate %}
                  {% else %}
                    {% set lastUsedRelativeDate = lastUsedShortDate %}
                    {% set lastUsedDisplay = lastUsedShortDate %}
                  {% endif %}
                {% endif %}
              {% else %}
                {% set lastUsedRelativeDate = 'Never' %}
                {% set lastUsedDisplay = 'never' %}
              {% endif %}
              {% set ownerSummary = lifecycleOwner == 'unassigned' ? 'Unassigned' : lifecycleOwner %}
              {% set riskToneClass = riskLabels|length ? 'has-attention' : (lifecycleRiskLevel == 'ok' ? 'is-clear' : 'has-attention') %}
              {% set statusToneClass = mode in ['active'] ? 'enabled' : (mode == 'expiring_soon' ? 'pending' : 'disabled') %}
              {% set riskSummary = riskLabels|length ? riskLabels|first : 'Clear' %}
              {% set riskMeta = riskLabels|length > 1 ? (riskLabels|length - 1) ~ ' more' : '' %}
              {% set ownerCpUrl = credential.ownerUserId ? cpUrl('users/' ~ credential.ownerUserId) : null %}
              {% set credentialWorkerEnv = revealedCredentialMatches ? revealedCredentialWorkerEnv : '' %}
              {% set credentialWorkerEnvFilename = revealedCredentialMatches ? revealedCredentialEnvFilename : '' %}

                <tr class="agents-accounts-registry-summary-row {{ isActiveState ? 'is-active' : 'is-inactive' }} {{ riskToneClass }}" data-agent-detail-item data-agent-view-mode="table" data-agent-card-id="{{ credential.id }}" data-agent-card-handle="{{ normalizedCredentialHandle|e('html_attr') }}">
                  <th scope="row" class="agents-accounts-registry-account agents-accounts-registry__body-cell agents-accounts-registry__body-cell--account">
                    <div class="agents-accounts-registry-account-name">{{ credential.displayName ?: credential.handle }}</div>
                  </th>
                  <td data-title="State" class="agents-accounts-registry__body-cell agents-accounts-registry__body-cell--state">
                    <div class="agents-accounts-registry-state">
                      <span class="status agents-agent-card-dot {{ statusToneClass }}" data-agent-status-dot data-agent-status-id="{{ credential.id }}" aria-label="State: {{ modeLabel }}" title="{{ modeLabel }}"></span>
                      <span class="visually-hidden" data-agent-state-label>{{ modeLabel }}</span>
                    </div>
                  </td>
                  {% if showRiskColumn %}
                    <td data-title="Risk" class="agents-accounts-registry-risk agents-accounts-registry__body-cell agents-accounts-registry__body-cell--risk">
                      <div class="agents-accounts-registry-risk-text">{{ riskSummary }}</div>
                      {% if riskMeta %}
                        <div class="agents-accounts-registry-value-stack__secondary">{{ riskMeta }}</div>
                      {% endif %}
                    </td>
                  {% endif %}
                  <td data-title="Purpose" class="agents-accounts-registry__body-cell agents-accounts-registry__body-cell--purpose">
                    <div class="agents-accounts-registry-purpose">{{ agentDescription }}</div>
                  </td>
                  <td data-title="Owner" class="agents-accounts-registry__body-cell agents-accounts-registry__body-cell--owner">
                    {% if ownerCpUrl %}
                      <a href="{{ ownerCpUrl }}">{{ ownerSummary }}</a>
                    {% else %}
                      <span class="agents-accounts-registry-owner-text">{{ ownerSummary }}</span>
                    {% endif %}
                  </td>
                  <td data-title="Access" class="agents-accounts-registry__body-cell agents-accounts-registry__body-cell--access">
                    <div class="agents-accounts-registry-value-stack">
                      <div class="agents-accounts-registry-value-stack__primary">{{ accessSummary }}</div>
                    </div>
                  </td>
                  <td data-title="Last used" class="agents-accounts-registry__body-cell agents-accounts-registry__body-cell--last-used">
                    <div class="agents-accounts-registry-value-stack agents-accounts-registry-value-stack--last-used">
                      <div class="agents-accounts-registry-value-stack__primary">{{ lastUsedRelativeDate }}</div>
                    </div>
                  </td>
                  <td data-title="Actions" class="agents-accounts-registry-actions agents-accounts-registry__body-cell agents-accounts-registry__body-cell--actions">
                    <div class="buttons">
                      <button class="btn small" type="button" data-agent-details-toggle data-target="{{ detailSourceId }}" aria-expanded="false">
                        <span>Details</span>
                      </button>
                      {% if canManageCredentials %}
                        <button
                          class="btn small"
                          type="button"
                          data-agent-edit
                          data-agent-id="{{ credential.id }}"
                          data-agent-handle="{{ credential.handle|e('html_attr') }}"
                          data-agent-display-name="{{ (credential.displayName ?: credential.handle)|e('html_attr') }}"
                          data-agent-description="{{ (credential.description ?? '')|e('html_attr') }}"
                          data-agent-scopes="{{ credential.scopes|json_encode|e('html_attr') }}"
                          data-agent-webhook-resource-types="{{ webhookResourceTypes|json_encode|e('html_attr') }}"
                          data-agent-webhook-actions="{{ webhookActions|json_encode|e('html_attr') }}"
                          data-agent-ttl-days="{{ expiryStatus == 'never' ? 0 : ((expiryStatus in ['active', 'expiring_soon'] and expiresInDays is not null) ? expiresInDays : '') }}"
                          data-agent-expiry-reminder-days="{{ expiryReminderDays }}"
                          data-agent-ip-allowlist="{{ ipAllowlist|join("\n")|e('html_attr') }}"
                          data-agent-owner-legacy="{{ (credential.ownerLegacy ?? credential.owner ?? '')|e('html_attr') }}"
                          data-agent-owner-user-id="{{ (credential.ownerUserId ?? '')|e('html_attr') }}"
                          data-agent-approval-recipient-user-ids="{{ (credential.approvalRecipientUserIds|default([]))|json_encode|e('html_attr') }}"
                          data-agent-force-human-approval="{{ (credential.forceHumanApproval ?? true) ? '1' : '0' }}"
                          data-agent-target-set-ids="{{ (credential.targetSetIds|default([]))|json_encode|e('html_attr') }}"
                        >Edit</button>
                      {% endif %}
                    </div>
                    <template id="{{ detailSourceId }}" data-agent-details-template>
                      <div class="agents-accounts-registry-details-wrap">
                        <div class="agents-agent-card-details-section">
                          <div class="agents-agent-card-detail-heading">Account</div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">ID:</span><span class="agents-agent-card-v">{{ credential.handle }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">prefix:</span><span class="agents-agent-card-v">{{ credential.tokenPrefix ?: 'n/a' }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">Last used:</span><span class="agents-agent-card-v">{{ lastUsedDisplay }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">ip:</span><span class="agents-agent-card-v">{{ credential.lastUsedIp ?: 'n/a' }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">method:</span><span class="agents-agent-card-v">{{ credential.lastAuthMethod ?: 'n/a' }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">rotated:</span><span class="agents-agent-card-v">{{ credential.rotatedAt ? credential.rotatedAt|date('Y-m-d, H:i:s', timezone='UTC') : 'never' }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">event routing:</span><span class="agents-agent-card-v">{{ webhookMode }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">expiry:</span><span class="agents-agent-card-v">{{ expirySummary }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">ip allowlist:</span><span class="agents-agent-card-v">{{ ipAllowlist|length ? ipAllowlist|join(', ') : 'none' }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">owner:</span><span class="agents-agent-card-v">{{ lifecycleOwner }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">approval recipients:</span><span class="agents-agent-card-v">{{ approvalRecipientLabels|length ? approvalRecipientLabels|join(', ') : 'global fallback' }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">target sets:</span><span class="agents-agent-card-v">{{ credentialTargetSetLabels|length ? credentialTargetSetLabels|join(', ') : 'none' }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">use case:</span><span class="agents-agent-card-v">{{ lifecycleUseCase }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">environment:</span><span class="agents-agent-card-v">{{ lifecycleEnvironment }}</span></div>
                          <div class="agents-agent-card-kv"><span class="agents-agent-card-k">lifecycle risk:</span><span class="agents-agent-card-v">{{ lifecycleRiskLevel|upper }}</span></div>
                        </div>
                        <div class="agents-agent-card-details-section agents-agent-card-details-section--actions">
                          <div class="agents-agent-card-detail-heading">Connect Worker</div>
                          <p class="agents-agent-card-detail-note">Create or rotate the account to reveal a one-time worker <code>.env</code> export. Use <strong>Test Account</strong> here to validate account state and safe read surfaces.</p>
                          {% if bootstrapTestMissingScopes|length %}
                            <p class="agents-agent-card-detail-note agents-agent-card-detail-note--warning">Missing bootstrap scopes: {{ bootstrapTestMissingScopes|join(', ') }}.</p>
                          {% endif %}
                          {% if credentialWorkerEnv %}
                            <textarea class="agents-worker-env-source" readonly hidden>{{ credentialWorkerEnv }}</textarea>
                            <pre class="agents-worker-env-preview"><code>{{ credentialWorkerEnv }}</code></pre>
                          {% endif %}
                          <div class="agents-agent-card-detail-actions">
                            {% if credentialWorkerEnv %}
                              <button class="btn formsubmit agents-card-btn" type="button" data-agent-copy-worker-env data-feedback-target="{{ tableWorkerEnvFeedbackId }}">Copy .env</button>
                              <button class="btn formsubmit agents-card-btn" type="button" data-agent-download-worker-env data-worker-env-filename="{{ credentialWorkerEnvFilename }}" data-feedback-target="{{ tableWorkerEnvFeedbackId }}">Download .env</button>
                            {% endif %}
                            <form method="post" accept-charset="UTF-8" data-agent-test-form data-feedback-target="{{ tableTestFeedbackId }}">
                              {{ csrfInput() }}
                              {{ actionInput('agents/dashboard/test-credential') }}
                              {{ redirectInput('agents/accounts?focusCardId=' ~ credential.id) }}
                              <input type="hidden" name="credentialId" value="{{ credential.id }}">
                              <button class="btn formsubmit agents-card-btn" type="submit" data-agent-test-submit data-label-idle="Test Account" data-label-busy="Testing...">Test Account</button>
                            </form>
                          </div>
                          {% if credentialWorkerEnv %}
                            <p class="agents-agent-card-detail-feedback agents-worker-env-feedback" id="{{ tableWorkerEnvFeedbackId }}" aria-live="polite"></p>
                          {% endif %}
                          <p class="agents-agent-card-detail-feedback" id="{{ tableTestFeedbackId }}" aria-live="polite"></p>
                        </div>
                        {% if governedContentRefreshHelperEnabled %}
                          <div class="agents-agent-card-details-section">
                            <div class="agents-agent-card-detail-heading">Governed content refresh</div>
                            <p class="agents-agent-card-detail-note">Use this account for a scheduled worker that reads entry metadata, prepares a draft proposal, and submits a governed approval request with the full draft payload.</p>
                            <div class="agents-agent-card-detail-actions">
                              <a class="btn formsubmit agents-card-btn" href="{{ governedContentRefreshWorkflowUrl }}" target="_blank" rel="noopener">Open workflow</a>
                              <a class="btn formsubmit agents-card-btn" href="{{ allowCpApprovalRequests ? (cpUrl('agents/approvals') ~ '#manualApprovalRequestSection') : cpUrl('agents/approvals') }}">{{ allowCpApprovalRequests ? 'Create request in Approvals' : 'Open Approvals' }}</a>
                            </div>
                          </div>
                        {% endif %}
                        {% if credentialTargetSets|length %}
                          <div class="agents-agent-card-details-section">
                            <div class="agents-agent-card-detail-heading">Governed write helpers</div>
                            <p class="agents-agent-card-detail-note">Use these bounded request examples when you need a safe governed draft-update payload for this account.</p>
                            {% for targetSet in credentialTargetSets %}
                              {% set helperEntryId = targetSet.allowedEntryIds|default([])|first ?: 0 %}
                              {% set helperSiteId = targetSet.allowedSiteIds|default([])|first ?: 0 %}
                              {% set helperEntryLabels = [] %}
                              {% for allowedEntry in targetSet.allowedEntries|default([]) %}
                                {% set helperEntryLabel = allowedEntry.label|default('')|trim %}
                                {% if helperEntryLabel %}
                                  {% set helperEntryLabels = helperEntryLabels|merge([helperEntryLabel]) %}
                                {% endif %}
                              {% endfor %}
                              {% set helperSiteLabels = [] %}
                              {% for allowedSite in targetSet.allowedSites|default([]) %}
                                {% set helperSiteLabel = allowedSite.label|default('')|trim %}
                                {% if helperSiteLabel %}
                                  {% set helperSiteLabels = helperSiteLabels|merge([helperSiteLabel]) %}
                                {% endif %}
                              {% endfor %}
                              <div class="agents-target-set-helper">
                                <div class="agents-target-set-helper__title">{{ targetSet.name ?: targetSet.handle }}</div>
                                {% if targetSet.description %}
                                  <p class="agents-agent-card-detail-note">{{ targetSet.description }}</p>
                                {% endif %}
                                <div class="agents-agent-card-kv"><span class="agents-agent-card-k">entries:</span><span class="agents-agent-card-v">{{ helperEntryLabels|length ? helperEntryLabels|join(', ') : 'none' }}</span></div>
                                <div class="agents-agent-card-kv"><span class="agents-agent-card-k">sites:</span><span class="agents-agent-card-v">{{ helperSiteLabels|length ? helperSiteLabels|join(', ') : 'none' }}</span></div>
                                <pre class="agents-target-set-helper__code"><code>{
  "actionType": "entry.updateDraft",
  "actionRef": "ENTRY-OPS-{{ helperEntryId ?: 'TARGET' }}",
  "reason": "Prepare draft update for editorial review",
  "metadata": {
    "source": "agent-runtime",
    "agentId": "{{ credential.handle }}",
    "traceId": "trace-entry-{{ helperEntryId ?: 'target' }}"
  },
  "payload": {
    "entryId": {{ helperEntryId }},
    "siteId": {{ helperSiteId }}
  }
}</code></pre>
                              </div>
                            {% endfor %}
                          </div>
                        {% endif %}
                        <div class="agents-agent-card-details-section">
                          <div class="agents-agent-card-detail-heading">Scopes</div>
                          <div class="agents-agent-card-scopes">
                            {% for scope in credential.scopes %}
                              <span class="agents-agent-scope-pill">{{ scope }}</span>
                            {% else %}
                              <span class="agents-agent-scope-pill">none</span>
                            {% endfor %}
                          </div>
                        </div>
                        <div class="agents-agent-card-details-section agents-agent-card-details-section--actions">
                          <div class="agents-agent-card-detail-heading">Actions</div>
                          <div class="agents-agent-card-detail-actions agents-accounts-registry-detail-actions">
                            {% if canPauseAction %}
                              {% if mode == 'paused' %}
                                <form method="post" accept-charset="UTF-8">
                                  {{ csrfInput() }}
                                  {{ actionInput('agents/dashboard/resume-credential') }}
                                  {{ redirectInput('agents/accounts') }}
                                  <input type="hidden" name="credentialId" value="{{ credential.id }}">
                                  <button class="btn formsubmit agents-card-btn" type="submit">Resume</button>
                                </form>
                              {% else %}
                                <form method="post" accept-charset="UTF-8">
                                  {{ csrfInput() }}
                                  {{ actionInput('agents/dashboard/pause-credential') }}
                                  {{ redirectInput('agents/accounts') }}
                                  <input type="hidden" name="credentialId" value="{{ credential.id }}">
                                  <button class="btn formsubmit agents-card-btn" type="submit">Pause</button>
                                </form>
                              {% endif %}
                            {% endif %}

                            {% if canRotateAction %}
                              <form method="post" accept-charset="UTF-8" data-agent-rotate-form>
                                {{ csrfInput() }}
                                {{ actionInput('agents/dashboard/rotate-credential') }}
                                {{ redirectInput('agents/accounts') }}
                                <input type="hidden" name="credentialId" value="{{ credential.id }}">
                                <button class="btn formsubmit agents-card-btn" type="submit" data-agent-action-submit data-label-idle="Rotate" data-label-busy="Rotating...">Rotate</button>
                              </form>
                            {% endif %}

                            {% if canRevokeAction %}
                              <form method="post" accept-charset="UTF-8" data-agent-revoke-form data-confirm-message="Revoke this account token?">
                                {{ csrfInput() }}
                                {{ actionInput('agents/dashboard/revoke-credential') }}
                                {{ redirectInput('agents/accounts') }}
                                <input type="hidden" name="credentialId" value="{{ credential.id }}">
                                <button class="btn formsubmit agents-card-btn" type="submit" data-agent-action-submit data-label-idle="Revoke" data-label-busy="Revoking...">Revoke</button>
                              </form>
                            {% endif %}

                            {% if canDeleteCredentials %}
                              <form method="post" accept-charset="UTF-8" onsubmit="return confirm('Delete this account permanently?');">
                                {{ csrfInput() }}
                                {{ actionInput('agents/dashboard/delete-credential') }}
                                {{ redirectInput('agents/accounts') }}
                                <input type="hidden" name="credentialId" value="{{ credential.id }}">
                                <button class="btn formsubmit agents-card-btn" type="submit">Delete</button>
                              </form>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </template>
                  </td>
                </tr>
            {% endfor %}
              </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="agents-accounts-view agents-accounts-view--cards" id="agentsAccountsCardsView" hidden>
          <div class="agents-card-list" id="agentsCardList">
          {% for credential in filteredManagedCredentials %}
            {% set mode = (credential.mode|default(''))|lower %}
            {% if mode == '' %}
              {% if credential.revoked %}
                {% set mode = 'revoked' %}
              {% elseif credential.expiryStatus|default('none') == 'expired' %}
                {% set mode = 'expired' %}
              {% elseif credential.paused|default(false) %}
                {% set mode = 'paused' %}
              {% elseif credential.expiryStatus|default('none') == 'expiring_soon' %}
                {% set mode = 'expiring_soon' %}
              {% else %}
                {% set mode = 'active' %}
              {% endif %}
            {% endif %}

            {% set modeLabel = mode == 'paused' ? 'Paused' : (mode == 'revoked' ? 'Revoked' : (mode == 'expired' ? 'Expired' : (mode == 'expiring_soon' ? 'Expiring soon' : 'Active'))) %}
            {% set isActiveState = mode in ['active', 'expiring_soon'] %}
            {% set cardStateClass = isActiveState ? 'is-active' : 'is-inactive' %}
            {% set detailsId = 'agent-details-' ~ credential.id %}
            {% set webhookResourceTypes = credential.webhookSubscriptions.resourceTypes ?? [] %}
            {% set webhookActions = credential.webhookSubscriptions.actions ?? [] %}
            {% set hasWebhookSubscriptions = webhookResourceTypes|length or webhookActions|length %}
            {% set expiryStatus = credential.expiryStatus ?? 'none' %}
            {% set expiresInDays = credential.expiresInDays ?? null %}
            {% set expiryReminderDays = credential.expiryReminderDays ?? 7 %}
            {% set ipAllowlist = credential.ipAllowlist ?? [] %}
            {% set hasWriteCapability = false %}
            {% for credentialScope in credential.scopes|default([]) %}
              {% set normalizedCredentialScope = credentialScope|lower %}
              {% if normalizedCredentialScope ends with ':write' or ':write:' in normalizedCredentialScope %}
                {% set hasWriteCapability = true %}
              {% endif %}
            {% endfor %}
            {% set agentDescription = credential.description ?: (descriptionByHandle[credential.handle] ?? 'Managed account for governed runtime operations.') %}
            {% set webhookMode = hasWebhookSubscriptions ? 'targeted' : 'disabled' %}
            {% set expirySummary = 'none' %}
            {% set canPauseAction = canPauseCredentials and not credential.revoked and mode not in ['expired', 'revoked'] %}
            {% set canRotateAction = canRotateCredentials %}
            {% set canRevokeAction = canRevokeCredentials and not credential.revoked %}
            {% set lifecycle = lifecycleByCredentialId[credential.id]|default(null) %}
            {% set lifecycleRiskLevel = lifecycle and lifecycle.risk.level is defined ? (lifecycle.risk.level|lower) : 'ok' %}
            {% set lifecycleOwner = credential.ownerLabel|default(lifecycle.metadata.owner|default('unassigned')) %}
            {% set lifecycleUseCase = lifecycle.metadata.useCase|default(credential.displayName ?: credential.handle) %}
            {% set lifecycleEnvironment = lifecycle.metadata.environment|default('unknown') %}
            {% set normalizedCredentialHandle = credential.handle|default('')|trim|lower %}
            {% set testFeedbackId = 'agent-test-feedback-' ~ credential.id %}
            {% set workerEnvFeedbackId = 'agent-worker-env-feedback-' ~ credential.id %}
            {% set revealedCredentialMatches = revealedCredential and revealedCredential.token and (
              (revealedCredentialId and revealedCredentialId == credential.id)
              or (revealedCredentialHandleNormalized and revealedCredentialHandleNormalized == normalizedCredentialHandle)
            ) %}
            {% set approvalRecipientLabels = [] %}
            {% for approvalRecipient in credential.approvalRecipients|default([]) %}
              {% set approvalRecipientLabel = approvalRecipient.label|default('')|trim %}
              {% if approvalRecipientLabel %}
                {% set approvalRecipientLabels = approvalRecipientLabels|merge([approvalRecipientLabel]) %}
              {% endif %}
            {% endfor %}
            {% set credentialTargetSets = writesExperimentalEnabled ? (credential.targetSets|default([])) : [] %}
            {% set credentialTargetSetLabels = [] %}
            {% for targetSet in credentialTargetSets %}
              {% set targetSetLabel = targetSet.name|default(targetSet.handle|default(''))|trim %}
              {% if targetSetLabel %}
                {% set credentialTargetSetLabels = credentialTargetSetLabels|merge([targetSetLabel]) %}
              {% endif %}
            {% endfor %}
            {% set bootstrapTestMissingScopes = [] %}
            {% for bootstrapTestScope in ['auth:read', 'health:read', 'readiness:read'] %}
              {% if bootstrapTestScope not in credential.scopes|default([]) %}
                {% set bootstrapTestMissingScopes = bootstrapTestMissingScopes|merge([bootstrapTestScope]) %}
              {% endif %}
            {% endfor %}
            {% set attentionStatuses = [] %}
            {% if listFilter == 'attention' %}
              {% for factor in lifecycle.risk.factors|default([]) %}
                {% set factorId = (factor.id|default(''))|lower %}
                {% set factorLabel = '' %}
                {% if factorId in ['stale_usage', 'never_used'] %}
                  {% set factorLabel = 'Stale Status' %}
                {% elseif factorId == 'expired' %}
                  {% set factorLabel = 'Expired credential' %}
                {% elseif factorId == 'expiring_soon' %}
                  {% set factorLabel = 'Expiring soon' %}
                {% elseif factorId == 'rotation_overdue' %}
                  {% set factorLabel = 'Rotation overdue' %}
                {% elseif factorId == 'rotation_due' %}
                  {% set factorLabel = 'Rotation due' %}
                {% elseif factorId == 'no_expiry_policy' %}
                  {% set factorLabel = 'No expiry policy' %}
                {% elseif factorId == 'environment_mismatch' %}
                  {% set factorLabel = 'Environment mismatch' %}
                {% elseif factorId == 'revoked' %}
                  {% set factorLabel = 'Revoked' %}
                {% endif %}
                {% if factorLabel and factorLabel not in attentionStatuses %}
                  {% set attentionStatuses = attentionStatuses|merge([factorLabel]) %}
                {% endif %}
              {% endfor %}
              {% if lifecycleOwner == 'unassigned' and 'Owner missing' not in attentionStatuses %}
                {% set attentionStatuses = attentionStatuses|merge(['Owner missing']) %}
              {% endif %}
            {% endif %}
            {% if expiryStatus == 'expired' %}
              {% set expirySummary = 'expired' %}
            {% elseif expiryStatus == 'never' %}
              {% set expirySummary = 'never' %}
            {% elseif expiryStatus == 'expiring_soon' %}
              {% set expirySummary = (expiresInDays is not null) ? (expiresInDays ~ ' day(s) left') : 'expiring soon' %}
            {% elseif expiryStatus == 'active' and expiresInDays is not null %}
              {% set expirySummary = expiresInDays ~ ' day(s) left' %}
            {% endif %}
            {% set governedContentRefreshHelperEnabled = writesExperimentalEnabled and hasWriteCapability and ('control:approvals:request' in credential.scopes|default([])) %}
            {% set lastUsedShortDate = credential.lastUsedAt ? credential.lastUsedAt|date('y/m/d', timezone='UTC') : 'Never' %}
            {% if credential.lastUsedAt %}
              {% set lastUsedAgeSeconds = ('now'|date('U')) - (credential.lastUsedAt|date('U')) %}
              {% if lastUsedAgeSeconds < 86400 %}
                {% set lastUsedRelativeDate = 'Today' %}
                {% set lastUsedDisplay = lastUsedRelativeDate %}
              {% elseif lastUsedAgeSeconds < 172800 %}
                {% set lastUsedRelativeDate = 'Yesterday' %}
                {% set lastUsedDisplay = lastUsedRelativeDate %}
              {% else %}
                {% set lastUsedDaysAgo = (lastUsedAgeSeconds / 86400)|round(0, 'floor') %}
                {% if lastUsedDaysAgo <= 7 %}
                  {% set lastUsedRelativeDate = lastUsedDaysAgo ~ ' days ago' %}
                  {% set lastUsedDisplay = lastUsedRelativeDate %}
                {% else %}
                  {% set lastUsedRelativeDate = lastUsedShortDate %}
                  {% set lastUsedDisplay = lastUsedShortDate %}
                {% endif %}
              {% endif %}
            {% else %}
              {% set lastUsedRelativeDate = 'Never' %}
              {% set lastUsedDisplay = 'never' %}
            {% endif %}
            {% set credentialWorkerEnv = revealedCredentialMatches ? revealedCredentialWorkerEnv : '' %}
            {% set credentialWorkerEnvFilename = revealedCredentialMatches ? revealedCredentialEnvFilename : '' %}

            <article class="agents-agent-card agents-card-surface {{ cardStateClass }}{{ listFilter == 'attention' and attentionStatuses|length ? ' has-attention-header' : '' }}" data-agent-card data-agent-detail-item data-agent-view-mode="cards" data-agent-card-id="{{ credential.id }}" data-agent-card-handle="{{ credential.handle|default('')|trim|lower|e('html_attr') }}">
              {% if revealedCredentialMatches %}
                <div class="agents-agent-token-overlay" id="revealedCredentialOverlay" role="dialog" aria-modal="false" aria-labelledby="revealedCredentialOverlayTitle">
                  <button class="agents-agent-token-overlay-close" id="revealedCredentialOverlayClose" type="button" aria-label="Close API token overlay">×</button>
                  <div class="agents-agent-token-overlay-body">
                    <h2 class="agents-agent-token-overlay-title" id="revealedCredentialOverlayTitle">Connect Worker Now</h2>
                    <p class="agents-agent-token-overlay-lead">Use this one-time reveal to export worker config and then run the example worker.</p>
                    <p class="agents-agent-token-overlay-token" id="revealedCredentialTokenPreview">{{ revealedCredential.token }}</p>
                    <textarea id="revealedCredentialToken" readonly hidden>{{ revealedCredential.token }}</textarea>
                    <textarea id="revealedCredentialWorkerEnv" readonly hidden>{{ revealedCredentialWorkerEnv }}</textarea>
                    <ol class="agents-agent-token-overlay-steps">
                      <li>Download the worker <code>.env</code> file or copy the token.</li>
                      <li>Follow the first worker guide and run the worker.</li>
                    </ol>
                    <div class="agents-agent-token-overlay-actions">
                      <button class="btn small agents-card-btn agents-token-overlay-btn" id="copyRevealedCredentialBtn" type="button">Copy token</button>
                      <button
                        class="btn small agents-card-btn agents-token-overlay-btn"
                        id="downloadRevealedCredentialEnvBtn"
                        type="button"
                        data-filename="{{ revealedCredentialEnvFilename }}"
                      >Download .env</button>
                      <a class="btn small agents-card-btn agents-token-overlay-btn" href="{{ firstWorkerGuideUrl }}" target="_blank" rel="noopener">Open guide</a>
                    </div>
                    <p class="agents-agent-token-overlay-note">This token is only shown once. Download the worker config now if you need a ready-to-run bootstrap artifact.</p>
                    <p class="agents-agent-token-overlay-feedback" id="revealedCredentialFeedback" aria-live="polite"></p>
                  </div>
                </div>
              {% endif %}
              {% if listFilter == 'attention' and attentionStatuses|length %}
                <div class="agents-agent-card-attention-header">{{ attentionStatuses|join(' | ') }}</div>
              {% endif %}
              <div class="agents-agent-card-content">
                <div class="agents-agent-card-header agents-card-surface__header">
                  <div class="agents-agent-card-title-wrap">
                    <div class="agents-agent-card-title">{{ credential.displayName ?: credential.handle }}</div>
                  </div>
                  <div class="agents-agent-card-indicators">
                    {% if hasWriteCapability and false %}
                      {% set writeApprovalRequired = credential.forceHumanApproval ?? true %}
                      <span
                        class="agents-agent-card-write-icon {{ writeApprovalRequired ? 'is-locked' : 'is-unlocked' }}"
                        aria-label="{{ writeApprovalRequired ? 'Writing capability (human approval required)' : 'Writing capability (no human approval required)' }}"
                        title="{{ writeApprovalRequired ? 'Writing capability (human approval required)' : 'Writing capability (no human approval required)' }}"
                      >
                        {% if writeApprovalRequired %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-pencil-fill" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                            <path d="M12.854.146a.5.5 0 0 0-.707 0L10.5 1.793 14.207 5.5l1.647-1.646a.5.5 0 0 0 0-.708zm.646 6.061L9.793 2.5 3.293 9H3.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.5h.5a.5.5 0 0 1 .5.5v.207zm-7.468 7.468A.5.5 0 0 1 6 13.5V13h-.5a.5.5 0 0 1-.5-.5V12h-.5a.5.5 0 0 1-.5-.5V11h-.5a.5.5 0 0 1-.5-.5V10h-.5a.5.5 0 0 1-.175-.032l-.179.178a.5.5 0 0 0-.11.168l-2 5a.5.5 0 0 0 .65.65l5-2a.5.5 0 0 0 .168-.11z"/>
                          </svg>
                        {% else %}
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-unlock-fill" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                            <path fill-rule="evenodd" d="M12 0a4 4 0 0 1 4 4v2.5h-1V4a3 3 0 1 0-6 0v2h.5A2.5 2.5 0 0 1 12 8.5v5A2.5 2.5 0 0 1 9.5 16h-7A2.5 2.5 0 0 1 0 13.5v-5A2.5 2.5 0 0 1 2.5 6H8V4a4 4 0 0 1 4-4"/>
                          </svg>
                        {% endif %}
                      </span>
                    {% endif %}
                    {% if mode == 'paused' %}
                      <span class="status disabled" aria-label="State: {{ modeLabel }}" title="{{ modeLabel }}"></span>
                    {% else %}
                      <span class="agents-agent-card-dot" data-agent-status-dot data-agent-status-id="{{ credential.id }}" aria-label="State: {{ modeLabel }}" title="{{ modeLabel }}"></span>
                    {% endif %}
                    {% if canManageCredentials %}
                      <button
                        class="agents-agent-card-edit-trigger"
                        type="button"
                        aria-label="Edit account"
                        data-agent-edit
                        data-agent-id="{{ credential.id }}"
                        data-agent-handle="{{ credential.handle|e('html_attr') }}"
                        data-agent-display-name="{{ (credential.displayName ?: credential.handle)|e('html_attr') }}"
                        data-agent-description="{{ (credential.description ?? '')|e('html_attr') }}"
                        data-agent-scopes="{{ credential.scopes|json_encode|e('html_attr') }}"
                        data-agent-webhook-resource-types="{{ webhookResourceTypes|json_encode|e('html_attr') }}"
                        data-agent-webhook-actions="{{ webhookActions|json_encode|e('html_attr') }}"
                        data-agent-ttl-days="{{ expiryStatus == 'never' ? 0 : ((expiryStatus in ['active', 'expiring_soon'] and expiresInDays is not null) ? expiresInDays : '') }}"
                        data-agent-expiry-reminder-days="{{ expiryReminderDays }}"
                        data-agent-ip-allowlist="{{ ipAllowlist|join("\n")|e('html_attr') }}"
                        data-agent-owner-legacy="{{ (credential.ownerLegacy ?? credential.owner ?? '')|e('html_attr') }}"
                        data-agent-owner-user-id="{{ (credential.ownerUserId ?? '')|e('html_attr') }}"
                        data-agent-approval-recipient-user-ids="{{ (credential.approvalRecipientUserIds|default([]))|json_encode|e('html_attr') }}"
                        data-agent-force-human-approval="{{ (credential.forceHumanApproval ?? true) ? '1' : '0' }}"
                        data-agent-target-set-ids="{{ (credential.targetSetIds|default([]))|json_encode|e('html_attr') }}"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-gear-fill" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
                          <path d="M9.405 1.05c-.413-1.4-2.397-1.4-2.81 0l-.1.34a1.464 1.464 0 0 1-2.105.872l-.31-.17c-1.283-.698-2.686.705-1.987 1.987l.169.311c.446.82.023 1.841-.872 2.105l-.34.1c-1.4.413-1.4 2.397 0 2.81l.34.1a1.464 1.464 0 0 1 .872 2.105l-.17.31c-.698 1.283.705 2.686 1.987 1.987l.311-.169a1.464 1.464 0 0 1 2.105.872l.1.34c.413 1.4 2.397 1.4 2.81 0l.1-.34a1.464 1.464 0 0 1 2.105-.872l.31.17c1.283.698 2.686-.705 1.987-1.987l-.169-.311a1.464 1.464 0 0 1 .872-2.105l.34-.1c1.4-.413 1.4-2.397 0-2.81l-.34-.1a1.464 1.464 0 0 1-.872-2.105l.17-.31c.698-1.283-.705-2.686-1.987-1.987l-.311.169a1.464 1.464 0 0 1-2.105-.872zM8 10.93a2.929 2.929 0 1 1 0-5.86 2.929 2.929 0 0 1 0 5.858z"/>
                        </svg>
                      </button>
                    {% endif %}
                  </div>
                </div>

                <div class="agents-agent-card-body agents-card-surface__body">
                  <p class="agents-agent-card-description">{{ agentDescription }}</p>

                  <div class="agents-agent-card-details-panel">
                    <button class="agents-agent-card-details-toggle" type="button" data-agent-details-toggle data-target="{{ detailsId }}" aria-expanded="false">
                      <span>Details</span>
                      <span class="agents-details-chevron" aria-hidden="true"></span>
                    </button>

                    <div id="{{ detailsId }}" class="agents-agent-card-details" data-agent-details-panel hidden>
                      <div class="agents-agent-card-details-section">
                        <div class="agents-agent-card-detail-heading">Account</div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">ID:</span><span class="agents-agent-card-v">{{ credential.handle }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">prefix:</span><span class="agents-agent-card-v">{{ credential.tokenPrefix ?: 'n/a' }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">Last used:</span><span class="agents-agent-card-v">{{ lastUsedDisplay }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">ip:</span><span class="agents-agent-card-v">{{ credential.lastUsedIp ?: 'n/a' }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">method:</span><span class="agents-agent-card-v">{{ credential.lastAuthMethod ?: 'n/a' }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">rotated:</span><span class="agents-agent-card-v">{{ credential.rotatedAt ? credential.rotatedAt|date('Y-m-d, H:i:s', timezone='UTC') : 'never' }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">event routing:</span><span class="agents-agent-card-v">{{ webhookMode }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">expiry:</span><span class="agents-agent-card-v">{{ expirySummary }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">ip allowlist:</span><span class="agents-agent-card-v">{{ ipAllowlist|length ? ipAllowlist|join(', ') : 'none' }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">owner:</span><span class="agents-agent-card-v">{{ lifecycleOwner }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">approval recipients:</span><span class="agents-agent-card-v">{{ approvalRecipientLabels|length ? approvalRecipientLabels|join(', ') : 'global fallback' }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">target sets:</span><span class="agents-agent-card-v">{{ credentialTargetSetLabels|length ? credentialTargetSetLabels|join(', ') : 'none' }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">use case:</span><span class="agents-agent-card-v">{{ lifecycleUseCase }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">environment:</span><span class="agents-agent-card-v">{{ lifecycleEnvironment }}</span></div>
                        <div class="agents-agent-card-kv"><span class="agents-agent-card-k">lifecycle risk:</span><span class="agents-agent-card-v">{{ lifecycleRiskLevel|upper }}</span></div>
                      </div>
                      <div class="agents-agent-card-details-section agents-agent-card-details-section--actions">
                        <div class="agents-agent-card-detail-heading">Connect Worker</div>
                        <p class="agents-agent-card-detail-note">Create or rotate the account to reveal a one-time worker <code>.env</code> export. Use <strong>Test Account</strong> here to validate account state and safe read surfaces.</p>
                        {% if bootstrapTestMissingScopes|length %}
                        <p class="agents-agent-card-detail-note agents-agent-card-detail-note--warning">Missing bootstrap scopes: {{ bootstrapTestMissingScopes|join(', ') }}.</p>
                        {% endif %}
                        {% if credentialWorkerEnv %}
                          <textarea class="agents-worker-env-source" readonly hidden>{{ credentialWorkerEnv }}</textarea>
                          <pre class="agents-worker-env-preview"><code>{{ credentialWorkerEnv }}</code></pre>
                        {% endif %}
                        <div class="agents-agent-card-detail-actions">
                          {% if credentialWorkerEnv %}
                            <button class="btn formsubmit agents-card-btn" type="button" data-agent-copy-worker-env data-feedback-target="{{ workerEnvFeedbackId }}">Copy .env</button>
                            <button class="btn formsubmit agents-card-btn" type="button" data-agent-download-worker-env data-worker-env-filename="{{ credentialWorkerEnvFilename }}" data-feedback-target="{{ workerEnvFeedbackId }}">Download .env</button>
                          {% endif %}
                          <form method="post" accept-charset="UTF-8" data-agent-test-form data-feedback-target="{{ testFeedbackId }}">
                            {{ csrfInput() }}
                            {{ actionInput('agents/dashboard/test-credential') }}
                            {{ redirectInput('agents/accounts?focusCardId=' ~ credential.id) }}
                            <input type="hidden" name="credentialId" value="{{ credential.id }}">
                            <button class="btn formsubmit agents-card-btn" type="submit" data-agent-test-submit data-label-idle="Test Account" data-label-busy="Testing...">Test Account</button>
                          </form>
                        </div>
                        {% if credentialWorkerEnv %}
                          <p class="agents-agent-card-detail-feedback agents-worker-env-feedback" id="{{ workerEnvFeedbackId }}" aria-live="polite"></p>
                        {% endif %}
                    <p class="agents-agent-card-detail-feedback" id="{{ testFeedbackId }}" aria-live="polite"></p>
                  </div>
                  {% if governedContentRefreshHelperEnabled %}
                    <div class="agents-agent-card-details-section">
                      <div class="agents-agent-card-detail-heading">Governed content refresh</div>
                      <p class="agents-agent-card-detail-note">Use this account for a scheduled worker that reads entry metadata, prepares a draft proposal, and submits a governed approval request with the full draft payload.</p>
                      <div class="agents-agent-card-detail-actions">
                        <a class="btn formsubmit agents-card-btn" href="{{ governedContentRefreshWorkflowUrl }}" target="_blank" rel="noopener">Open workflow</a>
                        <a class="btn formsubmit agents-card-btn" href="{{ allowCpApprovalRequests ? (cpUrl('agents/approvals') ~ '#manualApprovalRequestSection') : cpUrl('agents/approvals') }}">{{ allowCpApprovalRequests ? 'Create request in Approvals' : 'Open Approvals' }}</a>
                      </div>
                    </div>
                  {% endif %}
                  {% if credentialTargetSets|length %}
                    <div class="agents-agent-card-details-section">
                      <div class="agents-agent-card-detail-heading">Governed write helpers</div>
                          <p class="agents-agent-card-detail-note">Use these bounded request examples when you need a safe governed draft-update payload for this account.</p>
                          {% for targetSet in credentialTargetSets %}
                            {% set helperEntryId = targetSet.allowedEntryIds|default([])|first ?: 0 %}
                            {% set helperSiteId = targetSet.allowedSiteIds|default([])|first ?: 0 %}
                            {% set helperEntryLabels = [] %}
                            {% for allowedEntry in targetSet.allowedEntries|default([]) %}
                              {% set helperEntryLabel = allowedEntry.label|default('')|trim %}
                              {% if helperEntryLabel %}
                                {% set helperEntryLabels = helperEntryLabels|merge([helperEntryLabel]) %}
                              {% endif %}
                            {% endfor %}
                            {% set helperSiteLabels = [] %}
                            {% for allowedSite in targetSet.allowedSites|default([]) %}
                              {% set helperSiteLabel = allowedSite.label|default('')|trim %}
                              {% if helperSiteLabel %}
                                {% set helperSiteLabels = helperSiteLabels|merge([helperSiteLabel]) %}
                              {% endif %}
                            {% endfor %}
                            <div class="agents-target-set-helper">
                              <div class="agents-target-set-helper__title">{{ targetSet.name ?: targetSet.handle }}</div>
                              {% if targetSet.description %}
                                <p class="agents-agent-card-detail-note">{{ targetSet.description }}</p>
                              {% endif %}
                              <div class="agents-agent-card-kv"><span class="agents-agent-card-k">entries:</span><span class="agents-agent-card-v">{{ helperEntryLabels|length ? helperEntryLabels|join(', ') : 'none' }}</span></div>
                              <div class="agents-agent-card-kv"><span class="agents-agent-card-k">sites:</span><span class="agents-agent-card-v">{{ helperSiteLabels|length ? helperSiteLabels|join(', ') : 'none' }}</span></div>
                              <pre class="agents-target-set-helper__code"><code>{
  "actionType": "entry.updateDraft",
  "actionRef": "ENTRY-OPS-{{ helperEntryId ?: 'TARGET' }}",
  "reason": "Prepare draft update for editorial review",
  "metadata": {
    "source": "agent-runtime",
    "agentId": "{{ credential.handle }}",
    "traceId": "trace-entry-{{ helperEntryId ?: 'target' }}"
  },
  "payload": {
    "entryId": {{ helperEntryId }},
    "siteId": {{ helperSiteId }}
  }
}</code></pre>
                            </div>
                          {% endfor %}
                        </div>
                      {% endif %}
                    </div>
                  </div>

                </div>
              </div>

            </article>
          {% endfor %}
          </div>
        </div>
      {% else %}
        {% if listFilter != '' %}
          <p>No accounts match this filter. <a href="{{ clearFilterUrl }}">Show all</a></p>
        {% else %}
          <p>No managed accounts yet.</p>
        {% endif %}
      {% endif %}
    </section>

    </div>

    {% if canManageCredentials %}
      <div class="agents-page-shell agents-create-form-shell" id="createAgentFormHome" hidden>
        <div id="createAgentFormWrap" hidden>
          <p class="agents-subtle agents-add-section-note" id="addAgentEditStateNote" hidden>Edit mode is active. Form is shown inline under the selected card.</p>
          <div class="agents-create-agent-frame">
            <form method="post" accept-charset="UTF-8" id="agentCreateEditForm">
              {{ csrfInput() }}
              <input type="hidden" name="action" id="agentFormAction" value="agents/dashboard/create-credential">
              {{ redirectInput(credentialsRedirectUrl) }}
              <input type="hidden" name="credentialId" id="credentialId" value="">

              <h3 class="h4" id="agentFormModeHeading" style="margin: 0 0 6px;">Create an Account</h3>
              <p class="agents-subtle" id="agentFormModeHint" style="margin: 0 0 12px;">Create a new managed account and generate its API key.</p>

              {{ forms.textField({
                label: 'Display name',
                instructions: 'Human-friendly label.',
                id: 'credentialDisplayName',
                name: 'credentialDisplayName',
                placeholder: 'Operations Integration',
              }) }}

              {{ forms.textField({
                label: 'Short description',
                instructions: 'Short operator-facing note shown on the account card.',
                id: 'credentialDescription',
                name: 'credentialDescription',
                maxlength: 255,
                placeholder: 'What this account is for in one sentence.',
              }) }}

              {{ forms.textField({
                label: 'Account ID',
                instructions: 'Stable identifier used in logs/capabilities (letters, digits, :, _, -, .).',
                id: 'credentialHandle',
                name: 'credentialHandle',
                required: true,
                placeholder: 'operations-integration',
              }) }}

              {{ hiddenInput('credentialOwnerLegacyValue', defaultCredentialOwner ?? '', {
                id: 'credentialOwnerLegacyValue',
              }) }}

              <div id="credentialOwnerLegacyNoteWrap" hidden>
                <p class="agents-subtle agents-owner-legacy-note" id="credentialOwnerLegacyNote"></p>
              </div>

              {{ forms.elementSelectField({
                label: 'Owner',
                instructions: 'Responsible CP user for this account. Existing unresolved legacy owner values are preserved until you explicitly map them.',
                id: 'credentialOwnerUserId',
                name: 'credentialOwnerUserId',
                elementType: 'craft\\elements\\User',
                selectionLabel: 'Select owner'|t('app'),
                elements: defaultCredentialOwnerUserElements,
                single: true,
                viewMode: 'list-inline',
                sources: ['*'],
                criteria: {
                  status: ['active'],
                },
              }) }}

              <div id="credentialForceHumanApprovalWrap" style="display:none;">
                {{ forms.lightswitchField({
                  label: 'Always require human approval',
                  instructions: 'When enabled, this account cannot execute governed actions directly and must go through human approval.',
                  id: 'credentialForceHumanApproval',
                  name: 'credentialForceHumanApproval',
                  on: true,
                }) }}
              </div>

              <div id="credentialApprovalRecipientsWrap" style="display:none;">
                {{ forms.elementSelectField({
                  label: 'Approval recipients',
                  instructions: 'Optional. When selected, approval-related notifications for this account go to these users. Leave empty to fall back to the global operator notification recipients.',
                  id: 'credentialApprovalRecipientUserIds',
                  name: 'credentialApprovalRecipientUserIds',
                  elementType: 'craft\\elements\\User',
                  selectionLabel: 'Select recipients'|t('app'),
                  elements: [],
                  limit: null,
                  viewMode: 'list-inline',
                  sources: ['*'],
                  criteria: {
                    status: ['active'],
                  },
                }) }}
              </div>

              <div id="credentialTargetSetsWrap" style="display:none;">
                <div class="field">
                  <div class="heading">
                    <label id="credentialTargetSetsLabel">Target sets</label>
                  </div>
                  <div class="instructions">
                    <p>Optional. Constrain governed entry draft requests to the selected reusable target boundaries. <a href="{{ targetSetsUrl }}">Manage target sets</a>.</p>
                  </div>
                  {% if targetSets|length %}
                    <div class="agents-inline-checkboxes agents-inline-checkboxes--stacked" id="credentialTargetSetsField">
                      {% for targetSet in targetSets %}
                        <label class="agents-target-set-checkbox">
                          <input type="checkbox" name="credentialTargetSetIds[]" value="{{ targetSet.id }}">
                          <span class="agents-target-set-checkbox__copy">
                            <span class="agents-target-set-checkbox__title">{{ targetSet.name ?: targetSet.handle }}</span>
                            <span class="agents-target-set-checkbox__meta">{{ targetSet.allowedEntryIds|length }} entries · {{ targetSet.allowedSiteIds|length }} sites</span>
                          </span>
                        </label>
                      {% endfor %}
                    </div>
                  {% else %}
                    <p class="agents-subtle">No target sets yet. <a href="{{ targetSetsUrl }}">Create one in Target Sets</a>, then assign it to write-capable accounts here.</p>
                  {% endif %}
                </div>
              </div>

              <hr>

              <div class="field">
                <div class="heading">
                  <label id="credentialCapabilitiesLabel">Scopes</label>
                </div>
                <div class="instructions">
                  <p>Click to add/remove scopes for this key. <a href="{{ scopeGuideUrl }}" target="_blank" rel="noopener">Scope Guide &rarr;</a></p>
                </div>
                <div class="agents-capability-scope-picker" id="credentialCapabilitiesPills">
                  <div class="agents-capability-pills">
                    {% for scopeGroupKey in scopeGroupOrder %}
                      {% set scopeGroup = scopeGroups[scopeGroupKey] ?? null %}
                        {% if scopeGroup and scopeGroup.items|length %}
                          <div class="agents-capability-group">
                            <div class="agents-capability-group-title">{{ scopeGroup.label }}</div>
                            <div class="agents-capability-group-hint">{{ scopeGroup.hint }}</div>
                            <div class="agents-capability-group-pills">
                              {% for scope in scopeGroup.items %}
                                <label class="agents-capability-pill">
                                <input type="checkbox" name="credentialScopes[]" value="{{ scope }}">
                                <span class="agents-capability-pill-text">{{ scope }}</span>
                              </label>
                            {% endfor %}
                          </div>
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>

                  {% if externalResourceProviders|length %}
                    <div class="agents-external-capability-section">
                      <div class="agents-external-capability-section__title">External plugin scopes</div>
                      <div class="agents-external-capability-section__hint">Optional. These stay unchecked by default and appear only when another plugin registers an external resource provider.</div>
                      <div class="agents-external-capability-groups">
                        {% for provider in externalResourceProviders %}
                          {% if provider.resources|default([])|length %}
                            <section class="agents-external-capability-group">
                              <div class="agents-external-capability-group__title">{{ provider.name }}</div>
                              {% if provider.description %}
                                <div class="agents-external-capability-group__hint">{{ provider.description }}</div>
                              {% endif %}
                              <div class="agents-external-capability-group__resources">
                                {% for resource in provider.resources %}
                                  <label class="agents-external-capability-resource">
                                    <input type="checkbox" name="credentialScopes[]" value="{{ resource.scope }}">
                                    <span class="agents-external-capability-resource__copy">
                                      <span class="agents-external-capability-resource__title">{{ resource.name }}</span>
                                      <span class="agents-external-capability-resource__description">{{ resource.description ?: 'Read through the generic external-resource API surface.' }}</span>
                                      <span class="agents-external-capability-resource__meta">{{ resource.scope }}</span>
                                    </span>
                                  </label>
                                {% endfor %}
                              </div>
                            </section>
                          {% endif %}
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}
                </div>
              </div>

              <div class="field">
                <div class="heading">
                  <label>Event resource interests</label>
                </div>
                <div class="instructions">
                  <p>Optional. When targeted webhook routing is active, only matching resource events are sent for this account. Leave empty to keep this account out of targeted routing.</p>
                </div>
                <div class="agents-inline-checkboxes">
                  <label><input type="checkbox" name="credentialWebhookResourceTypes[]" value="entry"> entry</label>
                  <label><input type="checkbox" name="credentialWebhookResourceTypes[]" value="order"> order</label>
                  <label><input type="checkbox" name="credentialWebhookResourceTypes[]" value="product"> product</label>
                </div>
              </div>

              <div class="field">
                <div class="heading">
                  <label>Event action interests</label>
                </div>
                <div class="instructions">
                  <p>Optional. Leave empty to match all actions for the selected resource interests.</p>
                </div>
                <div class="agents-inline-checkboxes">
                  <label><input type="checkbox" name="credentialWebhookActions[]" value="created"> created</label>
                  <label><input type="checkbox" name="credentialWebhookActions[]" value="updated"> updated</label>
                  <label><input type="checkbox" name="credentialWebhookActions[]" value="deleted"> deleted</label>
                </div>
              </div>

              <hr>

              {{ forms.textField({
                label: 'Credential TTL (days)',
                instructions: 'Optional. Set `0` for explicit never-expire policy (excluded from no-expiry warnings). Leave blank to keep policy unset.',
                id: 'credentialTtlDays',
                name: 'credentialTtlDays',
                placeholder: '30',
              }) }}

              {{ forms.textField({
                label: 'Expiry reminder window (days)',
                instructions: 'Used for CP “expiring soon” warnings. Default is 7 when blank.',
                id: 'credentialExpiryReminderDays',
                name: 'credentialExpiryReminderDays',
                placeholder: '7',
              }) }}

              {{ forms.textareaField({
                label: 'IP allowlist (CIDR)',
                instructions: 'Optional. One CIDR or IP per line. Example: 203.0.113.0/24',
                id: 'credentialIpAllowlist',
                name: 'credentialIpAllowlist',
                rows: 3,
                placeholder: '203.0.113.0/24\\n198.51.100.20',
              }) }}

              <hr>

              <div class="agents-create-id-row" id="agentTokenRow">
                <div class="agents-create-id-field">
                  {{ forms.textField({
                    label: 'API-Key',
                    instructions: 'Optional. Use Generate Key or edit manually. Generated keys use <account-id>-<18 random chars>.',
                    id: 'credentialToken',
                    name: 'credentialToken',
                    placeholder: 'account-a1B2c3D4e5F6g7H8i9',
                  }) }}
                </div>
                <div class="agents-create-id-action">
                  <button class="btn" type="button" id="generateAgentTokenBtn">Generate Key</button>
                </div>
              </div>
              <div class="agents-token-rotation-note" id="agentTokenRotationNote" hidden>
                <p><strong>API keys are managed via rotation.</strong> Use the card’s <code>Rotate</code> action regularly and after any suspected exposure.</p>
              </div>

              <div class="agents-form-actions">
                <button class="btn submit" type="submit" id="agentFormSubmitBtn">Create Account</button>
                <button class="btn" type="button" id="agentFormCancelEditBtn" hidden>Cancel Edit</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    {% endif %}

    {% if suggestedAgentTemplates|length or secondaryAgentTemplates|length %}
      <hr class="agents-add-section-divider agents-section-break">
      <div class="agents-page-shell">
        {% if suggestedAgentTemplates|length %}
          <section class="border rounded p-3 agents-account-templates-section" id="accountTemplatesSection">
            <div class="agents-create-header">
              <h2 class="h4">Account Templates</h2>
            </div>
            <p class="agents-subtle agents-account-templates-note">Start from a reusable account profile built for common agency workflows. Adjust scopes only when the default access is not enough.</p>

            <div class="agents-account-templates-grid">
              {% for template in suggestedAgentTemplates %}
                {% set templateHandle = template.id|default('')|trim %}
                {% set templateDisplayName = template.displayName|default(templateHandle) %}
                {% set templateDescription = template.description|default('Suggested account profile.') %}
                {% set templateScopes = [] %}
                {% for templateScope in template.scopes|default('')|split(' ') %}
                  {% set normalizedTemplateScope = templateScope|trim %}
                  {% if normalizedTemplateScope %}
                    {% set templateScopes = templateScopes|merge([normalizedTemplateScope]) %}
                  {% endif %}
                {% endfor %}

                <article class="agents-account-template-card">
                  <div class="agents-account-template-copy">
                    <div class="agents-account-template-title">{{ templateDisplayName }}</div>
                    <p class="agents-account-template-description">{{ templateDescription }}</p>
                  </div>
                  <div class="agents-account-template-actions">
                    {% if canManageCredentials %}
                      <button
                        class="btn formsubmit agents-card-btn"
                        type="button"
                        data-agent-create-from-template
                        data-agent-template-handle="{{ templateHandle|e('html_attr') }}"
                        data-agent-template-display-name="{{ templateDisplayName|e('html_attr') }}"
                        data-agent-template-description="{{ templateDescription|e('html_attr') }}"
                        data-agent-template-scopes="{{ templateScopes|join(' ')|e('html_attr') }}"
                      >Use this template</button>
                    {% else %}
                      <span class="light">Create permission required.</span>
                    {% endif %}
                  </div>
                </article>
              {% endfor %}
            </div>
          </section>
        {% endif %}

        {% if secondaryAgentTemplates|length %}
          <section class="border rounded p-3 agents-account-templates-section agents-account-templates-section--secondary" id="moreAccountTemplatesSection">
            <div class="agents-create-header">
              <h2 class="h4">More templates</h2>
            </div>
            <p class="agents-subtle agents-account-templates-note">More specialized account profiles for localization, accessibility, change monitoring, and launch work.</p>

            <div class="agents-account-templates-grid">
              {% for template in secondaryAgentTemplates %}
                {% set templateHandle = template.id|default('')|trim %}
                {% set templateDisplayName = template.displayName|default(templateHandle) %}
                {% set templateDescription = template.description|default('Suggested account profile.') %}
                {% set templateScopes = [] %}
                {% for templateScope in template.scopes|default('')|split(' ') %}
                  {% set normalizedTemplateScope = templateScope|trim %}
                  {% if normalizedTemplateScope %}
                    {% set templateScopes = templateScopes|merge([normalizedTemplateScope]) %}
                  {% endif %}
                {% endfor %}

                <article class="agents-account-template-card">
                  <div class="agents-account-template-copy">
                    <div class="agents-account-template-title">{{ templateDisplayName }}</div>
                    <p class="agents-account-template-description">{{ templateDescription }}</p>
                  </div>
                  <div class="agents-account-template-actions">
                    {% if canManageCredentials %}
                      <button
                        class="btn formsubmit agents-card-btn"
                        type="button"
                        data-agent-create-from-template
                        data-agent-template-handle="{{ templateHandle|e('html_attr') }}"
                        data-agent-template-display-name="{{ templateDisplayName|e('html_attr') }}"
                        data-agent-template-description="{{ templateDescription|e('html_attr') }}"
                        data-agent-template-scopes="{{ templateScopes|join(' ')|e('html_attr') }}"
                      >Use this template</button>
                    {% else %}
                      <span class="light">Create permission required.</span>
                    {% endif %}
                  </div>
                </article>
              {% endfor %}
            </div>
          </section>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% if canManageCredentials %}
    {% js %}
      (() => {
        const agentForm = document.getElementById('agentCreateEditForm');
        const handleInput = document.getElementById('credentialHandle');
        const displayNameInput = document.getElementById('credentialDisplayName');
        const descriptionInput = document.getElementById('credentialDescription');
        const tokenInput = document.getElementById('credentialToken');
        const scopeField = document.getElementById('credentialCapabilitiesPills');
        const cardList = document.getElementById('agentsCardList');
        const cardCancelEditButtons = cardList
          ? Array.from(cardList.querySelectorAll('[data-agent-cancel-edit]'))
          : [];
        const templateCreateButtons = Array.from(document.querySelectorAll('[data-agent-create-from-template]'));
        const createToggle = document.getElementById('toggleCreateAgentForm');
        const createFormWrap = document.getElementById('createAgentFormWrap');
        const createFormHome = document.getElementById('createAgentFormHome');
        const formFrame = createFormWrap ? createFormWrap.querySelector('.agents-create-agent-frame') : null;
        const addAgentEditStateNote = document.getElementById('addAgentEditStateNote');
        const generateTokenBtn = document.getElementById('generateAgentTokenBtn');
        const tokenRow = document.getElementById('agentTokenRow');
        const tokenRotationNote = document.getElementById('agentTokenRotationNote');
        const formActionInput = document.getElementById('agentFormAction');
        const credentialIdInput = document.getElementById('credentialId');
        const formModeHeading = document.getElementById('agentFormModeHeading');
        const formModeHint = document.getElementById('agentFormModeHint');
        const submitBtn = document.getElementById('agentFormSubmitBtn');
        const cancelEditBtn = document.getElementById('agentFormCancelEditBtn');
        const ownerLegacyInput = document.getElementById('credentialOwnerLegacyValue');
        const ownerLegacyNoteWrap = document.getElementById('credentialOwnerLegacyNoteWrap');
        const ownerLegacyNote = document.getElementById('credentialOwnerLegacyNote');
        const ownerUserField = document.getElementById('credentialOwnerUserId');
        const approvalRecipientsField = document.getElementById('credentialApprovalRecipientUserIds');
        const credentialTargetSetsWrap = document.getElementById('credentialTargetSetsWrap');
        const forceHumanApprovalWrap = document.getElementById('credentialForceHumanApprovalWrap');
        const forceHumanApprovalSwitch = forceHumanApprovalWrap
          ? forceHumanApprovalWrap.querySelector('button.lightswitch')
          : null;
        const forceHumanApprovalHiddenInput = forceHumanApprovalWrap
          ? forceHumanApprovalWrap.querySelector('input[type="hidden"][name="credentialForceHumanApproval"]')
          : null;
        const approvalRecipientsWrap = document.getElementById('credentialApprovalRecipientsWrap');
        const ttlDaysInput = document.getElementById('credentialTtlDays');
        const expiryReminderDaysInput = document.getElementById('credentialExpiryReminderDays');
        const ipAllowlistInput = document.getElementById('credentialIpAllowlist');
        const defaultOwnerValue = {{ (defaultCredentialOwner ?? '')|json_encode|raw }};
        const defaultOwnerUserId = {{ (defaultCredentialOwnerUserId ?? null)|json_encode|raw }};
        const userElementType = 'craft\\elements\\User';
        const webhookResourceCheckboxes = agentForm
          ? Array.from(agentForm.querySelectorAll('input[name="credentialWebhookResourceTypes[]"]'))
          : [];
        const webhookActionCheckboxes = agentForm
          ? Array.from(agentForm.querySelectorAll('input[name="credentialWebhookActions[]"]'))
          : [];
        const credentialTargetSetCheckboxes = agentForm
          ? Array.from(agentForm.querySelectorAll('input[name="credentialTargetSetIds[]"]'))
          : [];
        const ownerUserSelect = () => getElementSelectInput(ownerUserField);
        const approvalRecipientsSelect = () => getElementSelectInput(approvalRecipientsField);
        let lastAutoGeneratedToken = '';
        let tokenTouchedManually = false;
        let handleTouchedManually = false;
        let formMode = 'create';
        let inlineEditHost = null;
        let activeEditCardId = null;
        let formStateBaseline = '';
        let isSubmittingForm = false;
        let ownerLegacyFallbackValue = `${defaultOwnerValue || ''}`;

        const secureRandomString = (length) => {
          const chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
          const charsLength = chars.length;
          if (length <= 0) {
            return '';
          }

          if (window.crypto && typeof window.crypto.getRandomValues === 'function') {
            const bytes = new Uint8Array(length);
            window.crypto.getRandomValues(bytes);
            let out = '';
            bytes.forEach((byte) => {
              out += chars[byte % charsLength];
            });
            return out;
          }

          let fallback = '';
          for (let i = 0; i < length; i++) {
            fallback += chars[Math.floor(Math.random() * charsLength)];
          }
          return fallback;
        };

        const toKebabCase = (value, maxLength = 64) => {
          const normalize = (input) => {
            return (input || '')
              .toString()
              .toLowerCase()
              .replace(/[_\s]+/g, '-')
              .replace(/[^a-z0-9-]+/g, '-')
              .replace(/-+/g, '-')
              .replace(/^-+|-+$/g, '')
              .slice(0, maxLength);
          };

          const source = (value || '').toString();
          if (window.Craft) {
            try {
              if (Craft.StringHelper && typeof Craft.StringHelper.toKebabCase === 'function') {
                return normalize(Craft.StringHelper.toKebabCase(source));
              }
              if (Craft.StringHelper && typeof Craft.StringHelper.toHandle === 'function') {
                return normalize(Craft.StringHelper.toHandle(source));
              }
              if (typeof Craft.toHandle === 'function') {
                return normalize(Craft.toHandle(source));
              }
            } catch (error) {
              // Fallback below.
            }
          }

          return normalize(source);
        };

        const generateTokenValue = (agentIdValue = '') => {
          const prefix = toKebabCase(agentIdValue, 64) || 'account';
          const randomLength = 18;
          return `${prefix}-${secureRandomString(randomLength)}`;
        };

        const asArray = (value) => {
          if (Array.isArray(value)) {
            return value.map((item) => `${item}`);
          }
          if (typeof value === 'string' && value.trim() !== '') {
            return value.split(/[\s,]+/).filter(Boolean);
          }
          return [];
        };

        const asBool = (value, fallback = false) => {
          if (typeof value === 'boolean') {
            return value;
          }
          if (typeof value === 'number') {
            return value !== 0;
          }
          if (typeof value === 'string') {
            const normalized = value.trim().toLowerCase();
            if (['1', 'true', 'yes', 'on'].includes(normalized)) {
              return true;
            }
            if (['0', 'false', 'no', 'off', ''].includes(normalized)) {
              return false;
            }
          }
          return fallback;
        };

        const isForceHumanApprovalOn = () => {
          if (!forceHumanApprovalSwitch) {
            return asBool(forceHumanApprovalHiddenInput ? forceHumanApprovalHiddenInput.value : '', false);
          }
          return forceHumanApprovalSwitch.classList.contains('on');
        };

        const setForceHumanApprovalState = (isOn) => {
          if (!forceHumanApprovalSwitch) {
            if (forceHumanApprovalHiddenInput) {
              forceHumanApprovalHiddenInput.value = isOn ? '1' : '';
            }
            return;
          }

          const normalized = !!isOn;
          forceHumanApprovalSwitch.classList.toggle('on', normalized);
          forceHumanApprovalSwitch.classList.remove('indeterminate');
          forceHumanApprovalSwitch.setAttribute('aria-checked', normalized ? 'true' : 'false');
          if (forceHumanApprovalHiddenInput) {
            forceHumanApprovalHiddenInput.value = normalized ? '1' : '';
          }
        };

        const toggleForceHumanApprovalState = () => {
          setForceHumanApprovalState(!isForceHumanApprovalOn());
        };

        const setCheckboxValues = (checkboxes, values) => {
          const selected = new Set(asArray(values));
          checkboxes.forEach((checkbox) => {
            checkbox.checked = selected.has(checkbox.value);
          });
        };

        const getElementSelectInput = (fieldElement) => {
          if (!fieldElement || !window.jQuery) {
            return null;
          }
          return window.jQuery(fieldElement).data('elementSelect') || null;
        };

        const getSelectedElementIds = (elementSelectInput) => {
          if (!elementSelectInput || typeof elementSelectInput.getElements !== 'function') {
            return [];
          }

          const selected = [];
          const elements = elementSelectInput.getElements();
          elements.each((index, element) => {
            const rawId = window.jQuery(element).data('id');
            const id = Number.parseInt(`${rawId || ''}`, 10);
            if (Number.isInteger(id) && id > 0 && !selected.includes(id)) {
              selected.push(id);
            }
          });
          return selected;
        };

        const clearElementSelectInput = (elementSelectInput) => {
          if (!elementSelectInput || typeof elementSelectInput.getElements !== 'function' || typeof elementSelectInput.removeElements !== 'function') {
            return;
          }

          const currentElements = elementSelectInput.getElements();
          if (currentElements && currentElements.length) {
            elementSelectInput.removeElements(currentElements);
          }
        };

        const fetchElementInfos = async (elementType, ids) => {
          const normalizedIds = asArray(ids)
            .map((value) => Number.parseInt(`${value || ''}`, 10))
            .filter((value, index, array) => Number.isInteger(value) && value > 0 && array.indexOf(value) === index);
          if (!normalizedIds.length || !window.Craft || typeof Craft.sendActionRequest !== 'function') {
            return [];
          }

          const response = await Craft.sendActionRequest('POST', 'app/render-elements', {
            data: {
              elements: normalizedIds.map((id) => ({
                type: elementType,
                id,
                siteId: (window.Craft && typeof Craft.siteId !== 'undefined') ? Craft.siteId : null,
                instances: [{
                  context: 'field',
                  ui: 'chip',
                  size: 'small',
                  showActionMenu: true,
                }],
              })),
            },
          });

          const payload = response && response.data ? response.data : {};
          const infos = [];
          normalizedIds.forEach((id) => {
            const rendered = payload.elements && payload.elements[id] ? payload.elements[id][0] : null;
            if (!rendered || !window.Craft || typeof Craft.getElementInfo !== 'function') {
              return;
            }
            infos.push(Craft.getElementInfo(rendered));
          });

          if (payload.headHtml) {
            await Craft.appendHeadHtml(payload.headHtml);
          }
          if (payload.bodyHtml) {
            await Craft.appendBodyHtml(payload.bodyHtml);
          }

          return infos;
        };

        const setElementSelectIds = async (elementSelectInput, ids, elementType = userElementType) => {
          if (!elementSelectInput || typeof elementSelectInput.selectElements !== 'function') {
            return;
          }

          const currentIds = getSelectedElementIds(elementSelectInput);
          const normalizedIds = asArray(ids)
            .map((value) => Number.parseInt(`${value || ''}`, 10))
            .filter((value, index, array) => Number.isInteger(value) && value > 0 && array.indexOf(value) === index)
            .sort((a, b) => a - b);
          const sameSelection = currentIds.length === normalizedIds.length
            && currentIds
              .slice()
              .sort((a, b) => a - b)
              .every((value, index) => value === normalizedIds[index]);
          if (sameSelection) {
            return;
          }

          clearElementSelectInput(elementSelectInput);
          const infos = await fetchElementInfos(elementType, normalizedIds);
          if (infos.length) {
            await elementSelectInput.selectElements(infos);
          }
        };

        const syncOwnerLegacyNote = () => {
          const selectedOwnerIds = getSelectedElementIds(ownerUserSelect());
          const hasOwnerSelection = selectedOwnerIds.length > 0;

          if (ownerLegacyInput) {
            ownerLegacyInput.value = hasOwnerSelection ? '' : `${ownerLegacyFallbackValue || ''}`;
          }

          if (!ownerLegacyNoteWrap || !ownerLegacyNote) {
            return;
          }

          if (!hasOwnerSelection && ownerLegacyFallbackValue) {
            ownerLegacyNote.textContent = `Legacy owner preserved: ${ownerLegacyFallbackValue}`;
            ownerLegacyNoteWrap.removeAttribute('hidden');
          } else {
            ownerLegacyNote.textContent = '';
            ownerLegacyNoteWrap.setAttribute('hidden', 'hidden');
          }
        };

        const isFormVisible = () => createFormWrap && !createFormWrap.hasAttribute('hidden');

        const trackedFormFields = () => {
          if (!agentForm) {
            return [];
          }
          const trackedHiddenNames = new Set([
            'credentialOwnerLegacyValue',
            'credentialOwnerUserId',
            'credentialApprovalRecipientUserIds',
          ]);
          return Array.from(agentForm.querySelectorAll('input[name^="credential"], textarea[name^="credential"], select[name^="credential"]'))
            .filter((field) => !field.disabled && (field.type !== 'hidden' || trackedHiddenNames.has(field.name)));
        };

        const serializeFormState = () => {
          return trackedFormFields()
            .map((field) => {
              if (field.type === 'checkbox' || field.type === 'radio') {
                return `${field.name}:${field.value}:${field.checked ? '1' : '0'}`;
              }
              return `${field.name}:${field.value || ''}`;
            })
            .sort()
            .join('|');
        };

        const captureFormBaseline = () => {
          formStateBaseline = serializeFormState();
          isSubmittingForm = false;
        };

        const hasUnsavedChanges = () => {
          if (!agentForm || !isFormVisible() || isSubmittingForm) {
            return false;
          }
          return serializeFormState() !== formStateBaseline;
        };

        const confirmDiscardFormChanges = () => {
          if (!hasUnsavedChanges()) {
            return true;
          }
          const fallback = 'You have unsaved changes. Are you sure you want to leave this page?';
          const message = (window.Craft && typeof Craft.t === 'function')
            ? Craft.t('app', fallback)
            : fallback;
          return window.confirm(message);
        };

        const autoPopulateTokenFromHandle = () => {
          if (formMode !== 'create' || !tokenInput || !handleInput) {
            return;
          }

          const currentValue = (tokenInput.value || '').trim();
          const shouldOverwrite = currentValue === ''
            || currentValue === lastAutoGeneratedToken
            || !tokenTouchedManually;

          if (!shouldOverwrite) {
            return;
          }

          const generated = generateTokenValue(handleInput.value || '');
          tokenInput.value = generated;
          lastAutoGeneratedToken = generated;
          tokenTouchedManually = false;
        };

        const setAddToggle = (label) => {
          if (!createToggle) {
            return;
          }
          createToggle.textContent = label;
        };

        const setAddSectionEditState = (active, mode = 'inline') => {
          if (createFormHome) {
            createFormHome.classList.toggle('is-editing-inline', active && mode === 'inline');
          }
          if (addAgentEditStateNote) {
            if (active) {
              addAgentEditStateNote.textContent = mode === 'inline'
                ? 'Edit mode is active. Form is shown inline under the selected card.'
                : 'Edit mode is active. Form is shown below.';
              addAgentEditStateNote.removeAttribute('hidden');
            } else {
              addAgentEditStateNote.textContent = 'Edit mode is active. Form is shown inline under the selected card.';
              addAgentEditStateNote.setAttribute('hidden', 'hidden');
            }
          }
        };

        const mountFormAtHome = () => {
          if (!createFormWrap || !createFormHome) {
            return;
          }
          if (createFormWrap.parentElement !== createFormHome) {
            createFormHome.appendChild(createFormWrap);
          }
        };

        const resolveCardById = (id) => {
          if (!cardList || !id) {
            return null;
          }
          return cardList.querySelector(`[data-agent-card-id="${id}"]`);
        };

        const resolveTableRowById = (id) => {
          return document.querySelector(`#agentsAccountsTableView tr[data-agent-detail-item][data-agent-card-id="${id}"]`);
        };

        const setOtherCardsDisabled = (activeCard, disabled) => {
          if (!cardList) {
            return;
          }
          const cards = Array.from(cardList.querySelectorAll('[data-agent-card]'));
          if (!disabled) {
            cardList.classList.remove('is-editing-active');
            cards.forEach((card) => {
              card.classList.remove('is-editing-target');
              card.classList.remove('is-editing-card');
              if (card === activeCard) {
                return;
              }
              card.querySelectorAll('button').forEach((button) => {
                if (button.dataset.prevDisabled === '1') {
                  button.disabled = true;
                } else {
                  button.disabled = false;
                }
                delete button.dataset.prevDisabled;
              });
            });
            return;
          }

          cardList.classList.add('is-editing-active');
          cards.forEach((card) => {
            const isTarget = card === activeCard;
            card.classList.toggle('is-editing-target', isTarget);
            card.classList.toggle('is-editing-card', isTarget);
            if (isTarget) {
              return;
            }
            card.querySelectorAll('button').forEach((button) => {
              button.dataset.prevDisabled = button.disabled ? '1' : '0';
              button.disabled = true;
            });
          });
        };

        const setOtherTableRowsDimmed = (activeRow, dimmed) => {
          const tableRegistryWrap = document.querySelector('#agentsAccountsTableView .agents-accounts-registry-wrap');
          if (!tableRegistryWrap) {
            return;
          }

          const rows = Array.from(tableRegistryWrap.querySelectorAll('tr[data-agent-detail-item][data-agent-view-mode="table"]'));
          if (!dimmed) {
            tableRegistryWrap.classList.remove('is-editing-active');
            rows.forEach((row) => {
              row.classList.remove('is-editing-target');
            });
            return;
          }

          tableRegistryWrap.classList.add('is-editing-active');
          rows.forEach((row) => {
            row.classList.toggle('is-editing-target', row === activeRow);
          });
        };

        const removeInlineEditHost = () => {
          const previousCard = resolveCardById(activeEditCardId);
          const previousTableRow = resolveTableRowById(activeEditCardId);
          setOtherCardsDisabled(previousCard, false);
          setOtherTableRowsDimmed(previousTableRow, false);
          activeEditCardId = null;
          setAddSectionEditState(false);

          if (inlineEditHost && inlineEditHost.parentElement) {
            inlineEditHost.parentElement.removeChild(inlineEditHost);
          }
          inlineEditHost = null;
          mountFormAtHome();
        };

        const mountInlineEditHost = (card) => {
          if (!cardList || !createFormWrap || !card) {
            return;
          }
          if (inlineEditHost && inlineEditHost.parentElement) {
            inlineEditHost.parentElement.removeChild(inlineEditHost);
          }

          const cards = Array.from(cardList.querySelectorAll('[data-agent-card]'));
          const rowCards = cards
            .filter((candidate) => Math.abs(candidate.offsetTop - card.offsetTop) <= 2)
            .sort((a, b) => a.offsetLeft - b.offsetLeft);
          const rowAnchorCard = rowCards.length ? rowCards[rowCards.length - 1] : card;

          inlineEditHost = document.createElement('div');
          inlineEditHost.className = 'agents-inline-edit-host';
