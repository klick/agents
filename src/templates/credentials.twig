      const revokeForms = Array.from(document.querySelectorAll('[data-agent-revoke-form]'));
      const focusQueryParams = new URLSearchParams(window.location.search || '');
      const requestedAccountView = (focusQueryParams.get('accountView') || '').trim().toLowerCase();
      const requestedFocusCardId = (focusQueryParams.get('focusCardId') || '').trim();
      const requestedFocusCardHandle = (focusQueryParams.get('focusCardHandle') || '').trim().toLowerCase();
      const requestFocusFirstVisible = ['1', 'true', 'yes', 'on'].includes((focusQueryParams.get('focusFirstVisible') || '').trim().toLowerCase());
      const accountViewStorageKey = 'agents.accounts.view';
      const validViews = new Set(['table', 'cards']);
      const detailModalBackdropId = 'agentsAccountDetailsModalBackdrop';
      const detailModalBodyOpenClass = 'agents-account-details-modal-open';
      let activeView = 'table';
      let activeDetailTrigger = null;

      const parseJsonArray = (value) => {
        if (typeof value !== 'string' || value.trim() === '') {
          return [];
        }

        try {
          const parsed = JSON.parse(value);
          if (Array.isArray(parsed)) {
            return parsed.map((item) => `${item}`);
          }
        } catch (error) {
          // Ignore parse issues and fall back to empty array.
        }

        return [];
      };

      const setFeedback = (target, message, tone = '') => {
        if (!target) {
          return;
        }

        target.textContent = message || '';
        target.classList.remove('is-pending', 'is-success', 'is-error');
        if (tone) {
          target.classList.add(tone);
        }
      };

      const showCpMessage = (message, tone = 'notice') => {
        if (!message) {
          return;
        }

        if (window.Craft && Craft.cp) {
          if (tone === 'error' && typeof Craft.cp.displayError === 'function') {
            Craft.cp.displayError(message);
            return;
          }

          if (typeof Craft.cp.displayNotice === 'function') {
            Craft.cp.displayNotice(message);
            return;
          }
        }

        if (tone === 'error') {
          window.console.error(message);
          return;
        }

        window.console.info(message);
      };

      const downloadWorkerEnvContent = (workerEnv, filename = 'agents-worker.env') => {
        if (!workerEnv) {
          return false;
        }

        const normalizedWorkerEnv = workerEnv.endsWith('\n') ? workerEnv : `${workerEnv}\n`;
        const blob = new Blob([normalizedWorkerEnv], { type: 'text/plain;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.appendChild(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
        return true;
      };

      const bindWorkerEnvDownloadButton = (button) => {
        if (!button || button.dataset.bound === '1') {
          return;
        }
        button.dataset.bound = '1';

        button.addEventListener('click', () => {
          const container = button.closest('.agents-agent-card-details-section, .agents-accounts-registry-details-wrap, .agents-agent-token-overlay')
            || button.parentElement
            || document;
          const workerEnvSource = container.querySelector('.agents-worker-env-source, #revealedCredentialWorkerEnv');
          const workerEnv = workerEnvSource ? (workerEnvSource.value || workerEnvSource.textContent || '') : '';
          const feedbackTarget = button.dataset.feedbackTarget
            ? document.getElementById(button.dataset.feedbackTarget)
            : null;
          if (!workerEnv) {
            if (feedbackTarget) {
              setFeedback(feedbackTarget, 'Create or rotate the account to reveal the worker .env first.', 'is-error');
            } else {
              showCpMessage('Create or rotate the account to reveal the worker .env first.', 'error');
            }
            return;
          }

          const filename = button.dataset.workerEnvFilename || button.dataset.filename || 'agents-worker.env';
          if (downloadWorkerEnvContent(workerEnv, filename)) {
            if (feedbackTarget) {
              setFeedback(feedbackTarget, 'Worker .env downloaded.', 'is-success');
            } else {
              showCpMessage('Worker .env downloaded.');
            }
          }
        });
      };

      const bindWorkerEnvCopyButton = (button) => {
        if (!button || button.dataset.bound === '1') {
          return;
        }
        button.dataset.bound = '1';

        button.addEventListener('click', async () => {
          const container = button.closest('.agents-agent-card-details-section, .agents-accounts-registry-details-wrap, .agents-agent-token-overlay')
            || button.parentElement
            || document;
          const workerEnvSource = container.querySelector('.agents-worker-env-source, #revealedCredentialWorkerEnv');
          const workerEnv = workerEnvSource ? (workerEnvSource.value || workerEnvSource.textContent || '') : '';
          const feedbackTarget = button.dataset.feedbackTarget
            ? document.getElementById(button.dataset.feedbackTarget)
            : null;
          if (!workerEnv) {
            if (feedbackTarget) {
              setFeedback(feedbackTarget, 'Create or rotate the account to reveal the worker .env first.', 'is-error');
            } else {
              showCpMessage('Create or rotate the account to reveal the worker .env first.', 'error');
            }
            return;
          }

          try {
            if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
              await navigator.clipboard.writeText(workerEnv);
            } else if (workerEnvSource) {
              workerEnvSource.focus();
              workerEnvSource.select();
              document.execCommand('copy');
            } else {
              throw new Error('clipboard-unavailable');
            }

            if (feedbackTarget) {
              setFeedback(feedbackTarget, 'Worker .env copied to clipboard.', 'is-success');
            } else {
              showCpMessage('Worker .env copied to clipboard.');
            }
          } catch (error) {
            if (feedbackTarget) {
              setFeedback(feedbackTarget, 'Unable to copy automatically. Select the .env block and copy manually.', 'is-error');
            } else {
              showCpMessage('Unable to copy automatically. Select the .env block and copy manually.', 'error');
            }
          }
        });
