      min-width: 0;
    }

    .agents-external-capability-resource__title {
      font-size: 13px;
      line-height: 1.35;
      font-weight: 700;
      color: #3f4a57;
    }

    .agents-external-capability-resource__description {
      font-size: 12px;
      line-height: 1.4;
      color: #596673;
    }

    .agents-external-capability-resource__meta {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      font-size: 11px;
      line-height: 1.35;
      color: #6d7782;
      word-break: break-word;
    }

    .agents-inline-checkboxes {
      display: flex;
      flex-wrap: wrap;
      gap: 14px 24px;
      padding-top: 4px;
    }

    .agents-inline-checkboxes label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
    }

    .agents-inline-checkboxes--stacked {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 10px;
    }

    .agents-target-set-checkbox {
      display: flex !important;
      align-items: flex-start !important;
      gap: 10px !important;
      padding: 10px 12px;
      border: 1px solid #d7dde3;
      border-radius: 3px;
      background: #ffffff;
    }

    .agents-target-set-checkbox__copy {
      display: flex;
      flex-direction: column;
      gap: 2px;
      min-width: 0;
    }

    .agents-target-set-checkbox__title {
      font-size: 13px;
      font-weight: 700;
      color: #3f4a57;
      line-height: 1.35;
    }

    .agents-target-set-checkbox__meta {
      font-size: 12px;
      line-height: 1.35;
      color: #6d7782;
    }

    .agents-target-set-helper {
      margin-top: 12px;
      padding-top: 12px;
      border-top: 1px solid #e1e7ee;
    }

    .agents-target-set-helper:first-of-type {
      margin-top: 0;
      padding-top: 0;
      border-top: 0;
    }

    .agents-target-set-helper__title {
      font-size: 13px;
      font-weight: 700;
      color: #3f4a57;
      line-height: 1.35;
      margin-bottom: 8px;
    }

    .agents-target-set-helper__code {
      margin: 10px 0 0;
      padding: 10px 12px;
      border: 1px solid #d7dde3;
      border-radius: 3px;
      background: #f8fafc;
      color: #3f4a57;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      font-size: 12px;
      line-height: 1.45;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .agents-create-id-row {
      display: grid;
      gap: 14px;
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .agents-create-id-row[hidden] {
      display: none !important;
    }

    .agents-create-agent-frame.is-edit-mode .agents-create-id-row {
      display: none !important;
    }

    .agents-create-id-action {
      padding-bottom: 24px;
    }

    .agents-create-agent-frame .btn.submit {
      margin-top: 10px;
    }

    .agents-account-templates-note {
      margin: 0 0 12px;
    }

    .agents-account-templates-grid {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .agents-account-template-card {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 14px;
      min-height: 156px;
      padding: 16px;
      border: 1px solid #bbc7d5;
      border-radius: 3px;
      background: #ffffff;
      color: #596673;
    }

    .agents-account-template-copy {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .agents-account-template-title {
      font-size: 14px;
      line-height: 1.25;
      font-weight: 700;
      color: #596673;
    }

    .agents-account-template-description {
      margin: 0;
      font-size: 12px;
      line-height: 16px;
      color: #596673;
    }

    .agents-account-template-actions {
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    @media (max-width: 767px) {
      .agents-create-id-row {
        grid-template-columns: 1fr;
      }

      .agents-create-id-action {
        padding-bottom: 0;
      }
    }
  {% endcss %}
{% endblock %}
