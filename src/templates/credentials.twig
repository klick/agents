  {% js %}
    (() => {
      const cardList = document.getElementById('agentsCardList');
      const detailToggles = Array.from(document.querySelectorAll('[data-agent-details-toggle]'));
      const detailPanels = Array.from(document.querySelectorAll('.agents-agent-card-details'));
      const editButtons = Array.from(document.querySelectorAll('[data-agent-edit]'));
      const focusQueryParams = new URLSearchParams(window.location.search || '');
      const requestedFocusCardId = (focusQueryParams.get('focusCardId') || '').trim();
      const requestedFocusCardHandle = (focusQueryParams.get('focusCardHandle') || '').trim().toLowerCase();
      const requestFocusFirstVisible = ['1', 'true', 'yes', 'on'].includes((focusQueryParams.get('focusFirstVisible') || '').trim().toLowerCase());

      const parseJsonArray = (value) => {
        if (typeof value !== 'string' || value.trim() === '') {
          return [];
        }

        try {
          const parsed = JSON.parse(value);
          if (Array.isArray(parsed)) {
            return parsed.map((item) => `${item}`);
          }
        } catch (error) {
          // Ignore parse issues and fall back to empty array.
        }

        return [];
      };

      const closeAll = () => {
        detailPanels.forEach((panel) => {
          panel.setAttribute('hidden', 'hidden');
        });
        detailToggles.forEach((button) => {
          button.setAttribute('aria-expanded', 'false');
          const card = button.closest('[data-agent-card]');
          if (card) {
            card.classList.remove('is-focused');
          }
        });
      };

      const resolveCardById = (id) => {
        if (!cardList || !id) {
          return null;
        }

        return cardList.querySelector(`[data-agent-card-id="${id}"]`);
      };

      const resolveCardByHandle = (handle) => {
        if (!cardList || !handle) {
          return null;
        }

        const normalizedHandle = `${handle}`.trim().toLowerCase();
        if (!normalizedHandle) {
          return null;
        }

        return Array.from(cardList.querySelectorAll('[data-agent-card]')).find((card) => {
          return (card.dataset.agentCardHandle || '').trim().toLowerCase() === normalizedHandle;
        }) || null;
      };

      const resolveFirstVisibleCard = () => {
        if (!cardList) {
          return null;
        }

        return Array.from(cardList.querySelectorAll('[data-agent-card]:not(.is-template)')).find((card) => {
          return !card.hasAttribute('hidden');
        }) || null;
      };

      const focusCard = (card) => {
        if (!card) {
          return;
        }

        const toggle = card.querySelector('[data-agent-details-toggle]');
        const targetId = toggle ? (toggle.dataset.target || '') : '';
        const target = targetId ? document.getElementById(targetId) : null;
        if (!toggle || !target) {
          return;
        }

        closeAll();
        target.removeAttribute('hidden');
        toggle.setAttribute('aria-expanded', 'true');
        card.classList.add('is-focused');
        card.scrollIntoView({ behavior: 'smooth', block: 'start', inline: 'nearest' });
      };

      detailToggles.forEach((button) => {
        button.addEventListener('click', () => {
          const targetId = button.dataset.target || '';
          const target = targetId ? document.getElementById(targetId) : null;
          if (!target) {
            return;
          }

          const isOpen = !target.hasAttribute('hidden');
          closeAll();
          if (!isOpen) {
            target.removeAttribute('hidden');
            button.setAttribute('aria-expanded', 'true');
            const card = button.closest('[data-agent-card]');
            if (card) {
              card.classList.add('is-focused');
            }
          }
        });
      });

      editButtons.forEach((button) => {
        button.addEventListener('click', () => {
          window.dispatchEvent(new CustomEvent('agents:edit-agent', {
            detail: {
              id: button.dataset.agentId || '',
              handle: button.dataset.agentHandle || '',
              displayName: button.dataset.agentDisplayName || '',
              description: button.dataset.agentDescription || '',
              scopes: parseJsonArray(button.dataset.agentScopes),
              webhookResourceTypes: parseJsonArray(button.dataset.agentWebhookResourceTypes),
              webhookActions: parseJsonArray(button.dataset.agentWebhookActions),
              ttlDays: button.dataset.agentTtlDays || '',
              expiryReminderDays: button.dataset.agentExpiryReminderDays || '',
              ipAllowlist: button.dataset.agentIpAllowlist || '',
              ownerLegacy: button.dataset.agentOwnerLegacy || '',
              ownerUserId: button.dataset.agentOwnerUserId || '',
              approvalRecipientUserIds: parseJsonArray(button.dataset.agentApprovalRecipientUserIds),
              forceHumanApproval: button.dataset.agentForceHumanApproval || '1',
              cardId: button.closest('[data-agent-card]')?.dataset.agentCardId || '',
            },
          }));
        });
      });

      closeAll();

      const requestedFocusCard = resolveCardById(requestedFocusCardId)
        || resolveCardByHandle(requestedFocusCardHandle)
        || (requestFocusFirstVisible ? resolveFirstVisibleCard() : null);
      if (requestedFocusCard) {
        focusCard(requestedFocusCard);
      }
    })();
