      };

      const resolveItemsById = (id, preferredView = activeView) => {
        if (!id) {
          return [];
        }

        const orderedViews = [preferredView, preferredView === 'cards' ? 'table' : 'cards']
          .filter((view, index, values) => validViews.has(view) && values.indexOf(view) === index);
        const matches = [];

        orderedViews.forEach((view) => {
          viewItems(view).forEach((item) => {
            if ((item.dataset.agentCardId || '').trim() === `${id}`) {
              matches.push(item);
            }
          });
        });

        return matches;
      };

      const resolveItemById = (id, preferredView = activeView) => {
        return resolveItemsById(id, preferredView)[0] || null;
      };

      const resolveItemByHandle = (handle, preferredView = activeView) => {
        if (!handle) {
          return null;
        }

        const normalizedHandle = `${handle}`.trim().toLowerCase();
        if (!normalizedHandle) {
          return null;
        }

        const orderedViews = [preferredView, preferredView === 'cards' ? 'table' : 'cards']
          .filter((view, index, values) => validViews.has(view) && values.indexOf(view) === index);
        for (const view of orderedViews) {
          const match = viewItems(view).find((item) => {
            return (item.dataset.agentCardHandle || '').trim().toLowerCase() === normalizedHandle;
          });
          if (match) {
            return match;
          }
        }

        return null;
      };

      const resolveFirstVisibleItem = (preferredView = activeView) => {
        const orderedViews = [preferredView, preferredView === 'cards' ? 'table' : 'cards']
          .filter((view, index, values) => validViews.has(view) && values.indexOf(view) === index);
        for (const view of orderedViews) {
          const container = getViewContainer(view);
          if (!container || container.hasAttribute('hidden')) {
            continue;
          }
          const match = viewItems(view).find((item) => !item.hasAttribute('hidden'));
          if (match) {
            return match;
          }
        }
        return null;
      };

      const resolveCredentialId = (source) => {
        if (!source) {
          return null;
        }

        const fromInput = source.querySelector ? source.querySelector('input[name="credentialId"]') : null;
        const rawValue = fromInput?.value
          || source.dataset?.agentId
          || source.closest?.('[data-agent-detail-item]')?.dataset?.agentCardId
          || '';
        const normalized = `${rawValue}`.trim();
        return normalized !== '' ? normalized : null;
      };

      const resolveCardById = (id) => {
        if (!cardsView || !id) {
          return null;
        }

        return cardsView.querySelector(`[data-agent-card][data-agent-card-id="${id}"]`);
      };

      const resolveStatusDots = (credentialId) => {
        return Array.from(document.querySelectorAll('[data-agent-status-dot]')).filter((dot) => {
          return (dot.dataset.agentStatusId || '').trim() === `${credentialId}`;
        });
      };

      const focusItem = (item, options = {}) => {
        if (!item) {
          return;
        }

        const itemView = validViews.has(item.dataset.agentViewMode || '') ? item.dataset.agentViewMode : activeView;
        if (options.activateView !== false) {
          setAccountsView(itemView, { persist: options.persistView !== false });
        }

        closeAll({ restoreFocus: false });
        item.classList.add('is-focused');
        item.scrollIntoView({ behavior: 'smooth', block: 'start', inline: 'nearest' });
      };

      const resolveDetailSource = (item, trigger) => {
        if (!item) {
          return null;
        }

        const credentialId = (item.dataset.agentCardId || '').trim();
        if (credentialId) {
          const template = document.getElementById(`agent-details-source-${credentialId}`);
          const templateContent = template && template.tagName === 'TEMPLATE'
            ? template.content.firstElementChild
            : null;
          if (templateContent) {
            return templateContent;
          }
        }

        const targetId = trigger ? (trigger.dataset.target || '').trim() : '';
        if (!targetId) {
          return null;
        }

        const fallbackPanel = document.getElementById(targetId);
        if (!fallbackPanel) {
          return null;
        }

        return fallbackPanel.querySelector('.agents-accounts-registry-details-wrap')
          || fallbackPanel.querySelector('.agents-agent-card-details')
          || fallbackPanel;
      };

      const cloneDetailContent = (source) => {
        const clone = source.cloneNode(true);
        clone.removeAttribute('hidden');
        clone.removeAttribute('id');
        clone.removeAttribute('data-agent-details-panel');

        clone.querySelectorAll('[id]').forEach((element) => {
          const originalId = element.id;
          if (!originalId) {
            return;
          }

          const modalId = `${originalId}-modal`;
          element.id = modalId;
          clone.querySelectorAll(`[data-feedback-target="${originalId}"]`).forEach((form) => {
            form.dataset.feedbackTarget = modalId;
          });
        });

        return clone;
      };

      const bindDetailModalContent = (container) => {
        if (!container) {
          return;
        }

        container.querySelectorAll('[data-agent-test-form]').forEach(bindAgentTestForm);
        container.querySelectorAll('[data-agent-rotate-form]').forEach(bindRotateForm);
        container.querySelectorAll('[data-agent-revoke-form]').forEach(bindRevokeForm);
        container.querySelectorAll('[data-agent-download-worker-env]').forEach(bindWorkerEnvDownloadButton);
        container.querySelectorAll('[data-agent-copy-worker-env]').forEach(bindWorkerEnvCopyButton);
      };

      const openDetailModal = (item, trigger) => {
        if (!item || !trigger) {
          return;
        }

        const source = resolveDetailSource(item, trigger);
        if (!source) {
          return;
        }

        closeAll({ restoreFocus: false });

        const title = item.querySelector('.agents-accounts-registry-account-name, .agents-agent-card-title')?.textContent?.trim()
          || 'Account details';
        const subtitle = item.querySelector('.agents-accounts-registry-account-handle')?.textContent?.trim()
          || (item.dataset.agentCardHandle || '').trim();
        const backdrop = document.createElement('div');
        backdrop.className = 'agents-account-details-modal-backdrop';
        backdrop.id = detailModalBackdropId;
        backdrop.innerHTML = `
          <div class="agents-account-details-modal" role="dialog" aria-modal="true" aria-labelledby="agentsAccountDetailsModalTitle" tabindex="-1">
            <div class="agents-account-details-modal__header">
              <div class="agents-account-details-modal__heading">
                <h2 class="agents-account-details-modal__title" id="agentsAccountDetailsModalTitle"></h2>
                <p class="agents-account-details-modal__subtitle"></p>
              </div>
              <button class="btn small agents-account-details-modal__close" type="button" data-agent-details-modal-close>Close</button>
            </div>
            <div class="agents-account-details-modal__body">
              <div class="agents-account-details-modal__content"></div>
            </div>
          </div>
        `;

        backdrop.querySelector('.agents-account-details-modal__title').textContent = title;
        const subtitleElement = backdrop.querySelector('.agents-account-details-modal__subtitle');
        if (subtitleElement) {
          if (subtitle) {
            subtitleElement.textContent = subtitle;
          } else {
            subtitleElement.hidden = true;
          }
        }
        backdrop.querySelector('.agents-account-details-modal__content').appendChild(cloneDetailContent(source));

        document.body.appendChild(backdrop);
        document.body.classList.add(detailModalBodyOpenClass);
        activeDetailTrigger = trigger;
        item.classList.add('is-focused');
        trigger.setAttribute('aria-expanded', 'true');

        bindDetailModalContent(backdrop);

        backdrop.addEventListener('click', (event) => {
          if (event.target === backdrop) {
            closeDetailModal();
          }
        });

        const closeButton = backdrop.querySelector('[data-agent-details-modal-close]');
        if (closeButton) {
          closeButton.addEventListener('click', () => {
            closeDetailModal();
          });
        }

        window.addEventListener('keydown', handleDetailModalKeydown);
        const modal = backdrop.querySelector('.agents-account-details-modal');
        if (modal) {
          window.requestAnimationFrame(() => {
            modal.focus();
          });
        }
      };

      const requestJson = async (form, fallbackMessage) => {
        const response = await fetch(form.getAttribute('action') || window.location.href, {
          method: 'POST',
          body: new FormData(form),
          credentials: 'same-origin',
          headers: {
            'Accept': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
          },
        });

        let payload = null;
        try {
          payload = await response.json();
        } catch (error) {
          payload = null;
        }

        if (!response.ok || !payload || payload.ok === false) {
          throw new Error(payload?.message || fallbackMessage || `Request failed (HTTP ${response.status}).`);
        }

        return payload;
      };

      const bindAgentTestForm = (form) => {
        if (!form || form.dataset.asyncBound === '1') {
          return;
        }
        form.dataset.asyncBound = '1';

        const runAsyncTest = async (event) => {
          if (event) {
            event.preventDefault();
            event.stopPropagation();
            if (typeof event.stopImmediatePropagation === 'function') {
              event.stopImmediatePropagation();
            }
          }

          const submitButton = form.querySelector('[data-agent-test-submit], button[type="submit"]');
          if (submitButton && submitButton.disabled) {
            return;
          }

          const busyLabel = 'Testing...';
          const feedbackTargetId = form.dataset.feedbackTarget || '';
          const feedbackTarget = feedbackTargetId ? document.getElementById(feedbackTargetId) : null;

          setFeedback(feedbackTarget, busyLabel, 'is-pending');
          if (submitButton) {
            submitButton.disabled = true;
          }

          try {
            const payload = await requestJson(form, 'Unable to test account.');
            setFeedback(feedbackTarget, payload.message || 'Account validated.', 'is-success');
          } catch (error) {
            const message = error instanceof Error ? error.message : 'Unable to test account.';
            setFeedback(feedbackTarget, message, 'is-error');
          } finally {
            if (submitButton) {
              const keepDisabled = submitButton.dataset.keepDisabled === '1';
              submitButton.disabled = keepDisabled;
              delete submitButton.dataset.keepDisabled;
            }
          }
        };

        form.addEventListener('submit', runAsyncTest);

        const submitButton = form.querySelector('[data-agent-test-submit], button[type="submit"]');
        if (submitButton) {
          submitButton.addEventListener('click', runAsyncTest, true);
        }
      };

      const bindLifecycleActionForm = (form, options) => {
        if (!form || form.dataset.asyncBound === '1') {
          return;
        }
        form.dataset.asyncBound = '1';

        const runAsyncAction = async (event) => {
          if (event) {
            event.preventDefault();
            event.stopPropagation();
            if (typeof event.stopImmediatePropagation === 'function') {
              event.stopImmediatePropagation();
            }
          }

          const submitButton = form.querySelector('[data-agent-action-submit], button[type="submit"]');
          if (submitButton && submitButton.disabled) {
            return;
          }

          const confirmMessage = form.dataset.confirmMessage || '';
          if (confirmMessage && !window.confirm(confirmMessage)) {
            return;
          }

          const busyLabel = options.pendingLabel || 'Working...';
          const feedbackTargetId = form.dataset.feedbackTarget || '';
          const feedbackTarget = feedbackTargetId ? document.getElementById(feedbackTargetId) : null;

          if (feedbackTarget) {
            setFeedback(feedbackTarget, busyLabel, 'is-pending');
          }
          if (submitButton) {
            submitButton.disabled = true;
          }

          try {
            const payload = await requestJson(form, options.errorMessage || 'Unable to complete action.');
            if (typeof options.onSuccess === 'function') {
              options.onSuccess(payload, form, feedbackTarget);
            }
            if (feedbackTarget) {
              setFeedback(feedbackTarget, payload.message || options.successMessage || 'Done.', 'is-success');
            } else {
              showCpMessage(payload.message || options.successMessage || 'Done.');
            }
          } catch (error) {
            const message = error instanceof Error ? error.message : (options.errorMessage || 'Unable to complete action.');
            if (feedbackTarget) {
              setFeedback(feedbackTarget, message, 'is-error');
            } else {
              showCpMessage(message, 'error');
            }
          } finally {
            if (submitButton) {
              const keepDisabled = submitButton.dataset.keepDisabled === '1';
              submitButton.disabled = keepDisabled;
              delete submitButton.dataset.keepDisabled;
            }
          }
        };

        form.addEventListener('submit', runAsyncAction);

        const submitButton = form.querySelector('[data-agent-action-submit], button[type="submit"]');
        if (submitButton) {
          submitButton.addEventListener('click', runAsyncAction, true);
        }
      };

      const bindRotateForm = (form) => {
        bindLifecycleActionForm(form, {
          pendingLabel: 'Rotating...',
          errorMessage: 'Unable to rotate account token.',
          onSuccess: (payload, actionForm) => {
            const openModal = getOpenDetailModal();
            const modalHost = openModal ? openModal.querySelector('.agents-account-details-modal') : null;
            if (modalHost) {
              renderCredentialOverlay(modalHost, payload, { variant: 'modal' });
              return;
            }

            const credentialId = resolveCredentialId(actionForm);
            const card = resolveCardById(credentialId);
            if (card) {
              setAccountsView('cards');
              focusItem(card);
              renderCredentialOverlay(card, payload);
            }
          },
        });
      };

      const bindRevokeForm = (form) => {
        bindLifecycleActionForm(form, {
          pendingLabel: 'Revoking...',
          errorMessage: 'Unable to revoke account token.',
          onSuccess: (payload, actionForm) => {
            closeDetailModal({ restoreFocus: false });
            const credentialId = resolveCredentialId(actionForm);
            if (!credentialId) {
              return;
            }

            updateCredentialState(credentialId, payload || {});
            const currentButton = actionForm.querySelector('[data-agent-action-submit], button[type="submit"]');
            if (currentButton) {
              currentButton.dataset.keepDisabled = '1';
            }
          },
        });
      };

      const bindCredentialOverlay = (overlay) => {
        if (!overlay || overlay.dataset.bound === '1') {
          return;
        }
        overlay.dataset.bound = '1';

        const tokenInput = overlay.querySelector('#revealedCredentialToken');
        const workerEnvInput = overlay.querySelector('#revealedCredentialWorkerEnv');
        const copyButton = overlay.querySelector('#copyRevealedCredentialBtn');
        const downloadEnvButton = overlay.querySelector('#downloadRevealedCredentialEnvBtn');
        const feedback = overlay.querySelector('#revealedCredentialFeedback');
        const closeButton = overlay.querySelector('#revealedCredentialOverlayClose');
        if (copyButton && tokenInput) {
          copyButton.addEventListener('click', async () => {
            const token = tokenInput.value || '';
            if (!token) {
              setFeedback(feedback, 'No token available to copy.', 'is-error');
              return;
            }

            try {
              if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
                await navigator.clipboard.writeText(token);
              } else {
                tokenInput.focus();
                tokenInput.select();
                document.execCommand('copy');
              }
              setFeedback(feedback, 'Token copied to clipboard.', 'is-success');
            } catch (error) {
              setFeedback(feedback, 'Unable to copy automatically. Select the token and copy manually.', 'is-error');
            }
          });
        }

        if (downloadEnvButton && workerEnvInput) {
          downloadEnvButton.addEventListener('click', () => {
            const workerEnv = workerEnvInput.value || '';
            if (!workerEnv) {
              setFeedback(feedback, 'No worker config available to download.', 'is-error');
              return;
            }

            const filename = downloadEnvButton.dataset.filename || 'agents-worker.env';
            if (downloadWorkerEnvContent(workerEnv, filename)) {
              setFeedback(feedback, 'Worker .env downloaded.', 'is-success');
            }
          });
        }

        if (closeButton) {
          closeButton.addEventListener('click', () => {
            const confirmed = window.confirm('Close this connect-worker overlay? The token will not be shown again after you dismiss it.');
            if (!confirmed) {
              return;
            }

            overlay.remove();
          });
        }
      };

      const renderCredentialOverlay = (host, payload, options = {}) => {
        if (!host || !payload || !payload.revealedCredential || !payload.revealedCredential.token) {
          return null;
        }

        const existingOverlay = document.getElementById('revealedCredentialOverlay');
        if (existingOverlay) {
          existingOverlay.remove();
        }

        const overlay = document.createElement('div');
        overlay.className = `agents-agent-token-overlay${options.variant === 'modal' ? ' agents-account-details-modal__token-overlay' : ''}`;
        overlay.id = 'revealedCredentialOverlay';
        overlay.setAttribute('role', 'dialog');
        overlay.setAttribute('aria-modal', 'false');
        overlay.setAttribute('aria-labelledby', 'revealedCredentialOverlayTitle');

        overlay.innerHTML = `
          <button class="agents-agent-token-overlay-close" id="revealedCredentialOverlayClose" type="button" aria-label="Close API token overlay">×</button>
          <div class="agents-agent-token-overlay-body">
            <h2 class="agents-agent-token-overlay-title" id="revealedCredentialOverlayTitle">Connect Worker Now</h2>
            <p class="agents-agent-token-overlay-lead">Use this one-time reveal to export worker config and then run the example worker.</p>
            <p class="agents-agent-token-overlay-token" id="revealedCredentialTokenPreview"></p>
            <textarea id="revealedCredentialToken" readonly hidden></textarea>
            <textarea id="revealedCredentialWorkerEnv" readonly hidden></textarea>
            <ol class="agents-agent-token-overlay-steps">
              <li>Download the worker <code>.env</code> file or copy the token.</li>
              <li>Follow the first worker guide and run the worker.</li>
            </ol>
            <div class="agents-agent-token-overlay-actions"></div>
            <p class="agents-agent-token-overlay-note">This token is only shown once. Download the worker config now if you need a ready-to-run bootstrap artifact.</p>
            <p class="agents-agent-token-overlay-feedback" id="revealedCredentialFeedback" aria-live="polite"></p>
          </div>
        `;

        overlay.querySelector('#revealedCredentialTokenPreview').textContent = payload.revealedCredential.token;
        overlay.querySelector('#revealedCredentialToken').value = payload.revealedCredential.token;
        overlay.querySelector('#revealedCredentialWorkerEnv').value = payload.workerEnv || '';

        const actions = overlay.querySelector('.agents-agent-token-overlay-actions');

        const copyButton = document.createElement('button');
        copyButton.className = 'btn small agents-card-btn agents-token-overlay-btn';
        copyButton.id = 'copyRevealedCredentialBtn';
        copyButton.type = 'button';
        copyButton.textContent = 'Copy token';
        actions.appendChild(copyButton);

        const downloadButton = document.createElement('button');
        downloadButton.className = 'btn small agents-card-btn agents-token-overlay-btn';
        downloadButton.id = 'downloadRevealedCredentialEnvBtn';
        downloadButton.type = 'button';
        downloadButton.dataset.filename = payload.envFilename || 'agents-worker.env';
        downloadButton.textContent = 'Download .env';
        actions.appendChild(downloadButton);

        const guideLink = document.createElement('a');
        guideLink.className = 'btn small agents-card-btn agents-token-overlay-btn';
        guideLink.href = payload.firstWorkerGuideUrl || card.querySelector('.agents-agent-card-detail-actions a')?.href || '#';
        guideLink.target = '_blank';
        guideLink.rel = 'noopener';
        guideLink.textContent = 'Open guide';
        actions.appendChild(guideLink);

        host.insertBefore(overlay, host.firstChild);
        bindCredentialOverlay(overlay);
        if (options.scroll !== false) {
          host.scrollIntoView({ behavior: 'smooth', block: 'start', inline: 'nearest' });
        }
        return overlay;
      };

      const updateCredentialState = (credentialId, payload = {}) => {
        const items = resolveItemsById(credentialId, 'table');
        items.forEach((item) => {
          item.classList.remove('is-active');
          item.classList.add('is-inactive');
          item.querySelectorAll('form .agents-card-btn, form button[type="submit"]').forEach((button) => {
            button.disabled = true;
          });
        });

        resolveStatusDots(credentialId).forEach((dot) => {
          dot.classList.remove('is-live-read', 'is-live-write');
          dot.style.background = '#596673';
          if (payload.stateLabel) {
            dot.setAttribute('aria-label', `State: ${payload.stateLabel}`);
            dot.setAttribute('title', payload.stateLabel);
          }
        });

        items.forEach((item) => {
          item.querySelectorAll('[data-agent-state-label]').forEach((label) => {
            label.textContent = payload.stateLabel || 'Revoked';
          });
        });
      };

      const initialOverlay = document.getElementById('revealedCredentialOverlay');
      let persistedView = 'table';
      try {
        const storedView = window.localStorage.getItem(accountViewStorageKey) || '';
        if (validViews.has(storedView)) {
          persistedView = storedView;
        }
      } catch (error) {
        persistedView = 'table';
      }

      if (validViews.has(requestedAccountView)) {
        persistedView = requestedAccountView;
      }

      setAccountsView(initialOverlay ? 'cards' : persistedView, { persist: false });

      viewButtons.forEach((button) => {
        button.addEventListener('click', () => {
          setAccountsView(button.dataset.agentViewMode || 'table');
        });
      });

      detailToggles.forEach((button) => {
        button.addEventListener('click', () => {
          const item = button.closest('[data-agent-detail-item]');
          openDetailModal(item, button);
        });
      });

      editButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const detailItem = button.closest('[data-agent-detail-item]');
          closeDetailModal({ restoreFocus: false });
          window.dispatchEvent(new CustomEvent('agents:edit-agent', {
            detail: {
              id: button.dataset.agentId || '',
              handle: button.dataset.agentHandle || '',
              displayName: button.dataset.agentDisplayName || '',
              description: button.dataset.agentDescription || '',
              scopes: parseJsonArray(button.dataset.agentScopes),
              webhookResourceTypes: parseJsonArray(button.dataset.agentWebhookResourceTypes),
              webhookActions: parseJsonArray(button.dataset.agentWebhookActions),
              ttlDays: button.dataset.agentTtlDays || '',
              expiryReminderDays: button.dataset.agentExpiryReminderDays || '',
              ipAllowlist: button.dataset.agentIpAllowlist || '',
              ownerLegacy: button.dataset.agentOwnerLegacy || '',
              ownerUserId: button.dataset.agentOwnerUserId || '',
              approvalRecipientUserIds: parseJsonArray(button.dataset.agentApprovalRecipientUserIds),
              targetSetIds: parseJsonArray(button.dataset.agentTargetSetIds),
              forceHumanApproval: button.dataset.agentForceHumanApproval || '1',
              cardId: detailItem?.dataset.agentCardId || '',
              viewMode: detailItem?.dataset.agentViewMode || '',
            },
          }));
        });
      });

      testForms.forEach(bindAgentTestForm);
      rotateForms.forEach(bindRotateForm);
      revokeForms.forEach(bindRevokeForm);
      document.querySelectorAll('[data-agent-download-worker-env]').forEach(bindWorkerEnvDownloadButton);
      document.querySelectorAll('[data-agent-copy-worker-env]').forEach(bindWorkerEnvCopyButton);

      window.AgentsCredentialCards = {
        bindAgentTestForm,
        bindCredentialOverlay,
        renderCredentialOverlay,
      };

      closeAll();

      const requestedFocusItem = resolveItemById(requestedFocusCardId, activeView)
        || resolveItemByHandle(requestedFocusCardHandle, activeView)
        || (requestFocusFirstVisible ? resolveFirstVisibleItem(activeView) : null);
      if (requestedFocusItem) {
        focusItem(requestedFocusItem, { persistView: false });
      } else if (initialOverlay) {
        const overlayHostCard = initialOverlay.closest('[data-agent-card]');
        if (overlayHostCard) {
          focusItem(overlayHostCard, { persistView: false });
        }
      }

      if (initialOverlay) {
        bindCredentialOverlay(initialOverlay);
      }
    })();
