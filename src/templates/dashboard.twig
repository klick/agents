  {% js %}
    (() => {
      if (window.__agentsDetailDialogsBound) {
        return;
      }
      window.__agentsDetailDialogsBound = true;

      const hasNativeDialog = typeof HTMLDialogElement !== 'undefined'
        && typeof HTMLDialogElement.prototype.showModal === 'function';
      const openDialogs = new WeakMap();

      const focusFirstCloseButton = (dialog) => {
        const closeButton = dialog.querySelector('[data-agents-detail-close]');
        if (closeButton) {
          window.requestAnimationFrame(() => closeButton.focus());
        }
      };

      const hydrateWebhookPayloadDialog = (dialog, trigger) => {
        if (!dialog || !trigger) {
          return;
        }

        const sourceId = trigger.getAttribute('data-agents-payload-source');
        const title = trigger.getAttribute('data-agents-payload-title') || 'Webhook Payload';
        const copy = trigger.getAttribute('data-agents-payload-copy') || 'Captured webhook payload.';
        const source = sourceId ? document.getElementById(sourceId) : null;
        const payload = source ? source.textContent || '{}' : '{}';

        const titleEl = dialog.querySelector('.agents-readiness-detail-dialog-title');
        const copyEl = dialog.querySelector('.agents-readiness-detail-dialog-copy');
        const bodyEl = dialog.querySelector('pre');

        if (titleEl) {
          titleEl.textContent = title;
        }
        if (copyEl) {
          copyEl.textContent = copy;
        }
        if (bodyEl) {
          bodyEl.textContent = payload;
        }
      };

      const restoreFocus = (dialog) => {
        const opener = openDialogs.get(dialog);
        if (opener && typeof opener.focus === 'function') {
          window.requestAnimationFrame(() => opener.focus());
        }
        openDialogs.delete(dialog);
      };

      const closeDialog = (dialog, options = {}) => {
        if (!dialog) {
          return;
        }
        const restoreTrigger = options.restoreTrigger !== false;
        if (hasNativeDialog && typeof dialog.close === 'function') {
          dialog.dataset.agentsDetailRestoreFocus = restoreTrigger ? '1' : '0';
          dialog.close();
          return;
        }
        dialog.removeAttribute('open');
        if (restoreTrigger) {
          restoreFocus(dialog);
        } else {
          openDialogs.delete(dialog);
        }
      };

      document.querySelectorAll('[data-agents-detail-dialog]').forEach((dialog) => {
        if (dialog.dataset.agentsDetailDialogBound === '1') {
          return;
        }
        dialog.dataset.agentsDetailDialogBound = '1';

        dialog.addEventListener('click', (event) => {
          if (event.target === dialog) {
            closeDialog(dialog);
          }
        });

        dialog.addEventListener('close', () => {
          const shouldRestore = dialog.dataset.agentsDetailRestoreFocus !== '0';
          delete dialog.dataset.agentsDetailRestoreFocus;
          if (shouldRestore) {
            restoreFocus(dialog);
          } else {
            openDialogs.delete(dialog);
          }
        });

        dialog.addEventListener('cancel', (event) => {
          if (!hasNativeDialog) {
            event.preventDefault();
            closeDialog(dialog);
          }
        });
      });

      document.addEventListener('click', (event) => {
        const openButton = event.target.closest('[data-agents-detail-open]');
        if (openButton) {
          const dialogId = openButton.getAttribute('data-agents-detail-open');
          const dialog = dialogId ? document.getElementById(dialogId) : null;
          if (!dialog) {
            return;
          }

          event.preventDefault();
          hydrateWebhookPayloadDialog(dialog, openButton);
          openDialogs.set(dialog, openButton);
          if (hasNativeDialog) {
            if (!dialog.open) {
              dialog.showModal();
            }
          } else {
            dialog.setAttribute('open', 'open');
          }
          focusFirstCloseButton(dialog);
          return;
        }

        const closeButton = event.target.closest('[data-agents-detail-close]');
        if (closeButton) {
          const dialog = closeButton.closest('[data-agents-detail-dialog]');
          if (dialog) {
            event.preventDefault();
            closeDialog(dialog);
          }
          return;
        }

        const dialogLink = event.target.closest('[data-agents-detail-dialog] a[href]');
        if (dialogLink) {
          const dialog = dialogLink.closest('[data-agents-detail-dialog]');
          if (dialog) {
            closeDialog(dialog, { restoreTrigger: false });
          }
        }
      });

      if (!hasNativeDialog) {
        document.addEventListener('keydown', (event) => {
          if (event.key !== 'Escape') {
            return;
          }
          const openDialog = document.querySelector('[data-agents-detail-dialog][open]');
          if (openDialog) {
            event.preventDefault();
            closeDialog(openDialog);
          }
        });
      }
    })();
  {% endjs %}
{% endblock %}
