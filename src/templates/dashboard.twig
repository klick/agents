{% extends "_layouts/cp" %}
{% set title = 'Agents Status' %}
{% set selectedSubnavItem = 'status' %}
{% set dashboardHeading = 'Status' %}
{% set tabIntro = 'Review runtime, integration, and security posture before integrations or releases.' %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <div class="agents-page-header">
    <div class="agents-page-header__copy">
      <h1>{{ dashboardHeading }}</h1>
      <p class="agents-page-intro">{{ tabIntro }}</p>
    </div>
  </div>

  <div class="agents-layout-stack">
    {% if activeDashboardTab == 'readiness' %}
      {% set readinessPreviewState = (craft.app.request.getQueryParam('previewState') ?? '')|lower %}
      {% set readinessTabScore = readinessSummary.readinessScore|default(0) %}
      {% set readinessTabStatus = (readinessSummary.status|default('unknown'))|lower %}
      {% set readinessTabWarnings = readinessDiagnostics.warnings|length %}
      {% set readinessTabConsumerCount = consumerLagSummary.count|default(0) %}
      {% set readinessTabMaxLagSeconds = consumerLagSummary.maxLagSeconds|default(0) %}
      {% set readinessTabScoreClass = readinessTabScore >= 100
        ? 'agents-metric--good'
        : (readinessTabScore >= 80 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabStatusClass = readinessTabStatus in ['ready', 'healthy', 'ok']
        ? 'agents-metric--good'
        : (readinessTabStatus in ['degraded', 'warning', 'warn', 'partial'] ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabWarningsClass = readinessTabWarnings == 0
        ? 'agents-metric--good'
        : (readinessTabWarnings <= 3 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabConsumerCountClass = readinessTabConsumerCount > 0
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}
      {% set readinessTabLagClass = readinessTabConsumerCount == 0
        ? 'agents-metric--warn'
        : (readinessTabMaxLagSeconds <= 60 ? 'agents-metric--good' : (readinessTabMaxLagSeconds <= 300 ? 'agents-metric--warn' : 'agents-metric--bad')) %}
      {% set telemetryRequestsTotal = observabilitySummary.requestsTotal|default(0) %}
      {% set telemetryAuthFailures = observabilitySummary.authFailuresTotal|default(0) %}
      {% set telemetryForbidden = observabilitySummary.forbiddenTotal|default(0) %}
      {% set telemetryRateLimit = observabilitySummary.rateLimitExceededTotal|default(0) %}
      {% set telemetryErrors5xx = observabilitySummary.errors5xxTotal|default(0) %}
      {% set telemetryQueueDepth = observabilitySummary.queueDepth|default(0) %}
      {% set telemetryDlqFailed = observabilitySummary.webhookDlqFailed|default(0) %}
      {% set telemetryConsumerLagMaxSeconds = observabilitySummary.consumerLagMaxSeconds|default(0) %}
      {% set telemetryActiveCredentials7d = observabilitySummary.activeCredentials7d|default(0) %}
      {% set reliabilityStatus = (observabilitySummary.reliabilityStatus|default('ok'))|lower %}
      {% set reliabilitySignalsWarn = observabilitySummary.reliabilitySignalsWarn|default(0) %}
      {% set reliabilitySignalsCritical = observabilitySummary.reliabilitySignalsCritical|default(0) %}
      {% set reliabilitySignalsEvaluated = observabilitySummary.reliabilitySignalsEvaluated|default(0) %}
      {% set reliabilityTopSignals = observabilitySummary.reliabilityTopSignals|default([]) %}
      {% set reliabilitySignals = observabilitySummary.reliabilitySignals|default([]) %}
      {% set trafficAccessSignalOrder = ['auth_failures', 'scope_denials', 'rate_limit_denials', 'server_errors_5xx'] %}
      {% set deliveryWebhooksSignalOrder = ['webhook_dlq_failed'] %}
      {% set integrationCapacitySignalOrder = ['consumer_lag_max_seconds', 'queue_depth'] %}
      {% set reliabilitySignalsById = {} %}
      {% for signal in reliabilitySignals %}
        {% set signalId = (signal.id ?? '')|trim %}
        {% if signalId %}
          {% set reliabilitySignalsById = reliabilitySignalsById|merge({ (signalId): signal }) %}
        {% endif %}
      {% endfor %}
      {% set securityWarningsList = securityPosture.warnings|default([])|slice(0, 6) %}
      {% set readinessWebhookPreviewRows = webhookDeadLetters|default([])|slice(0, 5) %}
      {% set readinessLagPreviewRows = consumerLagRows|default([])|slice(0, 5) %}
      {% set readinessReliabilityTopSignals = reliabilityTopSignals|default([])|slice(0, 5) %}
      {% set telemetryRequestsClass = telemetryRequestsTotal > 0 ? 'agents-metric--good' : 'agents-metric--warn' %}
      {% set telemetryAuthFailuresClass = telemetryAuthFailures == 0
        ? 'agents-metric--good'
        : (telemetryAuthFailures <= 5 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryForbiddenClass = telemetryForbidden == 0
        ? 'agents-metric--good'
        : (telemetryForbidden <= 5 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryRateLimitClass = telemetryRateLimit == 0
        ? 'agents-metric--good'
        : (telemetryRateLimit <= 10 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryErrors5xxClass = telemetryErrors5xx == 0
        ? 'agents-metric--good'
        : (telemetryErrors5xx <= 2 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryQueueDepthClass = telemetryQueueDepth <= 10
        ? 'agents-metric--good'
        : (telemetryQueueDepth <= 50 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryDlqFailedClass = telemetryDlqFailed == 0
        ? 'agents-metric--good'
        : (telemetryDlqFailed <= 10 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryConsumerLagClass = telemetryConsumerLagMaxSeconds <= 60
        ? 'agents-metric--good'
        : (telemetryConsumerLagMaxSeconds <= 300 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryActiveCredentialsClass = telemetryActiveCredentials7d > 0
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}
      {% set reliabilityStatusClass = reliabilityStatus == 'critical'
        ? 'agents-metric--bad'
        : (reliabilityStatus == 'warn' ? 'agents-metric--warn' : 'agents-metric--good') %}
      {% set securityCredentialCount = securityPosture.authentication.credentialCount|default(0) %}
      {% set securityTokenRequired = securityPosture.authentication.required ?? false %}
      {% set securityQueryTokenEnabled = securityPosture.authentication.allowQueryToken ?? false %}
      {% set securityPrivacyEnabled = securityPosture.privacy.redactEmail ?? false %}
      {% set securityWebhookUrlConfigured = securityPosture.webhook.urlConfigured ?? false %}
      {% set securityWebhookSecretConfigured = securityPosture.webhook.secretConfigured ?? false %}
      {% set securityWebhookMisconfigured = (securityWebhookUrlConfigured and not securityWebhookSecretConfigured) or ((not securityWebhookUrlConfigured) and securityWebhookSecretConfigured) %}
      {% set securityWarningsRaw = securityPosture.warnings|default([]) %}
      {% set securityWarningsFiltered = [] %}
      {% set securityBootstrapWarningCodes = securityCredentialCount == 0 and securityTokenRequired ? ['missing_credentials'] : [] %}
      {% set securityWarnings = 0 %}
      {% set securityErrors = 0 %}
      {% for warning in securityWarningsRaw %}
        {% set warningCode = (warning.code ?? '')|trim %}
        {% if warningCode not in securityBootstrapWarningCodes %}
          {% set securityWarningsFiltered = securityWarningsFiltered|merge([warning]) %}
          {% if (warning.level ?? 'warning') == 'error' %}
            {% set securityErrors = securityErrors + 1 %}
          {% else %}
            {% set securityWarnings = securityWarnings + 1 %}
          {% endif %}
        {% endif %}
      {% endfor %}
      {% set securityWarningsList = securityWarningsFiltered|slice(0, 6) %}
      {% set webhookEnabledForReadiness = securityPosture.webhook.enabled ?? false %}
      {% set webhookTestSinkConfig = webhookTestSinkSnapshot.config|default({}) %}
      {% set webhookTestSinkSummary = webhookTestSinkSnapshot.summary|default({}) %}
      {% set webhookTestSinkEvents = webhookTestSinkSnapshot.events|default([]) %}
      {% set webhookTestSinkEnabled = webhookTestSinkConfig.enabled ?? false %}
      {% set webhookTestSinkRequested = webhookTestSinkConfig.requested ?? false %}
      {% set webhookTestSinkVisible = (webhookTestSinkConfig.devMode ?? false) or webhookTestSinkRequested %}
      {% set webhookTestSinkStorageReady = webhookTestSinkConfig.storageReady ?? false %}
      {% set webhookTestSinkUrl = webhookTestSinkConfig.url ?? '' %}
      {% set webhookTestSinkWebhookUrlMatches = webhookTestSinkConfig.webhookUrlMatchesSink ?? false %}
      {% set webhookTestSinkWebhookUrlConfigured = webhookTestSinkConfig.webhookUrlConfigured ?? false %}
      {% set webhookTestSinkWebhookSecretConfigured = webhookTestSinkConfig.webhookSecretConfigured ?? false %}
      {% set webhookTestSinkWebhookTargetLabel = webhookTestSinkWebhookUrlMatches ? 'pointing to sink' : (webhookTestSinkWebhookUrlConfigured ? 'configured elsewhere' : 'not configured') %}
      {% set webhookTestSinkWebhookSecretLabel = webhookTestSinkWebhookSecretConfigured ? 'set' : 'missing' %}
      {% set webhookTestSinkRetentionLimit = webhookTestSinkConfig.retentionLimit ?? 200 %}
      {% set webhookTestSinkTotal = webhookTestSinkSummary.total|default(0) %}
      {% set webhookTestSinkValid = webhookTestSinkSummary.valid|default(0) %}
      {% set webhookTestSinkInvalid = webhookTestSinkSummary.invalid|default(0) %}
      {% set webhookTestSinkUnsigned = webhookTestSinkSummary.unsigned|default(0) %}
      {% set webhookTestSinkLastCapturedAt = webhookTestSinkSummary.lastCapturedAt ?: '' %}
      {% set webhookTestSinkCanSend = webhookTestSinkEnabled and webhookTestSinkStorageReady and webhookTestSinkWebhookUrlMatches and webhookTestSinkWebhookSecretConfigured %}
      {% set webhookTestSinkState = 'configured' %}
      {% set webhookTestSinkStateTone = 'good' %}
      {% set webhookTestSinkStatusLine = 'Last captured: ' ~ (webhookTestSinkLastCapturedAt ? webhookTestSinkLastCapturedAt|date('Y-m-d, H:i:s', timezone='UTC') : 'none yet') %}
      {% set webhookTestSinkNotice = '' %}
      {% set webhookTestSinkEmptyCopy = 'No deliveries captured yet. Click Send test webhook or trigger a real content event and run the queue.' %}
      {% if not webhookTestSinkRequested %}
        {% set webhookTestSinkState = 'setup' %}
        {% set webhookTestSinkStateTone = 'muted' %}
        {% set webhookTestSinkStatusLine = 'Status: Enable PLUGIN_AGENTS_WEBHOOK_TEST_SINK=true to turn on local capture in dev.' %}
        {% set webhookTestSinkNotice = 'The sink is opt-in. It reuses the normal runtime webhook URL and secret, so only point the runtime webhook target at the sink in local/dev.' %}
        {% set webhookTestSinkEmptyCopy = 'The sink is not enabled yet.' %}
      {% elseif not webhookTestSinkEnabled %}
        {% set webhookTestSinkState = 'dev-disabled' %}
        {% set webhookTestSinkStateTone = 'warn' %}
        {% set webhookTestSinkStatusLine = 'Status: Requested, but Craft devMode is off.' %}
        {% set webhookTestSinkNotice = 'The sink only runs when devMode is enabled. Leave production webhook delivery pointed at the real receiver.' %}
        {% set webhookTestSinkEmptyCopy = 'Captures are unavailable until devMode is enabled.' %}
      {% elseif not webhookTestSinkStorageReady %}
        {% set webhookTestSinkState = 'storage' %}
        {% set webhookTestSinkStateTone = 'warn' %}
        {% set webhookTestSinkStatusLine = 'Status: Storage unavailable until plugin migrations are applied.' %}
        {% set webhookTestSinkNotice = 'Run plugin migrations to create the local capture table before using the sink.' %}
        {% set webhookTestSinkEmptyCopy = 'Captures are unavailable until sink storage is ready.' %}
      {% elseif not webhookTestSinkWebhookUrlMatches or not webhookTestSinkWebhookSecretConfigured %}
        {% set webhookTestSinkState = 'misconfigured' %}
        {% set webhookTestSinkStateTone = 'warn' %}
        {% set webhookTestSinkStatusLine = 'Status: Runtime webhook transport is not fully pointed at the local sink.' %}
        {% set webhookTestSinkNotice = 'Runtime target is ' ~ webhookTestSinkWebhookTargetLabel ~ ' and secret is ' ~ webhookTestSinkWebhookSecretLabel ~ '. Point the runtime webhook URL at the sink URL below and keep the webhook secret configured to enable one-click test delivery.' %}
        {% set webhookTestSinkEmptyCopy = 'Captures will appear here once delivery is routed to the sink.' %}
      {% elseif webhookTestSinkTotal == 0 %}
        {% set webhookTestSinkState = 'empty' %}
        {% set webhookTestSinkStateTone = 'muted' %}
      {% endif %}
      {% set webhookProbeConfig = webhookProbeSnapshot.config|default({}) %}
      {% set webhookProbeSummary = webhookProbeSnapshot.summary|default({}) %}
      {% set webhookProbeRuns = webhookProbeSnapshot.runs|default([]) %}
      {% set webhookProbeEnabled = webhookProbeConfig.enabled ?? false %}
      {% set webhookProbeStorageReady = webhookProbeConfig.storageReady ?? false %}
      {% set webhookProbeUrlConfigured = webhookProbeConfig.urlConfigured ?? false %}
      {% set webhookProbeSecretConfigured = webhookProbeConfig.secretConfigured ?? false %}
      {% set webhookProbeTargetUrl = webhookProbeConfig.targetUrl ?? '' %}
      {% set webhookProbeCooldownActive = webhookProbeConfig.cooldownActive ?? false %}
      {% set webhookProbeCooldownRemainingSeconds = webhookProbeConfig.cooldownRemainingSeconds ?? 0 %}
      {% set webhookProbeNextAllowedAt = webhookProbeConfig.nextAllowedAt ?? null %}
      {% set webhookProbeTotal = webhookProbeSummary.total|default(0) %}
      {% set webhookProbeDelivered = webhookProbeSummary.delivered|default(0) %}
      {% set webhookProbeFailed = webhookProbeSummary.failed|default(0) %}
      {% set webhookProbeLastAttemptAt = webhookProbeSummary.lastAttemptAt ?? null %}
      {% set webhookProbeLastDeliveredAt = webhookProbeSummary.lastDeliveredAt ?? null %}
      {% set webhookProbeLastFailedAt = webhookProbeSummary.lastFailedAt ?? null %}
      {% set webhookProbeCanSend = webhookProbeEnabled and webhookProbeStorageReady and not webhookProbeCooldownActive %}
      {% set webhookProbeState = 'configured' %}
      {% set webhookProbeStateTone = 'good' %}
      {% set webhookProbeStatusLine = 'Status: Ready to validate the live webhook target with a synthetic signed probe.' %}
      {% set webhookProbeNotice = 'The probe uses the currently configured webhook URL and secret. It does not repoint delivery to a local sink and it does not mutate content.' %}
      {% set webhookProbeEmptyCopy = 'No production webhook probes have been sent yet.' %}
      {% if not webhookProbeStorageReady %}
        {% set webhookProbeState = 'storage' %}
        {% set webhookProbeStateTone = 'warn' %}
        {% set webhookProbeStatusLine = 'Status: Probe storage is unavailable until plugin migrations are applied.' %}
        {% set webhookProbeNotice = 'Run plugin migrations before using the production webhook probe.' %}
      {% elseif not webhookProbeUrlConfigured or not webhookProbeSecretConfigured %}
        {% set webhookProbeState = 'misconfigured' %}
        {% set webhookProbeStateTone = 'warn' %}
        {% set webhookProbeStatusLine = 'Status: Configure both the runtime webhook URL and signing secret before sending a production probe.' %}
        {% set webhookProbeNotice = 'The probe only runs against the live runtime webhook transport and requires both settings to be present.' %}
      {% elseif webhookProbeCooldownActive %}
        {% set webhookProbeState = 'cooldown' %}
        {% set webhookProbeStateTone = 'muted' %}
        {% set webhookProbeStatusLine = 'Status: Cooldown active for ' ~ webhookProbeCooldownRemainingSeconds ~ ' second' ~ (webhookProbeCooldownRemainingSeconds == 1 ? '' : 's') ~ '.' %}
        {% set webhookProbeNotice = 'Cooldown prevents repeated probe spam against the live receiver. Next allowed attempt: ' ~ (webhookProbeNextAllowedAt ? webhookProbeNextAllowedAt|date('Y-m-d, H:i:s', timezone='UTC') ~ ' UTC' : 'soon') ~ '.' %}
      {% elseif webhookProbeTotal == 0 %}
        {% set webhookProbeState = 'empty' %}
        {% set webhookProbeStateTone = 'muted' %}
        {% set webhookProbeStatusLine = 'Status: No production probe has been recorded yet.' %}
      {% elseif webhookProbeLastFailedAt and (not webhookProbeLastDeliveredAt or webhookProbeLastFailedAt >= webhookProbeLastDeliveredAt) %}
        {% set webhookProbeState = 'failed' %}
        {% set webhookProbeStateTone = 'warn' %}
        {% set webhookProbeStatusLine = 'Status: Last production probe failed at ' ~ webhookProbeLastFailedAt|date('Y-m-d, H:i:s', timezone='UTC') ~ ' UTC.' %}
      {% elseif webhookProbeLastDeliveredAt %}
        {% set webhookProbeStatusLine = 'Status: Last production probe succeeded at ' ~ webhookProbeLastDeliveredAt|date('Y-m-d, H:i:s', timezone='UTC') ~ ' UTC.' %}
      {% endif %}
      {% set notificationConfig = notificationSnapshot.config|default({}) %}
      {% set notificationSummary = notificationSnapshot.summary|default({}) %}
      {% set notificationMonitor = notificationSnapshot.systemMonitor|default({ status: 'unknown', payload: {} }) %}
      {% set notificationMonitorPayload = notificationMonitor.payload|default({}) %}
      {% set notificationRecentRows = notificationSnapshot.recentNotifications|default([]) %}
      {% set notificationEnabled = notificationConfig.enabled ?? false %}
      {% set notificationRecipients = notificationConfig.recipients ?? [] %}
      {% set notificationRecipientCount = notificationConfig.recipientCount ?? 0 %}
      {% set notificationGlobalRecipients = notificationConfig.globalRecipients ?? [] %}
      {% set notificationGlobalRecipientCount = notificationConfig.globalRecipientCount ?? 0 %}
      {% set notificationAccountRecipients = notificationConfig.accountRecipients ?? [] %}
      {% set notificationAccountRecipientCount = notificationConfig.accountRecipientCount ?? 0 %}
      {% set notificationEventToggles = notificationConfig.eventToggles ?? {} %}
      {% set notificationEnabledEvents = [] %}
      {% if notificationEventToggles.approval_requested ?? false %}{% set notificationEnabledEvents = notificationEnabledEvents|merge(['approval requests']) %}{% endif %}
      {% if notificationEventToggles.approval_decided ?? false %}{% set notificationEnabledEvents = notificationEnabledEvents|merge(['approval decisions']) %}{% endif %}
      {% if notificationEventToggles.execution_issue ?? false %}{% set notificationEnabledEvents = notificationEnabledEvents|merge(['execution issues']) %}{% endif %}
      {% if notificationEventToggles.webhook_dlq_failed ?? false %}{% set notificationEnabledEvents = notificationEnabledEvents|merge(['webhook DLQ failures']) %}{% endif %}
      {% if notificationEventToggles.status_changed ?? false %}{% set notificationEnabledEvents = notificationEnabledEvents|merge(['status changes']) %}{% endif %}
      {% set notificationMonitorStatus = (notificationMonitor.status ?? 'unknown')|lower %}
      {% set notificationMonitorTone = notificationMonitorStatus == 'critical'
        ? 'bad'
        : (notificationMonitorStatus == 'warn' ? 'warn' : (notificationMonitorStatus == 'ok' ? 'good' : 'muted')) %}
      {% set notificationStatusLine = notificationEnabled
        ? 'Status: enabled for ' ~ notificationRecipientCount ~ ' recipient' ~ (notificationRecipientCount == 1 ? '' : 's') ~ '.'
        : 'Status: disabled until operator notifications are enabled in Settings.' %}
      {% if notificationRecipientCount == 0 and notificationEnabled %}
        {% set notificationStatusLine = 'Status: enabled, but no valid recipients resolve from the current settings.' %}
      {% elseif notificationGlobalRecipientCount == 0 and notificationAccountRecipientCount > 0 and notificationEnabled %}
        {% set notificationStatusLine = 'Status: enabled via account-specific approval recipients (' ~ notificationAccountRecipientCount ~ ').' %}
      {% endif %}
      {% set notificationMonitorGeneratedAt = notificationMonitorPayload.generatedAt ?? null %}
      {% set notificationLastEvaluatedLabel = notificationMonitorGeneratedAt ?: 'never' %}
      {% set notificationLastSentAt = notificationSummary.lastSentAt ?? null %}
      {% set notificationLastSentRecipient = notificationSummary.lastSentRecipient ?? '' %}
      {% set notificationLastSentSubject = notificationSummary.lastSentSubject ?? '' %}
      {% set readinessDbAvailable = readinessDiagnostics.componentChecks.systemComponents.db ?? false %}
      {% set readinessCacheAvailable = readinessDiagnostics.componentChecks.systemComponents.cache ?? false %}
      {% set readinessUsersAvailable = readinessDiagnostics.componentChecks.systemComponents.users ?? false %}
      {% set readinessCoreServicesOk = readinessDbAvailable and readinessCacheAvailable and readinessUsersAvailable %}
      {% set readinessSecurityWarnings = securityWarnings %}
      {% set readinessSecurityErrors = securityErrors %}
      {% set readinessConsumerLagWarningCount = consumerLagSummary.warning|default(0) %}
      {% set readinessConsumerLagCriticalCount = consumerLagSummary.critical|default(0) %}
      {% set readinessHasIntegrationTelemetry = readinessTabConsumerCount > 0 or consumerLagRows|length > 0 %}
      {% set readinessGeneratedAt = observabilitySummary.generatedAt|default(readinessSummary.generatedAt|default('')) %}
      {% set readinessGeneratedAtTimestamp = readinessGeneratedAt ? readinessGeneratedAt|date('U') : 0 %}
      {% set readinessNowTimestamp = 'now'|date('U') %}
      {% set readinessEvaluatedAgeSeconds = readinessGeneratedAtTimestamp > 0 ? (readinessNowTimestamp - readinessGeneratedAtTimestamp) : null %}
      {% set readinessMetricsCurrent = readinessEvaluatedAgeSeconds is not same as(null) and readinessEvaluatedAgeSeconds >= 0 and readinessEvaluatedAgeSeconds <= 300 %}
      {% set readinessHasObservedTraffic = telemetryRequestsTotal > 0 %}
      {% set readinessHasActiveCredentials = telemetryActiveCredentials7d > 0 %}
      {% set readinessEvaluationLabel = 'unknown' %}
      {% if readinessEvaluatedAgeSeconds is not same as(null) %}
        {% if readinessEvaluatedAgeSeconds < 60 %}
          {% set readinessEvaluationLabel = 'just now' %}
        {% elseif readinessEvaluatedAgeSeconds < 3600 %}
          {% set readinessMinutesAgo = (readinessEvaluatedAgeSeconds / 60)|round(0, 'floor') %}
          {% set readinessEvaluationLabel = readinessMinutesAgo ~ ' minute' ~ (readinessMinutesAgo == 1 ? '' : 's') ~ ' ago' %}
        {% elseif readinessEvaluatedAgeSeconds < 86400 %}
          {% set readinessHoursAgo = (readinessEvaluatedAgeSeconds / 3600)|round(0, 'floor') %}
          {% set readinessEvaluationLabel = readinessHoursAgo ~ ' hour' ~ (readinessHoursAgo == 1 ? '' : 's') ~ ' ago' %}
        {% else %}
          {% set readinessDaysAgo = (readinessEvaluatedAgeSeconds / 86400)|round(0, 'floor') %}
          {% set readinessEvaluationLabel = readinessDaysAgo ~ ' day' ~ (readinessDaysAgo == 1 ? '' : 's') ~ ' ago' %}
        {% endif %}
      {% endif %}
      {% set readinessHasTrafficIssues = telemetryAuthFailures > 0
        or telemetryForbidden > 0
        or telemetryRateLimit > 0
        or telemetryErrors5xx > 0 %}
      {% set readinessHasDeliveryIssues = webhookEnabledForReadiness and telemetryDlqFailed > 0 %}
      {% set readinessHasIntegrationIssues = readinessConsumerLagWarningCount > 0
        or readinessConsumerLagCriticalCount > 0
        or telemetryConsumerLagMaxSeconds > 60 %}
      {% set readinessHasSecurityIssues = readinessSecurityWarnings > 0
        or readinessSecurityErrors > 0
        or (not securityTokenRequired)
        or securityQueryTokenEnabled
        or (not securityPrivacyEnabled)
        or securityWebhookMisconfigured %}
      {% set readinessHasCapacityIssues = telemetryQueueDepth > 10 %}
      {% set readinessHasBlockingGate = (not agentsEnabled) or (not readinessDbAvailable) %}
      {% set readinessHasDegradedSignals = readinessTabWarnings > 0
        or reliabilityStatus in ['warn', 'critical']
        or reliabilitySignalsWarn > 0
        or reliabilitySignalsCritical > 0
        or readinessHasTrafficIssues
        or readinessHasDeliveryIssues
        or readinessHasIntegrationIssues
        or readinessHasSecurityIssues
        or readinessHasCapacityIssues %}
      {% set readinessHasMonitoringGap = (not readinessMetricsCurrent)
        or reliabilitySignalsEvaluated == 0 %}
      {% set readinessHasObservationGap = (not readinessHasObservedTraffic)
        or (not readinessHasActiveCredentials) %}
      {% set readinessHasLowConfidence = readinessHasMonitoringGap or readinessHasObservationGap %}
      {% set readinessOnlyBootstrapGaps = (not readinessHasObservedTraffic)
        and (not readinessHasActiveCredentials)
        and (not readinessHasIntegrationTelemetry) %}
      {% set readinessIsBootstrapState = (not readinessHasBlockingGate)
        and (not readinessHasDegradedSignals)
        and readinessMetricsCurrent
        and reliabilitySignalsEvaluated > 0
        and readinessOnlyBootstrapGaps %}
      {% set readinessBlockingCount = 0 %}
      {% if not agentsEnabled %}
        {% set readinessBlockingCount = readinessBlockingCount + 1 %}
      {% endif %}
      {% if not readinessDbAvailable %}
        {% set readinessBlockingCount = readinessBlockingCount + 1 %}
      {% endif %}
      {% set readinessStateKey = 'ready' %}
      {% set readinessStateLabel = 'Ready' %}
      {% set readinessStateLead = 'Ready for machine traffic' %}
      {% set readinessStateSubcopy = 'No issues need attention right now.' %}
      {% set readinessStateTone = 'good' %}
      {% if readinessHasBlockingGate %}
        {% set readinessStateKey = 'blocked' %}
        {% set readinessStateLabel = 'Blocked' %}
        {% set readinessStateLead = 'Agents is not operationally fit for live machine traffic.' %}
        {% set readinessStateSubcopy = 'Resolve the blocking issues below before trusting this environment for production traffic.' %}
        {% set readinessStateTone = 'bad' %}
      {% elseif readinessHasDegradedSignals %}
        {% set readinessStateKey = 'degraded' %}
        {% set readinessStateLabel = 'Degraded' %}
        {% set readinessStateLead = 'Agents is handling traffic, but some conditions need attention.' %}
        {% set readinessStateSubcopy = 'Review the affected areas below, then use the detailed sections for full context.' %}
        {% set readinessStateTone = 'warn' %}
      {% elseif readinessIsBootstrapState %}
        {% set readinessStateKey = 'ready' %}
        {% set readinessStateLabel = 'Ready' %}
        {% set readinessStateLead = 'Core runtime is healthy and ready for your first account or integration.' %}
        {% set readinessStateSubcopy = 'Create a managed account or connect an external worker to start building live-readiness evidence.' %}
        {% set readinessStateTone = 'good' %}
      {% elseif readinessHasMonitoringGap %}
        {% set readinessStateKey = 'unproven' %}
        {% set readinessStateLabel = 'Unproven' %}
        {% set readinessStateLead = 'No blocking issues were detected, but live-readiness confidence is limited.' %}
        {% set readinessStateSubcopy = 'Recent traffic, account activity, or observability freshness is too thin for a high-confidence assessment.' %}
        {% set readinessStateTone = 'muted' %}
      {% elseif readinessHasObservationGap %}
        {% set readinessStateKey = 'ready' %}
        {% set readinessStateLabel = 'Ready' %}
        {% set readinessStateLead = 'Core runtime is healthy and ready for machine traffic.' %}
        {% set readinessStateSubcopy = 'No issues need attention right now. Confidence signals will strengthen as routine traffic and account activity build over time.' %}
        {% set readinessStateTone = 'good' %}
      {% endif %}
      {% set readinessShowReadyState = readinessStateKey == 'ready' %}
      {% set readinessConfidenceLabel = readinessHasObservedTraffic and readinessHasActiveCredentials and readinessMetricsCurrent
        ? 'high'
        : (readinessHasMonitoringGap ? 'limited' : 'building') %}
      {% set readinessTrafficLead = 'Guarded requests observed in the last 60 minutes' %}
      {% if not agentsEnabled %}
        {% set readinessTrafficLead = 'Runtime is disabled, so guarded traffic is blocked' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessTrafficLead = 'Recent traffic metrics are stale' %}
      {% elseif not readinessHasObservedTraffic %}
        {% set readinessTrafficLead = 'No guarded request issues detected in the last 60 minutes' %}
      {% elseif telemetryErrors5xx > 0 %}
        {% set readinessTrafficLead = 'Server errors are occurring on guarded routes' %}
      {% elseif telemetryAuthFailures > 0 or telemetryForbidden > 0 or telemetryRateLimit > 0 %}
        {% set readinessTrafficLead = 'Guarded traffic is seeing auth, scope, or rate-limit issues' %}
      {% endif %}
      {% set readinessDeliveryLead = 'Webhook delivery path is operational' %}
      {% if not webhookEnabledForReadiness %}
        {% set readinessDeliveryLead = 'Webhook delivery is not enabled for this environment' %}
      {% elseif telemetryDlqFailed > 0 %}
        {% set readinessDeliveryLead = 'Webhook delivery failures need replay or investigation' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessDeliveryLead = 'Delivery metrics are stale' %}
      {% endif %}
      {% set readinessDeliverySummary = 'No recent delivery failures detected' %}
      {% if not webhookEnabledForReadiness %}
        {% set readinessDeliverySummary = 'No delivery path is configured in this environment' %}
