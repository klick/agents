{% extends "_layouts/cp" %}
{% set title = "Agents Dashboard" %}
{% set selectedSubnavItem = "dashboard" %}
{% set dashboardHeadingByKey = {
  overview: 'Overview',
  readiness: 'Readiness',
  discovery: 'Discovery Docs',
  security: 'Security',
} %}
{% set dashboardHeading = dashboardHeadingByKey[activeDashboardTab]|default('Overview') %}
{% set tabIntroByKey = {
  overview: 'Operate the runtime, verify what is enabled, and jump straight to the right place for each change.',
  readiness: 'Review health signals, lag telemetry, and warnings before integrations or releases.',
  discovery: 'Manage discovery document freshness and quickly inspect what external agents can read.',
  security: 'Monitor auth posture, webhook reliability, and security warnings in one place.'
} %}
{% set dashboardSidebarNavItems = {} %}
{% for tab in dashboardTabs %}
  {% set dashboardSidebarNavItems = dashboardSidebarNavItems|merge({
    (tab.key): {
      label: tab.label,
      url: tab.url,
    }
  }) %}
{% endfor %}

{% block sidebar %}
  {% include "_includes/nav"
    with {
      label: 'Dashboard',
      items: dashboardSidebarNavItems,
      selectedItem: activeDashboardTab,
    }
    only
  %}
{% endblock %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <h1>{{ dashboardHeading }}</h1>
  <p class="agents-page-intro">{{ tabIntroByKey[activeDashboardTab] ?? 'Operator dashboard for governed runtime workflows.' }}</p>

  <div class="agents-layout-stack">
    {% if activeDashboardTab == 'overview' %}
      {% set discoveryEnabledCount = (discoveryEnabled.llms ? 1 : 0) + (discoveryEnabled.llmsFull ? 1 : 0) + (discoveryEnabled.commerce ? 1 : 0) %}
      {% set overviewReadinessScore = overviewReadiness.readinessScore|default(0) %}
      {% set overviewWarnings = securityWarningCounts.warnings|default(0) %}
      {% set overviewErrors = securityWarningCounts.errors|default(0) %}
      {% set readinessMetricClass = overviewReadinessScore >= 100
        ? 'agents-metric--good'
        : (overviewReadinessScore >= 80 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set warningMetricClass = overviewWarnings == 0
        ? 'agents-metric--good'
        : (overviewWarnings <= 3 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set errorMetricClass = overviewErrors == 0
        ? 'agents-metric--good'
        : (overviewErrors == 1 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set discoveryDocsMetricClass = discoveryEnabledCount >= 3
        ? 'agents-metric--good'
        : (discoveryEnabledCount > 0 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set webhookDeliveryMetricClass = webhookEnabled
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}

      <section class="border rounded p-3">
        <h2 class="h4">At a Glance</h2>
        <div class="agents-metric-grid">
          <div class="agents-metric {{ agentsEnabled ? 'agents-metric--good' : 'agents-metric--bad' }}">
            <div class="label">Runtime state</div>
            <div class="value" style="display: flex; align-items: center; gap: 8px;">
              <span class="status {{ agentsEnabled ? 'enabled' : 'disabled' }}"></span>
              {{ agentsEnabled ? 'Enabled' : 'Disabled' }}
            </div>
          </div>
          <div class="agents-metric {{ readinessMetricClass }}">
            <div class="label">Readiness score</div>
            <div class="value">{{ overviewReadinessScore }}/100</div>
          </div>
          <div class="agents-metric {{ discoveryDocsMetricClass }}">
            <div class="label">Discovery docs enabled</div>
            <div class="value">{{ discoveryEnabledCount }}/3</div>
          </div>
          <div class="agents-metric {{ webhookDeliveryMetricClass }}">
            <div class="label">Webhook delivery</div>
            <div class="value">{{ webhookEnabled ? 'On' : 'Off' }}</div>
          </div>
          <div class="agents-metric {{ warningMetricClass }}">
            <div class="label">Security warnings</div>
            <div class="value">{{ overviewWarnings }}</div>
          </div>
          <div class="agents-metric {{ errorMetricClass }}">
            <div class="label">Security errors</div>
            <div class="value">{{ overviewErrors }}</div>
          </div>
        </div>
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Diagnostics Bundle</h2>
        <form method="post" accept-charset="UTF-8">
          {{ csrfInput() }}
          {{ actionInput('agents/dashboard/download-diagnostics-bundle') }}
          {{ redirectInput('agents/dashboard/overview') }}
          <button class="btn submit" type="submit">Download Diagnostics Bundle (.json)</button>
        </form>
        <p class="agents-subtle">Runs auth/discovery/readiness/smoke checks and exports a support artifact for support handoff.</p>
      </section>

      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Readiness Snapshot</h2>
        <p>Status: <strong>{{ overviewReadiness.status|default('unknown') }}</strong></p>
        <p>Score: <strong>{{ overviewReadiness.readinessScore|default(0) }}</strong> / 100</p>
        <details class="agents-advanced">
          <summary><strong>Technical JSON</strong></summary>
          <pre class="border rounded p-3">{{ overviewReadinessJson }}</pre>
        </details>
      </section>
    {% endif %}

    {% if activeDashboardTab == 'readiness' %}
      {% set readinessTabScore = readinessSummary.readinessScore|default(0) %}
      {% set readinessTabStatus = (readinessSummary.status|default('unknown'))|lower %}
      {% set readinessTabWarnings = readinessDiagnostics.warnings|length %}
      {% set readinessTabConsumerCount = consumerLagSummary.count|default(0) %}
      {% set readinessTabMaxLagSeconds = consumerLagSummary.maxLagSeconds|default(0) %}
      {% set readinessTabScoreClass = readinessTabScore >= 100
        ? 'agents-metric--good'
        : (readinessTabScore >= 80 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabStatusClass = readinessTabStatus in ['ready', 'healthy', 'ok']
        ? 'agents-metric--good'
        : (readinessTabStatus in ['degraded', 'warning', 'warn', 'partial'] ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabWarningsClass = readinessTabWarnings == 0
        ? 'agents-metric--good'
        : (readinessTabWarnings <= 3 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabConsumerCountClass = readinessTabConsumerCount > 0
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}
      {% set readinessTabLagClass = readinessTabConsumerCount == 0
        ? 'agents-metric--warn'
        : (readinessTabMaxLagSeconds <= 60 ? 'agents-metric--good' : (readinessTabMaxLagSeconds <= 300 ? 'agents-metric--warn' : 'agents-metric--bad')) %}
      {% set telemetryRequestsTotal = observabilitySummary.requestsTotal|default(0) %}
      {% set telemetryAuthFailures = observabilitySummary.authFailuresTotal|default(0) %}
      {% set telemetryForbidden = observabilitySummary.forbiddenTotal|default(0) %}
      {% set telemetryRateLimit = observabilitySummary.rateLimitExceededTotal|default(0) %}
      {% set telemetryErrors5xx = observabilitySummary.errors5xxTotal|default(0) %}
      {% set telemetryQueueDepth = observabilitySummary.queueDepth|default(0) %}
      {% set telemetryDlqFailed = observabilitySummary.webhookDlqFailed|default(0) %}
      {% set telemetryConsumerLagMaxSeconds = observabilitySummary.consumerLagMaxSeconds|default(0) %}
      {% set telemetryActiveCredentials7d = observabilitySummary.activeCredentials7d|default(0) %}
      {% set reliabilityStatus = (observabilitySummary.reliabilityStatus|default('ok'))|lower %}
      {% set reliabilitySignalsWarn = observabilitySummary.reliabilitySignalsWarn|default(0) %}
      {% set reliabilitySignalsCritical = observabilitySummary.reliabilitySignalsCritical|default(0) %}
      {% set reliabilitySignalsEvaluated = observabilitySummary.reliabilitySignalsEvaluated|default(0) %}
      {% set reliabilityTopSignals = observabilitySummary.reliabilityTopSignals|default([]) %}
      {% set telemetryRequestsClass = telemetryRequestsTotal > 0 ? 'agents-metric--good' : 'agents-metric--warn' %}
      {% set telemetryAuthFailuresClass = telemetryAuthFailures == 0
        ? 'agents-metric--good'
        : (telemetryAuthFailures <= 5 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryForbiddenClass = telemetryForbidden == 0
        ? 'agents-metric--good'
        : (telemetryForbidden <= 5 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryRateLimitClass = telemetryRateLimit == 0
        ? 'agents-metric--good'
        : (telemetryRateLimit <= 10 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryErrors5xxClass = telemetryErrors5xx == 0
        ? 'agents-metric--good'
        : (telemetryErrors5xx <= 2 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryQueueDepthClass = telemetryQueueDepth <= 10
        ? 'agents-metric--good'
        : (telemetryQueueDepth <= 50 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryDlqFailedClass = telemetryDlqFailed == 0
        ? 'agents-metric--good'
        : (telemetryDlqFailed <= 10 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryConsumerLagClass = telemetryConsumerLagMaxSeconds <= 60
        ? 'agents-metric--good'
        : (telemetryConsumerLagMaxSeconds <= 300 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryActiveCredentialsClass = telemetryActiveCredentials7d > 0
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}
      {% set reliabilityStatusClass = reliabilityStatus == 'critical'
        ? 'agents-metric--bad'
        : (reliabilityStatus == 'warn' ? 'agents-metric--warn' : 'agents-metric--good') %}

      <section class="border rounded p-3">
        <h2 class="h4">Readiness Summary</h2>
        <div class="agents-metric-grid">
          <div class="agents-metric {{ readinessTabScoreClass }}">
            <div class="label">Overall score</div>
            <div class="value">{{ readinessTabScore }}/100</div>
          </div>
          <div class="agents-metric {{ readinessTabStatusClass }}">
            <div class="label">Status</div>
            <div class="value">{{ readinessSummary.status|default('unknown') }}</div>
          </div>
          <div class="agents-metric {{ readinessTabWarningsClass }}">
            <div class="label">Warnings</div>
            <div class="value">{{ readinessTabWarnings }}</div>
          </div>
          <div class="agents-metric {{ readinessTabConsumerCountClass }}">
            <div class="label">Sync integrations</div>
            <div class="value">{{ readinessTabConsumerCount }}</div>
          </div>
          <div class="agents-metric {{ readinessTabLagClass }}">
            <div class="label">Max lag</div>
            <div class="value">{{ readinessTabMaxLagSeconds }}s</div>
          </div>
        </div>
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Needs Attention Now</h2>
        <div class="agents-metric-grid">
          <div class="agents-metric {{ reliabilityStatusClass }}">
            <div class="label">Reliability status</div>
            <div class="value">{{ reliabilityStatus|upper }}</div>
          </div>
          <div class="agents-metric {{ reliabilitySignalsCritical > 0 ? 'agents-metric--bad' : 'agents-metric--good' }}">
            <div class="label">Critical signals</div>
            <div class="value">{{ reliabilitySignalsCritical }}</div>
          </div>
          <div class="agents-metric {{ reliabilitySignalsWarn > 0 ? 'agents-metric--warn' : 'agents-metric--good' }}">
            <div class="label">Warning signals</div>
            <div class="value">{{ reliabilitySignalsWarn }}</div>
          </div>
          <div class="agents-metric {{ reliabilitySignalsEvaluated > 0 ? 'agents-metric--good' : 'agents-metric--warn' }}">
            <div class="label">Signals evaluated</div>
            <div class="value">{{ reliabilitySignalsEvaluated }}</div>
          </div>
        </div>

        {% if reliabilityTopSignals|length %}
          <table class="data fullwidth" style="margin-top: 12px;">
            <thead>
            <tr>
              <th>Signal</th>
              <th>Current</th>
              <th>Trigger</th>
              <th>Primary response</th>
            </tr>
            </thead>
            <tbody>
            {% for signal in reliabilityTopSignals %}
              {% set signalThresholdLabel = signal.comparator ~ ' ' ~ (signal.severity == 'critical' ? signal.criticalThreshold : signal.warnThreshold) %}
              <tr>
                <td>
                  <strong>{{ signal.label }}</strong><br>
                  <span class="agents-subtle">{{ signal.severity|upper }}</span>
                </td>
                <td>{{ signal.value }}{% if signal.unit %} {{ signal.unit }}{% endif %}</td>
                <td><code>{{ signalThresholdLabel }}</code></td>
                <td>{{ signal.primaryResponse ?: 'Check observability runbook.' }}</td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        {% else %}
          <p class="agents-subtle" style="margin-top: 10px;">No warning or critical reliability signals detected.</p>
        {% endif %}
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Score Breakdown</h2>
        <table class="data fullwidth">
          <thead>
          <tr>
            <th>Check</th>
            <th>Weight</th>
            <th>Result</th>
            <th>Score</th>
          </tr>
          </thead>
          <tbody>
          {% for criterion in readinessDiagnostics.breakdown %}
            <tr>
              <td>{{ criterion.label }}</td>
              <td>{{ criterion.weight }}</td>
              <td>
                <span class="status {{ criterion.passed ? 'enabled' : 'disabled' }}"></span>
                {{ criterion.passed ? 'pass' : 'needs attention' }}
              </td>
              <td>{{ criterion.score }}</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Component Checks</h2>
        <div class="agents-two-col">
          <div>
            <span class="agents-kicker">System components</span>
            <ul class="agents-link-list">
              {% for key, value in readinessDiagnostics.componentChecks.systemComponents %}
                <li>{{ key }}: <strong>{{ value ? 'ok' : 'unavailable' }}</strong></li>
              {% endfor %}
            </ul>
          </div>
          <div>
            <span class="agents-kicker">Plugin checks</span>
            <ul class="agents-link-list">
              {% for key, value in readinessDiagnostics.componentChecks.enabledPlugins %}
                <li>{{ key }}: <strong>{{ value ? 'enabled' : 'disabled' }}</strong></li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Sync State Lag</h2>
        <p class="agents-subtle">
          Healthy: <strong>{{ consumerLagSummary.healthy|default(0) }}</strong>,
          warning: <strong>{{ consumerLagSummary.warning|default(0) }}</strong>,
          critical: <strong>{{ consumerLagSummary.critical|default(0) }}</strong>.
        </p>

        {% if consumerLagRows|length %}
          <table class="data fullwidth">
            <thead>
            <tr>
              <th>Integration</th>
              <th>Resource</th>
              <th>Checkpoint</th>
              <th>Lag</th>
              <th>Bucket</th>
            </tr>
            </thead>
            <tbody>
            {% for row in consumerLagRows|slice(0, 10) %}
              <tr>
                <td><code>{{ row.integrationKey }}</code></td>
                <td><code>{{ row.resourceType }}</code></td>
                <td>{{ row.checkpointAt ?: 'n/a' }}</td>
                <td>{{ row.lagSeconds }}s</td>
                <td><strong>{{ row.lagBucket }}</strong></td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
          {% if consumerLagRows|length > 10 %}
            <p class="agents-subtle">Showing top 10 highest lag rows.</p>
          {% endif %}
        {% else %}
          <p>No sync-state checkpoint telemetry submitted yet.</p>
        {% endif %}
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Telemetry Snapshot</h2>
        <p class="agents-subtle">Derived from the runtime observability surface (`GET /agents/v1/metrics`). Generated at {{ observabilitySummary.generatedAt|default('n/a') }}.</p>
        <div class="agents-metric-grid">
          <div class="agents-metric {{ telemetryRequestsClass }}">
            <div class="label">Guarded requests</div>
            <div class="value">{{ telemetryRequestsTotal }}</div>
          </div>
          <div class="agents-metric {{ telemetryAuthFailuresClass }}">
            <div class="label">Auth failures</div>
            <div class="value">{{ telemetryAuthFailures }}</div>
          </div>
          <div class="agents-metric {{ telemetryForbiddenClass }}">
            <div class="label">Scope denials (403)</div>
            <div class="value">{{ telemetryForbidden }}</div>
          </div>
          <div class="agents-metric {{ telemetryRateLimitClass }}">
            <div class="label">Rate-limit denials</div>
            <div class="value">{{ telemetryRateLimit }}</div>
          </div>
          <div class="agents-metric {{ telemetryErrors5xxClass }}">
            <div class="label">Server errors (5xx)</div>
            <div class="value">{{ telemetryErrors5xx }}</div>
          </div>
          <div class="agents-metric {{ telemetryQueueDepthClass }}">
            <div class="label">Queue depth</div>
            <div class="value">{{ telemetryQueueDepth }}</div>
          </div>
          <div class="agents-metric {{ telemetryDlqFailedClass }}">
            <div class="label">DLQ failed events</div>
            <div class="value">{{ telemetryDlqFailed }}</div>
          </div>
          <div class="agents-metric {{ telemetryConsumerLagClass }}">
            <div class="label">Max sync-state lag</div>
            <div class="value">{{ telemetryConsumerLagMaxSeconds }}s</div>
          </div>
          <div class="agents-metric {{ telemetryActiveCredentialsClass }}">
            <div class="label">Active credentials (7d)</div>
            <div class="value">{{ telemetryActiveCredentials7d }}</div>
          </div>
        </div>

        <details class="agents-advanced" style="margin-top: 8px;">
          <summary><strong>Telemetry JSON (Technical)</strong></summary>
          <pre class="border rounded p-3">{{ observabilitySnapshotJson }}</pre>
        </details>
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Runbook & Alert Guidance</h2>
        <table class="data fullwidth">
          <thead>
          <tr>
            <th>Signal</th>
            <th>Trigger</th>
            <th>Primary response</th>
          </tr>
          </thead>
          <tbody>
          {% for signal in observabilitySummary.reliabilitySignals|default([]) %}
            <tr>
              <td>{{ signal.label ?: signal.id }}</td>
              <td>Warn: <code>{{ signal.comparator }} {{ signal.warnThreshold }}</code><br>Critical: <code>{{ signal.comparator }} {{ signal.criticalThreshold }}</code></td>
              <td>{{ signal.primaryResponse ?: 'See observability runbook.' }}</td>
            </tr>
          {% else %}
            <tr>
              <td colspan="3">No reliability threshold catalog available.</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </section>

      {% if readinessDiagnostics.warnings|length %}
        <section class="border rounded p-3 warning">
          <h2 class="h4">Warnings</h2>
          <ul class="agents-link-list">
            {% for warning in readinessDiagnostics.warnings %}
              <li>{{ warning }}</li>
            {% endfor %}
          </ul>
        </section>
      {% endif %}

      <section class="border rounded p-3">
        <h2 class="h4">Advanced Diagnostics</h2>
        <details class="agents-advanced" style="margin-bottom: 8px;">
          <summary><strong>Health Data (Technical JSON)</strong></summary>
          <pre class="border rounded p-3">{{ readinessHealthJson }}</pre>
        </details>
        <details class="agents-advanced" style="margin-bottom: 8px;">
          <summary><strong>Readiness Data (Technical JSON)</strong></summary>
          <pre class="border rounded p-3">{{ readinessSummaryJson }}</pre>
        </details>
        <details class="agents-advanced">
          <summary><strong>Diagnostics (Technical JSON)</strong></summary>
          <pre class="border rounded p-3">{{ readinessDiagnosticsJson }}</pre>
        </details>
      </section>
    {% endif %}

    {% if activeDashboardTab == 'discovery' %}
      <section class="border rounded p-3">
        <h2 class="h4">Quick Actions</h2>
        <div class="agents-actions" style="margin-bottom: 8px;">
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="all">
            <button class="btn submit" type="submit">Refresh All</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="llms">
            <button class="btn" type="submit">Refresh llms.txt</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="llms-full">
            <button class="btn" type="submit">Refresh llms-full.txt</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="commerce">
            <button class="btn" type="submit">Refresh commerce.txt</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/clear-discovery-cache') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <button class="btn" type="submit">Clear cache</button>
          </form>
        </div>
        <p class="agents-subtle">Refresh cache after content or settings changes.</p>
      </section>

      <div class="agents-grid">
        {% for key, document in discoveryStatus.documents %}
          <section class="border rounded p-3">
            <h2 class="h4">{{ document.name }}</h2>
            <p>
              <span class="status {{ document.enabled ? 'enabled' : 'disabled' }}"></span>
              <strong>{{ document.enabled ? 'Enabled' : 'Disabled' }}</strong>
              <span class="agents-subtle">({{ document.path }})</span>
            </p>

            <table class="data fullwidth" style="margin-bottom: 8px;">
              <tbody>
              <tr>
                <th>URL</th>
                <td><a href="{{ document.url }}" target="_blank" rel="noopener">{{ document.url }}</a></td>
              </tr>
              <tr>
                <th>Last Modified</th>
                <td>{{ document.lastModified ?: 'n/a' }}</td>
              </tr>
              <tr>
                <th>Cache TTL</th>
                <td>{{ document.cacheTtlSeconds }} seconds</td>
              </tr>
              </tbody>
            </table>

            <details class="agents-advanced" style="margin-bottom: 8px;">
              <summary><strong>Preview</strong></summary>
              <pre class="rounded p-3" style="border: 1px solid #d1d5db; background: #f9fafb;"><code style="background: transparent; color: inherit;">{{ document.preview ?: '# Disabled' }}</code></pre>
            </details>

            <details class="agents-advanced">
              <summary><strong>Details</strong></summary>
              <table class="data fullwidth" style="margin-top: 8px;">
                <tbody>
                <tr><th>ETag</th><td>{{ document.etag ?: 'n/a' }}</td></tr>
                <tr><th>Bytes</th><td>{{ document.bytes }}</td></tr>
                <tr><th>Lines</th><td>{{ document.lineCount }}</td></tr>
                </tbody>
              </table>
            </details>
          </section>
        {% endfor %}
      </div>

      <section class="border rounded p-3">
        <h2 class="h4">Editing Path</h2>
        <ul class="agents-link-list">
          <li>Use <strong>Settings</strong> for custom body edits to <code>llms.txt</code> and <code>commerce.txt</code>.</li>
          <li>Use <code>config/agents.php</code> when you need environment-level overrides/lock-state.</li>
          <li>Use this tab for refresh and verification only.</li>
          <li>Do not place secrets in discovery documents.</li>
        </ul>
      </section>


      <hr>


      <section class="border rounded p-3">
        <details class="agents-advanced">
          <summary><strong>Discovery Docs Status (Technical JSON)</strong></summary>
          <pre class="border rounded p-3">{{ discoveryStatusJson }}</pre>
        </details>
      </section>
    {% endif %}

    {% if activeDashboardTab == 'security' %}
      {% set securityTokenRequired = securityPosture.authentication.required ?? false %}
      {% set securityCredentialCount = securityPosture.authentication.credentialCount|default(0) %}
      {% set securityWarnings = securityPosture.warningCounts.warnings|default(0) %}
      {% set securityErrors = securityPosture.warningCounts.errors|default(0) %}
      {% set securityDlqCount = webhookDeadLetters|length %}
      {% set securityTokenRequiredClass = securityTokenRequired ? 'agents-metric--good' : 'agents-metric--bad' %}
      {% set securityCredentialCountClass = securityCredentialCount > 0 ? 'agents-metric--good' : 'agents-metric--bad' %}
      {% set securityWarningsClass = securityWarnings == 0
        ? 'agents-metric--good'
        : (securityWarnings <= 3 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set securityErrorsClass = securityErrors == 0
        ? 'agents-metric--good'
        : (securityErrors == 1 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set securityDlqClass = securityDlqCount == 0
        ? 'agents-metric--good'
        : (securityDlqCount <= 10 ? 'agents-metric--warn' : 'agents-metric--bad') %}

      <section class="border rounded p-3">
        <h2 class="h4">Security Snapshot</h2>
        <div class="agents-metric-grid">
          <div class="agents-metric {{ securityTokenRequiredClass }}">
            <div class="label">Token required</div>
            <div class="value">{{ securityTokenRequired ? 'Yes' : 'No' }}</div>
          </div>
          <div class="agents-metric {{ securityCredentialCountClass }}">
            <div class="label">Active credentials</div>
            <div class="value">{{ securityCredentialCount }}</div>
          </div>
          <div class="agents-metric {{ securityWarningsClass }}">
            <div class="label">Warnings</div>
            <div class="value">{{ securityWarnings }}</div>
          </div>
          <div class="agents-metric {{ securityErrorsClass }}">
            <div class="label">Errors</div>
            <div class="value">{{ securityErrors }}</div>
          </div>
          <div class="agents-metric {{ securityDlqClass }}">
            <div class="label">DLQ events</div>
            <div class="value">{{ securityDlqCount }}</div>
          </div>
        </div>
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Environment Profile</h2>
        <ul class="agents-link-list">
          <li>Environment: <strong>{{ securityPosture.environment|default('unknown') }}</strong></li>
          <li>Profile: <strong>{{ securityPosture.profile.name|default('unknown') }}</strong></li>
          <li>Profile source: <strong>{{ securityPosture.profile.source|default('unknown') }}</strong></li>
          <li>Profile defaults applied: <strong>{{ securityPosture.profile.defaultsApplied ? 'yes' : 'no' }}</strong></li>
          <li>Effective policy version: <strong>{{ securityPosture.profile.effectivePolicyVersion|default('n/a') }}</strong></li>
        </ul>
        {% if securityPosture.profile.defaultsAppliedFields|length %}
          <p class="agents-subtle" style="margin-top: 8px;">
            Profile default fields: <strong>{{ securityPosture.profile.defaultsAppliedFields|join(', ') }}</strong>
          </p>
        {% endif %}
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Auth and Rate Posture</h2>
        <div class="agents-two-col">
          <div>
            <span class="agents-kicker">Authentication</span>
            <ul class="agents-link-list">
              <li>Token required: <strong>{{ securityPosture.authentication.required ? 'yes' : 'no' }}</strong></li>
              <li>Configured requirement: <strong>{{ securityPosture.authentication.requestedRequireToken ? 'yes' : 'no' }}</strong></li>
              <li>Forced in production: <strong>{{ securityPosture.authentication.tokenRequirementForcedInProd ? 'yes' : 'no' }}</strong></li>
              <li>Allow query-token auth: <strong>{{ securityPosture.authentication.allowQueryToken ? 'enabled' : 'disabled' }}</strong></li>
              <li>Fail in production when token missing: <strong>{{ securityPosture.authentication.failOnMissingTokenInProd ? 'yes' : 'no' }}</strong></li>
              <li>Env credentials: <strong>{{ securityPosture.authentication.envCredentialCount|default(0) }}</strong></li>
              <li>Managed CP credentials: <strong>{{ securityPosture.authentication.managedCredentialCount|default(0) }}</strong></li>
            </ul>
          </div>
          <div>
            <span class="agents-kicker">Rate limit and privacy</span>
            <ul class="agents-link-list">
              <li>Rate limit: <strong>{{ securityPosture.rateLimit.perMinute }}</strong> requests / {{ securityPosture.rateLimit.windowSeconds }}s</li>
              <li>Email redaction: <strong>{{ securityPosture.privacy.redactEmail ? 'enabled' : 'disabled' }}</strong></li>
              <li>Default scopes listed in runtime policy</li>
            </ul>
            <details class="agents-advanced" style="margin-top: 8px;">
              <summary><strong>Default token scopes</strong></summary>
              <ul class="agents-link-list" style="margin-top: 8px;">
                {% for scope in securityPosture.authentication.tokenScopes %}
                  <li>{{ scope }}</li>
                {% endfor %}
              </ul>
            </details>
          </div>
        </div>
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Webhook Reliability</h2>
        <ul class="agents-link-list" style="margin-bottom: 12px;">
          <li>Webhook enabled: <strong>{{ securityPosture.webhook.enabled ? 'yes' : 'no' }}</strong></li>
          <li>Webhook URL configured: <strong>{{ securityPosture.webhook.urlConfigured ? 'yes' : 'no' }}</strong></li>
          <li>Webhook secret configured: <strong>{{ securityPosture.webhook.secretConfigured ? 'yes' : 'no' }}</strong></li>
          <li>Destination host: <strong>{{ securityPosture.webhook.destinationHost ?: 'n/a' }}</strong></li>
          <li>Timeout seconds: <strong>{{ securityPosture.webhook.timeoutSeconds }}</strong></li>
          <li>Max attempts: <strong>{{ securityPosture.webhook.maxAttempts }}</strong></li>
        </ul>

        <h3 class="h5">Dead-Letter Queue</h3>
        <p class="agents-subtle">Final delivery failures are stored here and can be replayed.</p>

        <form method="post" accept-charset="UTF-8" style="margin-bottom: 10px;">
          {{ csrfInput() }}
          {{ actionInput('agents/dashboard/replay-webhook-dlq') }}
          {{ redirectInput('agents/dashboard/security') }}
          <input type="hidden" name="mode" value="all">
          <input type="hidden" name="limit" value="25">
          <button class="btn" type="submit">Replay up to 25 failed events</button>
        </form>

        {% if webhookDeadLetters|length %}
          <table class="data fullwidth">
            <thead>
            <tr>
              <th>ID</th>
              <th>Event</th>
              <th>Status</th>
              <th>Attempts</th>
              <th>Last Error</th>
              <th>Updated</th>
              <th>Replay</th>
            </tr>
            </thead>
            <tbody>
            {% for row in webhookDeadLetters %}
              <tr>
                <td>#{{ row.id }}</td>
                <td>
                  <code>{{ row.eventId }}</code><br>
                  <span class="light">{{ row.resourceType ?: 'resource' }}:{{ row.resourceId ?: 'n/a' }} {{ row.action ? '(' ~ row.action ~ ')' : '' }}</span>
                </td>
                <td><strong>{{ row.status }}</strong></td>
                <td>{{ row.attempts }}</td>
                <td>{{ row.lastError ?: 'n/a' }}</td>
                <td>{{ row.dateUpdated ?: row.dateCreated ?: 'n/a' }}</td>
                <td>
                  <form method="post" accept-charset="UTF-8">
                    {{ csrfInput() }}
                    {{ actionInput('agents/dashboard/replay-webhook-dlq') }}
                    {{ redirectInput('agents/dashboard/security') }}
                    <input type="hidden" name="id" value="{{ row.id }}">
                    <button class="btn" type="submit">Replay</button>
                  </form>
                </td>
              </tr>
            {% endfor %}
            </tbody>
          </table>
        {% else %}
          <p>No dead-letter events.</p>
        {% endif %}
      </section>


      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Warnings</h2>
        {% if securityPosture.warnings|length %}
          <ul class="agents-link-list">
            {% for warning in securityPosture.warnings %}
              <li><strong>[{{ warning.level|upper }}]</strong> {{ warning.message }}</li>
            {% endfor %}
          </ul>
        {% else %}
          <p>No active security warnings.</p>
        {% endif %}
      </section>


      <hr>


      <section class="border rounded p-3">
        <details class="agents-advanced">
          <summary><strong>Security Data (Technical JSON)</strong></summary>
          <pre class="border rounded p-3">{{ securityPostureJson }}</pre>
        </details>
      </section>
    {% endif %}
  </div>
{% endblock %}
