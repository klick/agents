{% extends "_layouts/cp" %}
{% set title = "Agents Dashboard" %}
{% set selectedSubnavItem = "dashboard" %}
{% set dashboardHeadingByKey = {
  overview: 'Overview',
  readiness: 'Readiness',
  discovery: 'Discovery Docs',
  security: 'Security',
} %}
{% set dashboardHeading = dashboardHeadingByKey[activeDashboardTab]|default('Overview') %}
{% set tabIntroByKey = {
  overview: 'Operate the runtime, verify what is enabled, and jump straight to the right place for each change.',
  readiness: 'Review health signals, lag telemetry, and warnings before integrations or releases.',
  discovery: 'Manage discovery document freshness and quickly inspect what external agents can read.',
  security: 'Monitor auth posture, webhook reliability, and security warnings in one place.'
} %}
{% set dashboardSidebarNavItems = {} %}
{% for tab in dashboardTabs %}
  {% set dashboardSidebarNavItems = dashboardSidebarNavItems|merge({
    (tab.key): {
      label: tab.label,
      url: tab.url,
    }
  }) %}
{% endfor %}

{% block sidebar %}
  {% include "_includes/nav"
    with {
      label: 'Dashboard',
      items: dashboardSidebarNavItems,
      selectedItem: activeDashboardTab,
    }
    only
  %}
{% endblock %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <div class="agents-page-header">
    <h1>{{ dashboardHeading }}</h1>
    <p class="agents-page-intro">{{ tabIntroByKey[activeDashboardTab] ?? 'Operator dashboard for governed runtime workflows.' }}</p>
  </div>

  <div class="agents-layout-stack">
    {% if activeDashboardTab == 'overview' %}
      {% set discoveryEnabledCount = (discoveryEnabled.llms ? 1 : 0) + (discoveryEnabled.llmsFull ? 1 : 0) + (discoveryEnabled.commerce ? 1 : 0) %}
      {% set overviewReadinessScore = overviewReadiness.readinessScore|default(0) %}
      {% set overviewWarnings = securityWarningCounts.warnings|default(0) %}
      {% set overviewErrors = securityWarningCounts.errors|default(0) %}
      {% set readinessMetricClass = overviewReadinessScore >= 100
        ? 'agents-metric--good'
        : (overviewReadinessScore >= 80 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set warningMetricClass = overviewWarnings == 0
        ? 'agents-metric--good'
        : (overviewWarnings <= 3 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set errorMetricClass = overviewErrors == 0
        ? 'agents-metric--good'
        : (overviewErrors == 1 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set discoveryDocsMetricClass = discoveryEnabledCount >= 3
        ? 'agents-metric--good'
        : (discoveryEnabledCount > 0 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set webhookDeliveryMetricClass = webhookEnabled
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}

      <section class="border rounded p-3">
        <h2 class="h4">At a Glance</h2>
        <div class="agents-overview-strip-wrap agents-metric-strip-wrap">
          <div class="agents-overview-strip agents-metric-strip">
          <div class="agents-metric agents-overview-strip-card agents-metric-strip-card {{ agentsEnabled ? 'agents-metric--good' : 'agents-metric--bad' }}">
            <div class="label">Runtime state</div>
            <div class="value" style="display: flex; align-items: center; gap: 8px;">
              <span class="status {{ agentsEnabled ? 'enabled' : 'disabled' }}"></span>
              {{ agentsEnabled ? 'Enabled' : 'Disabled' }}
            </div>
          </div>
          <div class="agents-metric agents-overview-strip-card agents-metric-strip-card {{ readinessMetricClass }}">
            <div class="label">Readiness score</div>
            <div class="value">{{ overviewReadinessScore }}/100</div>
          </div>
          <div class="agents-metric agents-overview-strip-card agents-metric-strip-card {{ discoveryDocsMetricClass }}">
            <div class="label">Discovery docs enabled</div>
            <div class="value">{{ discoveryEnabledCount }}/3</div>
          </div>
          <div class="agents-metric agents-overview-strip-card agents-metric-strip-card {{ webhookDeliveryMetricClass }}">
            <div class="label">Webhook delivery</div>
            <div class="value">{{ webhookEnabled ? 'On' : 'Off' }}</div>
          </div>
          <div class="agents-metric agents-overview-strip-card agents-metric-strip-card {{ warningMetricClass }}">
            <div class="label">Security warnings</div>
            <div class="value">{{ overviewWarnings }}</div>
          </div>
          <div class="agents-metric agents-overview-strip-card agents-metric-strip-card {{ errorMetricClass }}">
            <div class="label">Security errors</div>
            <div class="value">{{ overviewErrors }}</div>
          </div>
          </div>
        </div>
      </section>


      <hr>


      <section class="border rounded p-3" id="diagnosticsBundleSection">
        <h2 class="h4">Diagnostics Bundle</h2>
        <form method="post" accept-charset="UTF-8">
          {{ csrfInput() }}
          {{ actionInput('agents/dashboard/download-diagnostics-bundle') }}
          {{ redirectInput('agents/dashboard/overview') }}
          <button class="btn submit" type="submit">Download Diagnostics Bundle (.json)</button>
        </form>
        <p class="agents-subtle">Runs auth/discovery/readiness/smoke checks and exports a support artifact for support handoff.</p>
      </section>

      <hr>


      <section class="border rounded p-3">
        <h2 class="h4">Readiness Snapshot</h2>
        <p>Status: <strong>{{ overviewReadiness.status|default('unknown') }}</strong></p>
        <p>Score: <strong>{{ overviewReadiness.readinessScore|default(0) }}</strong> / 100</p>
        <details class="agents-advanced">
          <summary><strong>Technical JSON</strong></summary>
          <pre class="border rounded p-3">{{ overviewReadinessJson }}</pre>
        </details>
      </section>
    {% endif %}

    {% if activeDashboardTab == 'readiness' %}
      {% set readinessPreviewState = (craft.app.request.getQueryParam('previewState') ?? '')|lower %}
      {% set readinessTabScore = readinessSummary.readinessScore|default(0) %}
      {% set readinessTabStatus = (readinessSummary.status|default('unknown'))|lower %}
      {% set readinessTabWarnings = readinessDiagnostics.warnings|length %}
      {% set readinessTabConsumerCount = consumerLagSummary.count|default(0) %}
      {% set readinessTabMaxLagSeconds = consumerLagSummary.maxLagSeconds|default(0) %}
      {% set readinessTabScoreClass = readinessTabScore >= 100
        ? 'agents-metric--good'
        : (readinessTabScore >= 80 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabStatusClass = readinessTabStatus in ['ready', 'healthy', 'ok']
        ? 'agents-metric--good'
        : (readinessTabStatus in ['degraded', 'warning', 'warn', 'partial'] ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabWarningsClass = readinessTabWarnings == 0
        ? 'agents-metric--good'
        : (readinessTabWarnings <= 3 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set readinessTabConsumerCountClass = readinessTabConsumerCount > 0
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}
      {% set readinessTabLagClass = readinessTabConsumerCount == 0
        ? 'agents-metric--warn'
        : (readinessTabMaxLagSeconds <= 60 ? 'agents-metric--good' : (readinessTabMaxLagSeconds <= 300 ? 'agents-metric--warn' : 'agents-metric--bad')) %}
      {% set telemetryRequestsTotal = observabilitySummary.requestsTotal|default(0) %}
      {% set telemetryAuthFailures = observabilitySummary.authFailuresTotal|default(0) %}
      {% set telemetryForbidden = observabilitySummary.forbiddenTotal|default(0) %}
      {% set telemetryRateLimit = observabilitySummary.rateLimitExceededTotal|default(0) %}
      {% set telemetryErrors5xx = observabilitySummary.errors5xxTotal|default(0) %}
      {% set telemetryQueueDepth = observabilitySummary.queueDepth|default(0) %}
      {% set telemetryDlqFailed = observabilitySummary.webhookDlqFailed|default(0) %}
      {% set telemetryConsumerLagMaxSeconds = observabilitySummary.consumerLagMaxSeconds|default(0) %}
      {% set telemetryActiveCredentials7d = observabilitySummary.activeCredentials7d|default(0) %}
      {% set reliabilityStatus = (observabilitySummary.reliabilityStatus|default('ok'))|lower %}
      {% set reliabilitySignalsWarn = observabilitySummary.reliabilitySignalsWarn|default(0) %}
      {% set reliabilitySignalsCritical = observabilitySummary.reliabilitySignalsCritical|default(0) %}
      {% set reliabilitySignalsEvaluated = observabilitySummary.reliabilitySignalsEvaluated|default(0) %}
      {% set reliabilityTopSignals = observabilitySummary.reliabilityTopSignals|default([]) %}
      {% set telemetryRequestsClass = telemetryRequestsTotal > 0 ? 'agents-metric--good' : 'agents-metric--warn' %}
      {% set telemetryAuthFailuresClass = telemetryAuthFailures == 0
        ? 'agents-metric--good'
        : (telemetryAuthFailures <= 5 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryForbiddenClass = telemetryForbidden == 0
        ? 'agents-metric--good'
        : (telemetryForbidden <= 5 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryRateLimitClass = telemetryRateLimit == 0
        ? 'agents-metric--good'
        : (telemetryRateLimit <= 10 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryErrors5xxClass = telemetryErrors5xx == 0
        ? 'agents-metric--good'
        : (telemetryErrors5xx <= 2 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryQueueDepthClass = telemetryQueueDepth <= 10
        ? 'agents-metric--good'
        : (telemetryQueueDepth <= 50 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryDlqFailedClass = telemetryDlqFailed == 0
        ? 'agents-metric--good'
        : (telemetryDlqFailed <= 10 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryConsumerLagClass = telemetryConsumerLagMaxSeconds <= 60
        ? 'agents-metric--good'
        : (telemetryConsumerLagMaxSeconds <= 300 ? 'agents-metric--warn' : 'agents-metric--bad') %}
      {% set telemetryActiveCredentialsClass = telemetryActiveCredentials7d > 0
        ? 'agents-metric--good'
        : 'agents-metric--warn' %}
      {% set reliabilityStatusClass = reliabilityStatus == 'critical'
        ? 'agents-metric--bad'
        : (reliabilityStatus == 'warn' ? 'agents-metric--warn' : 'agents-metric--good') %}
      {% set securityCredentialCount = securityPosture.authentication.credentialCount|default(0) %}
      {% set securityTokenRequired = securityPosture.authentication.required ?? false %}
      {% set securityPrivacyEnabled = securityPosture.privacy.redactEmail ?? false %}
      {% set webhookEnabledForReadiness = securityPosture.webhook.enabled ?? false %}
      {% set readinessDbAvailable = readinessDiagnostics.componentChecks.systemComponents.db ?? false %}
      {% set readinessCacheAvailable = readinessDiagnostics.componentChecks.systemComponents.cache ?? false %}
      {% set readinessUsersAvailable = readinessDiagnostics.componentChecks.systemComponents.users ?? false %}
      {% set readinessCoreServicesOk = readinessDbAvailable and readinessCacheAvailable and readinessUsersAvailable %}
      {% set readinessSecurityWarnings = securityWarningCounts.warnings|default(0) %}
      {% set readinessSecurityErrors = securityWarningCounts.errors|default(0) %}
      {% set readinessConsumerLagWarningCount = consumerLagSummary.warning|default(0) %}
      {% set readinessConsumerLagCriticalCount = consumerLagSummary.critical|default(0) %}
      {% set readinessHasIntegrationTelemetry = readinessTabConsumerCount > 0 or consumerLagRows|length > 0 %}
      {% set readinessGeneratedAt = observabilitySummary.generatedAt|default(readinessSummary.generatedAt|default('')) %}
      {% set readinessGeneratedAtTimestamp = readinessGeneratedAt ? readinessGeneratedAt|date('U') : 0 %}
      {% set readinessNowTimestamp = 'now'|date('U') %}
      {% set readinessEvaluatedAgeSeconds = readinessGeneratedAtTimestamp > 0 ? (readinessNowTimestamp - readinessGeneratedAtTimestamp) : null %}
      {% set readinessMetricsCurrent = readinessEvaluatedAgeSeconds is not same as(null) and readinessEvaluatedAgeSeconds >= 0 and readinessEvaluatedAgeSeconds <= 300 %}
      {% set readinessHasObservedTraffic = telemetryRequestsTotal > 0 %}
      {% set readinessHasActiveCredentials = telemetryActiveCredentials7d > 0 %}
      {% set readinessEvaluationLabel = 'unknown' %}
      {% if readinessEvaluatedAgeSeconds is not same as(null) %}
        {% if readinessEvaluatedAgeSeconds < 60 %}
          {% set readinessEvaluationLabel = 'just now' %}
        {% elseif readinessEvaluatedAgeSeconds < 3600 %}
          {% set readinessMinutesAgo = (readinessEvaluatedAgeSeconds / 60)|round(0, 'floor') %}
          {% set readinessEvaluationLabel = readinessMinutesAgo ~ ' minute' ~ (readinessMinutesAgo == 1 ? '' : 's') ~ ' ago' %}
        {% elseif readinessEvaluatedAgeSeconds < 86400 %}
          {% set readinessHoursAgo = (readinessEvaluatedAgeSeconds / 3600)|round(0, 'floor') %}
          {% set readinessEvaluationLabel = readinessHoursAgo ~ ' hour' ~ (readinessHoursAgo == 1 ? '' : 's') ~ ' ago' %}
        {% else %}
          {% set readinessDaysAgo = (readinessEvaluatedAgeSeconds / 86400)|round(0, 'floor') %}
          {% set readinessEvaluationLabel = readinessDaysAgo ~ ' day' ~ (readinessDaysAgo == 1 ? '' : 's') ~ ' ago' %}
        {% endif %}
      {% endif %}
      {% set readinessHasTrafficIssues = telemetryAuthFailures > 0
        or telemetryForbidden > 0
        or telemetryRateLimit > 0
        or telemetryErrors5xx > 0 %}
      {% set readinessHasDeliveryIssues = webhookEnabledForReadiness and telemetryDlqFailed > 0 %}
      {% set readinessHasIntegrationIssues = readinessConsumerLagWarningCount > 0
        or readinessConsumerLagCriticalCount > 0
        or telemetryConsumerLagMaxSeconds > 60 %}
      {% set readinessHasSecurityIssues = readinessSecurityWarnings > 0 or readinessSecurityErrors > 0 %}
      {% set readinessHasCapacityIssues = telemetryQueueDepth > 10 %}
      {% set readinessHasBlockingGate = (not agentsEnabled) or (not readinessDbAvailable) or securityCredentialCount == 0 %}
      {% set readinessHasDegradedSignals = readinessTabWarnings > 0
        or reliabilityStatus in ['warn', 'critical']
        or reliabilitySignalsWarn > 0
        or reliabilitySignalsCritical > 0
        or readinessHasTrafficIssues
        or readinessHasDeliveryIssues
        or readinessHasIntegrationIssues
        or readinessHasSecurityIssues
        or readinessHasCapacityIssues %}
      {% set readinessHasLowConfidence = (not readinessMetricsCurrent)
        or reliabilitySignalsEvaluated == 0
        or (not readinessHasObservedTraffic)
        or (not readinessHasActiveCredentials) %}
      {% set readinessBlockingCount = 0 %}
      {% if not agentsEnabled %}
        {% set readinessBlockingCount = readinessBlockingCount + 1 %}
      {% endif %}
      {% if not readinessDbAvailable %}
        {% set readinessBlockingCount = readinessBlockingCount + 1 %}
      {% endif %}
      {% if securityCredentialCount == 0 %}
        {% set readinessBlockingCount = readinessBlockingCount + 1 %}
      {% endif %}
      {% set readinessStateKey = 'ready' %}
      {% set readinessStateLabel = 'Ready' %}
      {% set readinessStateLead = 'Ready for machine traffic' %}
      {% set readinessStateSubcopy = 'No issues need attention right now.' %}
      {% set readinessStateTone = 'good' %}
      {% if readinessHasBlockingGate %}
        {% set readinessStateKey = 'blocked' %}
        {% set readinessStateLabel = 'Blocked' %}
        {% set readinessStateLead = 'Agents is not operationally fit for live machine traffic.' %}
        {% set readinessStateSubcopy = 'Resolve the blocking issues below before trusting this environment for production traffic.' %}
        {% set readinessStateTone = 'bad' %}
      {% elseif readinessHasDegradedSignals %}
        {% set readinessStateKey = 'degraded' %}
        {% set readinessStateLabel = 'Degraded' %}
        {% set readinessStateLead = 'Agents is handling traffic, but some conditions need attention.' %}
        {% set readinessStateSubcopy = 'Review the affected areas below, then use the detailed sections for full context.' %}
        {% set readinessStateTone = 'warn' %}
      {% elseif readinessHasLowConfidence %}
        {% set readinessStateKey = 'unproven' %}
        {% set readinessStateLabel = 'Unproven' %}
        {% set readinessStateLead = 'No blocking issues were detected, but live-readiness confidence is limited.' %}
        {% set readinessStateSubcopy = 'Recent traffic, credential activity, or observability freshness is too thin for a high-confidence assessment.' %}
        {% set readinessStateTone = 'muted' %}
      {% endif %}
      {% set readinessShowReadyState = readinessStateKey == 'ready' %}
      {% set readinessConfidenceLabel = readinessHasObservedTraffic and readinessHasActiveCredentials and readinessMetricsCurrent
        ? 'high'
        : 'limited' %}
      {% set readinessTrafficLead = 'Guarded requests observed in the last 60 minutes' %}
      {% if not agentsEnabled %}
        {% set readinessTrafficLead = 'Runtime is disabled, so guarded traffic is blocked' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessTrafficLead = 'Recent traffic metrics are stale' %}
      {% elseif not readinessHasObservedTraffic %}
        {% set readinessTrafficLead = 'No guarded requests observed in the last 60 minutes' %}
      {% elseif telemetryErrors5xx > 0 %}
        {% set readinessTrafficLead = 'Server errors are occurring on guarded routes' %}
      {% elseif telemetryAuthFailures > 0 or telemetryForbidden > 0 or telemetryRateLimit > 0 %}
        {% set readinessTrafficLead = 'Guarded traffic is seeing auth, scope, or rate-limit issues' %}
      {% endif %}
      {% set readinessDeliveryLead = 'Webhook delivery path is operational' %}
      {% if not webhookEnabledForReadiness %}
        {% set readinessDeliveryLead = 'Webhook delivery is not enabled for this environment' %}
      {% elseif telemetryDlqFailed > 0 %}
        {% set readinessDeliveryLead = 'Webhook delivery failures need replay or investigation' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessDeliveryLead = 'Delivery metrics are stale' %}
      {% endif %}
      {% set readinessDeliverySummary = 'No recent delivery failures detected' %}
      {% if not webhookEnabledForReadiness %}
        {% set readinessDeliverySummary = 'No delivery path is configured in this environment' %}
      {% elseif telemetryDlqFailed > 0 %}
        {% set readinessDeliverySummary = telemetryDlqFailed ~ ' failed event' ~ (telemetryDlqFailed == 1 ? '' : 's') ~ ' need attention' %}
      {% endif %}
      {% set readinessIntegrationLead = 'No sync-state integrations are configured' %}
      {% if readinessConsumerLagCriticalCount > 0 %}
        {% set readinessIntegrationLead = 'One or more integrations are in critical lag' %}
      {% elseif readinessConsumerLagWarningCount > 0 or telemetryConsumerLagMaxSeconds > 60 %}
        {% set readinessIntegrationLead = 'One or more integrations are lagging behind' %}
      {% elseif readinessHasIntegrationTelemetry %}
        {% set readinessIntegrationLead = readinessMetricsCurrent ? 'Sync-state checkpoints are reporting' : 'Integration lag metrics are stale' %}
      {% endif %}
      {% set readinessIntegrationLagLine = 'Max sync lag is below warning threshold' %}
      {% if readinessConsumerLagCriticalCount > 0 %}
        {% set readinessIntegrationLagLine = readinessConsumerLagCriticalCount ~ ' critical lag issue' ~ (readinessConsumerLagCriticalCount == 1 ? '' : 's') ~ ' detected' %}
      {% elseif readinessConsumerLagWarningCount > 0 %}
        {% set readinessIntegrationLagLine = readinessConsumerLagWarningCount ~ ' warning lag issue' ~ (readinessConsumerLagWarningCount == 1 ? '' : 's') ~ ' detected' %}
      {% elseif telemetryConsumerLagMaxSeconds > 60 %}
        {% set readinessIntegrationLagLine = 'Max sync lag is above warning threshold' %}
      {% endif %}
      {% set readinessIntegrationStatusLine = 'No integrations are in warning or critical lag' %}
      {% if readinessConsumerLagWarningCount > 0 or readinessConsumerLagCriticalCount > 0 %}
        {% set readinessIntegrationStatusLine = 'Review lagging integrations in the table below' %}
      {% endif %}
      {% set readinessCheckpointLine = readinessHasIntegrationTelemetry
        ? 'Checkpoint telemetry available'
        : 'Checkpoint telemetry has not been submitted yet' %}
      {% set readinessCredentialLine = 'Runtime credentials available for access' %}
      {% if securityCredentialCount == 0 %}
        {% set readinessCredentialLine = 'No runtime credentials configured' %}
      {% elseif (securityPosture.authentication.managedCredentialCount|default(0)) > 0 %}
        {% set readinessCredentialLine = 'Managed credentials available for runtime access' %}
      {% endif %}
      {% set readinessCapacityLead = telemetryQueueDepth > 10
        ? 'Queue depth is elevated and may slow runtime work'
        : 'Queue depth is within normal range' %}
      {% set readinessBackpressureLine = 'No runtime backpressure detected' %}
      {% if telemetryQueueDepth > 50 %}
        {% set readinessBackpressureLine = 'Runtime backpressure is likely' %}
      {% elseif telemetryQueueDepth > 10 %}
        {% set readinessBackpressureLine = 'Runtime backpressure is building' %}
      {% endif %}
      {% set readinessCapacityLine = readinessHasActiveCredentials
        ? 'Active credentials seen in the last 7 days'
        : 'No recent credential usage observed' %}
      {% set readinessTokenLine = securityTokenRequired
        ? 'Token authentication required'
        : 'Token requirement is relaxed for this environment' %}
      {% set readinessPrivacyLine = securityPrivacyEnabled
        ? 'Default privacy protections active'
        : 'Privacy redaction is not enabled' %}
      {% set readinessSecurityStatusLine = readinessHasSecurityIssues
        ? 'Security warnings need review'
        : 'No active security warnings' %}
      {% set readinessObservabilityLine = readinessMetricsCurrent
        ? 'Runtime metrics snapshot available'
        : 'Runtime metrics snapshot is stale or missing' %}
      {% set readinessReliabilityLine = reliabilitySignalsEvaluated > 0
        ? 'Reliability thresholds evaluated'
        : 'Reliability thresholds have not been evaluated recently' %}
      {% set readinessReliabilityStatusLine = 'No warning or critical reliability signals detected' %}
      {% if reliabilitySignalsCritical > 0 %}
        {% set readinessReliabilityStatusLine = reliabilitySignalsCritical ~ ' critical reliability signal' ~ (reliabilitySignalsCritical == 1 ? '' : 's') ~ ' detected' %}
      {% elseif reliabilitySignalsWarn > 0 %}
        {% set readinessReliabilityStatusLine = reliabilitySignalsWarn ~ ' warning reliability signal' ~ (reliabilitySignalsWarn == 1 ? '' : 's') ~ ' detected' %}
      {% endif %}
      {% set readinessMonitoringLine = readinessHasObservedTraffic and readinessMetricsCurrent
        ? 'Monitoring is active for live traffic'
        : (readinessMetricsCurrent
          ? 'Monitoring is active, but recent traffic is limited'
          : 'Monitoring confidence is limited by stale metrics') %}
      {% set readinessHardGateRuntimeLine = agentsEnabled ? 'Runtime is enabled' : 'Runtime is disabled' %}
      {% set readinessHardGateDatabaseLine = readinessDbAvailable ? 'Database connection available' : 'Database connection unavailable' %}
      {% set readinessHardGateServicesLine = readinessCoreServicesOk ? 'Core Craft services available' : 'One or more core Craft services need attention' %}
      {% set readinessHardGateStatusLine = readinessHasBlockingGate
        ? readinessBlockingCount ~ ' blocking issue' ~ (readinessBlockingCount == 1 ? '' : 's') ~ ' detected'
        : 'No blocking configuration issues detected' %}
      {% set readinessTrafficSummaryTone = 'good' %}
      {% set readinessTrafficSummaryLabel = 'Good' %}
      {% if (not agentsEnabled) or (not readinessDbAvailable) %}
        {% set readinessTrafficSummaryTone = 'bad' %}
        {% set readinessTrafficSummaryLabel = 'Blocked' %}
      {% elseif readinessHasTrafficIssues %}
        {% set readinessTrafficSummaryTone = 'warn' %}
        {% set readinessTrafficSummaryLabel = 'Needs attention' %}
      {% elseif (not readinessMetricsCurrent) or (not readinessHasObservedTraffic) %}
        {% set readinessTrafficSummaryTone = 'muted' %}
        {% set readinessTrafficSummaryLabel = 'Unproven' %}
      {% endif %}
      {% set readinessDeliverySummaryTone = 'good' %}
      {% set readinessDeliverySummaryLabel = 'Good' %}
      {% if not webhookEnabledForReadiness %}
        {% set readinessDeliverySummaryTone = 'muted' %}
        {% set readinessDeliverySummaryLabel = 'Not enabled' %}
      {% elseif telemetryDlqFailed > 0 %}
        {% set readinessDeliverySummaryTone = 'warn' %}
        {% set readinessDeliverySummaryLabel = 'Needs attention' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessDeliverySummaryTone = 'muted' %}
        {% set readinessDeliverySummaryLabel = 'Unproven' %}
      {% endif %}
      {% set readinessIntegrationSummaryTone = 'good' %}
      {% set readinessIntegrationSummaryLabel = 'Good' %}
      {% if not readinessHasIntegrationTelemetry %}
        {% set readinessIntegrationSummaryTone = 'muted' %}
        {% set readinessIntegrationSummaryLabel = 'Not enabled' %}
      {% elseif readinessHasIntegrationIssues %}
        {% set readinessIntegrationSummaryTone = 'warn' %}
        {% set readinessIntegrationSummaryLabel = 'Needs attention' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessIntegrationSummaryTone = 'muted' %}
        {% set readinessIntegrationSummaryLabel = 'Unproven' %}
      {% endif %}
      {% set readinessSecuritySummaryTone = 'good' %}
      {% set readinessSecuritySummaryLabel = 'Good' %}
      {% if securityCredentialCount == 0 %}
        {% set readinessSecuritySummaryTone = 'bad' %}
        {% set readinessSecuritySummaryLabel = 'Blocked' %}
      {% elseif readinessHasSecurityIssues %}
        {% set readinessSecuritySummaryTone = 'warn' %}
        {% set readinessSecuritySummaryLabel = 'Needs attention' %}
      {% elseif not readinessHasActiveCredentials %}
        {% set readinessSecuritySummaryTone = 'muted' %}
        {% set readinessSecuritySummaryLabel = 'Unproven' %}
      {% endif %}
      {% set readinessEvaluationProofTone = 'good' %}
      {% if not readinessMetricsCurrent or reliabilitySignalsEvaluated == 0 %}
        {% set readinessEvaluationProofTone = 'warn' %}
      {% endif %}
      {% set readinessHardGateProofTone = readinessHasBlockingGate ? 'bad' : 'good' %}
      {% set readinessTrafficProofTone = readinessTrafficSummaryTone in ['warn', 'bad'] ? readinessTrafficSummaryTone : 'good' %}
      {% set readinessDeliveryProofTone = readinessDeliverySummaryTone in ['warn', 'bad'] ? readinessDeliverySummaryTone : 'good' %}
      {% set readinessIntegrationProofTone = readinessIntegrationSummaryTone in ['warn', 'bad'] ? readinessIntegrationSummaryTone : 'good' %}
      {% set readinessSecurityProofTone = readinessSecuritySummaryTone in ['warn', 'bad'] ? readinessSecuritySummaryTone : 'good' %}
      {% set readinessCapacityProofTone = telemetryQueueDepth > 50 ? 'bad' : (telemetryQueueDepth > 10 ? 'warn' : 'good') %}
      {% set readinessObservabilityProofTone = reliabilitySignalsCritical > 0
        ? 'bad'
        : ((not readinessMetricsCurrent) or reliabilitySignalsWarn > 0 or reliabilitySignalsEvaluated == 0 ? 'warn' : 'good') %}
      {% set readinessPreviewModeEnabled = readinessPreviewState in ['ready', 'degraded', 'blocked', 'unproven'] %}
      {% if readinessPreviewState == 'ready' %}
        {% set readinessStateKey = 'ready' %}
        {% set readinessStateLabel = 'Ready' %}
        {% set readinessStateLead = 'Ready for machine traffic.' %}
        {% set readinessStateSubcopy = 'No issues need attention right now.' %}
        {% set readinessStateTone = 'good' %}
        {% set readinessShowReadyState = true %}
        {% set readinessConfidenceLabel = 'high' %}
        {% set readinessTrafficLead = 'Guarded requests observed in the last 60 minutes' %}
        {% set readinessDeliveryLead = 'Webhook delivery path is operational' %}
        {% set readinessDeliverySummary = 'No recent delivery failures detected' %}
        {% set readinessIntegrationLead = 'Sync-state checkpoints are reporting' %}
        {% set readinessIntegrationLagLine = 'Max sync lag is below warning threshold' %}
        {% set readinessIntegrationStatusLine = 'No integrations are in warning or critical lag' %}
        {% set readinessCheckpointLine = 'Checkpoint telemetry available' %}
        {% set readinessCredentialLine = 'Managed credentials available for runtime access' %}
        {% set readinessCapacityLead = 'Queue depth is within normal range' %}
        {% set readinessBackpressureLine = 'No runtime backpressure detected' %}
        {% set readinessCapacityLine = 'Active credentials seen in the last 7 days' %}
        {% set readinessTokenLine = 'Token authentication required' %}
        {% set readinessPrivacyLine = 'Default privacy protections active' %}
        {% set readinessSecurityStatusLine = 'No active security warnings' %}
        {% set readinessObservabilityLine = 'Runtime metrics snapshot available' %}
        {% set readinessReliabilityLine = 'Reliability thresholds evaluated' %}
        {% set readinessReliabilityStatusLine = 'No warning or critical reliability signals detected' %}
        {% set readinessMonitoringLine = 'Monitoring is active for live traffic' %}
        {% set readinessHardGateRuntimeLine = 'Runtime is enabled' %}
        {% set readinessHardGateDatabaseLine = 'Database connection available' %}
        {% set readinessHardGateServicesLine = 'Core Craft services available' %}
        {% set readinessHardGateStatusLine = 'No blocking configuration issues detected' %}
        {% set readinessTrafficSummaryTone = 'good' %}
