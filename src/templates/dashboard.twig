                  type="button"
                  class="agents-readiness-ready-proof-trigger"
                  data-agents-detail-open="confidenceObservabilityDetailDialog"
                  aria-haspopup="dialog"
                  aria-controls="confidenceObservabilityDetailDialog"
                  aria-label="View Confidence / Observability detail"
                >
                  <span class="agents-readiness-ready-proof-trigger-hint">View detail</span>
                </button>
              </div>
              <ul class="agents-readiness-ready-proof-list">
                <li{% if (not readinessMetricsCurrent) or reliabilitySignalsCritical > 0 or reliabilitySignalsWarn > 0 or reliabilitySignalsEvaluated == 0 or (not readinessHasObservedTraffic) or (not readinessHasActiveCredentials) %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessMetricsCurrent and reliabilitySignalsEvaluated > 0 and readinessHasObservedTraffic and readinessHasActiveCredentials %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessObservabilityLine }}</li>
                <li>Last evaluated: <strong>{{ readinessEvaluationLabel }}</strong></li>
