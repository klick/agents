          impact: 'Backpressure may delay runtime work and follow-up processing.',
          primaryAction: 'Open queue runbook',
          secondaryAction: 'Check workers',
          primaryUrl: readinessUrl ~ '#readinessProofCapacityRuntime',
          secondaryUrl: readinessUrl ~ '#readinessProofObservability',
          surface: 'External',
        },
        {
          signal: 'Stale or low-confidence observability',
          stateLabel: readinessHasMonitoringGap ? 'Unproven' : 'Clear',
          stateTone: readinessHasMonitoringGap ? 'warn' : 'muted',
          impact: 'The readiness verdict is less trustworthy because signal quality is weak.',
          primaryAction: 'Recheck readiness',
          secondaryAction: 'Inspect observability',
          primaryUrl: readinessUrl ~ '#readinessStateCard',
          secondaryUrl: readinessUrl ~ '#readinessProofObservability',
          surface: 'Readiness',
        },
      ] %}
      {% set readinessActionRowsProblematic = [] %}
      {% if readinessPreviewState == 'ready' %}
        {% set readinessActionRowsProblematic = [] %}
      {% elseif readinessPreviewState == 'degraded' %}
        {% set readinessActionRowsProblematic = [
          {
            signal: 'Auth failures',
            stateLabel: 'Needs attention',
            stateTone: 'warn',
            impact: 'Accounts may be invalid or clients may be misconfigured.',
            primaryAction: 'Review accounts',
            secondaryAction: 'Inspect denied requests',
            primaryUrl: attentionAccountsUrl ~ '#agentsCardList',
            secondaryUrl: securityUrl ~ '#authRatePostureSection',
            surface: 'Accounts',
          },
          {
            signal: 'Webhook DLQ failures',
            stateLabel: 'Not enabled',
            stateTone: 'muted',
            impact: 'Subscribers may miss changes until webhook delivery is enabled.',
            primaryAction: 'Review security detail',
            secondaryAction: 'Review webhook posture',
            primaryUrl: securityUrl ~ '#webhookReliabilitySection',
            secondaryUrl: securityUrl ~ '#securitySnapshotSection',
            surface: 'Readiness / Security',
          },
          {
            signal: 'Sync lag',
            stateLabel: 'Needs attention',
            stateTone: 'warn',
            impact: 'Downstream systems may be operating on stale Craft or Commerce data.',
            primaryAction: 'Review lagging integrations',
            secondaryAction: 'Open lag details',
            primaryUrl: readinessUrl ~ '#readinessProofIntegrationHealth',
            secondaryUrl: settingsUrl ~ '#reliabilityThresholdsSection',
            surface: 'Readiness / External',
          },
        ] %}
      {% elseif readinessPreviewState == 'blocked' %}
        {% set readinessActionRowsProblematic = [
          {
            signal: 'Runtime disabled',
            stateLabel: 'Blocked',
            stateTone: 'bad',
            impact: 'Guarded machine traffic cannot run while the runtime is disabled.',
            primaryAction: 'Open plugin settings',
            secondaryAction: 'Review environment override',
            primaryUrl: settingsUrl ~ '#runtimeSwitchesSection',
            secondaryUrl: settingsUrl ~ '#configurationLocksSection',
            surface: 'Settings',
          },
          {
            signal: 'No accounts',
            stateLabel: 'Blocked',
            stateTone: 'bad',
            impact: 'No accounts are available for machine access.',
            primaryAction: 'Create managed account',
            secondaryAction: 'Open Accounts',
            primaryUrl: accountsUrl ~ '#addAgentSection',
            secondaryUrl: accountsUrl ~ '#agentsCardList',
            surface: 'Accounts',
          },
          {
            signal: 'Security warnings',
            stateLabel: 'Needs attention',
            stateTone: 'warn',
            impact: 'Auth or privacy posture may drift from production expectations.',
            primaryAction: 'Review security detail',
            secondaryAction: 'Review warnings',
            primaryUrl: securityUrl ~ '#securitySnapshotSection',
            secondaryUrl: securityUrl ~ '#securityWarningsSection',
            surface: 'Readiness / Security',
          },
          {
            signal: 'Sync lag',
            stateLabel: 'Needs attention',
            stateTone: 'warn',
            impact: 'Downstream systems may be operating on stale Craft or Commerce data.',
            primaryAction: 'Review lagging integrations',
            secondaryAction: 'Open lag details',
            primaryUrl: readinessUrl ~ '#readinessProofIntegrationHealth',
            secondaryUrl: settingsUrl ~ '#reliabilityThresholdsSection',
            surface: 'Readiness / External',
          },
        ] %}
      {% elseif readinessPreviewState == 'unproven' %}
        {% set readinessActionRowsProblematic = [
          {
            signal: 'Stale or low-confidence observability',
            stateLabel: 'Unproven',
            stateTone: 'warn',
            impact: 'The readiness verdict is less trustworthy because signal quality is weak.',
            primaryAction: 'Recheck readiness',
            secondaryAction: 'Inspect observability',
            primaryUrl: readinessUrl ~ '#readinessStateCard',
            secondaryUrl: readinessUrl ~ '#readinessProofObservability',
            surface: 'Readiness',
          },
        ] %}
      {% else %}
        {% for row in readinessActionRows %}
          {% if (row.stateLabel|lower) not in ['clear', 'optional'] %}
            {% set readinessActionRowsProblematic = readinessActionRowsProblematic|merge([row]) %}
          {% endif %}
        {% endfor %}
      {% endif %}
      {% if readinessPreviewState == '' and readinessIsBootstrapState %}
        {% set readinessActionRowsProblematic = [
          {
            signal: 'Managed accounts',
            stateLabel: 'Not created',
            stateTone: 'muted',
            impact: 'Create a scoped managed account when you are ready to connect your first external agent or worker.',
            primaryAction: 'Create managed account',
            secondaryAction: 'Open Accounts',
            primaryUrl: accountsUrl ~ '#addAgentSection',
            secondaryUrl: accountsUrl ~ '#agentsCardList',
            surface: 'Accounts',
          },
          {
            signal: 'Webhook delivery',
            stateLabel: 'Optional',
            stateTone: 'muted',
            impact: 'Enable webhook delivery if you want external workers to wake on content or commerce changes instead of polling.',
            primaryAction: 'Review webhook posture',
            secondaryAction: 'Open Settings',
            primaryUrl: readinessUrl ~ '#webhookReliabilitySection',
            secondaryUrl: settingsUrl ~ '#runtimeSwitchesSection',
            surface: 'Status / Settings',
          },
        ] %}
      {% endif %}
      {% set securityTokenRequired = securityPosture.authentication.required ?? false %}
      {% set securityQueryTokenEnabled = securityPosture.authentication.allowQueryToken ?? false %}
      {% set securityCredentialCount = securityPosture.authentication.credentialCount|default(0) %}
      {% set securityEnvCredentialCount = securityPosture.authentication.envCredentialCount|default(0) %}
      {% set securityManagedCredentialCount = securityPosture.authentication.managedCredentialCount|default(0) %}
      {% set securityCredentialIds = securityPosture.authentication.credentialIds|default([]) %}
      {% set securityDefaultScopes = securityPosture.authentication.tokenScopes|default([]) %}
      {% set securityDefaultScopeCount = securityDefaultScopes|length %}
      {% set securityDefaultScopePreview = securityDefaultScopes|slice(0, 3)|join(', ') %}
      {% set securityPrivacyRedaction = securityPosture.privacy.redactEmail ?? false %}
      {% set securityWebhookEnabled = securityPosture.webhook.enabled ?? false %}
      {% set securityWebhookUrlConfigured = securityPosture.webhook.urlConfigured ?? false %}
      {% set securityWebhookSecretConfigured = securityPosture.webhook.secretConfigured ?? false %}
      {% set securityWebhookDestinationHost = securityPosture.webhook.destinationHost ?: 'n/a' %}
      {% set securityWebhookTimeoutSeconds = securityPosture.webhook.timeoutSeconds|default(0) %}
      {% set securityWebhookMaxAttempts = securityPosture.webhook.maxAttempts|default(0) %}
      {% set securityRateLimitPerMinute = securityPosture.rateLimit.perMinute|default(0) %}
      {% set securityRateLimitWindowSeconds = securityPosture.rateLimit.windowSeconds|default(0) %}
      {% set securityDlqCount = webhookDeadLetters|length %}
      {% set securityActiveCredentials7d = observabilitySummary.activeCredentials7d|default(0) %}
      {% set securityAuthFailures = observabilitySummary.authFailuresTotal|default(0) %}
      {% set securityForbiddenTotal = observabilitySummary.forbiddenTotal|default(0) %}
      {% set securityRateLimitDenied = observabilitySummary.rateLimitExceededTotal|default(0) %}
      {% set securityErrors5xx = observabilitySummary.errors5xxTotal|default(0) %}
      {% set securityRequestsTotal = observabilitySummary.requestsTotal|default(0) %}
      {% set securityWebhookMisconfigured = (securityWebhookUrlConfigured and not securityWebhookSecretConfigured) or ((not securityWebhookUrlConfigured) and securityWebhookSecretConfigured) %}
      {% set securityHasRuntimeSignalIssues = securityAuthFailures > 0 or securityForbiddenTotal > 0 or securityRateLimitDenied > 0 or securityErrors5xx > 0 %}
      {% set securityAuthSummaryTone = 'good' %}
      {% if (not securityTokenRequired) or securityQueryTokenEnabled or securityHasRuntimeSignalIssues %}
        {% set securityAuthSummaryTone = 'warn' %}
      {% endif %}
      {% set securityCredentialSummaryTone = 'good' %}
      {% if securityTokenRequired and securityCredentialCount == 0 %}
        {% set securityCredentialSummaryTone = 'muted' %}
      {% elseif securityCredentialCount > 0 and securityActiveCredentials7d == 0 %}
        {% set securityCredentialSummaryTone = 'muted' %}
      {% endif %}
      {% set securityPolicySummaryTone = 'good' %}
      {% if securityErrors > 0 %}
        {% set securityPolicySummaryTone = 'bad' %}
      {% elseif securityWarnings > 0 or not securityPrivacyRedaction %}
        {% set securityPolicySummaryTone = 'warn' %}
      {% endif %}
      {% set securityWebhookSummaryTone = 'good' %}
      {% if not securityWebhookEnabled and not securityWebhookUrlConfigured and not securityWebhookSecretConfigured %}
        {% set securityWebhookSummaryTone = 'muted' %}
      {% elseif securityWebhookMisconfigured or securityDlqCount > 0 %}
        {% set securityWebhookSummaryTone = 'warn' %}
      {% endif %}
      {% set readinessHardGatesSummaryTone = readinessHasBlockingGate ? 'bad' : 'good' %}
      {% set readinessHardGatesSummaryLabel = readinessHasBlockingGate ? 'Blocked' : 'Good' %}
      {% set readinessTrafficAccessSummaryTone = 'good' %}
      {% set readinessTrafficAccessSummaryLabel = 'Good' %}
      {% if (not agentsEnabled) or (not readinessDbAvailable) %}
        {% set readinessTrafficAccessSummaryTone = 'bad' %}
        {% set readinessTrafficAccessSummaryLabel = 'Blocked' %}
      {% elseif readinessTrafficSummaryTone == 'warn' or securityAuthSummaryTone == 'warn' %}
        {% set readinessTrafficAccessSummaryTone = 'warn' %}
        {% set readinessTrafficAccessSummaryLabel = 'Needs attention' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessTrafficAccessSummaryTone = 'muted' %}
        {% set readinessTrafficAccessSummaryLabel = 'Monitoring' %}
      {% endif %}
      {% set readinessDeliveryWebhooksSummaryTone = 'good' %}
      {% set readinessDeliveryWebhooksSummaryLabel = 'Good' %}
      {% if (not webhookEnabledForReadiness) and (not securityWebhookEnabled) and (not securityWebhookUrlConfigured) and (not securityWebhookSecretConfigured) %}
        {% set readinessDeliveryWebhooksSummaryTone = 'muted' %}
        {% set readinessDeliveryWebhooksSummaryLabel = 'Not enabled' %}
      {% elseif readinessDeliverySummaryTone == 'warn' or securityWebhookSummaryTone == 'warn' %}
        {% set readinessDeliveryWebhooksSummaryTone = 'warn' %}
        {% set readinessDeliveryWebhooksSummaryLabel = 'Needs attention' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessDeliveryWebhooksSummaryTone = 'muted' %}
        {% set readinessDeliveryWebhooksSummaryLabel = 'Unproven' %}
      {% endif %}
      {% set readinessIntegrationCapacitySummaryTone = 'good' %}
      {% set readinessIntegrationCapacitySummaryLabel = 'Good' %}
      {% if readinessIntegrationSummaryTone == 'warn' or readinessCapacityProofTone in ['warn', 'bad'] %}
        {% set readinessIntegrationCapacitySummaryTone = 'warn' %}
        {% set readinessIntegrationCapacitySummaryLabel = 'Needs attention' %}
      {% elseif not readinessHasIntegrationTelemetry %}
        {% set readinessIntegrationCapacitySummaryTone = 'muted' %}
        {% set readinessIntegrationCapacitySummaryLabel = 'Optional' %}
      {% elseif not readinessMetricsCurrent %}
        {% set readinessIntegrationCapacitySummaryTone = 'muted' %}
        {% set readinessIntegrationCapacitySummaryLabel = 'Unproven' %}
      {% endif %}
      {% set readinessCredentialsPolicySummaryTone = 'good' %}
      {% set readinessCredentialsPolicySummaryLabel = 'Good' %}
      {% if securityCredentialSummaryTone == 'bad' or securityPolicySummaryTone == 'bad' %}
        {% set readinessCredentialsPolicySummaryTone = 'bad' %}
        {% set readinessCredentialsPolicySummaryLabel = 'Blocked' %}
      {% elseif readinessSecuritySummaryTone == 'warn' or securityPolicySummaryTone == 'warn' %}
        {% set readinessCredentialsPolicySummaryTone = 'warn' %}
        {% set readinessCredentialsPolicySummaryLabel = 'Needs attention' %}
      {% elseif securityCredentialSummaryTone == 'muted' %}
        {% set readinessCredentialsPolicySummaryTone = 'muted' %}
        {% set readinessCredentialsPolicySummaryLabel = 'Unproven' %}
      {% endif %}
      {% set readinessConfidenceSummaryTone = 'good' %}
      {% set readinessConfidenceSummaryLabel = 'Good' %}
      {% if reliabilitySignalsCritical > 0 or reliabilitySignalsWarn > 0 %}
        {% set readinessConfidenceSummaryTone = 'warn' %}
        {% set readinessConfidenceSummaryLabel = 'Needs attention' %}
      {% elseif readinessHasMonitoringGap %}
        {% set readinessConfidenceSummaryTone = 'muted' %}
        {% set readinessConfidenceSummaryLabel = 'Unproven' %}
      {% elseif readinessHasObservationGap %}
        {% set readinessConfidenceSummaryTone = 'good' %}
        {% set readinessConfidenceSummaryLabel = 'Building' %}
      {% endif %}
      {% if readinessIsBootstrapState %}
        {% set readinessTrafficAccessSummaryTone = 'muted' %}
        {% set readinessTrafficAccessSummaryLabel = 'Awaiting traffic' %}
        {% set readinessDeliveryWebhooksSummaryTone = 'muted' %}
        {% set readinessDeliveryWebhooksSummaryLabel = 'Optional' %}
        {% set readinessIntegrationCapacitySummaryTone = 'muted' %}
        {% set readinessIntegrationCapacitySummaryLabel = 'Optional' %}
        {% set readinessCredentialsPolicySummaryTone = 'good' %}
        {% set readinessCredentialsPolicySummaryLabel = 'Ready' %}
        {% set readinessConfidenceSummaryTone = 'good' %}
        {% set readinessConfidenceSummaryLabel = 'Building' %}
      {% endif %}
      {% set readinessTrafficAccessProofTone = readinessTrafficAccessSummaryTone in ['warn', 'bad'] ? readinessTrafficAccessSummaryTone : 'good' %}
      {% set readinessDeliveryWebhooksProofTone = readinessDeliveryWebhooksSummaryTone in ['warn', 'bad'] ? readinessDeliveryWebhooksSummaryTone : 'good' %}
      {% set readinessIntegrationCapacityProofTone = readinessIntegrationCapacitySummaryTone in ['warn', 'bad'] ? readinessIntegrationCapacitySummaryTone : 'good' %}
      {% set readinessCredentialsPolicyProofTone = readinessCredentialsPolicySummaryTone in ['warn', 'bad'] ? readinessCredentialsPolicySummaryTone : 'good' %}
      {% set readinessConfidenceProofTone = readinessConfidenceSummaryTone == 'good' ? 'good' : 'warn' %}
      {% set readinessSummaryTones = [
        readinessHardGatesSummaryTone,
        readinessTrafficAccessSummaryTone,
        readinessDeliveryWebhooksSummaryTone,
        readinessIntegrationCapacitySummaryTone,
        readinessCredentialsPolicySummaryTone,
        readinessConfidenceSummaryTone
      ] %}
      {% set readinessDisplayStateKey = readinessStateKey %}
      {% set readinessDisplayStateLabel = readinessStateLabel %}
      {% set readinessDisplayStateLead = readinessStateLead %}
      {% set readinessDisplayStateSubcopy = readinessStateSubcopy %}
      {% set readinessDisplayStateTone = readinessStateTone %}
      {% if readinessPreviewState == '' %}
        {% set readinessSummaryHasBad = 'bad' in readinessSummaryTones %}
        {% set readinessSummaryHasWarn = 'warn' in readinessSummaryTones %}
        {% set readinessSummaryHasMuted = 'muted' in readinessSummaryTones %}
        {% if readinessSummaryHasBad %}
          {% set readinessDisplayStateKey = 'blocked' %}
          {% set readinessDisplayStateLabel = 'Blocked' %}
          {% set readinessDisplayStateLead = 'Agents is not operationally fit for live machine traffic.' %}
          {% set readinessDisplayStateSubcopy = 'Resolve the blocked summary areas below before trusting this environment for production traffic.' %}
          {% set readinessDisplayStateTone = 'bad' %}
        {% elseif readinessSummaryHasWarn %}
          {% set readinessDisplayStateKey = 'degraded' %}
          {% set readinessDisplayStateLabel = 'Degraded' %}
          {% set readinessDisplayStateLead = 'Agents is handling traffic, but one or more visible status areas need attention.' %}
          {% set readinessDisplayStateSubcopy = 'The headline now follows the same summary buckets shown directly below.' %}
          {% set readinessDisplayStateTone = 'warn' %}
        {% elseif readinessIsBootstrapState %}
          {% set readinessDisplayStateKey = 'ready' %}
          {% set readinessDisplayStateLabel = 'Ready' %}
          {% set readinessDisplayStateLead = 'Core runtime is healthy and ready for your first account or integration.' %}
          {% set readinessDisplayStateSubcopy = 'Create a managed account or connect an external worker to start building live-readiness evidence.' %}
          {% set readinessDisplayStateTone = 'good' %}
        {% elseif readinessHasMonitoringGap or (readinessSummaryHasMuted and not readinessHasObservationGap) %}
          {% set readinessDisplayStateKey = 'unproven' %}
          {% set readinessDisplayStateLabel = 'Unproven' %}
          {% set readinessDisplayStateLead = 'No blocking issues were detected, but live-readiness confidence is limited.' %}
          {% set readinessDisplayStateSubcopy = 'Recent traffic, account activity, or observability freshness is too thin for a high-confidence assessment.' %}
          {% set readinessDisplayStateTone = 'muted' %}
        {% elseif readinessHasObservationGap %}
          {% set readinessDisplayStateKey = 'ready' %}
          {% set readinessDisplayStateLabel = 'Ready' %}
          {% set readinessDisplayStateLead = 'Core runtime is healthy and ready for machine traffic.' %}
          {% set readinessDisplayStateSubcopy = 'No issues need attention right now. Confidence signals will strengthen as routine traffic and account activity build over time.' %}
          {% set readinessDisplayStateTone = 'good' %}
        {% endif %}
      {% endif %}
      {% set readinessDisplayHeadlineLabel = readinessDisplayStateLabel %}
      {% if readinessDisplayStateKey == 'ready' and readinessHasObservationGap %}
        {% set readinessDisplayHeadlineLabel = 'Ready to Connect' %}
      {% endif %}
      {% set securityWarningPreview = securityWarningsFiltered|slice(0, 4) %}
      {% set securityProfileDefaultsAppliedFields = securityPosture.profile.defaultsAppliedFields|default([]) %}
      {% set securityLatestDlqRow = webhookDeadLetters|first %}
      {% set securityLatestDlqUpdatedAt = 'n/a' %}
      {% if securityLatestDlqRow and securityLatestDlqRow.dateUpdated is defined and securityLatestDlqRow.dateUpdated %}
        {% set securityLatestDlqUpdatedAt = securityLatestDlqRow.dateUpdated|date('Y-m-d, H:i:s', timezone='UTC') %}
      {% elseif securityLatestDlqRow and securityLatestDlqRow.dateCreated is defined and securityLatestDlqRow.dateCreated %}
        {% set securityLatestDlqUpdatedAt = securityLatestDlqRow.dateCreated|date('Y-m-d, H:i:s', timezone='UTC') %}
      {% endif %}

      <section class="border p-0 agents-readiness-ready-card agents-readiness-ready-card--{{ readinessDisplayStateTone }}" id="readinessStateCard">
        <div class="agents-readiness-ready-top">
          <div class="agents-readiness-ready-top-copy">
            <div class="agents-readiness-ready-heading">
              <span class="agents-readiness-ready-lamp agents-readiness-ready-lamp--{{ readinessDisplayStateTone }}" aria-hidden="true"></span>
              <span class="agents-readiness-ready-label">{{ readinessDisplayHeadlineLabel }}</span>
            </div>
            <p class="agents-readiness-ready-copy">
              {{ readinessDisplayStateLead }} {{ readinessDisplayStateSubcopy }} Last evaluated {{ readinessEvaluationLabel }}.
            </p>
          </div>
          <form method="post" accept-charset="UTF-8" class="agents-readiness-ready-refresh-form">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/clear-status-verdicts') }}
            {{ redirectInput('agents/status') }}
            <button
              class="btn agents-readiness-ready-refresh-button"
              type="submit"
              aria-label="Clear stale status verdicts"
              title="Clear stale status verdicts"
            >
              <svg class="agents-readiness-ready-refresh-icon" viewBox="0 0 21 24.0028" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M10.4982 4.75284C8.60709 4.75356 6.76709 5.36696 5.25383 6.50115C3.74056 7.63535 2.63548 9.22928 2.1041 11.0442C1.57273 12.8592 1.64366 14.7974 2.30627 16.5687C2.96888 18.3399 4.18751 19.8488 5.77963 20.8693C7.37174 21.8899 9.25165 22.3672 11.1378 22.2297C13.0239 22.0922 14.8147 21.3473 16.242 20.1066C17.6693 18.866 18.6562 17.1963 19.0549 15.3477C19.4536 13.4991 19.2427 11.571 18.4537 9.85234C18.3678 9.64338 18.3661 9.4093 18.4489 9.1991C18.5317 8.9889 18.6926 8.81886 18.8979 8.72458C19.1032 8.63029 19.337 8.61907 19.5504 8.69325C19.7637 8.76744 19.9402 8.92128 20.0427 9.12259C20.9894 11.1851 21.2425 13.4989 20.7638 15.7173C20.2852 17.9356 19.1007 19.9393 17.3878 21.428C15.6749 22.9167 13.5258 23.8104 11.2623 23.9751C8.9989 24.1399 6.74299 23.5669 4.83253 22.3419C2.92208 21.117 1.45992 19.306 0.665073 17.1804C-0.129774 15.0547 -0.214522 12.7287 0.423525 10.5508C1.06157 8.37289 2.38807 6.46033 4.20431 5.0996C6.02056 3.73888 8.22878 3.00322 10.4982 3.00284V4.75284Z" fill="currentColor"/>
                <path d="M10.4982 7.31834V0.437336C10.4982 0.354205 10.522 0.272803 10.5666 0.202663C10.6112 0.132523 10.6749 0.0765478 10.7502 0.0412923C10.8255 0.00603685 10.9092 -0.00703951 10.9917 0.00359438C11.0741 0.0142283 11.1518 0.0481323 11.2157 0.101336L15.3457 3.54184C15.5557 3.71684 15.5557 4.03884 15.3457 4.21384L11.2157 7.65434C11.1518 7.70754 11.0741 7.74144 10.9917 7.75208C10.9092 7.76271 10.8255 7.74963 10.7502 7.71438C10.6749 7.67912 10.6112 7.62315 10.5666 7.55301C10.522 7.48287 10.4982 7.40147 10.4982 7.31834Z" fill="currentColor"/>
              </svg>
            </button>
          </form>
        </div>

        <div class="agents-readiness-ready-summary" role="list" aria-label="Readiness summary">
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Hard Gates</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ readinessHardGatesSummaryTone }}{% if readinessHardGatesSummaryTone == 'bad' %} agents-readiness-ready-summary-value--alert{% endif %}">{{ readinessHardGatesSummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Traffic / Access</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ readinessTrafficAccessSummaryTone }}{% if readinessTrafficAccessSummaryTone == 'bad' or securityAuthSummaryTone == 'warn' %} agents-readiness-ready-summary-value--alert{% endif %}">{{ readinessTrafficAccessSummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Delivery / Webhooks</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ readinessDeliveryWebhooksSummaryTone }}{% if readinessDeliveryWebhooksSummaryTone == 'bad' or securityWebhookMisconfigured %} agents-readiness-ready-summary-value--alert{% endif %}">{{ readinessDeliveryWebhooksSummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Integration / Capacity</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ readinessIntegrationCapacitySummaryTone }}{% if readinessConsumerLagCriticalCount > 0 or telemetryQueueDepth > 50 %} agents-readiness-ready-summary-value--alert{% endif %}">{{ readinessIntegrationCapacitySummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Accounts / Policy</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ readinessCredentialsPolicySummaryTone }}{% if readinessCredentialsPolicySummaryTone in ['warn', 'bad'] %} agents-readiness-ready-summary-value--alert{% endif %}">{{ readinessCredentialsPolicySummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Confidence / Observability</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ readinessConfidenceSummaryTone }}{% if reliabilitySignalsCritical > 0 %} agents-readiness-ready-summary-value--alert{% endif %}">{{ readinessConfidenceSummaryLabel }}</strong>
          </div>
        </div>

        <details class="agents-readiness-ready-details"{% if readinessDisplayStateTone != 'good' %} open{% endif %}>
          <summary><span>Details</span></summary>
          <div class="agents-readiness-ready-grid">
            <section class="agents-readiness-ready-proof-card" id="readinessProofHardGates">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ readinessHardGateProofTone }}">Hard Gates</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li class="{{ not agentsEnabled ? 'agents-readiness-ready-proof-line--alert' : 'agents-readiness-ready-proof-line--ok' }}">{{ readinessHardGateRuntimeLine }}</li>
                <li class="{{ not readinessDbAvailable ? 'agents-readiness-ready-proof-line--alert' : 'agents-readiness-ready-proof-line--ok' }}">{{ readinessHardGateDatabaseLine }}</li>
                <li class="{{ not readinessCoreServicesOk ? 'agents-readiness-ready-proof-line--alert' : 'agents-readiness-ready-proof-line--ok' }}">{{ readinessHardGateServicesLine }}</li>
                <li{% if securityCredentialCount > 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessCredentialLine }}</li>
                <li class="{{ readinessHasBlockingGate ? 'agents-readiness-ready-proof-line--alert' : 'agents-readiness-ready-proof-line--ok' }}">{{ readinessHardGateStatusLine }}</li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="authRatePostureSection">
              <div id="readinessProofTrafficHealth" hidden></div>
              <div id="securityRuntimeSignalsSection" hidden></div>
              <div class="agents-readiness-ready-proof-head">
                <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ readinessTrafficAccessProofTone }}">Traffic / Access</h3>
                <button
                  type="button"
                  class="agents-readiness-ready-proof-trigger"
                  data-agents-detail-open="trafficAccessDetailDialog"
                  aria-haspopup="dialog"
                  aria-controls="trafficAccessDetailDialog"
                  aria-label="View Traffic / Access detail"
                >
                  <span class="agents-readiness-ready-proof-trigger-hint">View detail</span>
                </button>
              </div>
              <ul class="agents-readiness-ready-proof-list">
                <li{% if not agentsEnabled or telemetryAuthFailures > 0 or telemetryForbidden > 0 or telemetryRateLimit > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessMetricsCurrent and telemetryErrors5xx == 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessTrafficLead }}</li>
                <li class="{{ securityAuthFailures > 0 or securityForbiddenTotal > 0 ? 'agents-readiness-ready-proof-line--alert' : 'agents-readiness-ready-proof-line--ok' }}">Auth failures / scope denials: <strong>{{ securityAuthFailures }}</strong> / <strong>{{ securityForbiddenTotal }}</strong></li>
                <li{% if securityRateLimitDenied > 0 or securityErrors5xx > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif securityRateLimitDenied == 0 and securityErrors5xx == 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Rate-limit denials / server errors: <strong>{{ securityRateLimitDenied }}</strong> / <strong>{{ securityErrors5xx }}</strong></li>
                <li class="{{ (not securityTokenRequired) or securityQueryTokenEnabled ? 'agents-readiness-ready-proof-line--alert' : 'agents-readiness-ready-proof-line--ok' }}">Token required / query-token auth: <strong>{{ securityTokenRequired ? 'yes' : 'no' }}</strong> / <strong>{{ securityQueryTokenEnabled ? 'enabled' : 'disabled' }}</strong></li>
                <li>Rate limit: <strong>{{ securityRateLimitPerMinute }}</strong> requests / {{ securityRateLimitWindowSeconds }}s</li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="webhookReliabilitySection">
              <div id="readinessProofDeliveryHealth" hidden></div>
              <div id="webhookDlqOverviewSection" hidden></div>
              <div class="agents-readiness-ready-proof-head">
                <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ readinessDeliveryWebhooksProofTone }}">Delivery / Webhooks</h3>
                <button
                  type="button"
                  class="agents-readiness-ready-proof-trigger"
                  data-agents-detail-open="deliveryWebhooksDetailDialog"
                  aria-haspopup="dialog"
                  aria-controls="deliveryWebhooksDetailDialog"
                  aria-label="View Delivery / Webhooks detail"
                >
                  <span class="agents-readiness-ready-proof-trigger-hint">View detail</span>
                </button>
              </div>
              <ul class="agents-readiness-ready-proof-list">
                <li{% if (not webhookEnabledForReadiness) or securityWebhookMisconfigured or telemetryDlqFailed > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessMetricsCurrent %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessDeliveryLead }}</li>
                <li{% if securityWebhookMisconfigured %} class="agents-readiness-ready-proof-line--alert"{% elseif securityWebhookEnabled and securityWebhookUrlConfigured and securityWebhookSecretConfigured %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Webhook enabled / URL / secret: <strong>{{ securityWebhookEnabled ? 'yes' : 'no' }}</strong> / <strong>{{ securityWebhookUrlConfigured ? 'yes' : 'no' }}</strong> / <strong>{{ securityWebhookSecretConfigured ? 'yes' : 'no' }}</strong></li>
                <li{% if telemetryDlqFailed > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif webhookEnabledForReadiness and readinessMetricsCurrent and securityDlqCount == 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Failed events / latest update: <strong>{{ securityDlqCount }}</strong> / <strong>{{ securityLatestDlqUpdatedAt }}</strong></li>
                <li>Destination / timeout / attempts: <strong>{{ securityWebhookDestinationHost }}</strong> / {{ securityWebhookTimeoutSeconds }}s / {{ securityWebhookMaxAttempts }}</li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="readinessProofIntegrationHealth">
              <div id="readinessProofCapacityRuntime" hidden></div>
              <div class="agents-readiness-ready-proof-head">
                <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ readinessIntegrationCapacityProofTone }}">Integration / Capacity</h3>
                <button
                  type="button"
                  class="agents-readiness-ready-proof-trigger"
                  data-agents-detail-open="integrationCapacityDetailDialog"
                  aria-haspopup="dialog"
                  aria-controls="integrationCapacityDetailDialog"
                  aria-label="View Integration / Capacity detail"
                >
                  <span class="agents-readiness-ready-proof-trigger-hint">View detail</span>
                </button>
              </div>
              <ul class="agents-readiness-ready-proof-list">
                <li{% if readinessConsumerLagCriticalCount > 0 or readinessConsumerLagWarningCount > 0 or telemetryQueueDepth > 10 %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessHasIntegrationTelemetry and readinessMetricsCurrent %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessIntegrationLead }}</li>
                <li{% if readinessConsumerLagCriticalCount > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessHasIntegrationTelemetry and readinessConsumerLagWarningCount == 0 and telemetryConsumerLagMaxSeconds <= 60 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessIntegrationLagLine }}</li>
                <li{% if readinessConsumerLagCriticalCount > 0 or readinessConsumerLagWarningCount > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessHasIntegrationTelemetry %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessIntegrationStatusLine }}</li>
                <li{% if readinessHasIntegrationTelemetry %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessCheckpointLine }}</li>
                <li{% if telemetryQueueDepth <= 10 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessCapacityLead }}</li>
                <li{% if telemetryQueueDepth > 50 %} class="agents-readiness-ready-proof-line--alert"{% elseif telemetryQueueDepth <= 10 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Queue depth / backpressure: <strong>{{ telemetryQueueDepth }}</strong> / {{ readinessBackpressureLine }}</li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="securitySnapshotSection">
              <div id="readinessProofSecurityPosture" hidden></div>
              <div id="securityCredentialInventorySection" hidden></div>
              <div id="securityCredentialActivitySection" hidden></div>
              <div id="environmentProfileSection" hidden></div>
              <div id="securityWarningsSection" hidden></div>
              <div class="agents-readiness-ready-proof-head">
                <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ readinessCredentialsPolicyProofTone }}">Accounts / Policy</h3>
                <button
                  type="button"
                  class="agents-readiness-ready-proof-trigger"
                  data-agents-detail-open="credentialsPolicyDetailDialog"
                  aria-haspopup="dialog"
                  aria-controls="credentialsPolicyDetailDialog"
                  aria-label="View Accounts / Policy detail"
                >
                  <span class="agents-readiness-ready-proof-trigger-hint">View detail</span>
                </button>
              </div>
              <ul class="agents-readiness-ready-proof-list">
                <li{% if securityWarnings > 0 or securityErrors > 0 or not securityPrivacyRedaction %} class="agents-readiness-ready-proof-line--alert"{% elseif securityCredentialCount > 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Configured accounts: <strong>{{ securityCredentialCount }}</strong> total (<strong>{{ securityManagedCredentialCount }}</strong> managed, <strong>{{ securityEnvCredentialCount }}</strong> environment)</li>
                <li>Active accounts / guarded requests: <strong>{{ securityActiveCredentials7d }}</strong> / <strong>{{ securityRequestsTotal }}</strong></li>
                <li>Default scopes in runtime policy: <strong>{{ securityDefaultScopeCount }}</strong>{% if securityDefaultScopePreview %} ({{ securityDefaultScopePreview }}){% endif %}</li>
                <li>Environment / profile: <strong>{{ securityPosture.environment|default('unknown') }}</strong> / <strong>{{ securityPosture.profile.name|default('unknown') }}</strong></li>
                <li{% if not securityPrivacyRedaction %} class="agents-readiness-ready-proof-line--alert"{% elseif securityPrivacyRedaction and securityPosture.profile.defaultsApplied %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Privacy redaction / defaults applied: <strong>{{ securityPrivacyRedaction ? 'enabled' : 'disabled' }}</strong> / <strong>{{ securityPosture.profile.defaultsApplied ? 'yes' : 'no' }}</strong></li>
                <li{% if securityWarnings > 0 or securityErrors > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif securityWarnings == 0 and securityErrors == 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Warnings / errors: <strong>{{ securityWarnings }}</strong> / <strong>{{ securityErrors }}</strong></li>
                <li{% if securityWarningPreview|length %} class="agents-readiness-ready-proof-line--alert"{% else %} class="agents-readiness-ready-proof-line--ok"{% endif %}>
                  {% if securityWarningPreview|length %}
                    Latest warning: <strong>[{{ securityWarningPreview|first.level|upper }}]</strong> {{ securityWarningPreview|first.message }}
                  {% else %}
                    No active security warnings.
                  {% endif %}
                </li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="readinessProofObservability">
              <div id="readinessProofEvaluation" hidden></div>
              <div class="agents-readiness-ready-proof-head">
                <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ readinessConfidenceProofTone }}">Confidence / Observability</h3>
                <button
                  type="button"
                  class="agents-readiness-ready-proof-trigger"
                  data-agents-detail-open="confidenceObservabilityDetailDialog"
                  aria-haspopup="dialog"
                  aria-controls="confidenceObservabilityDetailDialog"
                  aria-label="View Confidence / Observability detail"
                >
                  <span class="agents-readiness-ready-proof-trigger-hint">View detail</span>
                </button>
              </div>
              <ul class="agents-readiness-ready-proof-list">
                <li{% if readinessHasMonitoringGap or reliabilitySignalsCritical > 0 or reliabilitySignalsWarn > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessMetricsCurrent and reliabilitySignalsEvaluated > 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessObservabilityLine }}</li>
                <li>Last evaluated: <strong>{{ readinessEvaluationLabel }}</strong></li>
                <li{% if not readinessMetricsCurrent %} class="agents-readiness-ready-proof-line--alert"{% elseif readinessMetricsCurrent %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Signal window / metrics freshness: <strong>last 60 minutes</strong> / <strong>{{ readinessMetricsCurrent ? 'current' : 'stale' }}</strong></li>
                <li{% if readinessConfidenceLabel in ['high', 'building'] %} class="agents-readiness-ready-proof-line--ok"{% endif %}>Confidence: <strong>{{ readinessConfidenceLabel }}</strong></li>
                <li{% if reliabilitySignalsEvaluated == 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif reliabilitySignalsEvaluated > 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessReliabilityLine }}</li>
                <li{% if reliabilitySignalsCritical > 0 or reliabilitySignalsWarn > 0 %} class="agents-readiness-ready-proof-line--alert"{% elseif reliabilitySignalsEvaluated > 0 %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessReliabilityStatusLine }}</li>
                <li{% if readinessMetricsCurrent %} class="agents-readiness-ready-proof-line--ok"{% endif %}>{{ readinessMonitoringLine }}</li>
              </ul>
            </section>
          </div>

          {% if readinessActionRowsProblematic|length %}
            <div class="agents-readiness-actions-block" id="readinessActionMappingSection">
              <div id="securityActionMappingSection" hidden></div>
              <div class="agents-readiness-actions-head">
                <h2 class="agents-readiness-actions-title">Action Mapping</h2>
              </div>

              <div class="agents-readiness-actions-table-wrap">
                <table class="agents-readiness-actions-table" role="table">
                  <colgroup>
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--signal">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--state">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--impact">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--action">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--surface">
                  </colgroup>
                  <thead>
                    <tr>
                      <th scope="col">Signal</th>
                      <th scope="col">Current state</th>
                      <th scope="col">Impact</th>
                      <th scope="col">Recommended Action</th>
                      <th scope="col">Surface</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in readinessActionRowsProblematic %}
                      {% set readinessActionSignalAlert = row.stateTone == 'bad' or (row.stateTone != 'muted' and row.signal in readinessSecuritySignalNames) %}
                      <tr data-state-tone="{{ row.stateTone }}">
                        <td><strong class="agents-readiness-actions-signal{% if readinessActionSignalAlert %} agents-readiness-actions-signal--alert{% endif %}">{{ row.signal }}</strong></td>
                        <td>
                          <strong class="agents-readiness-actions-state agents-readiness-actions-state--{{ row.stateTone }}{% if readinessActionSignalAlert %} agents-readiness-actions-state--alert{% endif %}">{{ row.stateLabel }}</strong>
                        </td>
                        <td>{{ row.impact }}</td>
                        <td>
                          <a href="{{ row.primaryUrl }}" class="agents-readiness-actions-primary"><strong>{{ row.primaryAction }}</strong></a>
                          <a href="{{ row.secondaryUrl }}" class="agents-readiness-actions-secondary">{{ row.secondaryAction }}</a>
                        </td>
                        <td>{{ row.surface }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          {% endif %}

          <section class="agents-diagnostics-bundle-card" id="diagnosticsBundleSection">
            <form method="post" accept-charset="UTF-8" class="agents-diagnostics-bundle-form">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/download-diagnostics-bundle') }}
              {{ redirectInput('agents/status') }}
              <button class="btn agents-diagnostics-bundle-button" type="submit">Download Diagnostics Bundle (.json)</button>
            </form>
          </section>
        </details>

        <dialog class="agents-readiness-detail-dialog" id="trafficAccessDetailDialog" data-agents-detail-dialog aria-labelledby="trafficAccessDetailDialogTitle">
          <div class="agents-readiness-detail-dialog-shell">
            <div class="agents-readiness-detail-dialog-head">
              <div class="agents-readiness-detail-dialog-heading">
                <h2 class="agents-readiness-detail-dialog-title" id="trafficAccessDetailDialogTitle">Traffic / Access Detail</h2>
                <p class="agents-readiness-detail-dialog-copy">Aggregate guarded-request posture from runtime counters, policy posture, and reliability thresholds.</p>
              </div>
              <button type="button" class="agents-readiness-detail-dialog-close" data-agents-detail-close aria-label="Close traffic and access detail">Close</button>
            </div>
            <div class="agents-readiness-detail-dialog-body">
              <div class="agents-readiness-detail-grid">
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Current Counters</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Guarded requests</dt>
                      <dd><strong>{{ securityRequestsTotal }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Auth failures</dt>
                      <dd><strong>{{ securityAuthFailures }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Scope denials</dt>
                      <dd><strong>{{ securityForbiddenTotal }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Rate-limit denials</dt>
                      <dd><strong>{{ securityRateLimitDenied }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Server errors (5xx)</dt>
                      <dd><strong>{{ securityErrors5xx }}</strong></dd>
                    </div>
                  </dl>
                </section>
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Policy Posture</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Token required</dt>
                      <dd><strong>{{ securityTokenRequired ? 'yes' : 'no' }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Query-token transport</dt>
                      <dd><strong>{{ securityQueryTokenEnabled ? 'enabled' : 'disabled' }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Configured rate limit</dt>
                      <dd><strong>{{ securityRateLimitPerMinute }}</strong> requests / {{ securityRateLimitWindowSeconds }}s</dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Assessment</dt>
                      <dd>{{ readinessTrafficLead }}</dd>
                    </div>
                  </dl>
                </section>
              </div>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Reliability Guidance</h3>
                {% set trafficAccessSignalCount = 0 %}
                <ul class="agents-readiness-detail-signal-list">
                  {% for signalId in trafficAccessSignalOrder %}
                    {% set signal = reliabilitySignalsById[signalId] ?? null %}
                    {% if signal %}
                      {% set trafficAccessSignalCount = trafficAccessSignalCount + 1 %}
                      <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ signal.severity|default('ok') }}">
                        <div class="agents-readiness-detail-signal-head">
                          <strong>{{ signal.label }}</strong>
                          <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ signal.severity|default('ok') }}">{{ (signal.severity|default('ok'))|upper }}</span>
                        </div>
                        <p class="agents-readiness-detail-signal-copy">
                          Current value <strong>{{ signal.value }}</strong> {{ signal.unit }}.
                          Warn {{ signal.comparator }} {{ signal.warnThreshold|number_format(0, '.', '') }};
                          critical {{ signal.comparator }} {{ signal.criticalThreshold|number_format(0, '.', '') }}.
                        </p>
                        {% if signal.primaryResponse %}
                          <p class="agents-readiness-detail-signal-copy">{{ signal.primaryResponse }}</p>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
                {% if trafficAccessSignalCount == 0 %}
                  <p class="agents-readiness-detail-empty">No traffic/access reliability signals are elevated right now.</p>
                {% endif %}
              </section>

              <div class="agents-readiness-detail-actions">
                <a href="{{ attentionAccountsUrl ~ '#agentsCardList' }}" class="agents-readiness-detail-action">Review accounts</a>
                <a href="{{ securityUrl ~ '#authRatePostureSection' }}" class="agents-readiness-detail-action">Inspect denied requests</a>
                <a href="{{ overviewUrl ~ '#diagnosticsBundleSection' }}" class="agents-readiness-detail-action">Download diagnostics bundle</a>
              </div>
            </div>
          </div>
        </dialog>

        <dialog class="agents-readiness-detail-dialog" id="deliveryWebhooksDetailDialog" data-agents-detail-dialog aria-labelledby="deliveryWebhooksDetailDialogTitle">
          <div class="agents-readiness-detail-dialog-shell">
            <div class="agents-readiness-detail-dialog-head">
              <div class="agents-readiness-detail-dialog-heading">
                <h2 class="agents-readiness-detail-dialog-title" id="deliveryWebhooksDetailDialogTitle">Delivery / Webhooks Detail</h2>
                <p class="agents-readiness-detail-dialog-copy">Webhook enablement, delivery posture, and dead-letter events from current runtime telemetry.</p>
              </div>
              <button type="button" class="agents-readiness-detail-dialog-close" data-agents-detail-close aria-label="Close delivery and webhooks detail">Close</button>
            </div>
            <div class="agents-readiness-detail-dialog-body">
              <div class="agents-readiness-detail-grid">
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Delivery Posture</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Webhook enabled</dt>
                      <dd><strong>{{ securityWebhookEnabled ? 'yes' : 'no' }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>URL / secret configured</dt>
                      <dd><strong>{{ securityWebhookUrlConfigured ? 'yes' : 'no' }}</strong> / <strong>{{ securityWebhookSecretConfigured ? 'yes' : 'no' }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Destination</dt>
                      <dd><strong>{{ securityWebhookDestinationHost }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Assessment</dt>
                      <dd>{{ readinessDeliveryLead }}</dd>
                    </div>
                  </dl>
                </section>
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Delivery Runtime</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Failed DLQ events</dt>
                      <dd><strong>{{ securityDlqCount }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Latest update</dt>
                      <dd><strong>{{ securityLatestDlqUpdatedAt }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Timeout / max attempts</dt>
                      <dd>{{ securityWebhookTimeoutSeconds }}s / {{ securityWebhookMaxAttempts }}</dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Configuration drift</dt>
                      <dd>{{ securityWebhookMisconfigured ? 'URL and secret do not fully match' : 'Configuration is internally consistent' }}</dd>
                    </div>
                  </dl>
                </section>
              </div>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Recent Failed Events</h3>
                {% if readinessWebhookPreviewRows|length %}
                  <ul class="agents-readiness-detail-signal-list">
                    {% for row in readinessWebhookPreviewRows %}
                      {% set rowSeverity = row.status|default('') == 'failed' ? 'warn' : 'ok' %}
                      <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ rowSeverity }}">
                        <div class="agents-readiness-detail-signal-head">
                          <strong>{{ row.eventId ?: ('DLQ #' ~ row.id) }}</strong>
                          <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ rowSeverity }}">{{ (row.status ?: 'unknown')|upper }}</span>
                        </div>
                        <p class="agents-readiness-detail-signal-copy">
                          {{ row.resourceType ?: 'resource' }}:{{ row.resourceId ?: 'n/a' }}{% if row.action %} ({{ row.action }}){% endif %}.
                          Attempts <strong>{{ row.attempts }}</strong>.
                        </p>
                        <p class="agents-readiness-detail-signal-copy">
                          Last error: <strong>{{ row.lastError ?: 'n/a' }}</strong>.
                          Updated <strong>{{ (row.dateUpdated ?: row.dateCreated) ? (row.dateUpdated ?: row.dateCreated)|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a' }}</strong>.
                        </p>
                      </li>
                    {% endfor %}
                  </ul>
                {% else %}
                  <p class="agents-readiness-detail-empty">No failed delivery events are currently stored in the dead-letter queue.</p>
                {% endif %}
              </section>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Reliability Guidance</h3>
                {% set deliveryWebhooksSignalCount = 0 %}
                <ul class="agents-readiness-detail-signal-list">
                  {% for signalId in deliveryWebhooksSignalOrder %}
                    {% set signal = reliabilitySignalsById[signalId] ?? null %}
                    {% if signal %}
                      {% set deliveryWebhooksSignalCount = deliveryWebhooksSignalCount + 1 %}
                      <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ signal.severity|default('ok') }}">
                        <div class="agents-readiness-detail-signal-head">
                          <strong>{{ signal.label }}</strong>
                          <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ signal.severity|default('ok') }}">{{ (signal.severity|default('ok'))|upper }}</span>
                        </div>
                        <p class="agents-readiness-detail-signal-copy">
                          Current value <strong>{{ signal.value }}</strong> {{ signal.unit }}.
                          Warn {{ signal.comparator }} {{ signal.warnThreshold|number_format(0, '.', '') }};
                          critical {{ signal.comparator }} {{ signal.criticalThreshold|number_format(0, '.', '') }}.
                        </p>
                        {% if signal.primaryResponse %}
                          <p class="agents-readiness-detail-signal-copy">{{ signal.primaryResponse }}</p>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
                {% if deliveryWebhooksSignalCount == 0 %}
                  <p class="agents-readiness-detail-empty">No delivery reliability signals are elevated right now.</p>
                {% endif %}
              </section>

              <div class="agents-readiness-detail-actions">
                <a href="{{ readinessUrl ~ '#webhookReliabilitySection' }}" class="agents-readiness-detail-action">Review webhook posture</a>
                <a href="{{ readinessUrl ~ '#webhookProbeSection' }}" class="agents-readiness-detail-action">Open webhook probe</a>
                <a href="{{ securityUrl ~ '#webhookDlqDetailSection' }}" class="agents-readiness-detail-action">Open dead-letter queue</a>
                {% if webhookTestSinkVisible %}
                  <a href="{{ readinessUrl ~ '#webhookTestSinkSection' }}" class="agents-readiness-detail-action">Open test sink</a>
                {% endif %}
                <a href="{{ overviewUrl ~ '#diagnosticsBundleSection' }}" class="agents-readiness-detail-action">Download diagnostics bundle</a>
              </div>
            </div>
          </div>
        </dialog>

        <dialog class="agents-readiness-detail-dialog" id="credentialsPolicyDetailDialog" data-agents-detail-dialog aria-labelledby="credentialsPolicyDetailDialogTitle">
          <div class="agents-readiness-detail-dialog-shell">
            <div class="agents-readiness-detail-dialog-head">
              <div class="agents-readiness-detail-dialog-heading">
                <h2 class="agents-readiness-detail-dialog-title" id="credentialsPolicyDetailDialogTitle">Accounts / Policy Detail</h2>
                <p class="agents-readiness-detail-dialog-copy">Account inventory, effective policy defaults, and current security warnings from the active environment profile.</p>
              </div>
              <button type="button" class="agents-readiness-detail-dialog-close" data-agents-detail-close aria-label="Close accounts and policy detail">Close</button>
            </div>
            <div class="agents-readiness-detail-dialog-body">
              <div class="agents-readiness-detail-grid">
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Account Inventory</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Total accounts</dt>
                      <dd><strong>{{ securityCredentialCount }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Managed / environment</dt>
                      <dd><strong>{{ securityManagedCredentialCount }}</strong> / <strong>{{ securityEnvCredentialCount }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Active accounts / guarded requests</dt>
                      <dd><strong>{{ securityActiveCredentials7d }}</strong> / <strong>{{ securityRequestsTotal }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Warning posture</dt>
                      <dd><strong>{{ securityWarnings }}</strong> warnings / <strong>{{ securityErrors }}</strong> errors</dd>
                    </div>
                  </dl>
                </section>
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Policy Posture</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Environment / profile</dt>
                      <dd><strong>{{ securityPosture.environment|default('unknown') }}</strong> / <strong>{{ securityPosture.profile.name|default('unknown') }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Profile source</dt>
                      <dd>{{ securityPosture.profile.source|default('unknown') }}</dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Defaults applied / privacy redaction</dt>
                      <dd><strong>{{ securityPosture.profile.defaultsApplied ? 'yes' : 'no' }}</strong> / <strong>{{ securityPrivacyRedaction ? 'enabled' : 'disabled' }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Effective policy version</dt>
                      <dd>{{ securityPosture.profile.effectivePolicyVersion|default('n/a') }}</dd>
                    </div>
                  </dl>
                </section>
              </div>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Runtime Scope Set</h3>
                {% if securityDefaultScopes|length %}
                  <div class="agents-readiness-detail-chip-list">
                    {% for scope in securityDefaultScopes %}
                      <code class="agents-readiness-detail-chip">{{ scope }}</code>
                    {% endfor %}
                  </div>
                {% else %}
                  <p class="agents-readiness-detail-empty">No runtime scopes are configured.</p>
                {% endif %}
                {% if securityProfileDefaultsAppliedFields|length %}
                  <p class="agents-readiness-detail-signal-copy">
                    Defaults applied to:
                    {% for field in securityProfileDefaultsAppliedFields %}
                      <code class="agents-readiness-detail-chip agents-readiness-detail-chip--inline">{{ field }}</code>{% if not loop.last %} {% endif %}
                    {% endfor %}
                  </p>
                {% endif %}
                {% if securityCredentialIds|length %}
                  <p class="agents-readiness-detail-signal-copy">
                    Active account ids:
                    {% for credentialId in securityCredentialIds|slice(0, 8) %}
                      <code class="agents-readiness-detail-chip agents-readiness-detail-chip--inline">{{ credentialId }}</code>{% if not loop.last %} {% endif %}
                    {% endfor %}
                  </p>
                {% endif %}
              </section>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Current Warnings</h3>
                {% if securityWarningsList|length %}
                  <ul class="agents-readiness-detail-signal-list">
                    {% for warning in securityWarningsList %}
                      {% set warningSeverity = warning.level|default('warning') == 'error' ? 'critical' : 'warn' %}
                      <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ warningSeverity }}">
                        <div class="agents-readiness-detail-signal-head">
                          <strong>{{ warning.level|default('warning')|upper }}</strong>
                          <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ warningSeverity }}">{{ warningSeverity == 'critical' ? 'ERROR' : 'WARN' }}</span>
                        </div>
                        <p class="agents-readiness-detail-signal-copy">{{ warning.message }}</p>
                      </li>
                    {% endfor %}
                  </ul>
                {% else %}
                  <p class="agents-readiness-detail-empty">No active security warnings or policy errors are present.</p>
                {% endif %}
              </section>

              <div class="agents-readiness-detail-actions">
                <a href="{{ accountsUrl ~ '#agentsCardList' }}" class="agents-readiness-detail-action">Open accounts</a>
                <a href="{{ settingsUrl ~ '#configurationLocksSection' }}" class="agents-readiness-detail-action">Inspect configuration locks</a>
                <a href="{{ readinessUrl ~ '#securityWarningsSection' }}" class="agents-readiness-detail-action">Review warnings in context</a>
              </div>
            </div>
          </div>
        </dialog>

        <dialog class="agents-readiness-detail-dialog" id="confidenceObservabilityDetailDialog" data-agents-detail-dialog aria-labelledby="confidenceObservabilityDetailDialogTitle">
          <div class="agents-readiness-detail-dialog-shell">
            <div class="agents-readiness-detail-dialog-head">
              <div class="agents-readiness-detail-dialog-heading">
                <h2 class="agents-readiness-detail-dialog-title" id="confidenceObservabilityDetailDialogTitle">Confidence / Observability Detail</h2>
                <p class="agents-readiness-detail-dialog-copy">Why the current readiness verdict is high-confidence or limited, based on signal freshness, live activity, and reliability evaluation coverage.</p>
              </div>
              <button type="button" class="agents-readiness-detail-dialog-close" data-agents-detail-close aria-label="Close confidence and observability detail">Close</button>
            </div>
            <div class="agents-readiness-detail-dialog-body">
              <div class="agents-readiness-detail-grid">
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Verdict Basis</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Readiness confidence</dt>
                      <dd><strong>{{ readinessConfidenceLabel }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Last evaluated</dt>
                      <dd><strong>{{ readinessEvaluationLabel }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Signal window / freshness</dt>
                      <dd>last 60 minutes / <strong>{{ readinessMetricsCurrent ? 'current' : 'stale' }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Assessment</dt>
                      <dd>{{ readinessMonitoringLine }}</dd>
                    </div>
                  </dl>
                </section>
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Observed Activity</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Guarded requests</dt>
                      <dd><strong>{{ telemetryRequestsTotal }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Active accounts (7d)</dt>
                      <dd><strong>{{ telemetryActiveCredentials7d }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Signals evaluated</dt>
                      <dd><strong>{{ reliabilitySignalsEvaluated }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Warn / critical signals</dt>
                      <dd><strong>{{ reliabilitySignalsWarn }}</strong> / <strong>{{ reliabilitySignalsCritical }}</strong></dd>
                    </div>
                  </dl>
                </section>
              </div>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Top Reliability Signals</h3>
                {% if readinessReliabilityTopSignals|length %}
                  <ul class="agents-readiness-detail-signal-list">
                    {% for signal in readinessReliabilityTopSignals %}
                      {% set signalSeverity = signal.severity|default('ok') %}
                      <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ signalSeverity }}">
                        <div class="agents-readiness-detail-signal-head">
                          <strong>{{ signal.label|default(signal.id|default('Signal')) }}</strong>
                          <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ signalSeverity }}">{{ signalSeverity|upper }}</span>
                        </div>
                        <p class="agents-readiness-detail-signal-copy">
                          Current value <strong>{{ signal.value|default(0) }}</strong>{% if signal.unit|default('') %} {{ signal.unit }}{% endif %}.
                          {% if signal.comparator is defined and signal.warnThreshold is defined and signal.criticalThreshold is defined %}
                            Warn {{ signal.comparator }} {{ signal.warnThreshold|number_format(0, '.', '') }};
                            critical {{ signal.comparator }} {{ signal.criticalThreshold|number_format(0, '.', '') }}.
                          {% endif %}
                        </p>
                        {% if signal.primaryResponse|default('') %}
                          <p class="agents-readiness-detail-signal-copy">{{ signal.primaryResponse }}</p>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% else %}
                  <p class="agents-readiness-detail-empty">No prioritized reliability signals are currently available.</p>
                {% endif %}
              </section>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Confidence Factors</h3>
                <ul class="agents-readiness-detail-signal-list">
                  <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ readinessMetricsCurrent ? 'ok' : 'warn' }}">
                    <div class="agents-readiness-detail-signal-head">
                      <strong>Metrics freshness</strong>
                      <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ readinessMetricsCurrent ? 'ok' : 'warn' }}">{{ readinessMetricsCurrent ? 'CURRENT' : 'STALE' }}</span>
                    </div>
                    <p class="agents-readiness-detail-signal-copy">{{ readinessObservabilityLine }}</p>
                  </li>
                  <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ readinessHasObservedTraffic ? 'ok' : 'warn' }}">
                    <div class="agents-readiness-detail-signal-head">
                      <strong>Recent guarded traffic</strong>
                      <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ readinessHasObservedTraffic ? 'ok' : 'warn' }}">{{ readinessHasObservedTraffic ? 'PRESENT' : 'LIMITED' }}</span>
                    </div>
                    <p class="agents-readiness-detail-signal-copy">{{ readinessTrafficLead }}</p>
                  </li>
                  <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ readinessHasActiveCredentials ? 'ok' : 'warn' }}">
                    <div class="agents-readiness-detail-signal-head">
                      <strong>Account activity</strong>
                      <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ readinessHasActiveCredentials ? 'ok' : 'warn' }}">{{ readinessHasActiveCredentials ? 'ACTIVE' : 'LIMITED' }}</span>
                    </div>
                    <p class="agents-readiness-detail-signal-copy">{{ readinessCapacityLine }}</p>
                  </li>
                </ul>
              </section>

              <div class="agents-readiness-detail-actions">
                <a href="{{ readinessUrl ~ '#readinessStateCard' }}" class="agents-readiness-detail-action">Recheck readiness</a>
                <a href="{{ overviewUrl ~ '#diagnosticsBundleSection' }}" class="agents-readiness-detail-action">Download diagnostics bundle</a>
                <a href="{{ readinessUrl ~ '#readinessProofObservability' }}" class="agents-readiness-detail-action">Review observability in context</a>
              </div>
            </div>
          </div>
        </dialog>

        <dialog class="agents-readiness-detail-dialog" id="integrationCapacityDetailDialog" data-agents-detail-dialog aria-labelledby="integrationCapacityDetailDialogTitle">
          <div class="agents-readiness-detail-dialog-shell">
            <div class="agents-readiness-detail-dialog-head">
              <div class="agents-readiness-detail-dialog-heading">
                <h2 class="agents-readiness-detail-dialog-title" id="integrationCapacityDetailDialogTitle">Integration / Capacity Detail</h2>
                <p class="agents-readiness-detail-dialog-copy">Checkpoint lag, queue pressure, and runtime capacity posture from current sync-state telemetry.</p>
              </div>
              <button type="button" class="agents-readiness-detail-dialog-close" data-agents-detail-close aria-label="Close integration and capacity detail">Close</button>
            </div>
            <div class="agents-readiness-detail-dialog-body">
              <div class="agents-readiness-detail-grid">
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Current Snapshot</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Tracked checkpoints</dt>
                      <dd><strong>{{ readinessTabConsumerCount }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Healthy / warning / critical</dt>
                      <dd><strong>{{ consumerLagSummary.healthy|default(0) }}</strong> / <strong>{{ consumerLagSummary.warning|default(0) }}</strong> / <strong>{{ consumerLagSummary.critical|default(0) }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Max sync-state lag</dt>
                      <dd><strong>{{ telemetryConsumerLagMaxSeconds }}</strong>s</dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Assessment</dt>
                      <dd>{{ readinessIntegrationLead }}</dd>
                    </div>
                  </dl>
                </section>
                <section class="agents-readiness-detail-panel">
                  <h3 class="agents-readiness-detail-panel-title">Capacity Posture</h3>
                  <dl class="agents-readiness-detail-list">
                    <div class="agents-readiness-detail-list-row">
                      <dt>Queue depth</dt>
                      <dd><strong>{{ telemetryQueueDepth }}</strong></dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Backpressure</dt>
                      <dd>{{ readinessBackpressureLine }}</dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Checkpoint telemetry</dt>
                      <dd>{{ readinessCheckpointLine }}</dd>
                    </div>
                    <div class="agents-readiness-detail-list-row">
                      <dt>Capacity assessment</dt>
                      <dd>{{ readinessCapacityLead }}</dd>
                    </div>
                  </dl>
                </section>
              </div>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Lagging Integrations</h3>
                {% if readinessLagPreviewRows|length %}
                  <ul class="agents-readiness-detail-signal-list">
                    {% for row in readinessLagPreviewRows %}
                      {% set lagSeverity = row.lagBucket == 'critical' ? 'critical' : (row.lagBucket == 'warning' ? 'warn' : 'ok') %}
                      <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ lagSeverity }}">
                        <div class="agents-readiness-detail-signal-head">
                          <strong>{{ row.integrationKey ?: 'unknown integration' }}{% if row.resourceType %} / {{ row.resourceType }}{% endif %}</strong>
                          <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ lagSeverity }}">{{ (row.lagBucket ?: 'healthy')|upper }}</span>
                        </div>
                        <p class="agents-readiness-detail-signal-copy">
                          Lag <strong>{{ row.lagSeconds }}</strong>s.
                          Last checkpoint <strong>{{ row.checkpointAt ? row.checkpointAt|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a' }}</strong>.
                        </p>
                        {% if row.updatedSince %}
                          <p class="agents-readiness-detail-signal-copy">Updated since <strong>{{ row.updatedSince }}</strong>.</p>
                        {% endif %}
                      </li>
                    {% endfor %}
                  </ul>
                {% else %}
                  <p class="agents-readiness-detail-empty">No sync-state checkpoints have been submitted yet.</p>
                {% endif %}
              </section>

              <section class="agents-readiness-detail-panel">
                <h3 class="agents-readiness-detail-panel-title">Reliability Guidance</h3>
                {% set integrationCapacitySignalCount = 0 %}
                <ul class="agents-readiness-detail-signal-list">
                  {% for signalId in integrationCapacitySignalOrder %}
                    {% set signal = reliabilitySignalsById[signalId] ?? null %}
                    {% if signal %}
                      {% set integrationCapacitySignalCount = integrationCapacitySignalCount + 1 %}
                      <li class="agents-readiness-detail-signal agents-readiness-detail-signal--{{ signal.severity|default('ok') }}">
                        <div class="agents-readiness-detail-signal-head">
                          <strong>{{ signal.label }}</strong>
                          <span class="agents-readiness-detail-signal-badge agents-readiness-detail-signal-badge--{{ signal.severity|default('ok') }}">{{ (signal.severity|default('ok'))|upper }}</span>
                        </div>
                        <p class="agents-readiness-detail-signal-copy">
                          Current value <strong>{{ signal.value }}</strong> {{ signal.unit }}.
                          Warn {{ signal.comparator }} {{ signal.warnThreshold|number_format(0, '.', '') }};
                          critical {{ signal.comparator }} {{ signal.criticalThreshold|number_format(0, '.', '') }}.
                        </p>
                        {% if signal.primaryResponse %}
                          <p class="agents-readiness-detail-signal-copy">{{ signal.primaryResponse }}</p>
                        {% endif %}
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
                {% if integrationCapacitySignalCount == 0 %}
                  <p class="agents-readiness-detail-empty">No integration or queue reliability signals are elevated right now.</p>
                {% endif %}
              </section>

              <div class="agents-readiness-detail-actions">
                <a href="{{ readinessUrl ~ '#readinessProofIntegrationHealth' }}" class="agents-readiness-detail-action">Review lagging integrations</a>
                <a href="{{ settingsUrl ~ '#reliabilityThresholdsSection' }}" class="agents-readiness-detail-action">Inspect lag thresholds</a>
                <a href="{{ overviewUrl ~ '#diagnosticsBundleSection' }}" class="agents-readiness-detail-action">Download diagnostics bundle</a>
              </div>
            </div>
          </div>
        </dialog>
      </section>

      {% if webhookDeadLetters|length %}
        <section class="border rounded p-3" id="webhookDlqDetailSection">
          <h2 class="h4">Webhook Dead-Letter Queue</h2>
          <p class="agents-subtle">Final delivery failures are stored here and can be replayed.</p>

          <form method="post" accept-charset="UTF-8" style="margin-bottom: 10px;">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/replay-webhook-dlq') }}
            {{ redirectInput('agents/status') }}
            <input type="hidden" name="mode" value="all">
            <input type="hidden" name="limit" value="25">
            <button class="btn" type="submit">Replay up to 25 failed events</button>
          </form>

          <div class="tablepane mx-0" style="margin-top: 0;">
            <table class="data fullwidth">
              <thead>
              <tr>
                <th>ID</th>
                <th>Event</th>
                <th>Status</th>
                <th>Attempts</th>
                <th>Last Error</th>
                <th>Updated</th>
                <th>Replay</th>
              </tr>
              </thead>
              <tbody>
              {% for row in webhookDeadLetters %}
                <tr>
                  <td>#{{ row.id }}</td>
                  <td>
                    <code>{{ row.eventId }}</code><br>
                    <span class="light">{{ row.resourceType ?: 'resource' }}:{{ row.resourceId ?: 'n/a' }} {{ row.action ? '(' ~ row.action ~ ')' : '' }}</span>
                  </td>
                  <td><strong>{{ row.status }}</strong></td>
                  <td>{{ row.attempts }}</td>
                  <td>{{ row.lastError ?: 'n/a' }}</td>
                  <td>{{ (row.dateUpdated ?: row.dateCreated) ? (row.dateUpdated ?: row.dateCreated)|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a' }}</td>
                  <td>
                    <form method="post" accept-charset="UTF-8">
                      {{ csrfInput() }}
                      {{ actionInput('agents/dashboard/replay-webhook-dlq') }}
                      {{ redirectInput('agents/status') }}
                      <input type="hidden" name="id" value="{{ row.id }}">
                      <button class="btn" type="submit">Replay</button>
                    </form>
                  </td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        </section>
      {% endif %}

      <section class="agents-webhook-probe-card border rounded p-0" id="webhookProbeSection">
        <div class="agents-webhook-probe-top agents-status-strip-card__top">
          <div class="agents-webhook-probe-header">
            <h2 class="agents-webhook-probe-title">Webhook Probe</h2>
          </div>
          <div class="agents-webhook-probe-actions">
            <form method="post" accept-charset="UTF-8" class="agents-webhook-probe-action-form">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/send-webhook-probe') }}
              {{ redirectInput('agents/status#webhookProbeSection') }}
              <button class="btn small agents-webhook-probe-button" type="submit"{% if not webhookProbeCanSend %} disabled{% endif %}>Send production probe</button>
            </form>
          </div>
        </div>
        <div class="agents-status-strip-card__subcopy">
          <p class="agents-webhook-probe-copy">Synthetic signed delivery against the live webhook receiver for transport validation without content mutation or sink repointing.</p>
          <p class="agents-webhook-probe-status agents-webhook-probe-status--{{ webhookProbeStateTone }}">{{ webhookProbeStatusLine }}</p>
        </div>

        <details class="agents-readiness-ready-details"{% if webhookProbeState in ['storage', 'misconfigured', 'failed'] %} open{% endif %}>
          <summary><span>Details</span></summary>
          <div class="agents-status-collapsible-body">
            <div class="agents-webhook-probe-summary">
              <div class="agents-webhook-probe-summary-item">
                <span class="agents-webhook-probe-summary-label">Delivered / failed</span>
                <strong class="agents-webhook-probe-summary-value">{{ webhookProbeDelivered }} / {{ webhookProbeFailed }}</strong>
              </div>
              <div class="agents-webhook-probe-summary-item">
                <span class="agents-webhook-probe-summary-label">Last attempt</span>
                <strong class="agents-webhook-probe-summary-value">{{ webhookProbeLastAttemptAt ? webhookProbeLastAttemptAt|date('Y-m-d, H:i:s', timezone='UTC') ~ ' UTC' : 'Never' }}</strong>
              </div>
              <div class="agents-webhook-probe-summary-item">
                <span class="agents-webhook-probe-summary-label">Target URL</span>
                <strong class="agents-webhook-probe-summary-value">{{ webhookProbeTargetUrl ? 'Configured' : 'Missing' }}</strong>
              </div>
              <div class="agents-webhook-probe-summary-item">
                <span class="agents-webhook-probe-summary-label">Cooldown</span>
                <strong class="agents-webhook-probe-summary-value">{{ webhookProbeCooldownActive ? webhookProbeCooldownRemainingSeconds ~ 's remaining' : 'Ready' }}</strong>
              </div>
            </div>

            <div class="agents-webhook-probe-row">
              <span class="agents-webhook-probe-row-label">Target URL:</span>
              <span class="agents-webhook-probe-row-copy">{% if webhookProbeTargetUrl %}<code class="agents-webhook-probe-url">{{ webhookProbeTargetUrl }}</code>{% else %}Not configured{% endif %}</span>
            </div>
            <div class="agents-webhook-probe-row">
              <span class="agents-webhook-probe-row-label">Last success:</span>
              <span class="agents-webhook-probe-row-copy">{{ webhookProbeLastDeliveredAt ? webhookProbeLastDeliveredAt|date('Y-m-d, H:i:s', timezone='UTC') ~ ' UTC' : 'None yet' }}</span>
            </div>
            <div class="agents-webhook-probe-row">
              <span class="agents-webhook-probe-row-label">Last failure:</span>
              <span class="agents-webhook-probe-row-copy">{{ webhookProbeLastFailedAt ? webhookProbeLastFailedAt|date('Y-m-d, H:i:s', timezone='UTC') ~ ' UTC' : 'None recorded' }}</span>
            </div>

            {% if webhookProbeNotice %}
              <div class="agents-webhook-probe-row agents-webhook-probe-row--notice agents-webhook-probe-row--notice-{{ webhookProbeStateTone }}">
                <p class="agents-webhook-probe-notice-copy">{{ webhookProbeNotice }}</p>
              </div>
            {% endif %}

            <div class="agents-webhook-probe-log">
              <div class="agents-webhook-probe-log-head">
                <h3 class="agents-webhook-probe-log-title">Recent probe runs</h3>
              </div>

              {% if webhookProbeRuns|length %}
                <div class="agents-webhook-probe-table-wrap">
                  <table class="agents-webhook-probe-table">
                    <colgroup>
                      <col class="agents-webhook-probe-col agents-webhook-probe-col--probe">
                      <col class="agents-webhook-probe-col agents-webhook-probe-col--actor">
                      <col class="agents-webhook-probe-col agents-webhook-probe-col--status">
                      <col class="agents-webhook-probe-col agents-webhook-probe-col--attempted">
                      <col class="agents-webhook-probe-col agents-webhook-probe-col--payload">
                    </colgroup>
                    <thead>
                    <tr>
                      <th>Probe</th>
                      <th>Triggered by</th>
                      <th>Status</th>
                      <th>Attempted</th>
                      <th>Payload</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in webhookProbeRuns %}
                      {% set probeStatusTone = row.status == 'delivered' ? 'agents-status-chip--good' : 'agents-status-chip--bad' %}
                      <tr>
                        <td>
                          <div class="agents-webhook-probe-event-stack">
                            <strong class="agents-webhook-probe-event-label">{{ row.probeId }}</strong>
                            <span class="agents-webhook-probe-event-copy">{{ row.eventId }}</span>
                          </div>
                        </td>
                        <td>{{ row.triggeredByLabel ?: 'Unknown admin' }}</td>
                        <td>
                          <div class="agents-webhook-probe-status-stack">
                            <span class="agents-status-chip {{ probeStatusTone }}">{{ row.status }}</span>
                            <span class="agents-webhook-probe-status-copy">
                              {% if row.httpStatusCode %}
                                HTTP {{ row.httpStatusCode }}{{ row.httpReason ? ' (' ~ row.httpReason ~ ')' : '' }}
                              {% elseif row.errorMessage %}
                                {{ row.errorMessage }}
                              {% else %}
                                n/a
                              {% endif %}
                            </span>
                          </div>
                        </td>
                        <td>{{ row.dateCreated ? row.dateCreated|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a' }}</td>
                        <td>
                          <button
                            type="button"
                            class="agents-webhook-probe-payload-trigger"
                            data-agents-detail-open="webhookProbePayloadDialog"
                            data-agents-payload-source="webhookProbePayload-{{ row.id }}"
                            data-agents-payload-title="Webhook Probe Payload"
                            data-agents-payload-copy="{{ row.probeId ~ ' · ' ~ (row.triggeredByLabel ?: 'Unknown admin') ~ ' · ' ~ (row.dateCreated ? row.dateCreated|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a') }}"
                            aria-haspopup="dialog"
                            aria-controls="webhookProbePayloadDialog"
                          >› VIEW</button>
                          <script type="application/json" id="webhookProbePayload-{{ row.id }}">{{ row.payloadJson }}</script>
                        </td>
                      </tr>
                    {% endfor %}
                    </tbody>
                  </table>
                </div>
              {% else %}
                <div class="agents-webhook-probe-empty">
                  <p class="agents-webhook-probe-empty-copy">{{ webhookProbeEmptyCopy }}</p>
                </div>
              {% endif %}
            </div>

            <div class="agents-webhook-probe-footer">
              <ul class="agents-link-list agents-webhook-probe-notes">
                <li>The production probe uses the live runtime webhook URL and signing secret.</li>
                <li>Probe payloads are explicitly marked with <code>eventKind=probe</code>, <code>isProbe=true</code>, and a stable <code>probeId</code>.</li>
                <li>A successful probe validates signed outbound HTTP delivery. It does not prove real content hooks or the normal business queue path fired.</li>
                <li>Cooldown limits repeated probe traffic against the receiver.</li>
              </ul>
            </div>
          </div>
        </details>
      </section>

      <dialog class="agents-readiness-detail-dialog agents-readiness-detail-dialog--payload" id="webhookProbePayloadDialog" data-agents-detail-dialog aria-labelledby="webhookProbePayloadDialogTitle">
        <div class="agents-readiness-detail-dialog-shell">
          <div class="agents-readiness-detail-dialog-head">
            <div class="agents-readiness-detail-dialog-heading">
              <h2 class="agents-readiness-detail-dialog-title" id="webhookProbePayloadDialogTitle">Webhook Probe Payload</h2>
              <p class="agents-readiness-detail-dialog-copy" id="webhookProbePayloadDialogCopy">Captured production probe payload.</p>
            </div>
            <button type="button" class="agents-readiness-detail-dialog-close" data-agents-detail-close aria-label="Close webhook probe payload detail">Close</button>
          </div>
          <div class="agents-readiness-detail-dialog-body">
            <div class="agents-webhook-probe-payload">
              <pre class="border rounded p-3" id="webhookProbePayloadDialogBody">{}</pre>
            </div>
          </div>
        </div>
      </dialog>

      {% if webhookTestSinkVisible %}
        <section class="agents-webhook-test-sink-card border rounded p-0" id="webhookTestSinkSection">
          <div class="agents-webhook-test-sink-top agents-status-strip-card__top">
            <div class="agents-webhook-test-sink-header">
              <h2 class="agents-webhook-test-sink-title">Webhook Test Sink</h2>
            </div>
            {% if webhookTestSinkRequested %}
              <div class="agents-webhook-test-sink-actions">
                <form method="post" accept-charset="UTF-8" class="agents-webhook-test-sink-action-form">
                  {{ csrfInput() }}
                  {{ actionInput('agents/dashboard/send-webhook-test-sink-delivery') }}
                  {{ redirectInput('agents/status#webhookTestSinkSection') }}
                  <button class="btn small agents-webhook-test-sink-button" type="submit"{% if not webhookTestSinkCanSend %} disabled{% endif %}>Send test webhook</button>
                </form>
                <form method="post" accept-charset="UTF-8" class="agents-webhook-test-sink-action-form">
                  {{ csrfInput() }}
                  {{ actionInput('agents/dashboard/clear-webhook-test-sink') }}
                  {{ redirectInput('agents/status#webhookTestSinkSection') }}
                  <button class="btn small agents-webhook-test-sink-button" type="submit"{% if not webhookTestSinkStorageReady or webhookTestSinkTotal == 0 %} disabled{% endif %}>Clear captures</button>
                </form>
              </div>
            {% endif %}
          </div>
          <div class="agents-status-strip-card__subcopy">
            <p class="agents-webhook-test-sink-copy">Dev-only local receiver for inspecting outbound webhook deliveries before wiring a real automation endpoint.</p>
            <p class="agents-webhook-test-sink-status agents-webhook-test-sink-status--{{ webhookTestSinkStateTone }}">{{ webhookTestSinkStatusLine }}</p>
          </div>

          <details class="agents-readiness-ready-details">
            <summary><span>Details</span></summary>
            <div class="agents-status-collapsible-body">
              <div class="agents-webhook-test-sink-row agents-webhook-test-sink-row--url">
                <span class="agents-webhook-test-sink-row-label">Sink URL:</span>
                <code class="agents-webhook-test-sink-url">{{ webhookTestSinkUrl }}</code>
              </div>

              {% if webhookTestSinkState != 'configured' and webhookTestSinkNotice %}
                <div class="agents-webhook-test-sink-row agents-webhook-test-sink-row--notice agents-webhook-test-sink-row--notice-{{ webhookTestSinkStateTone }}">
                  <p class="agents-webhook-test-sink-notice-copy">{{ webhookTestSinkNotice }}</p>
                </div>
              {% endif %}

              <div class="agents-webhook-test-sink-captures">
                <div class="agents-webhook-test-sink-captures-head">
                  <h3 class="agents-webhook-test-sink-captures-title">Captures:</h3>
                </div>

                {% if webhookTestSinkStorageReady and webhookTestSinkEvents|length %}
                  <div class="agents-webhook-test-sink-table-wrap">
                    <table class="agents-webhook-test-sink-table">
                      <colgroup>
                        <col class="agents-webhook-test-sink-col agents-webhook-test-sink-col--id">
                        <col class="agents-webhook-test-sink-col agents-webhook-test-sink-col--event">
                        <col class="agents-webhook-test-sink-col agents-webhook-test-sink-col--verification">
                        <col class="agents-webhook-test-sink-col agents-webhook-test-sink-col--routing">
                        <col class="agents-webhook-test-sink-col agents-webhook-test-sink-col--captured">
                        <col class="agents-webhook-test-sink-col agents-webhook-test-sink-col--payload">
                      </colgroup>
                      <thead>
                      <tr>
                        <th>ID</th>
                        <th>Event</th>
                        <th>Verification</th>
                        <th>Routing</th>
                        <th>Captured</th>
                        <th>Payload</th>
                      </tr>
                      </thead>
                      <tbody>
                      {% for row in webhookTestSinkEvents %}
                        {% set verificationTone = row.verificationStatus == 'valid'
                          ? 'agents-status-chip--good'
                          : (row.verificationStatus == 'invalid' ? 'agents-status-chip--bad' : 'agents-status-chip--muted') %}
                        {% set routingLabel = row.subscriptionMode ?: 'n/a' %}
                        <tr>
                          <td>#{{ row.id }}</td>
                          <td>
                            <div class="agents-webhook-test-sink-event-stack">
                              <span class="agents-webhook-test-sink-event-id">{{ row.eventId ?: 'n/a' }}</span>
                              <span class="agents-webhook-test-sink-event-copy">{{ row.resourceType ?: 'resource' }}:{{ row.resourceId ?: 'n/a' }}{{ row.action ? ' (' ~ row.action ~ ')' : '' }}</span>
                            </div>
                          </td>
                          <td>
                            <div class="agents-webhook-test-sink-verification-stack">
                              <span class="agents-status-chip {{ verificationTone }}">{{ row.verificationStatus }}</span>
                              <span class="agents-webhook-test-sink-detail-copy">{{ row.requestMethod }} / {{ row.payloadBytes }} bytes</span>
                            </div>
                          </td>
                          <td>
                            <div class="agents-webhook-test-sink-routing-stack">
                              <strong class="agents-webhook-test-sink-routing-label">{{ routingLabel }}</strong>
                              {% if row.subscriptionCredentialHandles|length %}
                                <span class="agents-webhook-test-sink-detail-copy">{{ row.subscriptionCredentialHandles|join(', ') }}</span>
                              {% endif %}
                            </div>
                          </td>
                          <td>{{ row.dateCreated ? row.dateCreated|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a' }}</td>
                          <td>
                            <button
                              type="button"
                              class="agents-webhook-test-sink-payload-trigger"
                              data-agents-detail-open="webhookTestSinkPayloadDialog"
                              data-agents-payload-source="webhookTestSinkPayload-{{ row.id }}"
                              data-agents-payload-title="Webhook Payload"
                              data-agents-payload-copy="{{ (row.eventId ?: 'n/a') ~ ' · ' ~ (row.resourceType ?: 'resource') ~ ':' ~ (row.resourceId ?: 'n/a') ~ (row.action ? ' (' ~ row.action ~ ')' : '') ~ ' · ' ~ row.requestMethod ~ ' / ' ~ row.payloadBytes ~ ' bytes · ' ~ (row.dateCreated ? row.dateCreated|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a') }}"
                              aria-haspopup="dialog"
                              aria-controls="webhookTestSinkPayloadDialog"
                            >› VIEW</button>
                            <script type="application/json" id="webhookTestSinkPayload-{{ row.id }}">{{ row.payloadJson }}</script>
                          </td>
                        </tr>
                      {% endfor %}
                      </tbody>
                    </table>
                  </div>
                {% else %}
                  <div class="agents-webhook-test-sink-empty">
                    <p class="agents-webhook-test-sink-empty-copy">{{ webhookTestSinkEmptyCopy }}</p>
                    {% if webhookTestSinkStorageReady %}
                      <p class="agents-webhook-test-sink-empty-meta">Captured / valid / invalid / unsigned: <strong>{{ webhookTestSinkTotal }}</strong> / <strong>{{ webhookTestSinkValid }}</strong> / <strong>{{ webhookTestSinkInvalid }}</strong> / <strong>{{ webhookTestSinkUnsigned }}</strong></p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>

              <div class="agents-webhook-test-sink-footer">
                <ul class="agents-link-list agents-webhook-test-sink-notes">
                  <li><code>PLUGIN_AGENTS_WEBHOOK_URL</code> and <code>PLUGIN_AGENTS_WEBHOOK_SECRET</code> are the normal runtime webhook settings.</li>
                  <li>Only point <code>PLUGIN_AGENTS_WEBHOOK_URL</code> at the sink URL above in local/dev.</li>
                  <li>Keep <code>PLUGIN_AGENTS_WEBHOOK_SECRET</code> configured so signatures can be verified.</li>
                  <li>Use <strong>Send test webhook</strong> for a one-click local delivery check, or save an entry/product/order to test a real content-triggered event.</li>
                  <li>The sink keeps the latest {{ webhookTestSinkRetentionLimit }} captured deliveries.</li>
                </ul>
              </div>
            </div>
          </details>
        </section>

        <dialog class="agents-readiness-detail-dialog agents-readiness-detail-dialog--payload" id="webhookTestSinkPayloadDialog" data-agents-detail-dialog aria-labelledby="webhookTestSinkPayloadDialogTitle">
          <div class="agents-readiness-detail-dialog-shell">
            <div class="agents-readiness-detail-dialog-head">
              <div class="agents-readiness-detail-dialog-heading">
                <h2 class="agents-readiness-detail-dialog-title" id="webhookTestSinkPayloadDialogTitle">Webhook Payload</h2>
                <p class="agents-readiness-detail-dialog-copy" id="webhookTestSinkPayloadDialogCopy">Captured webhook payload.</p>
              </div>
              <button type="button" class="agents-readiness-detail-dialog-close" data-agents-detail-close aria-label="Close webhook payload detail">Close</button>
            </div>
            <div class="agents-readiness-detail-dialog-body">
              <div class="agents-webhook-test-sink-payload">
                <pre class="border rounded p-3" id="webhookTestSinkPayloadDialogBody">{}</pre>
              </div>
            </div>
          </div>
        </dialog>
      {% endif %}

      {% if notificationEnabled %}
      <section class="agents-operator-notifications-card border rounded p-0" id="operatorNotificationsSection">
        <div class="agents-operator-notifications-top agents-status-strip-card__top">
          <div class="agents-operator-notifications-header">
            <h2 class="agents-operator-notifications-title">Operator Notifications</h2>
          </div>
          <div class="agents-operator-notifications-actions">
            <a href="{{ settingsUrl ~ '#notificationsSection' }}" class="btn small agents-operator-notifications-button">Notification settings</a>
            <form method="post" accept-charset="UTF-8" class="agents-operator-notifications-action-form">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/run-notifications-check') }}
              {{ redirectInput('agents/status#operatorNotificationsSection') }}
              <button class="btn small agents-operator-notifications-button" type="submit">Run status check</button>
            </form>
          </div>
        </div>
        <div class="agents-status-strip-card__subcopy">
          <p class="agents-operator-notifications-copy">Email-first notifications for approvals, execution issues, webhook delivery failures, and scheduled status changes.</p>
          <p class="agents-operator-notifications-status agents-operator-notifications-status--{{ notificationEnabled and notificationRecipientCount > 0 ? 'good' : 'warn' }}">{{ notificationStatusLine }}</p>
        </div>

        <details class="agents-readiness-ready-details">
          <summary><span>Details</span></summary>
          <div class="agents-status-collapsible-body">
            <div class="agents-operator-notifications-summary">
              <div class="agents-operator-notifications-summary-item">
                <span class="agents-operator-notifications-summary-label">Recipients</span>
                <strong class="agents-operator-notifications-summary-value">{{ notificationRecipientCount }}</strong>
              </div>
              <div class="agents-operator-notifications-summary-item">
                <span class="agents-operator-notifications-summary-label">Last monitor status</span>
                <strong class="agents-operator-notifications-summary-value agents-operator-notifications-summary-value--{{ notificationMonitorTone }}">{{ notificationMonitorStatus|upper }}</strong>
              </div>
              <div class="agents-operator-notifications-summary-item">
                <span class="agents-operator-notifications-summary-label">Sent / failed</span>
                <strong class="agents-operator-notifications-summary-value">{{ notificationSummary.sent|default(0) }} / {{ notificationSummary.failed|default(0) }}</strong>
              </div>
              <div class="agents-operator-notifications-summary-item">
                <span class="agents-operator-notifications-summary-label">Last evaluated</span>
                <strong class="agents-operator-notifications-summary-value">{{ notificationLastEvaluatedLabel }}</strong>
              </div>
            </div>

            <div class="agents-operator-notifications-row">
              <span class="agents-operator-notifications-row-label">Recipients:</span>
              {% if notificationRecipients|length %}
                {% if notificationGlobalRecipientCount > 0 and notificationAccountRecipientCount > 0 %}
                  <span class="agents-operator-notifications-row-copy">Global: {{ notificationGlobalRecipients|join(', ') }}. Account-specific approvals: {{ notificationAccountRecipients|join(', ') }}.</span>
                {% elseif notificationGlobalRecipientCount > 0 %}
                  <span class="agents-operator-notifications-row-copy">{{ notificationGlobalRecipients|join(', ') }}</span>
                {% else %}
                  <span class="agents-operator-notifications-row-copy">Account-specific approvals: {{ notificationAccountRecipients|join(', ') }}</span>
                {% endif %}
              {% else %}
                <span class="agents-operator-notifications-row-copy">No valid recipients currently resolve from the configured value.</span>
              {% endif %}
            </div>

            <div class="agents-operator-notifications-row">
              <span class="agents-operator-notifications-row-label">Enabled events:</span>
              {% if notificationEnabledEvents|length %}
                <span class="agents-operator-notifications-row-copy">{{ notificationEnabledEvents|join(', ') }}</span>
              {% else %}
                <span class="agents-operator-notifications-row-copy">No notification events are enabled.</span>
              {% endif %}
            </div>

            <div class="agents-operator-notifications-row">
              <span class="agents-operator-notifications-row-label">Last handoff:</span>
              {% if notificationLastSentAt %}
                <span class="agents-operator-notifications-row-copy">
                  Sent to {{ notificationLastSentRecipient ?: 'configured recipient' }} at {{ notificationLastSentAt|date('Y-m-d, H:i:s', timezone='UTC') }}{% if notificationLastSentSubject %} ({{ notificationLastSentSubject }}){% endif %}.
                </span>
              {% else %}
                <span class="agents-operator-notifications-row-copy">No successful notification delivery has been recorded yet.</span>
              {% endif %}
            </div>

            {% if notificationMonitorPayload.issues|default([])|length %}
              <div class="agents-operator-notifications-row agents-operator-notifications-row--notice agents-operator-notifications-row--notice-{{ notificationMonitorTone }}">
                <p class="agents-operator-notifications-notice-copy">{{ notificationMonitorPayload.issues|slice(0, 3)|join(' ') }}</p>
              </div>
            {% endif %}

            <div class="agents-operator-notifications-log">
              <div class="agents-operator-notifications-log-head">
                <h3 class="agents-operator-notifications-log-title">Recent deliveries</h3>
              </div>

              {% if notificationRecentRows|length %}
                <div class="agents-operator-notifications-table-wrap">
                  <table class="agents-operator-notifications-table">
                    <colgroup>
                      <col class="agents-operator-notifications-col agents-operator-notifications-col--event">
                      <col class="agents-operator-notifications-col agents-operator-notifications-col--recipient">
                      <col class="agents-operator-notifications-col agents-operator-notifications-col--status">
                      <col class="agents-operator-notifications-col agents-operator-notifications-col--attempts">
                      <col class="agents-operator-notifications-col agents-operator-notifications-col--updated">
                    </colgroup>
                    <thead>
                    <tr>
                      <th>Event</th>
                      <th>Recipient</th>
                      <th>Status</th>
                      <th>Attempts</th>
                      <th>Updated</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for row in notificationRecentRows %}
                      {% set notificationStatusTone = row.status == 'sent'
                        ? 'agents-status-chip--good'
                        : (row.status == 'failed' ? 'agents-status-chip--bad' : 'agents-status-chip--muted') %}
                      <tr>
                        <td>
                          <div class="agents-operator-notifications-event-stack">
                            <strong class="agents-operator-notifications-event-label">{{ row.eventLabel }}</strong>
                            <span class="agents-operator-notifications-event-copy">{{ row.subject }}</span>
                            {% if row.errorMessage %}
                              <span class="agents-operator-notifications-event-copy">{{ row.errorMessage }}</span>
                            {% endif %}
                          </div>
                        </td>
                        <td>
                          {% if row.recipientCpEditUrl %}
                            <a href="{{ cpUrl(row.recipientCpEditUrl) }}">{{ row.recipientLabel }}</a>
                          {% else %}
                            {{ row.recipientLabel ?: row.recipient }}
                          {% endif %}
                          {% if row.recipientChannelLabel %}
                            <span class="agents-operator-notifications-recipient-channel"> &rarr; {{ row.recipientChannelLabel }}</span>
                          {% endif %}
                        </td>
                        <td><span class="agents-status-chip {{ notificationStatusTone }}">{{ row.status }}</span></td>
                        <td>{{ row.attempts }}</td>
                        <td>{{ (row.lastAttemptAt ?: row.sentAt ?: row.dateCreated) ? (row.lastAttemptAt ?: row.sentAt ?: row.dateCreated)|date('Y-m-d, H:i:s', timezone='UTC') : 'n/a' }}</td>
                      </tr>
                    {% endfor %}
                    </tbody>
                  </table>
                </div>
              {% else %}
                <div class="agents-operator-notifications-empty">
                  <p class="agents-operator-notifications-empty-copy">No notification deliveries have been recorded yet.</p>
                </div>
              {% endif %}
            </div>
          </div>
        </details>
      </section>
      {% endif %}

    {% endif %}

  </div>

  {% css %}
    .agents-page-header__copy {
      min-width: 0;
      width: 100%;
    }

    .agents-layout-stack {
      --agents-readiness-border: #bbc7d5;
      display: flex;
      flex-direction: column;
      align-items: stretch;
    }

    #readinessStateCard {
      order: 10;
    }

    #operatorNotificationsSection {
      order: 20;
    }

    #webhookProbeSection,
    #webhookProbePayloadDialog {
      order: 25;
    }

    #webhookTestSinkSection,
    #webhookTestSinkPayloadDialog {
      order: 30;
    }

    #webhookDlqDetailSection {
      order: 40;
    }

    .agents-readiness-ready-card {
      --agents-readiness-accent: #108e80;
      --agents-readiness-alert-color: #c24f42;
      width: 100%;
      max-width: 1400px;
      margin: 0 auto;
      border: 1px solid var(--agents-readiness-border);
      border-radius: 3px;
      background: #fff;
      box-shadow: none;
      overflow: hidden;
    }

    .agents-readiness-actions-state {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .agents-readiness-actions-state--good {
      color: #108e80;
    }

    .agents-readiness-actions-state--warn {
      color: #c58a1b;
    }

    .agents-readiness-actions-state--bad {
      color: #c24f42;
    }

    .agents-readiness-actions-state--muted {
      color: #6d7782;
    }

    .agents-readiness-ready-card--warn {
      --agents-readiness-accent: #c58a1b;
      --agents-readiness-alert-color: #c58a1b;
    }

    .agents-readiness-ready-card--bad {
      --agents-readiness-accent: #c24f42;
      --agents-readiness-alert-color: #c24f42;
    }

    .agents-readiness-ready-card--muted {
      --agents-readiness-accent: #6d7782;
    }

    .agents-readiness-ready-top {
      padding: 24px 12px;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 12px;
      border-bottom: 1px solid var(--agents-readiness-border);
      text-align: left;
    }

    .agents-readiness-ready-top-copy {
      min-width: 0;
      display: flex;
      flex: 1 1 auto;
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }

    .agents-readiness-ready-heading {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 12px;
      color: var(--agents-readiness-accent);
    }

    .agents-readiness-ready-lamp {
      width: 24px;
      height: 24px;
      border-radius: 999px;
      background: var(--agents-readiness-accent);
      flex: 0 0 auto;
    }

    .agents-readiness-ready-label {
      color: inherit;
      font-size: 32px;
      font-weight: 800;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: 0.01em;
    }

    .agents-readiness-ready-copy {
      margin: 0;
      color: #596673;
      font-size: 14px;
      line-height: normal;
    }

    .agents-readiness-ready-refresh-form {
      margin: 0;
      flex: 0 0 auto;
    }

    .agents-readiness-ready-refresh-button.btn {
      width: 20px;
      min-width: 20px;
      height: 20px;
      min-height: 20px;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      background-image: none;
      box-shadow: none;
      color: var(--gray-500);
    }

    .agents-readiness-ready-refresh-icon {
      display: block;
      width: 20px;
      height: 20px;
      overflow: visible;
    }

    .agents-readiness-ready-refresh-button.btn:hover,
