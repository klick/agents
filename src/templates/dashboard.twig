                <li>{{ readinessMonitoringLine }}</li>
              </ul>
            </section>
          </div>

          {% if readinessActionRowsProblematic|length %}
            <div class="agents-readiness-actions-block" id="readinessActionMappingSection">
              <div class="agents-readiness-actions-head">
                <h2 class="agents-readiness-actions-title">Action Mapping</h2>
              </div>

              <div class="agents-readiness-actions-table-wrap">
                <table class="agents-readiness-actions-table" role="table">
                  <colgroup>
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--signal">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--state">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--impact">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--action">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--surface">
                  </colgroup>
                  <thead>
                    <tr>
                      <th scope="col">Signal</th>
                      <th scope="col">Current state</th>
                      <th scope="col">Impact</th>
                      <th scope="col">Recommended Action</th>
                      <th scope="col">Surface</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in readinessActionRowsProblematic %}
                      <tr data-state-tone="{{ row.stateTone }}">
                        <td><strong class="agents-readiness-actions-signal">{{ row.signal }}</strong></td>
                        <td>
                          <strong class="agents-readiness-actions-state agents-readiness-actions-state--{{ row.stateTone }}">{{ row.stateLabel }}</strong>
                        </td>
                        <td>{{ row.impact }}</td>
                        <td>
                          <a href="{{ row.primaryUrl }}" class="agents-readiness-actions-primary"><strong>{{ row.primaryAction }}</strong></a>
                          <a href="{{ row.secondaryUrl }}" class="agents-readiness-actions-secondary">{{ row.secondaryAction }}</a>
                        </td>
                        <td>{{ row.surface }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          {% endif %}
        </details>
      </section>

    {% endif %}

    {% if activeDashboardTab == 'discovery' %}
      <section class="border rounded p-3">
        <h2 class="h4">Quick Actions</h2>
        <div class="agents-actions" style="margin-bottom: 8px;">
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="all">
            <button class="btn submit" type="submit">Refresh All</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="llms">
            <button class="btn" type="submit">Refresh llms.txt</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="llms-full">
            <button class="btn" type="submit">Refresh llms-full.txt</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/prewarm-discovery') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <input type="hidden" name="target" value="commerce">
            <button class="btn" type="submit">Refresh commerce.txt</button>
          </form>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/clear-discovery-cache') }}
            {{ redirectInput('agents/dashboard/discovery') }}
            <button class="btn" type="submit">Clear cache</button>
          </form>
        </div>
        <p class="agents-subtle">Refresh cache after content or settings changes.</p>
      </section>

      <div class="agents-discovery-doc-grid">
        {% for key, document in discoveryStatus.documents %}
          {% set discoveryKey = key|default('') %}
          {% set bodyFieldName = discoveryKey == 'llms' ? 'llmsTxtBody' : (discoveryKey == 'commerce' ? 'commerceTxtBody' : '') %}
          {% set bodyLock = discoveryKey == 'llms'
            ? (discoverySettingsLocks.llmsTxtBodySettingLocked ?? false)
            : (discoveryKey == 'commerce' ? (discoverySettingsLocks.commerceTxtBodySettingLocked ?? false) : true) %}
          {% set canEditBody = bodyFieldName != '' and not bodyLock %}
          {% set configuredBody = bodyFieldName != '' ? (attribute(discoverySettings, bodyFieldName)|default('')) : '' %}
          {% set bodyValue = (document.body is defined and document.body is not same as(null)) ? document.body : '' %}
          {% set previewValue = bodyValue != '' ? bodyValue : (configuredBody != '' ? configuredBody : (document.preview ?: '# Disabled')) %}
          {% set refreshTarget = discoveryKey == 'llms' ? 'llms' : (discoveryKey == 'commerce' ? 'commerce' : 'llms-full') %}
          {% set toggleEnableField = discoveryKey == 'llms' ? 'enableLlmsTxt' : (discoveryKey == 'commerce' ? 'enableCommerceTxt' : 'enableLlmsFullTxt') %}

          <section class="agents-discovery-doc-card">
            <div class="agents-discovery-doc-card-head">
              <h2 class="agents-discovery-doc-card-title">{{ document.name }}</h2>
              <span class="status {{ document.enabled ? 'enabled' : 'disabled' }}"></span>
            </div>

            <div class="agents-discovery-doc-meta">
              <div><strong>URL:</strong> <a href="{{ document.url }}" target="_blank" rel="noopener">{{ document.path }}</a></div>
              <div><strong>Last Modified:</strong> <span>{{ document.lastModified ?: 'n/a' }}</span></div>
              <div><strong>Cache TTL:</strong> <span>{{ document.cacheTtlSeconds }} seconds</span></div>
            </div>

            <form method="post" accept-charset="UTF-8" class="agents-discovery-doc-editor" id="discovery-editor-{{ discoveryKey }}">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/save-settings') }}
              {{ redirectInput('agents/dashboard/discovery') }}
              <textarea
                class="agents-discovery-doc-preview"
                name="{{ bodyFieldName ?: '_readonlyPreview' }}"
                rows="12"
                {% if not canEditBody %}readonly{% endif %}
              >{{ previewValue }}</textarea>
              {% if bodyFieldName == '' %}
                <p class="agents-subtle" style="margin: 8px 0 0;">This document is generated-only and cannot be edited inline.</p>
              {% elseif bodyLock %}
                <p class="agents-subtle" style="margin: 8px 0 0;">Inline edit is locked by <code>config/agents.php</code>.</p>
              {% endif %}

            </form>

            <form method="post" accept-charset="UTF-8" class="agents-discovery-doc-inline-form" id="discovery-reset-{{ discoveryKey }}">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/save-settings') }}
              {{ redirectInput('agents/dashboard/discovery') }}
              <input type="hidden" name="resetDiscoveryBodyTarget" value="{{ discoveryKey == 'commerce' ? 'commerce' : 'llms' }}">
            </form>
            <form method="post" accept-charset="UTF-8" class="agents-discovery-doc-inline-form" id="discovery-refresh-{{ discoveryKey }}">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/prewarm-discovery') }}
              {{ redirectInput('agents/dashboard/discovery') }}
              <input type="hidden" name="target" value="{{ refreshTarget }}">
            </form>
            <form method="post" accept-charset="UTF-8" class="agents-discovery-doc-inline-form" id="discovery-toggle-{{ discoveryKey }}">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/save-settings') }}
              {{ redirectInput('agents/dashboard/discovery') }}
              <input type="hidden" name="{{ toggleEnableField }}" value="{{ document.enabled ? 0 : 1 }}">
            </form>

            <div class="agents-discovery-doc-actions">
              {% if canEditBody %}
                <button class="btn submit" type="submit" form="discovery-editor-{{ discoveryKey }}">Save</button>
              {% endif %}
              <div class="agents-discovery-doc-btn-group">
                <button
                  class="btn agents-discovery-doc-btn"
                  type="submit"
                  form="discovery-reset-{{ discoveryKey }}"
                  {% if bodyFieldName == '' or bodyLock %}disabled{% endif %}
                >Reset</button>
                <button class="btn agents-discovery-doc-btn" type="submit" form="discovery-refresh-{{ discoveryKey }}">Refresh</button>
              </div>
              <button
                class="btn agents-discovery-doc-btn"
                type="submit"
                form="discovery-toggle-{{ discoveryKey }}"
              >{{ document.enabled ? 'Disable' : 'Enable' }}</button>
            </div>

            <div class="agents-discovery-doc-details-row">
              <details class="agents-advanced agents-discovery-doc-details">
                <summary><strong>Details</strong></summary>
                <div class="tablepane mx-0" style="margin-top: 8px;">
                  <table class="data fullwidth">
                    <tbody>
                    <tr><th>URL</th><td><a href="{{ document.url }}" target="_blank" rel="noopener">{{ document.url }}</a></td></tr>
                    <tr><th>ETag</th><td>{{ document.etag ?: 'n/a' }}</td></tr>
                    <tr><th>Bytes</th><td>{{ document.bytes }}</td></tr>
                    <tr><th>Lines</th><td>{{ document.lineCount }}</td></tr>
                  </tbody>
                  </table>
                </div>
              </details>
            </div>
          </section>
        {% endfor %}
      </div>

      <section class="border rounded p-3">
        <h2 class="h4">Editing Path</h2>
        <ul class="agents-link-list">
          <li>Edit <code>llms.txt</code> and <code>commerce.txt</code> directly in the cards above.</li>
          <li>Use <code>config/agents.php</code> when you need environment-level overrides/lock-state.</li>
          <li>Use this tab for refresh and verification only.</li>
          <li>Do not place secrets in discovery documents.</li>
        </ul>
      </section>


      <hr>


      <section class="border rounded p-3">
        <details class="agents-advanced">
          <summary><strong>Discovery Docs Status (Technical JSON)</strong></summary>
          <pre class="border rounded p-3">{{ discoveryStatusJson }}</pre>
        </details>
      </section>
    {% endif %}

    {% if activeDashboardTab == 'security' %}
      {% set securityTokenRequired = securityPosture.authentication.required ?? false %}
      {% set securityRequestedRequireToken = securityPosture.authentication.requestedRequireToken ?? false %}
      {% set securityTokenForcedInProd = securityPosture.authentication.tokenRequirementForcedInProd ?? false %}
      {% set securityQueryTokenEnabled = securityPosture.authentication.allowQueryToken ?? false %}
      {% set securityFailOnMissingTokenInProd = securityPosture.authentication.failOnMissingTokenInProd ?? false %}
      {% set securityCredentialCount = securityPosture.authentication.credentialCount|default(0) %}
      {% set securityEnvCredentialCount = securityPosture.authentication.envCredentialCount|default(0) %}
      {% set securityManagedCredentialCount = securityPosture.authentication.managedCredentialCount|default(0) %}
      {% set securityDefaultScopes = securityPosture.authentication.tokenScopes|default([]) %}
      {% set securityDefaultScopeCount = securityDefaultScopes|length %}
      {% set securityDefaultScopePreview = securityDefaultScopes|slice(0, 3)|join(', ') %}
      {% set securityWarnings = securityPosture.warningCounts.warnings|default(0) %}
      {% set securityErrors = securityPosture.warningCounts.errors|default(0) %}
      {% set securityPrivacyRedaction = securityPosture.privacy.redactEmail ?? false %}
      {% set securityWebhookEnabled = securityPosture.webhook.enabled ?? false %}
      {% set securityWebhookUrlConfigured = securityPosture.webhook.urlConfigured ?? false %}
      {% set securityWebhookSecretConfigured = securityPosture.webhook.secretConfigured ?? false %}
      {% set securityWebhookDestinationHost = securityPosture.webhook.destinationHost ?: 'n/a' %}
      {% set securityWebhookTimeoutSeconds = securityPosture.webhook.timeoutSeconds|default(0) %}
      {% set securityWebhookMaxAttempts = securityPosture.webhook.maxAttempts|default(0) %}
      {% set securityRateLimitPerMinute = securityPosture.rateLimit.perMinute|default(0) %}
      {% set securityRateLimitWindowSeconds = securityPosture.rateLimit.windowSeconds|default(0) %}
      {% set securityDlqCount = webhookDeadLetters|length %}
      {% set securityActiveCredentials7d = observabilitySummary.activeCredentials7d|default(0) %}
      {% set securityAuthFailures = observabilitySummary.authFailuresTotal|default(0) %}
      {% set securityForbiddenTotal = observabilitySummary.forbiddenTotal|default(0) %}
      {% set securityRateLimitDenied = observabilitySummary.rateLimitExceededTotal|default(0) %}
      {% set securityErrors5xx = observabilitySummary.errors5xxTotal|default(0) %}
      {% set securityRequestsTotal = observabilitySummary.requestsTotal|default(0) %}
      {% set securityGeneratedAt = observabilitySummary.generatedAt|default('') %}
      {% set securityGeneratedAtTimestamp = securityGeneratedAt ? securityGeneratedAt|date('U') : 0 %}
      {% set securityNowTimestamp = 'now'|date('U') %}
      {% set securityEvaluatedAgeSeconds = securityGeneratedAtTimestamp > 0 ? (securityNowTimestamp - securityGeneratedAtTimestamp) : null %}
      {% set securityEvaluationLabel = 'unknown' %}
      {% if securityEvaluatedAgeSeconds is not same as(null) %}
        {% if securityEvaluatedAgeSeconds < 60 %}
          {% set securityEvaluationLabel = 'just now' %}
        {% elseif securityEvaluatedAgeSeconds < 3600 %}
          {% set securityMinutesAgo = (securityEvaluatedAgeSeconds / 60)|round(0, 'floor') %}
          {% set securityEvaluationLabel = securityMinutesAgo ~ ' minute' ~ (securityMinutesAgo == 1 ? '' : 's') ~ ' ago' %}
        {% elseif securityEvaluatedAgeSeconds < 86400 %}
          {% set securityHoursAgo = (securityEvaluatedAgeSeconds / 3600)|round(0, 'floor') %}
          {% set securityEvaluationLabel = securityHoursAgo ~ ' hour' ~ (securityHoursAgo == 1 ? '' : 's') ~ ' ago' %}
        {% else %}
          {% set securityDaysAgo = (securityEvaluatedAgeSeconds / 86400)|round(0, 'floor') %}
          {% set securityEvaluationLabel = securityDaysAgo ~ ' day' ~ (securityDaysAgo == 1 ? '' : 's') ~ ' ago' %}
        {% endif %}
      {% endif %}
      {% set securityConfidenceLabel = securityCredentialCount > 0 and securityActiveCredentials7d > 0 and securityRequestsTotal > 0 ? 'high' : 'limited' %}
      {% set securityWebhookMisconfigured = (securityWebhookUrlConfigured and not securityWebhookSecretConfigured) or ((not securityWebhookUrlConfigured) and securityWebhookSecretConfigured) %}
      {% set securityHasRuntimeSignalIssues = securityAuthFailures > 0 or securityForbiddenTotal > 0 or securityRateLimitDenied > 0 or securityErrors5xx > 0 %}
      {% set securityAuthSummaryTone = 'good' %}
      {% set securityAuthSummaryLabel = 'Good' %}
      {% if (not securityTokenRequired) or securityQueryTokenEnabled or securityHasRuntimeSignalIssues %}
        {% set securityAuthSummaryTone = 'warn' %}
        {% set securityAuthSummaryLabel = 'Needs attention' %}
      {% endif %}
      {% set securityCredentialSummaryTone = 'good' %}
      {% set securityCredentialSummaryLabel = 'Good' %}
      {% if securityTokenRequired and securityCredentialCount == 0 %}
        {% set securityCredentialSummaryTone = 'bad' %}
        {% set securityCredentialSummaryLabel = 'Blocked' %}
      {% elseif securityCredentialCount > 0 and securityActiveCredentials7d == 0 %}
        {% set securityCredentialSummaryTone = 'muted' %}
        {% set securityCredentialSummaryLabel = 'Unproven' %}
      {% endif %}
      {% set securityPolicySummaryTone = 'good' %}
      {% set securityPolicySummaryLabel = 'Good' %}
      {% if securityErrors > 0 %}
        {% set securityPolicySummaryTone = 'bad' %}
        {% set securityPolicySummaryLabel = 'Blocked' %}
      {% elseif securityWarnings > 0 or not securityPrivacyRedaction %}
        {% set securityPolicySummaryTone = 'warn' %}
        {% set securityPolicySummaryLabel = 'Needs attention' %}
      {% endif %}
      {% set securityWebhookSummaryTone = 'good' %}
      {% set securityWebhookSummaryLabel = 'Good' %}
      {% if not securityWebhookEnabled and not securityWebhookUrlConfigured and not securityWebhookSecretConfigured %}
        {% set securityWebhookSummaryTone = 'muted' %}
        {% set securityWebhookSummaryLabel = 'Not enabled' %}
      {% elseif securityWebhookMisconfigured or securityDlqCount > 0 %}
        {% set securityWebhookSummaryTone = 'warn' %}
        {% set securityWebhookSummaryLabel = 'Needs attention' %}
      {% endif %}
      {% set securityHasBlockingIssues = securityPolicySummaryTone == 'bad' or securityCredentialSummaryTone == 'bad' %}
      {% set securityHasDegradedSignals = (not securityHasBlockingIssues) and (
        securityAuthSummaryTone == 'warn'
        or securityPolicySummaryTone == 'warn'
        or securityWebhookSummaryTone == 'warn'
      ) %}
      {% set securityHasLowConfidence = (not securityHasBlockingIssues) and (not securityHasDegradedSignals) and securityCredentialSummaryTone == 'muted' %}
      {% set securityStateKey = 'ready' %}
      {% set securityStateLabel = 'Good' %}
      {% set securityStateLead = 'Security posture is aligned for governed machine access.' %}
      {% set securityStateSubcopy = 'Token enforcement, credential coverage, and webhook posture do not need attention right now.' %}
      {% set securityStateTone = 'good' %}
      {% if securityHasBlockingIssues %}
        {% set securityStateKey = 'blocked' %}
        {% set securityStateLabel = 'Blocked' %}
        {% set securityStateLead = 'Security posture is not acceptable for trusted machine traffic.' %}
        {% set securityStateSubcopy = 'Resolve the blocking issues below before treating this environment as safely operational.' %}
        {% set securityStateTone = 'bad' %}
      {% elseif securityHasDegradedSignals %}
        {% set securityStateKey = 'degraded' %}
        {% set securityStateLabel = 'Needs Attention' %}
        {% set securityStateLead = 'Security posture is working, but one or more controls need follow-up.' %}
        {% set securityStateSubcopy = 'Review the affected areas below, then use the action map to route the next operator step.' %}
        {% set securityStateTone = 'warn' %}
      {% elseif securityHasLowConfidence %}
        {% set securityStateKey = 'unproven' %}
        {% set securityStateLabel = 'Unproven' %}
        {% set securityStateLead = 'No blocking issue is visible, but recent credential and traffic evidence is thin.' %}
        {% set securityStateSubcopy = 'Treat this verdict as low-confidence until machine access has been exercised recently.' %}
        {% set securityStateTone = 'muted' %}
      {% endif %}
      {% set securityAuthProofTone = securityAuthSummaryTone in ['warn', 'bad'] ? securityAuthSummaryTone : 'good' %}
      {% set securityCredentialProofTone = securityCredentialSummaryTone in ['warn', 'bad'] ? securityCredentialSummaryTone : 'good' %}
      {% set securityPolicyProofTone = securityPolicySummaryTone in ['warn', 'bad'] ? securityPolicySummaryTone : 'good' %}
      {% set securityRuntimeSignalsProofTone = securityErrors5xx > 0
        ? 'bad'
        : ((securityAuthFailures > 0 or securityForbiddenTotal > 0 or securityRateLimitDenied > 0) ? 'warn' : 'good') %}
      {% set securityWebhookProofTone = securityWebhookSummaryTone in ['warn', 'bad'] ? securityWebhookSummaryTone : 'good' %}
      {% set securityDlqProofTone = securityDlqCount > 0 ? 'warn' : 'good' %}
      {% set securityActivityProofTone = (securityActiveCredentials7d > 0 and securityRequestsTotal > 0) ? 'good' : 'warn' %}
      {% set securityWarningsProofTone = securityErrors > 0 ? 'bad' : (securityWarnings > 0 ? 'warn' : 'good') %}
      {% set securitySettingsUrl = cpUrl('agents/settings') %}
      {% set securityAccountsUrl = cpUrl('agents/credentials') %}
      {% set securityAttentionAccountsUrl = cpUrl('agents/credentials', { listFilter: 'attention', focusFirstVisible: 1 }) %}
      {% set securityDashboardUrl = cpUrl('agents/dashboard/security') %}
      {% set securityActionRows = [
        {
          signal: 'Token enforcement relaxed',
          stateLabel: not securityTokenRequired ? 'Needs attention' : 'Clear',
          stateTone: not securityTokenRequired ? 'warn' : 'muted',
          impact: 'Requests can reach guarded surfaces without the standard token requirement.',
          primaryAction: 'Open plugin settings',
          secondaryAction: 'Review configuration locks',
          primaryUrl: securitySettingsUrl ~ '#runtimeSwitchesSection',
          secondaryUrl: securitySettingsUrl ~ '#configurationLocksSection',
          surface: 'Settings',
        },
        {
          signal: 'No runtime credentials',
          stateLabel: securityTokenRequired and securityCredentialCount == 0 ? 'Blocked' : 'Clear',
          stateTone: securityTokenRequired and securityCredentialCount == 0 ? 'bad' : 'muted',
          impact: 'Token enforcement cannot succeed because no usable credentials are configured.',
          primaryAction: 'Create managed account',
          secondaryAction: 'Open Accounts',
          primaryUrl: securityAccountsUrl ~ '#addAgentSection',
          secondaryUrl: securityAccountsUrl ~ '#agentsCardList',
          surface: 'Accounts',
        },
        {
          signal: 'Query-token transport',
          stateLabel: securityQueryTokenEnabled ? 'Needs attention' : 'Clear',
          stateTone: securityQueryTokenEnabled ? 'warn' : 'muted',
          impact: 'Tokens can be exposed through URLs, referrers, and copied links when query transport is enabled.',
          primaryAction: 'Open plugin settings',
          secondaryAction: 'Review auth posture',
          primaryUrl: securitySettingsUrl ~ '#runtimeSwitchesSection',
          secondaryUrl: securityDashboardUrl ~ '#authRatePostureSection',
          surface: 'Settings / Security',
        },
        {
          signal: 'Privacy redaction disabled',
          stateLabel: not securityPrivacyRedaction ? 'Needs attention' : 'Clear',
          stateTone: not securityPrivacyRedaction ? 'warn' : 'muted',
          impact: 'Sensitive address and order context may be returned with less protection than expected.',
          primaryAction: 'Review policy posture',
          secondaryAction: 'Inspect configuration locks',
          primaryUrl: securityDashboardUrl ~ '#authRatePostureSection',
          secondaryUrl: securitySettingsUrl ~ '#configurationLocksSection',
          surface: 'Security / Settings',
        },
        {
          signal: 'Auth failures',
          stateLabel: securityAuthFailures > 0 ? 'Needs attention' : 'Clear',
          stateTone: securityAuthFailures > 0 ? 'warn' : 'muted',
          impact: 'Credentials may be invalid or clients may be misconfigured.',
          primaryAction: 'Review credentials',
          secondaryAction: 'Inspect auth posture',
          primaryUrl: securityAttentionAccountsUrl ~ '#agentsCardList',
          secondaryUrl: securityDashboardUrl ~ '#authRatePostureSection',
          surface: 'Accounts / Security',
        },
        {
          signal: 'Scope denials',
          stateLabel: securityForbiddenTotal > 0 ? 'Needs attention' : 'Clear',
          stateTone: securityForbiddenTotal > 0 ? 'warn' : 'muted',
          impact: 'One or more credentials cannot complete their expected requests.',
          primaryAction: 'Inspect scopes',
          secondaryAction: 'Open Accounts',
          primaryUrl: securityDashboardUrl ~ '#authRatePostureSection',
          secondaryUrl: securityAccountsUrl ~ '#agentsCardList',
          surface: 'Security / Accounts',
        },
        {
          signal: 'Rate-limit denials',
          stateLabel: securityRateLimitDenied > 0 ? 'Needs attention' : 'Clear',
          stateTone: securityRateLimitDenied > 0 ? 'warn' : 'muted',
          impact: 'Clients may be overrunning policy limits and throttling themselves.',
          primaryAction: 'Review auth / rate posture',
          secondaryAction: 'Inspect runtime signals',
          primaryUrl: securityDashboardUrl ~ '#authRatePostureSection',
          secondaryUrl: securityDashboardUrl ~ '#securityRuntimeSignalsSection',
          surface: 'Security',
        },
        {
          signal: 'Webhook configuration',
          stateLabel: securityWebhookMisconfigured ? 'Needs attention' : 'Clear',
          stateTone: securityWebhookMisconfigured ? 'warn' : 'muted',
          impact: 'Webhook delivery is partially configured and cannot operate safely until both URL and secret are present.',
          primaryAction: 'Review webhook posture',
          secondaryAction: 'Inspect configuration locks',
          primaryUrl: securityDashboardUrl ~ '#webhookReliabilitySection',
          secondaryUrl: securitySettingsUrl ~ '#configurationLocksSection',
          surface: 'Security / Settings',
        },
        {
          signal: 'Failed DLQ events',
          stateLabel: securityDlqCount > 0 ? 'Needs attention' : 'Clear',
          stateTone: securityDlqCount > 0 ? 'warn' : 'muted',
          impact: 'Final webhook delivery failures require replay or investigation.',
          primaryAction: 'Open replay queue',
          secondaryAction: 'Review webhook posture',
          primaryUrl: securityDashboardUrl ~ '#webhookDlqDetailSection',
          secondaryUrl: securityDashboardUrl ~ '#webhookReliabilitySection',
          surface: 'Security',
        },
        {
          signal: 'Security warnings',
          stateLabel: securityErrors > 0 ? 'Blocked' : (securityWarnings > 0 ? 'Needs attention' : 'Clear'),
          stateTone: securityErrors > 0 ? 'bad' : (securityWarnings > 0 ? 'warn' : 'muted'),
          impact: 'Policy warnings or errors indicate the runtime posture no longer matches expected production safeguards.',
          primaryAction: 'Review warnings',
          secondaryAction: 'Review environment profile',
          primaryUrl: securityDashboardUrl ~ '#securityWarningsSection',
          secondaryUrl: securityDashboardUrl ~ '#environmentProfileSection',
          surface: 'Security',
        },
        {
          signal: 'Low recent credential activity',
          stateLabel: securityCredentialCount > 0 and securityActiveCredentials7d == 0 ? 'Unproven' : 'Clear',
          stateTone: securityCredentialCount > 0 and securityActiveCredentials7d == 0 ? 'muted' : 'muted',
          impact: 'Security posture is harder to trust when credentials have not been exercised recently.',
          primaryAction: 'Open Accounts',
          secondaryAction: 'Review runtime signals',
          primaryUrl: securityAccountsUrl ~ '#agentsCardList',
          secondaryUrl: securityDashboardUrl ~ '#securityCredentialActivitySection',
          surface: 'Accounts / Security',
        },
      ] %}
      {% set securityActionRowsProblematic = [] %}
      {% for row in securityActionRows %}
        {% if (row.stateLabel|lower) != 'clear' %}
          {% set securityActionRowsProblematic = securityActionRowsProblematic|merge([row]) %}
        {% endif %}
      {% endfor %}
      {% set securityWarningPreview = securityPosture.warnings|default([])|slice(0, 4) %}
      {% set securityLatestDlqRow = webhookDeadLetters|first %}
      {% set securityLatestDlqUpdatedAt = 'n/a' %}
      {% if securityLatestDlqRow and securityLatestDlqRow.dateUpdated is defined and securityLatestDlqRow.dateUpdated %}
        {% set securityLatestDlqUpdatedAt = securityLatestDlqRow.dateUpdated %}
      {% elseif securityLatestDlqRow and securityLatestDlqRow.dateCreated is defined and securityLatestDlqRow.dateCreated %}
        {% set securityLatestDlqUpdatedAt = securityLatestDlqRow.dateCreated %}
      {% endif %}

      <section class="border p-0 agents-readiness-ready-card agents-readiness-ready-card--{{ securityStateTone }}" id="securitySnapshotSection">
        <div class="agents-readiness-ready-top">
          <div class="agents-readiness-ready-heading">
            <span class="agents-readiness-ready-lamp agents-readiness-ready-lamp--{{ securityStateTone }}" aria-hidden="true"></span>
            <span class="agents-readiness-ready-label">{{ securityStateLabel }}</span>
          </div>
          <p class="agents-readiness-ready-copy">
            {{ securityStateLead }}
            <br>
            {{ securityStateSubcopy }}
            <br>
            Last evaluated {{ securityEvaluationLabel }}.
          </p>
        </div>

        <div class="agents-readiness-ready-summary" role="list" aria-label="Security summary">
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Auth / Rate</span>
            <span class="agents-readiness-ready-summary-arrow" aria-hidden="true">→</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ securityAuthSummaryTone }}">{{ securityAuthSummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Credentials</span>
            <span class="agents-readiness-ready-summary-arrow" aria-hidden="true">→</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ securityCredentialSummaryTone }}">{{ securityCredentialSummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Webhook Reliability</span>
            <span class="agents-readiness-ready-summary-arrow" aria-hidden="true">→</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ securityWebhookSummaryTone }}">{{ securityWebhookSummaryLabel }}</strong>
          </div>
          <div class="agents-readiness-ready-summary-item" role="listitem">
            <span class="agents-readiness-ready-summary-label">Policy / Environment</span>
            <span class="agents-readiness-ready-summary-arrow" aria-hidden="true">→</span>
            <strong class="agents-readiness-ready-summary-value agents-readiness-ready-summary-value--{{ securityPolicySummaryTone }}">{{ securityPolicySummaryLabel }}</strong>
          </div>
        </div>

        <details class="agents-readiness-ready-details" open>
          <summary><span>Details +</span></summary>
          <div class="agents-readiness-ready-grid">
            <section class="agents-readiness-ready-proof-card" id="authRatePostureSection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityAuthProofTone }}">Auth / Rate Posture</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li>Token required: <strong>{{ securityTokenRequired ? 'yes' : 'no' }}</strong></li>
                <li>Query-token auth: <strong>{{ securityQueryTokenEnabled ? 'enabled' : 'disabled' }}</strong></li>
                <li>Rate limit: <strong>{{ securityRateLimitPerMinute }}</strong> requests / {{ securityRateLimitWindowSeconds }}s</li>
                <li>Email redaction: <strong>{{ securityPrivacyRedaction ? 'enabled' : 'disabled' }}</strong></li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="securityCredentialInventorySection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityCredentialProofTone }}">Credential Inventory</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li>Configured credentials: <strong>{{ securityCredentialCount }}</strong></li>
                <li>Managed CP credentials: <strong>{{ securityManagedCredentialCount }}</strong></li>
                <li>Env credentials: <strong>{{ securityEnvCredentialCount }}</strong></li>
                <li>Default scopes in runtime policy: <strong>{{ securityDefaultScopeCount }}</strong></li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="environmentProfileSection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityPolicyProofTone }}">Policy / Environment</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li>Environment: <strong>{{ securityPosture.environment|default('unknown') }}</strong></li>
                <li>Profile: <strong>{{ securityPosture.profile.name|default('unknown') }}</strong> ({{ securityPosture.profile.source|default('unknown') }})</li>
                <li>Defaults applied: <strong>{{ securityPosture.profile.defaultsApplied ? 'yes' : 'no' }}</strong></li>
                <li>Effective policy version: <strong>{{ securityPosture.profile.effectivePolicyVersion|default('n/a') }}</strong></li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="securityRuntimeSignalsSection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityRuntimeSignalsProofTone }}">Runtime Signals</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li>Auth failures: <strong>{{ securityAuthFailures }}</strong></li>
                <li>Scope denials: <strong>{{ securityForbiddenTotal }}</strong></li>
                <li>Rate-limit denials: <strong>{{ securityRateLimitDenied }}</strong></li>
                <li>Server errors (5xx): <strong>{{ securityErrors5xx }}</strong></li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="webhookReliabilitySection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityWebhookProofTone }}">Webhook Reliability</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li>Webhook enabled: <strong>{{ securityWebhookEnabled ? 'yes' : 'no' }}</strong></li>
                <li>URL configured: <strong>{{ securityWebhookUrlConfigured ? 'yes' : 'no' }}</strong></li>
                <li>Secret configured: <strong>{{ securityWebhookSecretConfigured ? 'yes' : 'no' }}</strong></li>
                <li>Host / timeout: <strong>{{ securityWebhookDestinationHost }}</strong> / {{ securityWebhookTimeoutSeconds }}s</li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="webhookDlqOverviewSection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityDlqProofTone }}">Dead-Letter Queue</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li>Failed events: <strong>{{ securityDlqCount }}</strong></li>
                <li>{{ securityDlqCount > 0 ? 'Replay controls available below' : 'No failed webhook events detected' }}</li>
                <li>Max attempts: <strong>{{ securityWebhookMaxAttempts }}</strong></li>
                <li>Latest update: <strong>{{ securityLatestDlqUpdatedAt }}</strong></li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="securityCredentialActivitySection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityActivityProofTone }}">Credential Activity</h3>
              <ul class="agents-readiness-ready-proof-list">
                <li>Last evaluated: <strong>{{ securityEvaluationLabel }}</strong></li>
                <li>Active credentials in last 7 days: <strong>{{ securityActiveCredentials7d }}</strong></li>
                <li>Observed guarded requests: <strong>{{ securityRequestsTotal }}</strong></li>
                <li>Confidence: <strong>{{ securityConfidenceLabel }}</strong></li>
              </ul>
            </section>

            <section class="agents-readiness-ready-proof-card" id="securityWarningsSection">
              <h3 class="agents-readiness-ready-proof-title agents-readiness-ready-proof-title--{{ securityWarningsProofTone }}">Security Warnings</h3>
              <ul class="agents-readiness-ready-proof-list">
                {% if securityWarningPreview|length %}
                  {% for warning in securityWarningPreview %}
                    <li><strong>[{{ warning.level|upper }}]</strong> {{ warning.message }}</li>
                  {% endfor %}
                {% else %}
                  <li>No active security warnings.</li>
                  <li>Errors: <strong>{{ securityErrors }}</strong></li>
                  <li>Warnings: <strong>{{ securityWarnings }}</strong></li>
                  <li>Requested token requirement: <strong>{{ securityRequestedRequireToken ? 'yes' : 'no' }}</strong></li>
                {% endif %}
              </ul>
            </section>
          </div>

          {% if securityActionRowsProblematic|length %}
            <div class="agents-readiness-actions-block" id="securityActionMappingSection">
              <div class="agents-readiness-actions-head">
                <h2 class="agents-readiness-actions-title">Action Mapping</h2>
              </div>

              <div class="agents-readiness-actions-table-wrap">
                <table class="agents-readiness-actions-table" role="table">
                  <colgroup>
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--signal">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--state">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--impact">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--action">
                    <col class="agents-readiness-actions-col agents-readiness-actions-col--surface">
                  </colgroup>
                  <thead>
                    <tr>
                      <th scope="col">Signal</th>
                      <th scope="col">Current state</th>
                      <th scope="col">Impact</th>
                      <th scope="col">Recommended Action</th>
                      <th scope="col">Surface</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for row in securityActionRowsProblematic %}
                      <tr data-state-tone="{{ row.stateTone }}">
                        <td><strong class="agents-readiness-actions-signal">{{ row.signal }}</strong></td>
                        <td>
                          <strong class="agents-readiness-actions-state agents-readiness-actions-state--{{ row.stateTone }}">{{ row.stateLabel }}</strong>
                        </td>
                        <td>{{ row.impact }}</td>
                        <td>
                          <a href="{{ row.primaryUrl }}" class="agents-readiness-actions-primary"><strong>{{ row.primaryAction }}</strong></a>
                          <a href="{{ row.secondaryUrl }}" class="agents-readiness-actions-secondary">{{ row.secondaryAction }}</a>
                        </td>
                        <td>{{ row.surface }}</td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          {% endif %}
        </details>
      </section>

      {% if webhookDeadLetters|length %}
        <section class="border rounded p-3" id="webhookDlqDetailSection">
          <h2 class="h4">Webhook Dead-Letter Queue</h2>
          <p class="agents-subtle">Final delivery failures are stored here and can be replayed.</p>

          <form method="post" accept-charset="UTF-8" style="margin-bottom: 10px;">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/replay-webhook-dlq') }}
            {{ redirectInput('agents/dashboard/security') }}
            <input type="hidden" name="mode" value="all">
            <input type="hidden" name="limit" value="25">
            <button class="btn" type="submit">Replay up to 25 failed events</button>
          </form>

          <div class="tablepane mx-0" style="margin-top: 0;">
            <table class="data fullwidth">
              <thead>
              <tr>
                <th>ID</th>
                <th>Event</th>
                <th>Status</th>
                <th>Attempts</th>
                <th>Last Error</th>
                <th>Updated</th>
                <th>Replay</th>
              </tr>
              </thead>
              <tbody>
              {% for row in webhookDeadLetters %}
                <tr>
                  <td>#{{ row.id }}</td>
                  <td>
                    <code>{{ row.eventId }}</code><br>
                    <span class="light">{{ row.resourceType ?: 'resource' }}:{{ row.resourceId ?: 'n/a' }} {{ row.action ? '(' ~ row.action ~ ')' : '' }}</span>
                  </td>
                  <td><strong>{{ row.status }}</strong></td>
                  <td>{{ row.attempts }}</td>
                  <td>{{ row.lastError ?: 'n/a' }}</td>
                  <td>{{ row.dateUpdated ?: row.dateCreated ?: 'n/a' }}</td>
                  <td>
                    <form method="post" accept-charset="UTF-8">
                      {{ csrfInput() }}
                      {{ actionInput('agents/dashboard/replay-webhook-dlq') }}
                      {{ redirectInput('agents/dashboard/security') }}
                      <input type="hidden" name="id" value="{{ row.id }}">
                      <button class="btn" type="submit">Replay</button>
                    </form>
                  </td>
                </tr>
              {% endfor %}
              </tbody>
            </table>
          </div>
        </section>
      {% endif %}

      <section class="border rounded p-3">
        <details class="agents-advanced">
          <summary><strong>Security Data (Technical JSON)</strong></summary>
          <pre class="border rounded p-3">{{ securityPostureJson }}</pre>
        </details>
      </section>
    {% endif %}
  </div>

  {% css %}
    .agents-discovery-doc-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
    }

    @media (min-width: 960px) {
      .agents-discovery-doc-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    .agents-discovery-doc-card {
      border: 1px solid #bfc9d6;
      border-radius: 6px;
      background: #ffffff;
      box-shadow: 0 4px 4px rgba(0, 0, 0, 0.06);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .agents-discovery-doc-card-head {
      padding: 12px 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .agents-discovery-doc-card-title {
      margin: 0;
      font-size: 18px;
      line-height: 1.2;
      font-weight: 700;
      color: #596673;
    }

    .agents-discovery-doc-meta {
      padding: 0 12px 20px;
      display: grid;
      gap: 4px;
      font-size: 12px;
      line-height: 1.35;
      color: #596673;
    }

    .agents-discovery-doc-editor {
      margin: 0;
      padding: 0;
      display: block;
    }

    .agents-discovery-doc-preview {
      width: 100%;
      min-height: 220px;
      border: 0;
      border-radius: 0;
      background: #e5ebf2;
      color: inherit;
      padding: 12px;
      resize: vertical;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      font-size: 12px;
      line-height: 1.35;
      box-shadow: none;
    }

    .agents-discovery-doc-preview[readonly] {
      background: #e3e9f0;
      cursor: default;
    }

    .agents-discovery-doc-actions {
      padding: 10px 12px 8px;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      gap: 8px;
      flex-wrap: nowrap;
      white-space: nowrap;
    }

    .agents-discovery-doc-inline-form {
      margin: 0;
      display: inline-flex;
    }

    .agents-discovery-doc-btn.btn {
      border: 0;
      box-shadow: none;
      background: #d4dbe4;
      color: #000000;
      border-radius: 4px;
      padding: 7px 10px;
      font-size: 12px;
      line-height: 1;
      min-height: 30px;
      white-space: nowrap;
    }

    .agents-discovery-doc-btn.btn:hover,
    .agents-discovery-doc-btn.btn:focus {
      background: #c6cfda;
      color: #000000;
    }

    .agents-discovery-doc-btn.btn:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      background: #d4dbe4;
      color: #000000;
    }

    .agents-discovery-doc-btn-group {
      display: inline-flex;
      align-items: center;
      border-radius: 4px;
      overflow: hidden;
    }

    .agents-discovery-doc-btn-group .agents-discovery-doc-btn.btn + .agents-discovery-doc-btn.btn {
      margin-left: 1px;
    }

    .agents-discovery-doc-btn-group .agents-discovery-doc-btn.btn {
      border-radius: 0;
    }

    .agents-discovery-doc-details-row {
      padding: 0 12px 12px;
    }

    .agents-discovery-doc-details-row .agents-advanced > summary {
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
    }

    .agents-readiness-ready-card {
      --agents-readiness-accent: #108e80;
      --agents-readiness-border: #c8d0da;
      width: 100%;
      max-width: 1400px;
      margin: 0 auto;
      border: 1px solid var(--agents-readiness-border);
      border-radius: 3px;
      background: #fff;
      box-shadow: none;
      overflow: hidden;
    }

    .agents-readiness-actions-state {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .agents-readiness-actions-state--good {
      color: #108e80;
    }

    .agents-readiness-actions-state--warn {
      color: #c58a1b;
    }

    .agents-readiness-actions-state--bad {
      color: #c24f42;
    }

    .agents-readiness-actions-state--muted {
      color: #6d7782;
    }

    .agents-readiness-ready-card--warn {
      --agents-readiness-accent: #c58a1b;
    }

    .agents-readiness-ready-card--bad {
      --agents-readiness-accent: #c24f42;
    }

    .agents-readiness-ready-card--muted {
      --agents-readiness-accent: #6d7782;
    }

    .agents-readiness-ready-top {
      padding: 24px 12px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
      border-bottom: 1px solid var(--agents-readiness-border);
      text-align: center;
    }

    .agents-readiness-ready-heading {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .agents-readiness-ready-lamp {
      width: 18px;
      height: 18px;
      border-radius: 999px;
      background: var(--agents-readiness-accent);
      flex: 0 0 auto;
    }

    .agents-readiness-ready-label {
      color: #596673;
      font-size: 36px;
      font-weight: 800;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: 0.01em;
    }

    .agents-readiness-ready-copy {
      margin: 0;
      color: #596673;
      font-size: 14px;
      line-height: 1.35;
    }

    .agents-readiness-ready-summary {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: stretch;
      gap: 0;
      background: transparent;
      border-bottom: 1px solid var(--agents-readiness-border);
    }

    .agents-readiness-ready-summary-item {
      flex: 0 0 auto;
      min-width: 0;
      padding: 12px;
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      gap: 12px;
      border-right: 1px solid var(--agents-readiness-border);
      background: #fff;
      color: #596673;
      font-size: 14px;
      line-height: 1.2;
      text-align: center;
    }

    .agents-readiness-ready-summary-item:first-child {
      border-left: 1px solid var(--agents-readiness-border);
    }

    .agents-readiness-ready-summary-label,
    .agents-readiness-ready-summary-arrow {
      font-weight: 400;
    }

    .agents-readiness-ready-summary-value {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.02em;
      text-transform: uppercase;
    }

    .agents-readiness-ready-summary-value--good {
      color: #108e80;
    }

    .agents-readiness-ready-summary-value--warn {
      color: #c58a1b;
    }

    .agents-readiness-ready-summary-value--bad {
      color: #c24f42;
    }

    .agents-readiness-ready-summary-value--muted {
      color: #6d7782;
    }

    .agents-readiness-ready-details > summary {
      list-style: none;
      cursor: pointer;
      user-select: none;
      padding: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      color: #596673;
      font-size: 12px;
      font-weight: 700;
      line-height: 1;
    }

    .agents-readiness-ready-details > summary::-webkit-details-marker {
      display: none;
    }

    .agents-readiness-ready-details[open] > summary {
      border-bottom: 1px solid var(--agents-readiness-border);
    }

    .agents-readiness-ready-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      background: var(--agents-readiness-border);
    }

    .agents-readiness-ready-proof-card {
      min-width: 0;
      padding: 12px;
      background: #fff;
      color: #596673;
    }

    .agents-readiness-ready-proof-title {
      margin: 0 0 6px;
      color: #596673;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
    }

    .agents-readiness-ready-proof-title--warn {
      color: #c58a1b;
    }

    .agents-readiness-ready-proof-title--bad {
      color: #c24f42;
    }

    .agents-readiness-ready-proof-list {
      margin: 0;
      padding: 0;
      list-style: none;
      color: #596673;
      font-size: 12px;
      line-height: 1.4;
    }

    .agents-readiness-ready-proof-list li + li {
      margin-top: 1px;
    }

    .agents-readiness-actions-block {
      border-top: 1px solid var(--agents-readiness-border);
    }

    .agents-readiness-actions-head {
      padding: 24px 12px 12px;
      border-bottom: 1px solid var(--agents-readiness-border);
      text-align: center;
    }

    .agents-readiness-actions-title {
      margin: 0;
      color: #596673;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.2;
    }

    .agents-readiness-actions-copy {
      margin: 2px 0 0;
      color: #596673;
      font-size: 12px;
      line-height: 1.4;
    }

    .agents-readiness-actions-table-wrap {
      padding: 24px 12px 0;
      overflow-x: auto;
    }

    .agents-readiness-actions-table {
      width: 100%;
      min-width: 1240px;
      border-collapse: collapse;
      table-layout: fixed;
      color: #596673;
      font-size: 12px;
      line-height: 1.45;
    }

    .agents-readiness-actions-col--signal {
      width: 11.69%;
    }

    .agents-readiness-actions-col--state {
      width: 21.43%;
    }

    .agents-readiness-actions-col--impact {
      width: 32.47%;
    }

    .agents-readiness-actions-col--action {
      width: 18.83%;
    }

    .agents-readiness-actions-col--surface {
      width: 15.58%;
    }

    .agents-readiness-actions-table th,
    .agents-readiness-actions-table td {
      text-align: left;
      vertical-align: top;
    }

    .agents-readiness-actions-table th {
      padding: 0 0 12px;
    }

    .agents-readiness-actions-table tbody td {
      padding-top: 24px;
      padding-bottom: 24px;
    }

    .agents-readiness-actions-table th + th,
    .agents-readiness-actions-table td + td {
      padding-left: 16px;
    }

    .agents-readiness-actions-table thead th {
      border-bottom: 1px solid #596673;
      color: #596673;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.2;
    }

    .agents-readiness-actions-table tbody td {
      border-bottom: 1px solid var(--agents-readiness-border);
      color: #596673;
    }

    .agents-readiness-actions-table tbody tr:last-child td {
      border-bottom: none;
    }

    .agents-readiness-actions-signal {
      color: #596673;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.2;
    }

    .agents-readiness-actions-primary,
    .agents-readiness-actions-secondary {
      display: block;
      text-decoration: none;
    }

    .agents-readiness-actions-primary {
      color: #2563eb;
      line-height: 1.25;
    }

    .agents-readiness-actions-secondary {
      margin-top: 2px;
      color: #596673;
      line-height: 1.25;
    }

    @media (max-width: 1023px) {
      .agents-readiness-ready-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 767px) {
      .agents-readiness-ready-top {
        padding: 20px 12px;
      }

      .agents-readiness-ready-label {
        font-size: 30px;
      }

      .agents-readiness-ready-grid {
        grid-template-columns: 1fr;
      }

      .agents-readiness-ready-summary {
        flex-direction: column;
      }

      .agents-readiness-ready-summary-item {
        width: 100%;
        justify-content: flex-start;
        text-align: left;
      }

      .agents-readiness-actions-table-wrap {
        padding-top: 12px;
      }
    }
  {% endcss %}
{% endblock %}
