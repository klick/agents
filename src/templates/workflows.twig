  <script>
    (() => {
      const forms = Array.from(document.querySelectorAll('[data-job-form]'));
      if (!forms.length) {
        return;
      }

      const debounce = (fn, wait = 180) => {
        let timeoutId = null;
        return (...args) => {
          window.clearTimeout(timeoutId);
          timeoutId = window.setTimeout(() => fn(...args), wait);
        };
      };

      const refreshAccountPicker = async (form) => {
        const container = form.querySelector('[data-job-account-picker-container]');
        if (!container || !container.dataset.matchUrl) {
          return;
        }

        const formData = new FormData(form);
        const selectedAccount = form.querySelector('input[name="workflowAccountId"]:checked');
        if (selectedAccount && !formData.get('workflowAccountId')) {
          formData.set('workflowAccountId', selectedAccount.value);
        }

        container.classList.add('is-loading');
        container.setAttribute('aria-busy', 'true');

        try {
          const response = await fetch(container.dataset.matchUrl, {
            method: 'POST',
            headers: {
              'Accept': 'application/json',
              'X-Requested-With': 'XMLHttpRequest',
            },
            credentials: 'same-origin',
            body: formData,
          });

          const payload = await response.json();
          if (!response.ok || !payload || payload.ok !== true || typeof payload.html !== 'string') {
            throw new Error('Unable to refresh account matches.');
          }

          container.innerHTML = payload.html;
        } catch (error) {
          if (window.Craft && typeof window.Craft.cp !== 'undefined' && typeof window.Craft.cp.displayError === 'function') {
            window.Craft.cp.displayError('Unable to refresh account matches right now.');
          }
        } finally {
          container.classList.remove('is-loading');
          container.removeAttribute('aria-busy');
        }
      };

      const bindJobForm = (form) => {
        const queueRefresh = debounce(() => refreshAccountPicker(form));

        form.addEventListener('change', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) {
            return;
          }

          const name = target.getAttribute('name') || '';
          if (name === 'workflowAccountId') {
            return;
          }

          if (
            name === 'workflowSourceKeys[]'
            || name === 'workflowSectionHandles[]'
            || name === 'workflowSiteIds[]'
            || name === 'workflowEntryIds[]'
            || name === 'workflowProductIds[]'
          ) {
            queueRefresh();
          }
        });

        form.addEventListener('input', (event) => {
          const target = event.target;
          if (!(target instanceof HTMLElement)) {
            return;
          }

          const name = target.getAttribute('name') || '';
          if (name === 'workflowName' || name === 'workflowDescription') {
            queueRefresh();
          }
        });

        ['workflowEntryIds', 'workflowProductIds'].forEach((id) => {
          const elementField = form.querySelector(`#${id}`);
          if (!elementField || typeof MutationObserver === 'undefined') {
            return;
          }

          const observer = new MutationObserver(() => queueRefresh());
          observer.observe(elementField, {
            childList: true,
            subtree: true,
            attributes: true,
          });
        });
      };

      forms.forEach(bindJobForm);
    })();
  </script>
