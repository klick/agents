{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = selectedWorkflow ? (selectedWorkflow.name ?: 'Job') : 'Jobs' %}
{% set selectedSubnavItem = 'jobs' %}
{% set workflowsIndexUrl = cpUrl('agents/workflows') %}
{% set workflowCreateUrl = cpUrl('agents/workflows', { workflowCreate: 'create' }) ~ '#workflowCreateSection' %}
{% set currentWorkflow = selectedWorkflow ?? null %}
{% set currentTemplate = currentWorkflow ? (currentWorkflow.template ?? null) : (selectedCreateTemplate ?? workflowTemplates[0] ?? null) %}
{% set currentTemplateRequiredScopes = currentTemplate.requiredScopes ?? [] %}
{% set currentConfig = currentWorkflow ? (currentWorkflow.config ?? {}) : (createJobState ?? {}) %}
{% set currentEntryIds = currentWorkflow ? (editJobState.entryIds ?? []) : (createJobState.entryIds ?? []) %}
{% set currentProductIds = currentWorkflow ? (editJobState.productIds ?? []) : (createJobState.productIds ?? []) %}
{% set currentSectionHandles = currentWorkflow ? (editJobState.sectionHandles ?? []) : (createJobState.sectionHandles ?? []) %}
{% set currentSiteIds = currentWorkflow ? (editJobState.siteIds ?? []) : (createJobState.siteIds ?? []) %}
{% set currentSourceKeys = currentWorkflow ? (editJobState.sourceKeys ?? []) : (createJobState.sourceKeys ?? []) %}
{% set workflowListFilterRaw = (craft.app.request.getQueryParam('listFilter', '')|lower) %}
{% set workflowListFilter = workflowListFilterRaw == 'attention' ? 'attention' : '' %}
{% set showWorkflowRiskColumn = workflowListFilter == 'attention' %}
{% set workflowAllFilterUrl = cpUrl('agents/workflows') %}
{% set workflowAttentionFilterUrl = cpUrl('agents/workflows', { listFilter: 'attention' }) %}
{% set filteredWorkflows = [] %}
{% for workflow in workflows %}
  {% set includeWorkflow = true %}
  {% if workflowListFilter == 'attention' %}
    {% set includeWorkflow = workflow.needsAttention|default(false) %}
  {% endif %}
  {% if includeWorkflow %}
    {% set filteredWorkflows = filteredWorkflows|merge([workflow]) %}
  {% endif %}
{% endfor %}
{% set workflowWeekdayLabels = {
  1: 'Mon',
  2: 'Tue',
  3: 'Wed',
  4: 'Thu',
  5: 'Fri',
  6: 'Sat',
  7: 'Sun'
} %}
{% set workflowTypesCount = workflowTemplates|length %}
{% set workflowTypesExpanded = workflows|length == 0 or showCreateWorkflow %}

{% block content %}
  {% include 'agents/_partials/cp-ui' %}

  <div class="agents-page-shell">
    <div class="agents-page-header">
      <div class="agents-page-header__copy">
        <h1>{{ currentWorkflow ? currentWorkflow.name : 'Jobs' }}</h1>
        {% if currentWorkflow %}
          <p class="agents-page-intro">Job type: <strong>{{ currentTemplate.displayName ?? currentWorkflow.templateHandle }}</strong> &middot; Schedule: {{ currentWorkflow.scheduleLabel }} &middot; Account: {{ include('agents/_partials/managed-account-ref', {
            label: currentWorkflow.accountDisplayName,
            url: accountsUrl,
          }, with_context = false) }} &middot; Boundary: {{ currentWorkflow.readBoundary.summary ?: (currentWorkflow.configSummary ?: (currentTemplate.focusLabel ?? 'Configured review scope')) }}</p>
        {% endif %}
      </div>
      <div class="agents-page-header__actions">
        {% if currentWorkflow %}
          <a class="btn" href="{{ workflowsIndexUrl }}">Overview</a>
          <form method="post" accept-charset="UTF-8">
            {{ csrfInput() }}
            {{ actionInput('agents/dashboard/download-workflow-bundle') }}
            {{ redirectInput('agents/workflows/' ~ currentWorkflow.id) }}
            <input type="hidden" name="workflowId" value="{{ currentWorkflow.id }}">
            <button class="btn" type="submit">Handoff</button>
          </form>
          {% if canManageWorkflows %}
            <form method="post" accept-charset="UTF-8">
              {{ csrfInput() }}
              {{ actionInput('agents/dashboard/duplicate-workflow') }}
              {{ redirectInput('agents/workflows/' ~ currentWorkflow.id) }}
              <input type="hidden" name="workflowId" value="{{ currentWorkflow.id }}">
              <button class="btn" type="submit">Duplicate</button>
            </form>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>

  <div class="agents-layout-stack">
    {% if not currentWorkflow %}
      <div class="agents-page-shell">
        <section class="agents-workflows-summary" aria-label="Job Filters">
          <section class="agents-table-toolbar" aria-label="Job view options">
            <div class="agents-table-toolbar__filters">
              <div class="agents-filter-strip-wrap">
                <nav class="agents-filter-strip" aria-label="Job filters">
                  <a class="agents-filter-strip__item{{ workflowListFilter == '' ? ' is-selected' : '' }}" href="{{ workflowAllFilterUrl }}">All</a>
                  <a class="agents-filter-strip__item{{ workflowListFilter == 'attention' ? ' is-selected' : '' }}" href="{{ workflowAttentionFilterUrl }}">Need attention</a>
                </nav>
              </div>
            </div>
            {% if canManageWorkflows %}
              <div class="agents-table-toolbar__controls">
                <a class="btn submit" href="{{ workflowCreateUrl }}">+ Add</a>
              </div>
            {% endif %}
          </section>
        </section>

        <section class="agents-workflows-registry-shell agents-standard-registry-shell">
          <div class="tableview tablepane agents-workflows-registry-wrap agents-standard-registry-wrap">
            <table class="data fullwidth big agents-workflows-registry agents-standard-registry" data-name="Jobs">
              <caption class="visually-hidden">Jobs registry</caption>
              <colgroup>
                <col class="agents-workflows-registry__col agents-workflows-registry__col--icon">
                <col class="agents-workflows-registry__col agents-workflows-registry__col--workflow">
                {% if showWorkflowRiskColumn %}
                  <col class="agents-workflows-registry__col agents-workflows-registry__col--risk">
                {% endif %}
                <col class="agents-workflows-registry__col agents-workflows-registry__col--schedule">
                <col class="agents-workflows-registry__col agents-workflows-registry__col--account">
                <col class="agents-workflows-registry__col agents-workflows-registry__col--focus">
                <col class="agents-workflows-registry__col agents-workflows-registry__col--run">
                <col class="agents-workflows-registry__col agents-workflows-registry__col--actions">
              </colgroup>
              <thead>
                <tr>
                  <th scope="col" class="agents-standard-registry__header-cell agents-workflows-registry__header-cell--icon"><span class="visually-hidden">Type</span></th>
                  <th scope="col" class="agents-standard-registry__header-cell">Job</th>
                  {% if showWorkflowRiskColumn %}
                    <th scope="col" class="agents-standard-registry__header-cell agents-table-attention-heading">Risk</th>
                  {% endif %}
                  <th scope="col" class="agents-standard-registry__header-cell">Schedule</th>
                  <th scope="col" class="agents-standard-registry__header-cell">Managed Account</th>
                  <th scope="col" class="agents-standard-registry__header-cell">Boundary</th>
                  <th scope="col" class="agents-standard-registry__header-cell">Latest Run</th>
                  <th scope="col" class="agents-standard-registry__header-cell">Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for workflow in filteredWorkflows %}
                  {% set latestRun = workflow.latestRun ?? null %}
                  {% set workflowWeekdayLabel = workflowWeekdayLabels[workflow.weekday|default(0)] ?? 'Day' %}
                  {% set workflowScheduleTableLabel = workflow.timeOfDay ? (workflowWeekdayLabel ~ ' ' ~ workflow.timeOfDay) : 'Manual' %}
                  <tr class="agents-workflows-registry__row{% if workflow.needsAttention %} agents-workflows-registry__row--attention{% endif %}">
                    <td class="agents-workflows-registry__body-cell agents-workflows-registry__body-cell--icon" aria-hidden="true">
                      <span class="agents-workflows-registry-icon">
                        <svg focusable="false" preserveAspectRatio="xMidYMid meet" fill="currentColor" width="32" height="32" viewBox="0 0 32 32" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
                          <path d="M30,13A11,11,0,0,0,19,2H11a9,9,0,0,0-9,9v3a5,5,0,0,0,5,5H8.1A5,5,0,0,0,13,23h1.38l4,7,1.73-1-4-6.89A2,2,0,0,0,14.38,21H13a3,3,0,0,1,0-6h1V13H13a5,5,0,0,0-4.9,4H7a3,3,0,0,1-3-3V12H6A3,3,0,0,0,9,9V8H7V9a1,1,0,0,1-1,1H4.08A7,7,0,0,1,11,4h6V6a1,1,0,0,1-1,1H14V9h2a3,3,0,0,0,3-3V4a9,9,0,0,1,8.05,5H26a3,3,0,0,0-3,3v1h2V12a1,1,0,0,1,1-1h1.77A8.76,8.76,0,0,1,28,13v1a5,5,0,0,1-5,5H20v2h3a7,7,0,0,0,3-.68V21a3,3,0,0,1-3,3H22v2h1a5,5,0,0,0,5-5V18.89A7,7,0,0,0,30,14Z"></path>
                          <title>Cognitive</title>
                        </svg>
                      </span>
                    </td>
                    <th scope="row" class="agents-workflows-registry__body-cell agents-workflows-registry__body-cell--workflow">
                      <div class="agents-workflows-registry__title">{{ workflow.name }}</div>
                    </th>
                    {% if showWorkflowRiskColumn %}
                      <td class="agents-workflows-registry__body-cell agents-workflows-registry__body-cell--risk">
                        <div class="agents-workflows-registry__stack">
                          <div class="agents-workflows-registry-risk-text agents-table-attention-text">{{ workflow.attentionSummary ?: 'Needs review' }}</div>
                          {% if workflow.attentionMeta %}
                            <div class="agents-workflows-registry__meta agents-table-attention-meta">{{ workflow.attentionMeta }}</div>
                          {% endif %}
                        </div>
                      </td>
                    {% endif %}
                    <td class="agents-workflows-registry__body-cell">{{ workflowScheduleTableLabel }}</td>
                    <td class="agents-workflows-registry__body-cell">{{ include('agents/_partials/managed-account-ref', {
                      label: workflow.accountDisplayName,
                      url: accountsUrl,
                    }, with_context = false) }}</td>
                    <td class="agents-workflows-registry__body-cell">{{ workflow.configSummary ?: (workflow.template.focusLabel ?? 'Configured review scope') }}</td>
                    <td class="agents-workflows-registry__body-cell">
                      {% if latestRun %}
                        <div class="agents-workflows-registry__stack">
                          <div>{{ latestRun.status|title }}</div>
                          <div class="agents-workflows-registry__meta">{{ include('agents/_partials/relative-short-date', { value: latestRun.completedAt ?: latestRun.startedAt ?: latestRun.scheduledFor }, with_context = false) }}</div>
                        </div>
                      {% else %}
                        <span class="light">No runs yet</span>
                      {% endif %}
                    </td>
                    <td class="agents-workflows-registry__body-cell agents-workflows-registry__body-cell--actions">
                      <div class="buttons">
                        <a class="btn small" href="{{ cpUrl('agents/workflows/' ~ workflow.id) }}">Open</a>
                        <form method="post" accept-charset="UTF-8">
                          {{ csrfInput() }}
                          {{ actionInput('agents/dashboard/download-workflow-bundle') }}
                          {{ redirectInput('agents/workflows') }}
                          <input type="hidden" name="workflowId" value="{{ workflow.id }}">
                          <button class="btn small" type="submit">Handoff</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                {% else %}
                  <tr>
                    <td colspan="{{ showWorkflowRiskColumn ? 8 : 7 }}" class="agents-workflows-registry__body-cell agents-workflows-registry__body-cell--empty agents-standard-registry__body-cell--empty">No jobs yet. Start from a read-only job type.</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <p class="agents-page-intro agents-page-intro--after-table">Create and manage recurring read-only jobs without turning Agents into a hosted agent. Agents stores schedule intent, bindings, bundle export, and run visibility. Your agent still executes the real work.</p>
      </div>

        {% if workflowTypesCount %}
          <hr class="agents-add-section-divider agents-section-break">
        {% endif %}

        {% if workflowTypesCount or (canManageWorkflows and showCreateWorkflow) %}
        <div class="agents-page-shell">
        {% endif %}

        {% if workflowTypesCount %}
          <details class="agents-workflow-types-panel"{% if workflowTypesExpanded %} open{% endif %} id="workflowTypesSection">
            <summary class="agents-workflow-types-toggle">
              <span class="agents-workflow-types-toggle__copy">
                <span class="agents-workflow-types-toggle__title">Job Types</span>
                <span class="agents-workflow-types-toggle__meta">{{ workflowTypesCount }} available</span>
              </span>
            </summary>

            <div class="agents-workflow-types-panel__body">
              <p class="agents-subtle agents-workflow-types-note">Job types stay curated for now so Agents can validate required access, generate the right handoff bundle, and keep agent expectations predictable.</p>

              <div class="tableview tablepane agents-workflow-types-registry-wrap agents-standard-registry-wrap">
                <table class="data fullwidth big agents-workflow-types-registry agents-standard-registry" data-name="Job Types">
                  <caption class="visually-hidden">Job types</caption>
                  <colgroup>
                    <col class="agents-workflow-types-registry__col agents-workflow-types-registry__col--type">
                    <col class="agents-workflow-types-registry__col agents-workflow-types-registry__col--purpose">
                    <col class="agents-workflow-types-registry__col agents-workflow-types-registry__col--coverage">
                    <col class="agents-workflow-types-registry__col agents-workflow-types-registry__col--actions">
                  </colgroup>
                  <thead>
                    <tr>
                      <th scope="col" class="agents-standard-registry__header-cell">Job Type</th>
                      <th scope="col" class="agents-standard-registry__header-cell">Purpose</th>
                      <th scope="col" class="agents-standard-registry__header-cell">Coverage</th>
                      <th scope="col" class="agents-standard-registry__header-cell">Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for template in workflowTemplates %}
                      {% set templateCreateUrl = cpUrl('agents/workflows', {
                        workflowCreate: 'create',
                        workflowTemplate: template.handle,
                      }) ~ '#workflowCreateSection' %}
                      <tr>
                        <th scope="row" class="agents-standard-registry__body-cell agents-workflow-types-registry__body-cell--type">
                          <div class="agents-workflow-types-registry__title">{{ template.displayName }}</div>
                        </th>
                        <td class="agents-standard-registry__body-cell">{{ template.description }}</td>
                        <td class="agents-standard-registry__body-cell">
                          <div class="agents-workflow-types-registry__stack">
                            <div>{{ template.focusLabel ?? 'Configured review scope' }}</div>
                            <div class="agents-workflow-types-registry__meta">Read-only · {{ (template.requiredScopes ?? [])|length }} required scopes</div>
                          </div>
                        </td>
                        <td class="agents-standard-registry__body-cell agents-workflow-types-registry__body-cell--actions">
                          {% if canManageWorkflows %}
                            <div class="buttons">
                              <a class="btn small" href="{{ templateCreateUrl }}">Use this type</a>
                            </div>
                          {% else %}
                            <span class="light">Manage permission required.</span>
                          {% endif %}
                        </td>
                      </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </details>
        {% endif %}

        {% if canManageWorkflows and showCreateWorkflow %}
          <section class="agents-workflows-create-shell" id="workflowCreateSection">
            <div class="agents-create-header">
              <div>
                <h2 class="h4">Create Job</h2>
                <p class="agents-subtle agents-workflows-note">Type: {{ currentTemplate.displayName ?? 'Job type' }} &middot; <a href="#workflowTypesSection">Browse job types</a></p>
              </div>
            </div>

            <div class="agents-workflows-form-shell agents-job-create-form-shell">
              <form method="post" accept-charset="UTF-8" data-job-form class="agents-job-create-form">
                {{ csrfInput() }}
                {{ actionInput('agents/dashboard/create-workflow') }}
                {{ redirectInput('agents/workflows') }}
                <input type="hidden" name="workflowTemplateHandle" value="{{ currentTemplate.handle ?? '' }}">
                <input type="hidden" name="workflowStatus" value="active">
                <input type="hidden" name="workflowCadence" value="weekly">

                <section class="agents-job-create-section agents-job-create-section--intro">
                  {{ forms.textField({
                    label: 'Job name',
                    id: 'workflowName',
                    name: 'workflowName',
                    required: true,
                    value: createJobState.name ?? currentTemplate.displayName ?? 'Job',
                    instructions: 'Operator-facing name shown in the jobs registry.',
                  }) }}

                  {{ forms.textField({
                    label: 'Short description',
                    id: 'workflowDescription',
                    name: 'workflowDescription',
                    maxlength: 255,
                    value: createJobState.description ?? currentTemplate.description ?? '',
                    instructions: 'Short purpose statement for operators and reviewers.',
                  }) }}

                  {{ forms.textareaField({
                    label: 'Prompt / policy context',
                    id: 'workflowPromptContext',
                    name: 'workflowPromptContext',
                    rows: 4,
                    value: createJobState.promptContext ?? '',
                    instructions: 'Describe what the agent should produce or review. Keep the prompt focused on the work, not on access.',
                  }) }}
                </section>

                <div class="agents-job-create-divider" aria-hidden="true"></div>

                <section class="agents-job-create-section agents-job-create-section--sources">
                  <div class="field">
                    <div class="heading"><label>What should the agent read?</label></div>
                    <div class="instructions"><p>Click the content needs for this Job. Agents uses these picks to reduce the account list asynchronously.</p></div>
                    <div class="agents-job-source-groups">
                      {% for sourceGroupKey, sourceGroup in workflowSourceGroups %}
                        {% set hasGroupSources = false %}
                        {% for sourceKey, source in workflowSourceCatalog %}
                          {% if source.group == sourceGroupKey %}
                            {% set hasGroupSources = true %}
                          {% endif %}
                        {% endfor %}
                        {% if hasGroupSources %}
                          <section class="agents-job-source-group">
                            <div class="agents-job-source-group__header">
                              <div class="agents-job-source-group__title">{{ sourceGroup.label }}</div>
                            <div class="agents-job-source-group__description">{{ sourceGroup.description }}</div>
                          </div>
                          <div class="agents-capability-group-pills agents-job-source-pill-row">
                            {% for sourceKey, source in workflowSourceCatalog %}
                              {% if source.group == sourceGroupKey %}
                                <label class="agents-capability-pill agents-capability-pill--job" title="{{ source.description }}">
                                  <input type="checkbox" name="workflowSourceKeys[]" value="{{ source.key }}"{% if source.key in (createJobState.sourceKeys ?? []) %} checked{% endif %}>
                                  <span class="agents-capability-pill-copy">
                                    <span class="agents-capability-pill-title">{{ source.label }}</span>
                                  </span>
                                </label>
                              {% endif %}
                            {% endfor %}
                          </div>
                          </section>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>

                  <div class="agents-job-boundary-grid">
                    {{ forms.elementSelectField({
                      label: 'Entries',
                      instructions: 'Optional boundary for a tighter entry review scope. Leave blank for section- or site-level review.',
                      id: 'workflowEntryIds',
                      name: 'workflowEntryIds',
                      elementType: 'craft\\elements\\Entry',
                      selectionLabel: 'Select entries'|t('app'),
                      elements: [],
                      limit: null,
                      viewMode: 'list-inline',
                      sources: ['*'],
                      criteria: {
                        status: null,
                      },
                    }) }}

                    {% if workflowProductElementType %}
                      {{ forms.elementSelectField({
                        label: 'Products',
                        instructions: 'Optional boundary for commerce-facing jobs. Leave blank when products are not part of the boundary.',
                        id: 'workflowProductIds',
                        name: 'workflowProductIds',
                        elementType: workflowProductElementType,
                        selectionLabel: 'Select products'|t('app'),
                        elements: [],
                        limit: null,
                        viewMode: 'list-inline',
                        sources: ['*'],
                      }) }}
                    {% endif %}

                    <div class="field">
                      <div class="heading"><label>Sections</label></div>
                      <div class="instructions"><p>Optional boundary for a tighter section-level review scope.</p></div>
                      <div class="agents-job-boundary-pills">
                        {% for section in availableSections %}
                          <label class="agents-job-boundary-pill">
                            <input type="checkbox" name="workflowSectionHandles[]" value="{{ section.handle }}"{% if section.handle in (createJobState.sectionHandles ?? []) %} checked{% endif %}>
                            <span class="agents-job-boundary-pill__copy">{{ section.name ?: section.handle }}</span>
                          </label>
                        {% endfor %}
                      </div>
                    </div>

                    <div class="field">
                      <div class="heading"><label>Sites</label></div>
                      <div class="instructions"><p>Optional boundary for a tighter site-level review scope.</p></div>
                      <div class="agents-job-boundary-pills">
                        {% for site in availableSites %}
                          <label class="agents-job-boundary-pill">
                            <input type="checkbox" name="workflowSiteIds[]" value="{{ site.id }}"{% if site.id in (createJobState.siteIds ?? []) %} checked{% endif %}>
                            <span class="agents-job-boundary-pill__copy">{{ site.name ?: ('Site #' ~ site.id) }}</span>
                          </label>
                        {% endfor %}
                      </div>
                    </div>
                  </div>
                </section>

                <section class="agents-job-create-section">
                  <div class="field">
                    <div class="heading"><label>Accounts</label></div>
                    <div class="instructions"><p>All accounts are shown first. As you define content needs and boundaries, Agents narrows the list to compatible accounts.</p></div>
                    <div
                      id="workflowAccountPicker"
                      data-job-account-picker-container
                      data-match-url="{{ actionUrl('agents/dashboard/workflow-account-matches') }}"
                    >
                      {% include 'agents/_partials/job-account-picker' with {
                        accountSelection: createAccountSelection,
                        pickerLayout: 'flat',
                        showIntro: false,
                      } only %}
                    </div>
                  </div>
                </section>

                <div class="agents-job-create-divider" aria-hidden="true"></div>

                <section class="agents-job-create-section">
                  <div class="agents-workflows-schedule-panel">
                    <div class="agents-workflows-schedule-panel__title">Schedule</div>
                    <div class="agents-workflows-schedule-grid">
                      <div class="field">
                        <div class="heading"><label for="workflowWeekday">Day</label></div>
                        <div class="select">
                          <select id="workflowWeekday" name="workflowWeekday" required>
                            {% for option in workflowWeekdayOptions %}
                              <option value="{{ option.value }}"{% if option.value == (createJobState.weekday ?? 4) %} selected{% endif %}>{{ option.label }}</option>
                            {% endfor %}
                          </select>
                        </div>
                      </div>

                      {{ forms.timeField({
                        label: 'Time',
                        id: 'workflowTimeOfDay',
                        name: 'workflowTimeOfDay',
                        value: createJobState.timeOfDay ?? '08:00',
                        required: true,
                        minuteIncrement: 15,
                      }) }}
                    </div>
                  </div>
                </section>

                <div class="agents-job-create-divider" aria-hidden="true"></div>

                {{ forms.textareaField({
                  label: 'Operator notes',
                  id: 'workflowOperatorNotes',
                  name: 'workflowOperatorNotes',
                  rows: 3,
                  value: createJobState.operatorNotes ?? '',
                  instructions: 'Internal reminder shown only in Craft.',
                }) }}

                <div class="agents-form-actions">
                  <button class="btn submit" type="submit">Create Job</button>
                  <a class="btn" href="{{ workflowsIndexUrl }}">Cancel</a>
                </div>
              </form>
            </div>
          </section>
        {% endif %}
        {% if workflowTypesCount or (canManageWorkflows and showCreateWorkflow) %}
        </div>
        {% endif %}
    {% else %}
      <div class="agents-page-shell">
        <section class="agents-workflows-summary">
              <div class="agents-metric-strip-wrap">
                <div class="agents-metric-strip">
              <div class="agents-metric-strip-card">
                <div class="agents-metric-strip-card__top">
                  <div class="agents-metric-strip-card__label">Status</div>
                  <div class="agents-metric-strip-card__value">{{ currentWorkflow.status|title }}</div>
                </div>
              </div>
              <div class="agents-metric-strip-card">
                <div class="agents-metric-strip-card__top">
                  <div class="agents-metric-strip-card__label">Schedule</div>
                  <div class="agents-metric-strip-card__value">{{ currentWorkflow.scheduleLabel }}</div>
                </div>
              </div>
              <div class="agents-metric-strip-card">
                <div class="agents-metric-strip-card__top">
                  <div class="agents-metric-strip-card__label">Next due</div>
                  <div class="agents-metric-strip-card__value">{{ currentWorkflow.nextDueLabel }}</div>
                </div>
              </div>
              <div class="agents-metric-strip-card">
                <div class="agents-metric-strip-card__top">
                  <div class="agents-metric-strip-card__label">Latest run</div>
                  <div class="agents-metric-strip-card__value">{{ currentWorkflow.latestRun ? currentWorkflow.latestRun.status|title : 'No runs yet' }}</div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <div class="agents-workflows-detail-grid">
          <section class="agents-workflows-edit-shell border rounded p-3">
            <div class="agents-create-header">
              <div>
                <h2 class="h4">Job configuration</h2>
                <p class="agents-subtle agents-workflows-note">Edit job intent, boundary, and schedule. Execution still happens outside Craft.</p>
              </div>
            </div>

            {% if canManageWorkflows %}
              <form method="post" accept-charset="UTF-8" data-job-form>
                {{ csrfInput() }}
                {{ actionInput('agents/dashboard/update-workflow') }}
                {{ redirectInput('agents/workflows/' ~ currentWorkflow.id) }}
                <input type="hidden" name="workflowId" value="{{ currentWorkflow.id }}">
                <input type="hidden" name="workflowTemplateHandle" value="{{ currentWorkflow.templateHandle }}">
                <input type="hidden" name="workflowCadence" value="weekly">

                {{ forms.textField({
                  label: 'Job name',
                  id: 'workflowName',
                  name: 'workflowName',
                  required: true,
                  value: editJobState.name ?? currentWorkflow.name,
                }) }}

                {{ forms.textField({
                  label: 'Short description',
                  id: 'workflowDescription',
                  name: 'workflowDescription',
                  maxlength: 255,
                  value: editJobState.description ?? currentWorkflow.description,
                }) }}

                {{ forms.textareaField({
                  label: 'Prompt / policy context',
                  id: 'workflowPromptContext',
                  name: 'workflowPromptContext',
                  rows: 4,
                  value: editJobState.promptContext ?? currentConfig.promptContext ?? '',
                }) }}

                <div class="field">
                  <div class="heading"><label>What should the agent read?</label></div>
                  <div class="instructions"><p>Click the content needs for this Job. Agents uses these picks to reduce the account list asynchronously.</p></div>
                  <div class="agents-job-source-groups">
                    {% for sourceGroupKey, sourceGroup in workflowSourceGroups %}
                      {% set hasGroupSources = false %}
                      {% for sourceKey, source in workflowSourceCatalog %}
                        {% if source.group == sourceGroupKey %}
                          {% set hasGroupSources = true %}
                        {% endif %}
                      {% endfor %}
                      {% if hasGroupSources %}
                        <section class="agents-job-source-group">
                          <div class="agents-job-source-group__header">
                            <div class="agents-job-source-group__title">{{ sourceGroup.label }}</div>
                          <div class="agents-job-source-group__description">{{ sourceGroup.description }}</div>
                        </div>
                        <div class="agents-capability-group-pills agents-job-source-pill-row">
                          {% for sourceKey, source in workflowSourceCatalog %}
                            {% if source.group == sourceGroupKey %}
                              <label class="agents-capability-pill agents-capability-pill--job" title="{{ source.description }}">
                                <input type="checkbox" name="workflowSourceKeys[]" value="{{ source.key }}"{% if source.key in (editJobState.sourceKeys ?? []) %} checked{% endif %}>
                                <span class="agents-capability-pill-copy">
                                  <span class="agents-capability-pill-title">{{ source.label }}</span>
                                </span>
                              </label>
                            {% endif %}
                          {% endfor %}
                        </div>
                        </section>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>

                <div class="agents-workflows-schedule-panel">
                  <div class="agents-workflows-schedule-panel__title">Schedule</div>
                  <div class="agents-workflows-schedule-grid">
                    <div class="field">
                      <div class="heading"><label for="workflowWeekday">Day</label></div>
                      <div class="select">
                        <select id="workflowWeekday" name="workflowWeekday" required>
                          {% for option in workflowWeekdayOptions %}
                            <option value="{{ option.value }}"{% if option.value == (editJobState.weekday ?? currentWorkflow.weekday ?? 4) %} selected{% endif %}>{{ option.label }}</option>
                          {% endfor %}
                        </select>
                      </div>
                    </div>

                    {{ forms.timeField({
                      label: 'Time',
                      id: 'workflowTimeOfDay',
                      name: 'workflowTimeOfDay',
                      value: editJobState.timeOfDay ?? currentWorkflow.timeOfDay ?? '08:00',
                      required: true,
                      minuteIncrement: 15,
                    }) }}
                  </div>
                </div>

                <div class="agents-workflows-form-grid">
                  {{ forms.elementSelectField({
                    label: 'Entries',
                    instructions: 'Optional boundary for a tighter entry review scope.',
                    id: 'workflowEntryIds',
                    name: 'workflowEntryIds',
                    elementType: 'craft\\elements\\Entry',
                    selectionLabel: 'Select entries'|t('app'),
                    elements: selectedWorkflowEntryElements ?? [],
                    limit: null,
                    viewMode: 'list-inline',
                    sources: ['*'],
                    criteria: {
                      status: null,
                    },
                  }) }}

                  {% if workflowProductElementType %}
                    {{ forms.elementSelectField({
                      label: 'Products',
                      instructions: 'Optional boundary for commerce-facing jobs.',
                      id: 'workflowProductIds',
                      name: 'workflowProductIds',
                      elementType: workflowProductElementType,
                      selectionLabel: 'Select products'|t('app'),
                      elements: selectedWorkflowProductElements ?? [],
                      limit: null,
                      viewMode: 'list-inline',
                      sources: ['*'],
                    }) }}
                  {% endif %}
                </div>

                <div class="agents-workflows-form-grid">
                  <div class="field">
                    <div class="heading"><label>Sections</label></div>
                    <div class="instructions"><p>Optional section boundary. Leave blank for broader review.</p></div>
                    <div class="agents-inline-checkboxes agents-inline-checkboxes--stacked">
                      {% for section in availableSections %}
                        <label class="agents-workflow-checkbox">
                          <input type="checkbox" name="workflowSectionHandles[]" value="{{ section.handle }}"{% if section.handle in currentSectionHandles %} checked{% endif %}>
                          <span class="agents-workflow-checkbox__copy">
                            <span class="agents-workflow-checkbox__title">{{ section.name ?: section.handle }}</span>
                            <span class="agents-workflow-checkbox__meta">{{ section.handle }}</span>
                          </span>
                        </label>
                      {% endfor %}
                    </div>
                  </div>

                  <div class="field">
                    <div class="heading"><label>Sites</label></div>
                    <div class="instructions"><p>Optional site boundary. Leave blank when the job may review all configured sites.</p></div>
                    <div class="agents-inline-checkboxes agents-inline-checkboxes--stacked">
                      {% for site in availableSites %}
                        <label class="agents-workflow-checkbox">
                          <input type="checkbox" name="workflowSiteIds[]" value="{{ site.id }}"{% if site.id in currentSiteIds %} checked{% endif %}>
                          <span class="agents-workflow-checkbox__copy">
                            <span class="agents-workflow-checkbox__title">{{ site.name ?: ('Site #' ~ site.id) }}</span>
                            <span class="agents-workflow-checkbox__meta">{{ site.handle ?: ('#' ~ site.id) }}</span>
                          </span>
                        </label>
                      {% endfor %}
                    </div>
                  </div>
                </div>

                <div class="field">
                  <div class="heading"><label>Managed account</label></div>
                  <div class="instructions"><p>All accounts are shown first. As you define content needs and boundaries, Agents narrows the list to compatible accounts.</p></div>
                  <div
                    id="workflowAccountPicker"
                    data-job-account-picker-container
                    data-match-url="{{ actionUrl('agents/dashboard/workflow-account-matches') }}"
                  >
                    {% include 'agents/_partials/job-account-picker' with {
                      accountSelection: editAccountSelection,
                      showIntro: false,
                    } only %}
                  </div>
                </div>

                {{ forms.textareaField({
                  label: 'Operator notes',
                  id: 'workflowOperatorNotes',
                  name: 'workflowOperatorNotes',
                  rows: 3,
                  value: editJobState.operatorNotes ?? currentConfig.operatorNotes ?? '',
                }) }}

                <div class="agents-form-actions">
                  <button class="btn submit" type="submit">Save Job</button>
                  <a class="btn" href="{{ workflowsIndexUrl }}">Back</a>
                </div>
              </form>
              <form method="post" accept-charset="UTF-8" onsubmit="return confirm('Delete this job?');" class="agents-workflows-delete-form">
                {{ csrfInput() }}
                {{ actionInput('agents/dashboard/delete-workflow') }}
                <input type="hidden" name="workflowId" value="{{ currentWorkflow.id }}">
                <button class="btn" type="submit">Delete</button>
              </form>
            {% else %}
              <div class="agents-workflows-readonly">
                <div><strong>Description:</strong> {{ currentWorkflow.description ?: 'No description yet.' }}</div>
                <div><strong>Job type:</strong> {{ currentTemplate.displayName ?? currentWorkflow.templateHandle }}</div>
                <div><strong>Managed account:</strong> {{ include('agents/_partials/managed-account-ref', {
                  label: currentWorkflow.accountDisplayName,
                  url: accountsUrl,
                }, with_context = false) }}</div>
                <div><strong>Boundary:</strong> {{ currentWorkflow.readBoundary.summary ?: (currentWorkflow.configSummary ?: (currentTemplate.focusLabel ?? 'Configured review scope')) }}</div>
                <div><strong>Entry IDs:</strong> {{ currentEntryIds|length ? currentEntryIds|join(', ') : 'Unbounded' }}</div>
                <div><strong>Product IDs:</strong> {{ currentProductIds|length ? currentProductIds|join(', ') : 'Unbounded' }}</div>
                <div><strong>Sections:</strong> {{ currentSectionHandles|length ? currentSectionHandles|join(', ') : 'Unbounded' }}</div>
                <div><strong>Sites:</strong> {{ currentSiteIds|length ? currentSiteIds|join(', ') : 'Unbounded' }}</div>
              </div>
            {% endif %}
          </section>

          <div class="agents-workflows-sidebar">
            <section class="border rounded p-3 agents-workflows-side-card">
              <h2 class="h4">Job type</h2>
              <p class="agents-subtle">{{ currentTemplate.description ?? 'Job type.' }}</p>
              <p><a href="{{ currentTemplate.docsUrl ?? workflowLibraryUrl }}" target="_blank" rel="noopener">Job library &rarr;</a> &middot; <a href="{{ firstWorkerGuideUrl }}" target="_blank" rel="noopener">First agent &rarr;</a></p>
            </section>

            <section class="border rounded p-3 agents-workflows-side-card">
              <h2 class="h4">Agent execution</h2>
              <div class="agents-workflows-side-stack">
                <div><strong>Mode:</strong> Poll-first agent</div>
                <div><strong>Job mode:</strong> {{ currentTemplate.mode == 'read-only' ? 'Read-only review' : currentTemplate.mode|title }}</div>
                <div><strong>Boundary:</strong> {{ currentWorkflow.readBoundary.summary ?: 'Unbounded read review' }}</div>
                <div><strong>Account fit:</strong> {{ currentWorkflow.accountScopeCoverage.isBroader ? 'Broader than this job' : 'Aligned with this job' }}</div>
                {% if currentWorkflow.accountScopeCoverage.isBroader and currentWorkflow.accountScopeCoverage.meta %}
                  <div><strong>Extra scopes:</strong> {{ currentWorkflow.accountScopeCoverage.meta }}</div>
                {% endif %}
                <div><strong>Last agent:</strong> {{ currentWorkflow.lastWorkerId ?: 'None yet' }}</div>
                <div><strong>Last claim:</strong> {{ currentWorkflow.lastClaimedAt ? include('agents/_partials/relative-short-date', { value: currentWorkflow.lastClaimedAt }, with_context = false) : 'Never' }}</div>
                <div><strong>Last heartbeat:</strong> {{ currentWorkflow.lastHeartbeatAt ? include('agents/_partials/relative-short-date', { value: currentWorkflow.lastHeartbeatAt }, with_context = false) : 'Never' }}</div>
              </div>
            </section>

            <section class="border rounded p-3 agents-workflows-side-card">
              <h2 class="h4">Recent runs</h2>
              {% if selectedWorkflowRuns|length %}
                <div class="tableview tablepane agents-workflows-runs-wrap">
                  <table class="data fullwidth">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Summary</th>
                      </tr>
                    </thead>
                    <tbody>
                      {% for run in selectedWorkflowRuns %}
                        <tr>
                          <td>{{ run.id }}</td>
                          <td>{{ run.status|title }}</td>
                          <td>{{ include('agents/_partials/relative-short-date', { value: run.completedAt ?: run.startedAt ?: run.scheduledFor }, with_context = false) }}</td>
                          <td>{{ run.summary ?: 'No summary yet.' }}</td>
                        </tr>
                      {% endfor %}
                    </tbody>
                  </table>
                </div>
              {% else %}
                <p class="agents-subtle">No runs yet. This job stores run history after an agent discovers due work and reports run lifecycle events through the job API contract.</p>
              {% endif %}
            </section>

            <section class="border rounded p-3 agents-workflows-side-card">
              <h2 class="h4">Agent Handoff</h2>
              <p class="agents-subtle">Download a handoff bundle with `README.md`, `.env.example`, example script files, a cron example, explicit boundary guidance, and the job polling/reporting contract. Live tokens stay on the account surface.</p>
              <form method="post" accept-charset="UTF-8">
                {{ csrfInput() }}
                {{ actionInput('agents/dashboard/download-workflow-bundle') }}
                <input type="hidden" name="workflowId" value="{{ currentWorkflow.id }}">
                <button class="btn" type="submit">Download handoff</button>
              </form>
            </section>
          </div>
        </div>
      </div>
    {% endif %}
  </div>

